{
  "name": "HRCB Methodology",
  "version": "3.7",
  "lite_version": "lite-1.6",
  "updated_at": "2026-03-04",
  "license": "CC-BY-SA-4.0",
  "documentation": "https://observatory.unratified.org/methodology",
  "source_code": "https://github.com/safety-quotient-lab/observatory",
  "framework": "Universal Declaration of Human Rights (A/RES/217(III), 1948-12-10)",
  "provisions_scored": 31,
  "provision_range": "Preamble (0) + Articles 1-30",

  "scoring": {
    "scale": [-1.0, 1.0],
    "channels": {
      "editorial": "What the content says about human rights",
      "structural": "What the site does — privacy, tracking, accessibility, transparency"
    },
    "classifications": [
      { "label": "Strong positive",   "min":  0.6, "max":  1.0 },
      { "label": "Moderate positive",  "min":  0.3, "max":  0.6 },
      { "label": "Mild positive",      "min":  0.1, "max":  0.3 },
      { "label": "Neutral",            "min": -0.1, "max":  0.1 },
      { "label": "Mild negative",      "min": -0.3, "max": -0.1 },
      { "label": "Moderate negative",  "min": -0.6, "max": -0.3 },
      { "label": "Strong negative",    "min": -1.0, "max": -0.6 }
    ],
    "content_type_weights": {
      "_description": "Editorial and structural channel weights by content type [E, S]",
      "ED": [0.6, 0.4],
      "PO": [0.3, 0.7],
      "LP": [0.3, 0.7],
      "PR": [0.5, 0.5],
      "AC": [0.4, 0.6],
      "MI": [0.7, 0.3],
      "AD": [0.2, 0.8],
      "HR": [0.5, 0.5],
      "CO": [0.4, 0.6],
      "ME": [0.5, 0.5],
      "MX": [0.5, 0.5]
    },
    "content_type_codes": {
      "ED": "Editorial / News",
      "PO": "Policy / Government",
      "LP": "Landing Page / Product",
      "PR": "Press Release / Marketing",
      "AC": "Academic / Research",
      "MI": "Media / Investigative",
      "AD": "Advertisement",
      "HR": "Human Rights Focused",
      "CO": "Corporate / Business",
      "ME": "Meta / Commentary",
      "MX": "Mixed / Unclassified"
    }
  },

  "evidence": {
    "strength_levels": {
      "H": { "label": "High", "weight": 1.0, "max_score": 1.0 },
      "M": { "label": "Medium", "weight": 0.7, "max_score": 0.7 },
      "L": { "label": "Low", "weight": 0.4, "max_score": 0.4 }
    },
    "confidence_weights": {
      "H": 1.0,
      "M": 0.6,
      "L": 0.2
    }
  },

  "setl": {
    "name": "Structural-Editorial Tension Level",
    "description": "Measures divergence between editorial claims and structural reality",
    "formula": "avg(sqrt(|E-S| * max(|E|,|S|)) * sign(E-S))",
    "range": [-1.0, 1.0],
    "rights_washing_threshold": {
      "setl_min": 0.25,
      "editorial_min": 0.1,
      "structural_max": -0.1,
      "badge": "says != does"
    }
  },

  "volatility": {
    "thresholds": {
      "low": { "max_stddev": 0.10 },
      "medium": { "max_stddev": 0.25 },
      "high": { "min_stddev": 0.25 }
    }
  },

  "consensus": {
    "weighting": {
      "base_weight_full": 1.0,
      "base_weight_lite": 0.5,
      "confidence_floor_full": 0.5,
      "confidence_floor_lite": 0.2,
      "truncation_discount": "1 - (truncation_pct * 0.5)",
      "neutral_discount": 0.5,
      "neutral_discount_condition": "lite eval with editorial=0 and confidence >= 0.7"
    },
    "divergence_alert": {
      "warn_threshold": 0.25,
      "error_threshold": 0.50
    }
  },

  "fair_witness": {
    "description": "Evidence transparency protocol — observable facts separated from interpretive inferences",
    "rules": [
      "Every non-ND section requires at least 1 witness_fact",
      "Facts must follow E-Prime: no 'to be' verbs (is, are, was, were, be, been, being)",
      "Target 1-3 facts and 1-2 inferences per section",
      "Inferences explain the mapping from evidence to score"
    ]
  },

  "propaganda_techniques": {
    "framework": "PTC-18 (ACL D19-1565)",
    "tiers": {
      "A": { "weight": 3, "techniques": ["reductio_ad_hitlerum", "appeal_to_fear", "name_calling", "false_dilemma", "thought_terminating_cliche"] },
      "B": { "weight": 2, "techniques": ["causal_oversimplification", "strawman", "whataboutism", "bandwagon", "flag_waving", "exaggeration", "doubt"] },
      "C": { "weight": 1, "techniques": ["loaded_language", "repetition", "appeal_to_authority", "slogans", "red_herring", "obfuscation"] }
    }
  },

  "rights_tensions": {
    "max_per_evaluation": 3,
    "fields": ["article_a", "article_b", "label"],
    "full_eval_only": true
  },

  "rights_entanglement_map": {
    "clustering_method": "single-linkage hierarchical",
    "correlation_threshold": 0.35
  },

  "domain_context_profile": {
    "modifier_cap": [-0.30, 0.30],
    "description": "Per-article context modifier from domain-level policies"
  },

  "lite": {
    "editorial_scale": [0, 100],
    "editorial_normalization": "(score - 50) / 50 → [-1, +1]",
    "transparency_quotient": {
      "indicators": ["tq_author", "tq_date", "tq_sources", "tq_corrections", "tq_conflicts"],
      "tq_score": "sum / 5",
      "structural_proxy": "tq_score * 2 - 1",
      "structural_proxy_content_types": ["ED", "HR", "MI", "PO"]
    }
  },

  "psq": {
    "version": "1.0",
    "status": "experimental",
    "framework": "PSQ (Psychoemotional Safety Quotient)",
    "description": "Independent reader psychoemotional safety signal — measures how safe content is to consume, distinct from HRCB (rights stance)",
    "scoring_scale": [0, 10],
    "g_psq": "confidence-weighted protective/threat split",
    "display_normalization": "(psq - 5) / 5 → [-1, +1]",
    "dimensions": [
      "threat_exposure", "hostility_index", "authority_dynamics",
      "energy_dissipation", "regulatory_capacity", "resilience_baseline",
      "trust_conditions", "cooling_capacity", "defensive_architecture",
      "contractual_clarity"
    ],
    "threat_dimensions": ["threat_exposure", "hostility_index", "authority_dynamics", "energy_dissipation"],
    "protective_dimensions": ["regulatory_capacity", "resilience_baseline", "trust_conditions", "cooling_capacity", "defensive_architecture", "contractual_clarity"],
    "transparency_quotient": {
      "indicators": ["tq_author", "tq_date", "tq_sources", "tq_corrections", "tq_conflicts"],
      "tq_score": "sum / 5"
    }
  }
}
