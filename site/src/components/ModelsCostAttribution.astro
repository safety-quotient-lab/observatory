---
// SPDX-License-Identifier: Apache-2.0

interface Props {
  costStats: any[];
  dailyCostStats: any[];
  MODEL_PRICING: Record<string, { inPerMTok: number; outPerMTok: number }>;
  modelCost: (model: string, tokIn: number, tokOut: number) => number;
  dcDays: string[];
  dcTotals: number[];
  dcMax: number;
}

const { costStats, MODEL_PRICING, modelCost, dcDays, dcTotals, dcMax } = Astro.props;

const totalCost7d  = costStats.reduce((s, r) => s + modelCost(r.eval_model, r.tokens_in_7d,  r.tokens_out_7d),  0);
const totalCost30d = costStats.reduce((s, r) => s + modelCost(r.eval_model, r.tokens_in_30d, r.tokens_out_30d), 0);
const totalEvals7d  = costStats.reduce((s, r) => s + r.evals_7d,  0);
const totalEvals30d = costStats.reduce((s, r) => s + r.evals_30d, 0);
---

{costStats.length > 0 && (
  <details open class="collapsible-section">
    <summary>
      Cost Attribution
      <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
        estimated API spend per model (approx.)
      </span>
    </summary>
    <div class="table-wrap">
    <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
      <tr style="color: var(--fg-secondary); font-size: 9px; border-bottom: 1px solid var(--color-border);">
        <td style="padding: 3px 6px;">Model</td>
        <td style="padding: 3px 6px; text-align: right;">Evals 7d</td>
        <td style="padding: 3px 6px; text-align: right;">Evals 30d</td>
        <td style="padding: 3px 6px; text-align: right;">Tok In 7d</td>
        <td style="padding: 3px 6px; text-align: right;">Tok Out 7d</td>
        <td style="padding: 3px 6px; text-align: right;">$/eval 7d</td>
        <td style="padding: 3px 6px; text-align: right;">Est Cost 7d</td>
        <td style="padding: 3px 6px; text-align: right;">Est Cost 30d</td>
      </tr>
      {costStats.map(r => {
        const cost7d  = modelCost(r.eval_model, r.tokens_in_7d,  r.tokens_out_7d);
        const cost30d = modelCost(r.eval_model, r.tokens_in_30d, r.tokens_out_30d);
        const isFree  = !MODEL_PRICING[r.eval_model];
        const costColor = cost7d > 5 ? 'var(--color-warning)' : cost7d > 1 ? 'var(--fg-primary)' : 'var(--fg-secondary)';
        const cpe = r.evals_7d > 0 && !isFree ? cost7d / r.evals_7d : null;
        return (
          <tr style="border-bottom: 1px solid var(--bg-highlight);">
            <td style="padding: 3px 6px; color: var(--fg-primary);">
              {r.eval_model.replace('claude-', '').replace('-20251001', '').replace('-20251022', '')}
              <span style="color: var(--color-border); font-size: 9px; margin-left: 4px;">{r.eval_provider}</span>
            </td>
            <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{r.evals_7d}</td>
            <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{r.evals_30d}</td>
            <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary); font-family: monospace;">{(r.tokens_in_7d / 1000).toFixed(0)}k</td>
            <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary); font-family: monospace;">{(r.tokens_out_7d / 1000).toFixed(0)}k</td>
            <td style={`padding: 3px 6px; text-align: right; font-family: monospace; color: ${isFree ? 'var(--color-border)' : 'var(--fg-secondary)'};`}>
              {isFree ? 'free' : cpe == null ? '—' : `$${cpe < 0.01 ? cpe.toFixed(4) : cpe.toFixed(3)}`}
            </td>
            <td style={`padding: 3px 6px; text-align: right; font-family: monospace; color: ${isFree ? 'var(--color-border)' : costColor};`}>
              {isFree ? 'free' : cost7d === 0 ? '—' : `$${cost7d.toFixed(3)}`}
            </td>
            <td style={`padding: 3px 6px; text-align: right; font-family: monospace; color: ${isFree ? 'var(--color-border)' : costColor};`}>
              {isFree ? 'free' : cost30d === 0 ? '—' : `$${cost30d.toFixed(2)}`}
            </td>
          </tr>
        );
      })}
      <tr style="border-top: 1px solid var(--color-border); font-weight: bold;">
        <td style="padding: 3px 6px; color: var(--fg-secondary);">Total</td>
        <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{totalEvals7d}</td>
        <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{totalEvals30d}</td>
        <td colspan="3"></td>
        <td style={`padding: 3px 6px; text-align: right; font-family: monospace; color: ${totalCost7d > 5 ? 'var(--color-warning)' : 'var(--fg-primary)'};`}>
          ${totalCost7d.toFixed(3)}
        </td>
        <td style={`padding: 3px 6px; text-align: right; font-family: monospace; color: ${totalCost30d > 20 ? 'var(--color-warning)' : 'var(--fg-primary)'};`}>
          ${totalCost30d.toFixed(2)}
        </td>
      </tr>
    </table>
    </div>

    {/* Daily burn rate chart */}
    {dcDays.length > 1 && (
      <div style="margin-top: 10px;">
        <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
          Daily burn rate
          <span style="text-transform: none; letter-spacing: 0; color: var(--color-border); margin-left: 6px;">last 14 days · billed models only</span>
        </div>
        <svg viewBox={`0 0 ${dcDays.length * 10} 48`} style="width: 100%; height: 48px; overflow: visible;" preserveAspectRatio="none">
          {dcTotals.map((cost, i) => {
            const h = dcMax > 0 ? (cost / dcMax) * 44 : 0;
            return h > 0 ? <rect x={i * 10} y={44 - h} width={9} height={h} fill="var(--color-warning)" opacity="0.75" /> : null;
          })}
        </svg>
        <div style="display: flex; justify-content: space-between; margin-top: 2px; font-size: 9px; color: var(--fg-secondary); font-family: monospace;">
          <span>{dcDays[0]?.slice(5)}</span>
          <span style="color: var(--fg-primary);">peak ${dcMax.toFixed(3)}/day</span>
          <span>{dcDays[dcDays.length - 1]?.slice(5)}</span>
        </div>
      </div>
    )}

    <div style="margin-top: 4px; color: var(--color-border); font-size: 9px;">
      Pricing approximate (Anthropic list rates). Workers AI and free-tier OpenRouter models not billed. Zero token rows = pre-2026-02-28 evals with no token data.
    </div>
  </details>
)}
