---
declare const __BUILD_HASH__: string;
declare const __BUILD_TIME__: string;
const buildHash = typeof __BUILD_HASH__ !== 'undefined' ? __BUILD_HASH__ : 'dev';
const buildTime = typeof __BUILD_TIME__ !== 'undefined' ? __BUILD_TIME__ : '';
---

<table width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding: 10px 0;">
      <table style="margin: 0 auto;">
        <tr>
          <td style="text-align: center; padding-top: 10px; border-top: 2px solid #ff6600;">
            <span class="subtext">
              <a href="/about">About HRCB</a> |
              <a href="/article/19">By Right</a> |
              <a href="https://news.ycombinator.com/newsguidelines.html">HN Guidelines</a> |
              <a href="https://news.ycombinator.com/newsfaq.html">HN FAQ</a> |
              <a href="https://github.com/kashif/unudhr">Source</a> |
              <a href="https://www.un.org/en/about-us/universal-declaration-of-human-rights">UDHR</a>
            </span>
            <div style="color: #444; font-size: 7pt; margin-top: 6px;">
              build {buildHash}{buildTime ? ` · ${buildTime} UTC` : ''}
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
