---
declare const __BUILD_HASH__: string;
declare const __BUILD_TIME__: string;
const buildHash = typeof __BUILD_HASH__ !== 'undefined' ? __BUILD_HASH__ : 'dev';
const buildTime = typeof __BUILD_TIME__ !== 'undefined' ? __BUILD_TIME__ : '';

interface Props {
  lastEvaluatedAt?: string | null;
}
const { lastEvaluatedAt } = Astro.props;
---

<div id="donate-nudge" style="display:none; align-items:center; justify-content:space-between; gap:12px; padding:8px 14px; background:rgba(213,101,0,0.08); border:1px solid rgba(213,101,0,0.2); border-radius:6px; margin-bottom:8px; flex-wrap:wrap;">
  <span style="color:var(--fg-primary); font-size:9pt;">
    HN HRCB runs on API credits and donations — no ads.
    <a href="#" id="nudge-donate" style="color:var(--color-orange); text-decoration:underline;">Support the project →</a>
  </span>
  <button id="nudge-dismiss" style="background:none; border:none; cursor:pointer; color:var(--fg-secondary); font-size:11pt; padding:2px 4px; line-height:1;" title="Dismiss">✕</button>
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding: 10px 0;">
      <table style="margin: 0 auto;">
        <tr>
          <td style="text-align: center; padding-top: 10px; border-top: 2px solid var(--color-orange);">
            <span class="subtext">
              <a href="/about">About HRCB</a> |
              <a href="/article/19">By Right</a> |
              <a href="https://news.ycombinator.com/newsguidelines.html">HN Guidelines</a> |
              <a href="https://news.ycombinator.com/newsfaq.html">HN FAQ</a> |
              <a href="https://github.com/kashifshah/unudhr">Source</a> |
              <a href="https://www.un.org/en/about-us/universal-declaration-of-human-rights">UDHR</a> |
              <a href="/support" style="color:var(--color-orange);">Donate</a> |
              <a href="/feed.xml">RSS</a>
            </span>
            <div style="color: var(--color-border); font-size: var(--font-xs); margin-top: 6px;">
              <span title="Build version">build {buildHash}</span>{buildTime ? <span title="Deployed"> · deployed {buildTime} UTC</span> : ''}{lastEvaluatedAt ? <span title="Last evaluation completed"> · evaluated {lastEvaluatedAt} UTC</span> : ''}
            </div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<script is:inline>
  (function() {
    function checkDonated() {
      var ts = localStorage.getItem('hrcb_donated');
      return ts && (Date.now() - new Date(ts).getTime()) < 604800000;
    }
    function checkNudgeDismissed() {
      var ts = localStorage.getItem('hrcb_nudge_dismissed');
      return ts && (Date.now() - new Date(ts).getTime()) < 2592000000;
    }
    if (!checkDonated() && !checkNudgeDismissed()) {
      var nudge = document.getElementById('donate-nudge');
      if (nudge) nudge.style.display = 'flex';
    }
    var dismissBtn = document.getElementById('nudge-dismiss');
    if (dismissBtn) {
      dismissBtn.addEventListener('click', function() {
        localStorage.setItem('hrcb_nudge_dismissed', new Date().toISOString());
        var nudge = document.getElementById('donate-nudge');
        if (nudge) nudge.style.display = 'none';
      });
    }
    var nudgeDonate = document.getElementById('nudge-donate');
    if (nudgeDonate) {
      nudgeDonate.addEventListener('click', function(e) {
        e.preventDefault();
        var modal = document.getElementById('donate-modal');
        if (modal) modal.style.display = 'flex';
      });
    }
  })();
</script>
