---
import { modifierColor, formatScore } from '../lib/colors';
import type { DcpElement } from '../lib/types';

interface Props {
  elements: Record<string, DcpElement>;
}

const { elements } = Astro.props;

const DCP_LABELS: Record<string, string> = {
  privacy: 'Privacy',
  tos: 'Terms of Service',
  accessibility: 'Accessibility',
  mission: 'Mission',
  editorial_code: 'Editorial Code',
  ownership: 'Ownership',
  access_model: 'Access Model',
  ad_tracking: 'Ad/Tracking',
};

const DCP_GROUPS: { label: string; keys: string[] }[] = [
  { label: 'Legal & Terms', keys: ['privacy', 'tos'] },
  { label: 'Identity & Mission', keys: ['mission', 'editorial_code', 'ownership'] },
  { label: 'Access & Distribution', keys: ['access_model', 'ad_tracking', 'accessibility'] },
];

// Collect any keys not in a defined group
const groupedKeys = DCP_GROUPS.flatMap(g => g.keys);
const ungroupedKeys = Object.keys(elements).filter(k => !groupedKeys.includes(k));
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-surface-3">
        <th class="text-left py-2 px-3 text-gray-400 font-medium">Element</th>
        <th class="text-center py-2 px-3 text-gray-400 font-medium w-24">Modifier</th>
        <th class="text-left py-2 px-3 text-gray-400 font-medium">Affects</th>
        <th class="text-left py-2 px-3 text-gray-400 font-medium">Note</th>
      </tr>
    </thead>
    <tbody>
      {DCP_GROUPS.map((group, gi) => {
        const groupRows = group.keys.filter(k => elements[k]);
        if (groupRows.length === 0) return null;
        return (
          <>
            <tr style={`background: ${gi % 2 === 0 ? 'rgba(13,70,85,0.25)' : 'rgba(9,57,70,0.2)'};`}>
              <td colspan="4" class="py-1 px-3" style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.06em; border-top: 1px solid var(--color-border);">
                {group.label}
              </td>
            </tr>
            {groupRows.map(key => {
              const el = elements[key];
              const color = modifierColor(el.modifier);
              return (
                <tr class="border-b border-surface-3/50 hover:bg-surface-2/50 transition-colors">
                  <td class="py-2 px-3 font-medium text-gray-300">{DCP_LABELS[key] || key}</td>
                  <td class="py-2 px-3 text-center">
                    <span
                      class="badge"
                      style={`background: ${color}20; color: ${color}; border: 1px solid ${color}40`}
                    >
                      {el.modifier === null ? '—' : formatScore(el.modifier)}
                    </span>
                  </td>
                  <td class="py-2 px-3">
                    <div class="flex flex-wrap gap-1">
                      {el.affects.map((a) => (
                        <span class="text-xs px-1.5 py-0.5 rounded score-font" style="background: rgba(26,85,104,0.4); color: var(--fg-emphasis); border: 1px solid var(--color-border);">
                          {a}
                        </span>
                      ))}
                    </div>
                  </td>
                  <td class="py-2 px-3 text-gray-400 text-xs max-w-md">{el.note}</td>
                </tr>
              );
            })}
          </>
        );
      })}
      {ungroupedKeys.map(key => {
        const el = elements[key];
        const color = modifierColor(el.modifier);
        return (
          <tr class="border-b border-surface-3/50 hover:bg-surface-2/50 transition-colors">
            <td class="py-2 px-3 font-medium text-gray-300">{DCP_LABELS[key] || key}</td>
            <td class="py-2 px-3 text-center">
              <span
                class="badge"
                style={`background: ${color}20; color: ${color}; border: 1px solid ${color}40`}
              >
                {el.modifier === null ? '—' : formatScore(el.modifier)}
              </span>
            </td>
            <td class="py-2 px-3">
              <div class="flex flex-wrap gap-1">
                {el.affects.map((a) => (
                  <span class="text-xs px-1.5 py-0.5 rounded score-font" style="background: rgba(26,85,104,0.4); color: var(--fg-emphasis); border: 1px solid var(--color-border);">
                    {a}
                  </span>
                ))}
              </div>
            </td>
            <td class="py-2 px-3 text-gray-400 text-xs max-w-md">{el.note}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
