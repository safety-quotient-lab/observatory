---
// SPDX-License-Identifier: Apache-2.0
import { modelDisplayName, isLiteMode, getModelDef } from '../lib/shared-eval';
import type { ComparedStory } from '../lib/db';

interface Props {
  totalStories: number;
  modelIds: string[];
  comparedStories: ComparedStory[];
}

const { totalStories, modelIds, comparedStories } = Astro.props;
---

{totalStories > 0 && (
  <details class="collapsible-section">
    <summary>
      All Compared Stories
      <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">{totalStories}</span>
    </summary>
    <div class="table-wrap">
    <div style="max-height: 600px; overflow-y: auto;">
      <table cellpadding="0" cellspacing="0" width="100%" style="min-width: 500px;">
        <tr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; position: sticky; top: 0; background: var(--bg-highlight);">
          <td style="padding: 3px 6px;">Story</td>
          <td style="padding: 3px 6px;">Domain</td>
          {modelIds.map(m => (
            <td style="padding: 3px 6px; text-align: center;">
              {modelDisplayName(m)}
              {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: var(--color-orange); font-size: 6pt; margin-left: 2px;">lite</span>}
            </td>
          ))}
          <td style="padding: 3px 6px; text-align: center;">&Delta;</td>
        </tr>
        {comparedStories.map(s => (
          <tr style={`border-top: 1px solid var(--bg-surface);${!s.allAgree ? ' background: rgba(220, 38, 38, 0.04);' : ''}`}>
            <td style="padding: 2px 6px; font-size: var(--font-xs);">
              <a href={`/item/${s.hn_id}`} style="color: var(--fg-emphasis); text-decoration: none;" title={s.title}>
                {s.title ? (s.title.length > 50 ? s.title.slice(0, 50) + '...' : s.title) : '---'}
              </a>
            </td>
            <td style="padding: 2px 6px; font-size: var(--font-xs); color: var(--fg-secondary);">
              {s.domain ? (
                <a href={`/domain/${s.domain}`} style="color: var(--fg-secondary); text-decoration: none;">{s.domain.length > 20 ? s.domain.slice(0, 20) + '...' : s.domain}</a>
              ) : '---'}
            </td>
            {modelIds.map(mid => {
              const me = s.models.find(m => m.model === mid);
              return (
                <td style={`padding: 2px 6px; text-align: center; color: ${me ? me.scoreColor : 'var(--fg-secondary)'}; font-size: var(--font-sm);`}>
                  {me ? me.scoreFormatted : '---'}
                </td>
              );
            })}
            <td style={`padding: 2px 6px; text-align: center; color: ${s.maxDelta >= 0.3 ? 'var(--color-negative)' : s.maxDelta >= 0.15 ? 'var(--color-warning)' : 'var(--fg-secondary)'}; font-size: var(--font-sm);`}>
              {s.maxDelta != null ? s.maxDelta.toFixed(2) : '—'}
            </td>
          </tr>
        ))}
      </table>
    </div>
    </div>
  </details>
)}
