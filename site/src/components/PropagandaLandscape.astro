---
// SPDX-License-Identifier: Apache-2.0
import { scoreToColor, formatScore } from '../lib/colors';

interface Props {
  techniqueEntries: [string, number][];
  maxTechniqueCount: number;
  propagandaStories: any[];
}

const { techniqueEntries, maxTechniqueCount, propagandaStories } = Astro.props;
---

<div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
  <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Propaganda Landscape</div>

  {techniqueEntries.length > 0 && (
    <div style="margin-bottom: 14px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 6px;">Technique Distribution</div>
      <table cellpadding="0" cellspacing="0" width="100%">
        {techniqueEntries.map(([technique, count]) => {
          const pct = maxTechniqueCount > 0 ? Math.round((count / maxTechniqueCount) * 100) : 0;
          return (
            <tr>
              <td title={technique} style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                {technique}
              </td>
              <td style="padding: 3px 8px;">
                <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                  <div style={`width: ${pct}%; height: 100%; background: var(--color-negative-light); border-radius: 3px;`}></div>
                </div>
              </td>
              <td style="width: 40px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                <a href={`/stories?pt=${encodeURIComponent(technique)}`} style="color: inherit; text-decoration: none;" title={`Stories flagged for ${technique}`}>{count}</a>
              </td>
            </tr>
          );
        })}
      </table>
    </div>
  )}

  {propagandaStories.length > 0 ? (
    <div>
      <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 6px;">Top Flagged Stories</div>
      <div class="table-wrap">
      <table class="prop-table" cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs); min-width: 480px;">
        <tr style="color: var(--fg-secondary);">
          <td style="padding: 4px 0;">Title</td>
          <td class="prop-domain" style="width: 120px; padding: 4px 0;">Domain</td>
          <td style="width: 50px; text-align: right; padding: 4px 0;">Flags</td>
          <td style="width: 60px; text-align: right; padding: 4px 0;">HRCB</td>
        </tr>
        {propagandaStories.map(s => (
          <tr style="border-top: 1px solid var(--bg-surface);">
            <td title={s.title} style="padding: 4px 0; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <a href={`/item/${s.hn_id}`} style="color: var(--fg-primary); text-decoration: none;">{s.title}</a>
            </td>
            <td class="prop-domain" title={s.domain ?? '--'} style="width: 120px; padding: 4px 0; color: var(--fg-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              {s.domain ? <a href={`/domain/${s.domain}`} style="color: var(--fg-secondary); text-decoration: none;">{s.domain}</a> : '--'}
            </td>
            <td style="width: 50px; text-align: right; padding: 4px 0; color: var(--color-negative-light);" class="score-font">
              {s.pt_flag_count}
            </td>
            <td style="width: 60px; text-align: right; padding: 4px 0;">
              <span style={`color: ${scoreToColor(s.hcb_editorial_mean ?? s.hcb_weighted_mean)};`} class="score-font">{formatScore(s.hcb_editorial_mean ?? s.hcb_weighted_mean)}</span>
            </td>
          </tr>
        ))}
      </table>
      </div>
    </div>
  ) : (
    <div style="color: var(--fg-secondary); font-size: var(--font-xs); padding: 8px 0;">No propaganda flags detected yet.</div>
  )}
</div>

<style>
  .table-wrap {
    overflow-x: auto;
  }
  @media (max-width: 540px) {
    .prop-domain { display: none; }
    .prop-table { min-width: 260px !important; }
  }
</style>
