---
// SPDX-License-Identifier: Apache-2.0
import type { CI } from '../lib/stats';

interface TdRow {
  label: string;
  pct: number | null;
  ci: CI;
}

interface Props {
  tdRows: TdRow[];
  tdN: number;
  tdMeasured: number;
  doneCt: number;
  highTdPct: number | null;
}

const { tdRows, tdN, tdMeasured, doneCt, highTdPct } = Astro.props;
---

<div id="transparency" style="margin-bottom: 20px;">
  <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
    Transparency
  </h2>
  <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
    Who's transparent about what they write? <a href="/article/19" style="color: var(--channel-editorial);">UDHR Article 19</a> protects expression — but expression without disclosure undermines trust.
    <a href="/sources" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">by source &rarr;</a>
  </p>
  <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
    <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
      {tdRows.map(({ label, pct, ci }) => (
        <tr>
          <td style="width: 155px; color: var(--fg-primary); white-space: nowrap;">{label}</td>
          <td style="padding: 0 8px;">
            <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
              <div style={`background: var(--color-positive); opacity: 0.5; border-radius: 3px; height: 14px; width: ${pct ?? 0}%;`}></div>
            </div>
          </td>
          <td style="width: 70px; text-align: right; color: var(--fg-primary); white-space: nowrap;" class="score-font">
            {pct !== null ? (
              <span title={`95% CI: ${(ci.lower * 100).toFixed(1)}–${(ci.upper * 100).toFixed(1)}% (Wilson, n=${tdN})`}>
                {pct.toFixed(0)}%<span style="color: var(--fg-secondary); font-size: var(--font-xs);"> ±{Math.ceil(ci.margin)}</span>
              </span>
            ) : 'n/a'}
          </td>
        </tr>
      ))}
    </table>
    <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
      <a href="/status#signal-coverage" style="color: var(--fg-secondary); text-decoration: none; border-bottom: 1px dotted var(--color-border);" title={`${tdMeasured} of ${doneCt} evaluated stories have transparency data`}>{tdMeasured.toLocaleString()} stories measured.</a>
      {highTdPct !== null && (
        <> <span style="color: var(--color-positive);">{highTdPct.toFixed(0)}%</span> meet high transparency standards.</>
      )}
      <a href="/api/v1/signals" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 6px; white-space: nowrap;">data &rarr;</a>
    </p>
  </div>
</div>
