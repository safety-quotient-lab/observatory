---
import { scoreToColor, formatScore, classificationColor, classificationTextColor } from '../lib/colors';
import HeatMap from './HeatMap.astro';
import type { Score } from '../lib/types';
import type { Story, StoryWithMiniScores } from '../lib/db';

interface Props {
  story: Story | StoryWithMiniScores;
  scores?: Score[];
  rank?: number;
}

const { story, scores, rank } = Astro.props;

const hasEval = story.eval_status === 'done' && story.hcb_weighted_mean !== null;
const meanColor = hasEval ? scoreToColor(story.hcb_weighted_mean) : '#555';
// Classification can be a full paragraph — truncate to just the label for tooltips
const classLabel = story.hcb_classification?.split(' — ')[0] || story.hcb_classification;

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

{/* Title row */}
<tr class="athing">
  <td align="right" valign="top" class="title" style="padding-right: 5px;">
    <span style="color: #828282; font-size: 10pt;">
      {rank !== undefined ? `${rank}.` : ''}
    </span>
  </td>
  <td valign="top" style="padding-right: 5px; width: 44px; text-align: center;">
    {hasEval ? (
      <a href={`/item/${story.hn_id}`} title={`HRCB: ${formatScore(story.hcb_weighted_mean)} — ${classLabel}`}>
        <span
          class="score-font"
          style={`color: ${meanColor}; font-size: 9pt; font-weight: bold;`}
        >
          {formatScore(story.hcb_weighted_mean)}
        </span>
      </a>
    ) : story.eval_status === 'evaluating' ? (
      <span class="eval-spinner" style="color: #60a5fa; font-size: 8pt; display: inline-block;" title="Evaluating...">&#9881;</span>
    ) : (
      <button
        class="trigger-btn"
        data-hn-id={story.hn_id}
        title={story.eval_status === 'failed'
          ? `Failed: ${story.eval_error || 'unknown error'} — click to evaluate now`
          : story.eval_status === 'skipped'
            ? `Skipped: ${story.eval_error || ''} — click to evaluate now`
            : 'Evaluate now'}
        style={`background: none; border: none; cursor: pointer; padding: 2px 4px; font-size: 10pt; color: ${story.eval_status === 'failed' ? '#dc2626' : story.eval_status === 'pending' ? '#eab308' : '#555'}; transition: color 0.15s;`}
      >
        &#9654;
      </button>
    )}
  </td>
  <td class="title">
    <span class="titleline">
      <a href={story.url || `https://news.ycombinator.com/item?id=${story.hn_id}`}
         target={story.url ? '_blank' : undefined}
         rel={story.url ? 'noopener' : undefined}
      >
        {story.title}
      </a>
    </span>
    {story.domain && (
      <span class="sitebit" style="font-size: 8pt; margin-left: 5px;">
        (<a href={`https://${story.domain}`} target="_blank" rel="noopener">{story.domain}</a>)
      </span>
    )}
  </td>
</tr>
{/* Subtext row */}
<tr>
  <td colspan="2"></td>
  <td class="subtext">
    {story.hn_score !== null && <span>{story.hn_score} points</span>}
    {story.hn_by && <span> by <a href={`https://news.ycombinator.com/user?id=${story.hn_by}`}>{story.hn_by}</a></span>}
    <span> {timeAgo(story.hn_time)}</span>
    <span> | </span>
    {story.hn_comments !== null && (
      <a href={`https://news.ycombinator.com/item?id=${story.hn_id}`} target="_blank" rel="noopener">
        {story.hn_comments} comments
      </a>
    )}
    {hasEval ? (
      <>
        <span> | </span>
        <a href={`/item/${story.hn_id}`} style="color: #ff6600;">hrcb</a>
      </>
    ) : story.eval_status === 'evaluating' ? (
      <span> | <span style="color: #60a5fa; font-size: 8pt;">evaluating</span></span>
    ) : story.eval_status === 'pending' ? (
      <span> | <span style="color: #eab308; font-size: 8pt;">queued</span></span>
    ) : story.eval_status === 'failed' ? (
      <span> | <span style="color: #dc2626; font-size: 8pt;">failed</span></span>
    ) : story.eval_status === 'skipped' ? (
      <span> | <span style="color: #555; font-size: 8pt;">skipped</span></span>
    ) : null}
  </td>
</tr>
{/* Mini heatmap row for evaluated stories */}
{hasEval && scores && scores.length > 0 && (
  <tr>
    <td colspan="2"></td>
    <td style="padding: 2px 0 4px 0;">
      <a href={`/item/${story.hn_id}`}>
        <HeatMap scores={scores} compact={true} showLabels={false} />
      </a>
    </td>
  </tr>
)}
{/* Spacer row */}
<tr style="height: 5px;"></tr>
