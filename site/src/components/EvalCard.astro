---
// SPDX-License-Identifier: Apache-2.0
import { scoreToColor, formatScore, classificationColor, classificationTextColor, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence, normalizePsq, formatPsqScore } from '../lib/colors';
import MiniBar from './MiniBar.astro';
import type { Story, StoryWithMiniScores } from '../lib/db';
import { modelShortName, isLiteMode } from '../lib/shared-eval';
import type { RaterEvalRef } from '../lib/db';

interface Props {
  story: Story | StoryWithMiniScores;
  rank?: number;
  raterModels?: RaterEvalRef[]; // model refs with done evals for this story
}

const { story, rank, raterModels } = Astro.props;
// Other models (beyond the story's eval_model) that have evaluated this story
const otherModels = (raterModels || []).filter(m => m.eval_model !== story.eval_model);

const hasEval = story.hcb_weighted_mean != null || story.hcb_editorial_mean != null;
// Lite-only: no weighted_mean, OR weighted_mean exists but structural channel is missing
// (malformed full eval that returned editorial-only — treat as lite for display)
const isLiteOnly = hasEval && (story.hcb_weighted_mean == null || story.hcb_structural_mean == null);
// Display HRCB: weighted_mean for full evals, editorial_mean for lite-only
const displayScore = story.hcb_weighted_mean ?? story.hcb_editorial_mean;
// Score of 0.0 indicates insufficient signal for meaningful evaluation — flag with ~ prefix.
// Cross-model validation shows zeros cluster on thin/neutral content, not a single-model failure.
const editorialUncertainDisplay = hasEval && displayScore === 0;
const displayColor = hasEval ? scoreToColor(displayScore) : 'var(--fg-secondary)';
const structuralScore = story.hcb_structural_mean;
const classLabel = story.hcb_classification?.split(' — ')[0] || story.hcb_classification;

const miniScores = 'miniScores' in story ? story.miniScores : [];
const hnTextPreview = 'hn_text_preview' in story ? (story as StoryWithMiniScores).hn_text_preview : null;

// Compute aggregate SETL from miniScores
const setlValues = miniScores
  .map(s => computeSetl(s.structural, s.editorial))
  .filter((v): v is number => v !== null);
const aggSetl = setlValues.length > 0
  ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
  : null;

// Compute evidence-weighted confidence
const confidence = computeConfidence(story.hcb_evidence_h, story.hcb_evidence_m, story.hcb_evidence_l, story.hcb_nd_count);

// Rights-washing flag: high editorial + low structural = SETL divergence warning
const rightsWashing = !isLiteOnly && aggSetl !== null && aggSetl >= 0.25 && story.hcb_editorial_mean != null && story.hcb_structural_mean != null && story.hcb_editorial_mean > 0.1 && story.hcb_structural_mean < -0.1;

// Compute editorial/structural averages from miniScores
const editorialVals = miniScores.map(s => s.editorial).filter((v): v is number => v !== null);
const structuralVals = miniScores.map(s => s.structural).filter((v): v is number => v !== null);
const avgEditorial = editorialVals.length > 0 ? editorialVals.reduce((a, b) => a + b, 0) / editorialVals.length : null;
const avgStructural = structuralVals.length > 0 ? structuralVals.reduce((a, b) => a + b, 0) / structuralVals.length : null;

// PSQ (Psychological Safety Quotient) — independent signal
const hasPsq = story.psq_score != null;
const psqNormalized = normalizePsq(story.psq_score);
const psqColor = psqNormalized != null ? scoreToColor(psqNormalized) : 'var(--fg-secondary)';

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

{/* Title row */}
<tr class="athing">
  <td align="right" valign="top" class="title" style="padding-right: 5px;">
    <span style="color: var(--fg-secondary); font-size: var(--font-base);">
      {rank !== undefined ? `${rank}.` : ''}
    </span>
  </td>
  <td valign="top" style="padding-right: 5px; width: 90px; min-width: 90px; text-align: left; white-space: nowrap;">
    {hasEval ? (
      <a href={`/item/${story.hn_id}`} style="text-decoration: none;" title={`Editorial: ${formatScore(displayScore)} — ${classLabel} | Conf: ${formatConfidence(confidence)} | Structural: ${structuralScore !== null ? formatScore(structuralScore) : 'ND'} | SETL: ${formatSetl(aggSetl)}`}>
        <div class="tripartite-score">
          <div class="score-row" data-channel="hrcb">
            <abbr class="score-font score-label" style="text-decoration: none;" title="Human Rights Compatibility Bias: directional lean of content relative to UDHR provisions, from −1.0 to +1.0">HRCB</abbr>
            <span class="score-font score-value" style={`color: ${editorialUncertainDisplay ? 'var(--color-nd)' : (isLiteOnly ? 'var(--fg-secondary)' : displayColor)};`} title={editorialUncertainDisplay ? 'Score indeterminate: content lacked sufficient signal for meaningful evaluation' : undefined}>
              {editorialUncertainDisplay ? 'ND' : formatScore(displayScore)}
            </span>
          </div>
          <div class="score-row" data-channel="editorial">
            <abbr class="score-font score-label" style="text-decoration: none;" title="Editorial channel: what the content says about rights">E</abbr>
            <span class="score-font score-value" style={`color: ${story.hcb_editorial_mean !== null ? scoreToColor(story.hcb_editorial_mean) : 'var(--fg-secondary)'};`}>
              {story.hcb_editorial_mean !== null ? formatScore(story.hcb_editorial_mean) : '--'}
            </span>
          </div>
          {!isLiteOnly ? (
            <div class="score-row" data-channel="structural">
              <abbr class="score-font score-label" style="text-decoration: none;" title="Structural channel: what the hosting site does (privacy, access, tracking)">S</abbr>
              <span class="score-font score-value" style={`color: ${structuralScore !== null ? scoreToColor(structuralScore) : 'var(--fg-secondary)'};`}>
                {structuralScore !== null ? formatScore(structuralScore) : '--'}
              </span>
            </div>
          ) : (
            <div class="score-row" data-channel="structural">
              <abbr class="score-font score-label" style="text-decoration: none;" title="Structural channel: what the hosting site does — full eval needed">S</abbr>
              <button
                class="trigger-btn lite-upgrade-btn"
                data-hn-id={story.hn_id}
                title="Lite eval — full structural analysis costs API credits. Click to evaluate (donors only)."
                aria-label="Run full evaluation"
                style="background: none; border: none; cursor: pointer; padding: 0; font-size: var(--font-xs); color: var(--color-orange); line-height: 1.4;"
              >&#9654;</button>
            </div>
          )}
          {hasPsq && (
            <div class="score-row" data-channel="psq">
              <abbr class="score-font score-label" style="text-decoration: none;" title="Psychological Safety Quotient: how safe the content is to read, from −1.0 to +1.0. Ordinal only — rank-order is meaningful, distances between scores are not.">PSQ</abbr>
              <span class="score-font score-value" style={`color: ${psqColor};`}>
                {formatPsqScore(story.psq_score)}
              </span>
              <span class="psq-experimental">experimental</span>
            </div>
          )}
        </div>
      </a>
    ) : story.eval_status === 'evaluating' ? (
      <span class="eval-spinner" style="color: var(--channel-editorial); font-size: var(--font-sm); display: inline-block;" title="Evaluating...">&#9881;</span>
    ) : story.eval_status === 'failed' ? (
      <a href={`/item/${story.hn_id}`}
         title={`Failed: ${story.eval_error || 'unknown error'} — click for details`}
         style="text-decoration: none; padding: var(--space-xs) var(--space-sm); font-size: var(--font-base); color: var(--color-negative);"
      >
        &#10007;
      </a>
    ) : (
      <button
        class="trigger-btn"
        data-hn-id={story.hn_id}
        title={story.eval_status === 'skipped'
            ? `Skipped: ${story.eval_error || ''} — click to evaluate now`
            : 'Evaluate now'}
        aria-label={story.eval_status === 'skipped'
            ? `Skipped: ${story.eval_error || ''} — click to evaluate now`
            : 'Evaluate now'}
        style={`background: none; border: none; cursor: pointer; padding: var(--space-xs) var(--space-sm); font-size: var(--font-base); color: ${story.eval_status === 'pending' ? 'var(--color-warning)' : 'var(--fg-secondary)'}; transition: color 0.15s;`}
      >
        &#9654;
      </button>
    )}
  </td>
  <td class="title">
    <span class="titleline">
      <a href={story.url || `https://news.ycombinator.com/item?id=${story.hn_id}`}
         target={story.url ? '_blank' : undefined}
         rel={story.url ? 'noopener' : undefined}
      >
        {story.title}
      </a>
    </span>
    {story.domain && (
      <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
        (<a href={`/domain/${story.domain}`}>{story.domain}</a>)
      </span>
    )}
  </td>
</tr>
{/* Self-post text preview for Ask HN */}
{!story.url && hnTextPreview && (
  <tr>
    <td colspan="2"></td>
    <td style="padding: 2px 0 0 0;">
      <span style="color: var(--fg-secondary); font-size: var(--font-sm); font-style: italic;">
        {hnTextPreview.length >= 100 ? hnTextPreview + '...' : hnTextPreview}
      </span>
    </td>
  </tr>
)}
{/* Subtext row */}
<tr>
  <td colspan="2"></td>
  <td class="subtext">
    {story.hn_score !== null && <span>{story.hn_score} points</span>}
    {story.hn_by && <span> by <a href={`/user/${story.hn_by}`}>{story.hn_by}</a></span>}
    <span> {timeAgo(story.hn_time)}</span>
    <span> | </span>
    {story.hn_comments !== null && (
      <a href={`https://news.ycombinator.com/item?id=${story.hn_id}`} target="_blank" rel="noopener">
        {story.hn_comments} comments
      </a>
    )}
    {hasEval ? (
      <>
        <span> | </span>
        <a href={`/item/${story.hn_id}`} style="color: var(--color-orange);">hrcb</a>
        {story.schema_version && (
          <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 4px;"
                title={`Schema version ${story.schema_version}`}>
            v{story.schema_version}
          </span>
        )}
        {story.hcb_theme_tag && (
          <span class="badge" style="background: rgba(43,144,216,0.15); color: var(--color-violet); font-size: var(--font-xs); margin-left: 4px;"
                title={`Theme: ${story.hcb_theme_tag}`}>
            {story.hcb_theme_tag}
          </span>
        )}
        {story.hcb_classification && !isLiteOnly && (
          <span class="badge" style={`background: ${classificationColor(story.hcb_classification)}; color: ${classificationTextColor(story.hcb_classification)}; font-size: var(--font-xs); margin-left: 4px;`}
                title={story.hcb_classification}>
            {classLabel}
          </span>
        )}
        {otherModels.length > 0 && otherModels.map(m => (
          <a href={`/item/${story.hn_id}?model=${m.eval_model}`}
             class="badge"
             style={`background: ${isLiteMode(m.prompt_mode) ? 'rgba(213,101,0,0.15)' : 'var(--bg-positive)'}; color: ${isLiteMode(m.prompt_mode) ? 'var(--color-orange)' : 'var(--color-positive-medium)'}; font-size: var(--font-xs); margin-left: 3px; text-decoration: none;`}
             title={`Also evaluated by ${m.eval_model}${isLiteMode(m.prompt_mode) ? ' (lite — editorial only)' : ''}`}>
            {modelShortName(m.eval_model)}{isLiteMode(m.prompt_mode) && <span class="lite-icon" style="margin-left: 2px; vertical-align: middle;" title="Lite eval — click for details" onclick="event.preventDefault();event.stopPropagation();window.location.href='/about#eval-modes'" role="link">L</span>}
          </a>
        ))}
        {(story.consensus_model_count ?? 0) >= 2 && story.consensus_score != null && (
          <span
            class="badge"
            style={`background: ${(story.consensus_spread ?? 0) > 0.3 ? 'rgba(217,119,6,0.15)' : 'rgba(43,144,216,0.10)'}; color: ${(story.consensus_spread ?? 0) > 0.3 ? 'var(--color-warning)' : 'var(--fg-emphasis)'}; font-size: var(--font-xs); margin-left: 3px;`}
            title={`Consensus across ${story.consensus_model_count} models: ${story.consensus_score > 0 ? '+' : ''}${story.consensus_score.toFixed(3)}${story.consensus_spread != null ? ` (spread ±${(story.consensus_spread / 2).toFixed(3)})` : ''}`}
          >×{story.consensus_model_count}{story.consensus_spread != null ? ` ±${(story.consensus_spread / 2).toFixed(2)}` : ''}</span>
        )}
        {rightsWashing && (
          <span
            class="badge"
            style="background: rgba(217,119,6,0.15); color: var(--color-warning); font-size: var(--font-xs); margin-left: 3px;"
            title={`Rights-washing: editorial says positive (E:${formatScore(story.hcb_editorial_mean)}) but structural behavior is negative (S:${formatScore(story.hcb_structural_mean)}). SETL: ${formatSetl(aggSetl)}`}
          >⚠ says≠does</span>
        )}
      </>
    ) : story.eval_status === 'evaluating' ? (
      <span> | <span style="color: var(--channel-editorial); font-size: var(--font-sm);">evaluating</span></span>
    ) : story.eval_status === 'pending' ? (
      <span> | <span style="color: var(--color-warning); font-size: var(--font-sm);">queued</span></span>
    ) : story.eval_status === 'failed' ? (
      <span> | <a href={`/item/${story.hn_id}`} style="color: var(--color-negative); font-size: var(--font-sm);">failed</a></span>
    ) : story.eval_status === 'skipped' ? (
      <span> | <span style="color: var(--fg-secondary); font-size: var(--font-sm);">skipped</span></span>
    ) : null}
  </td>
</tr>
{/* Mini heatmap row for evaluated stories */}
{hasEval && miniScores.length > 0 && (
  <tr>
    <td colspan="2"></td>
    <td style="padding: 2px 0 4px 0;">
      <a href={`/item/${story.hn_id}`} style="text-decoration: none;">
        <MiniBar scores={miniScores} />
      </a>
    </td>
  </tr>
)}
{/* Spacer row */}
<tr style="height: 5px;"></tr>
