---
const currentPath = Astro.url.pathname;

function isActive(prefix: string): boolean {
  if (prefix === '/') return currentPath === '/' || currentPath.startsWith('/item/') || currentPath === '/past' || currentPath === '/velocity' || currentPath === '/dynamics';
  if (prefix === '/rights') return currentPath.startsWith('/rights') || currentPath.startsWith('/article/');
  if (prefix === '/sources') return currentPath === '/sources' || currentPath === '/domains' || currentPath.startsWith('/domain/') || currentPath === '/users' || currentPath.startsWith('/user/') || currentPath === '/factions';
  if (prefix === '/trends') return currentPath === '/trends' || currentPath === '/seldon';
  if (prefix === '/system') return currentPath === '/system' || currentPath === '/models';
  return currentPath === prefix;
}

const navItems = [
  { href: '/', label: 'stories', prefix: '/' },
  { href: '/rights', label: 'rights', prefix: '/rights' },
  { href: '/sources', label: 'sources', prefix: '/sources' },
  { href: '/trends', label: 'trends', prefix: '/trends' },
  { href: '/system', label: 'system', prefix: '/system' },
  { href: '/about', label: 'about', prefix: '/about' },
];
---

<table role="presentation" style="background-color: #d56500; padding: 2px;" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td style="width: 18px; padding-right: 4px;">
      <a href="/">
        <div style="width: 18px; height: 18px; border: 1px solid white; display: flex; align-items: center; justify-content: center;">
          <span style="color: white; font-weight: bold; font-size: 13px; line-height: 1;">H</span>
        </div>
      </a>
    </td>
    <td style="line-height: 12pt; height: 10px;">
      <span class="pagetop">
        <b class="hnname" style="margin-right: 10px;">
          <a href="/" style="color: black; text-decoration: none;">HN HRCB</a>
        </b>
        <span class="nav-links" style="font-size: var(--font-base);">
          {navItems.map((item, i) => (
            <>
              {i > 0 && ' | '}
              <a href={item.href} style={`color: black;${isActive(item.prefix) ? ' font-weight: bold;' : ''}`} aria-current={isActive(item.prefix) ? 'page' : undefined}>{item.label}</a>
            </>
          ))}
        </span>
      </span>
    </td>
  </tr>
</table>
