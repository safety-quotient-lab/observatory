---
// SPDX-License-Identifier: Apache-2.0
const currentPath = Astro.url.pathname;

function isActive(prefix: string): boolean {
  if (prefix === '/') return currentPath === '/';
  if (prefix === '/stories') return currentPath === '/stories' || currentPath.startsWith('/item/') || currentPath === '/past' || currentPath === '/velocity' || currentPath === '/dynamics';
  if (prefix === '/rights') return currentPath.startsWith('/rights') || currentPath.startsWith('/article/');
  if (prefix === '/sources') return currentPath === '/sources' || currentPath === '/domains' || currentPath.startsWith('/domain/') || currentPath === '/users' || currentPath.startsWith('/user/') || currentPath === '/factions';
  if (prefix === '/status') return currentPath.startsWith('/status');
  return currentPath === prefix;
}

const navItems = [
  { href: '/stories', label: 'stories', prefix: '/stories' },
  { href: '/signals', label: 'signals', prefix: '/signals' },
  { href: '/sources', label: 'sources', prefix: '/sources' },
  { href: '/rights', label: 'rights', prefix: '/rights' },
  { href: '/about', label: 'about', prefix: '/about' },
  { href: '/search', label: 'search', prefix: '/search' },
];
---

<table role="presentation" style="background-color: var(--color-orange); padding: 2px;" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    <td style="width: 18px; padding-right: 4px;">
      <a href="/">
        <div style="width: 18px; height: 18px; border: 1px solid white; display: flex; align-items: center; justify-content: center;">
          <span style="color: white; font-weight: bold; font-size: 13px; line-height: 1;">H</span>
        </div>
      </a>
    </td>
    <td style="line-height: 12pt; height: 10px;">
      <span class="pagetop">
        <b class="hnname" style="margin-right: 10px;">
          <a href="/" style="color: black; text-decoration: none;">HRO</a>
        </b>
        <span class="nav-links" style="font-size: var(--font-base);">
          {navItems.map((item, i) => (
            <>
              {i > 0 && ' | '}
              <a href={item.href} style={`color: black;${isActive(item.prefix) ? ' font-weight: bold;' : ''}`} aria-current={isActive(item.prefix) ? 'page' : undefined}>{item.label}</a>
            </>
          ))}
        </span>
      </span>
    </td>
    <td style="text-align: right; padding-right: 8px; white-space: nowrap;">
      <span style="font-size: 9pt; font-family: Verdana, Geneva, sans-serif;">
        <button class="theme-btn" data-theme="light" style="background:none;border:none;cursor:pointer;font-size:9pt;color:black;padding:1px 3px;font-weight:bold;" title="Light mode">light</button>
        <span style="color:rgba(0,0,0,0.4);">|</span>
        <button class="theme-btn" data-theme="dark" style="background:none;border:none;cursor:pointer;font-size:9pt;color:black;padding:1px 3px;opacity:0.55;" title="Dark mode">dark</button>
      </span>
    </td>
  </tr>
</table>
