---
// SPDX-License-Identifier: Apache-2.0

interface VarEntry {
  code: string;
  label: string;
  color: string;
  variance: number;
}

interface Props {
  interClusterVar: VarEntry[];
  maxVar: number;
}

const { interClusterVar, maxVar } = Astro.props;
---

<table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
  <tr>
    <td style="padding: 12px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
        What Drives Differentiation
        <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
          inter-cluster variance per signal dimension
        </span>
      </div>
      <div style="overflow-x: auto;">
      <svg width="500" viewBox={`0 0 500 ${interClusterVar.length * 28 + 10}`} style="display: block;">
        {interClusterVar.map((v, i) => {
          const barW = (v.variance / maxVar) * 350;
          const y = i * 28 + 5;
          return (
            <g>
              <text x="70" y={y + 14} fill="var(--fg-secondary)" font-size="10" font-family="monospace" text-anchor="end">{v.code}</text>
              <rect x="80" y={y + 2} width={350} height="16" rx="2" fill="var(--bg-surface)" />
              <rect x="80" y={y + 2} width={Math.max(barW, 2)} height="16" rx="2" fill={v.color} opacity="0.8">
                <title>{v.label}: variance {v.variance.toFixed(3)}</title>
              </rect>
              <text x={85 + barW} y={y + 14} fill="var(--fg-secondary)" font-size="9" font-family="monospace">{v.variance.toFixed(3)}</text>
            </g>
          );
        })}
      </svg>
      </div>
    </td>
  </tr>
</table>
