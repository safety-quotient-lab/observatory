---
// SPDX-License-Identifier: Apache-2.0
import { scoreToColor, formatScore, evidenceColor, directionalityColor, computeSetl, formatSetl, setlToColor, fwRatioColor, formatFwRatio } from '../lib/colors';
import { ARTICLE_TITLES } from '../lib/udhr';
import type { Score } from '../lib/types';

interface Props {
  score: Score;
  index: number;
  channel?: 'editorial' | 'structural';
}

const { score, index, channel } = Astro.props;

// Pick the display value based on channel
const displayValue = channel === 'editorial' ? score.editorial
  : channel === 'structural' ? score.structural
  : score.final;
const isND = displayValue === null;
const color = scoreToColor(displayValue);
const title = ARTICLE_TITLES[score.section] || score.section;

const EVIDENCE_LABELS: Record<string, string> = {H: 'High', M: 'Medium', L: 'Low'};
const DIRECTION_LABELS: Record<string, string> = {A: 'Advocacy', F: 'Framing', P: 'Practice', C: 'Coverage'};
const sectionMatch = score.section.match(/^Article\s+(\d+)$/i);
const sectionIndex = score.section === 'Preamble' ? 0 : sectionMatch ? parseInt(sectionMatch[1], 10) : null;
const articleSetl = computeSetl(score.structural, score.editorial);

const hasFw = (score.witness_facts && score.witness_facts.length > 0) || (score.witness_inferences && score.witness_inferences.length > 0);
const fwRatio = score.witness_ratio ?? null;
---

<details class="group border-b border-surface-3/50">
  <summary class="flex items-center gap-3 py-3 px-4 cursor-pointer hover:bg-surface-2/50 transition-colors select-none">
    <!-- Score cell -->
    <div
      class="w-10 h-10 rounded flex items-center justify-center score-font text-xs font-bold shrink-0"
      style={`background: ${isND ? '#6b728020' : color + '30'}; color: ${isND ? '#6b7280' : color}; border: 1px solid ${isND ? '#6b7280' : color}40`}
    >
      {formatScore(displayValue)}
    </div>

    <!-- Section info -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        {sectionIndex !== null ? (
          <a href={`/article/${sectionIndex}`} class="score-font text-sm text-gray-300" style="text-decoration: none; color: inherit;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">{score.section}</a>
        ) : (
          <span class="score-font text-sm text-gray-300">{score.section}</span>
        )}
        <span class="text-sm text-gray-500">{title}</span>
      </div>
    </div>

    <!-- Badges -->
    <div class="flex items-center gap-1.5 shrink-0 ev-badges">
      {score.evidence && (
        <span
          class="badge text-[10px]"
          style={`background: ${evidenceColor(score.evidence)}20; color: ${evidenceColor(score.evidence)};`}
        >
          {EVIDENCE_LABELS[score.evidence] || score.evidence}
        </span>
      )}
      {score.directionality.map((d) => (
        <span
          class="badge text-[10px]"
          style={`background: ${directionalityColor(d)}20; color: ${directionalityColor(d)};`}
        >
          {DIRECTION_LABELS[d] || d}
        </span>
      ))}
    </div>

    <!-- Chevron -->
    <svg class="w-4 h-4 text-gray-500 transition-transform group-open:rotate-180 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>

  <div class="px-4 pb-4 pt-1 ml-[52px]">
    {!isND ? (
      channel === 'editorial' ? (
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Editorial</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.editorial)}`}>
              {formatScore(score.editorial)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2" title="Structural-Editorial Tension Level">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">SETL</div>
            <div class="score-font text-sm" style={`color: ${setlToColor(articleSetl)}`}>
              {formatSetl(articleSetl)}
            </div>
          </div>
        </div>
      ) : channel === 'structural' ? (
        <div class="grid grid-cols-3 gap-3 mb-3">
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Structural</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.structural)}`}>
              {formatScore(score.structural)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Context Modifier</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.context_modifier)}`}>
              {formatScore(score.context_modifier)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2" title="Structural-Editorial Tension Level">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">SETL</div>
            <div class="score-font text-sm" style={`color: ${setlToColor(articleSetl)}`}>
              {formatSetl(articleSetl)}
            </div>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-3">
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Editorial</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.editorial)}`}>
              {formatScore(score.editorial)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Structural</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.structural)}`}>
              {formatScore(score.structural)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2" title="Structural-Editorial Tension Level">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">SETL</div>
            <div class="score-font text-sm" style={`color: ${setlToColor(articleSetl)}`}>
              {formatSetl(articleSetl)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Combined</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.combined)}`}>
              {formatScore(score.combined)}
            </div>
          </div>
          <div class="bg-surface-2 rounded px-3 py-2">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Context Modifier</div>
            <div class="score-font text-sm" style={`color: ${scoreToColor(score.context_modifier)}`}>
              {formatScore(score.context_modifier)}
            </div>
          </div>
        </div>
      )
    ) : null}
    <p class="text-sm text-gray-400 leading-relaxed fw-hide">{
      channel === 'editorial' ? (score.editorial_note || score.note)
        : channel === 'structural' ? (score.structural_note || score.note)
        : score.note
    }</p>

    {hasFw && channel !== 'structural' && (
      <>
        <div class="fw-only" style="display:none;">
          {fwRatio !== null && (
            <span
              class="badge text-[10px] mb-2 inline-block"
              style={`background: ${fwRatioColor(fwRatio)}20; color: ${fwRatioColor(fwRatio)};`}
            >
              FW Ratio: {formatFwRatio(fwRatio)}
            </span>
          )}
        </div>
        {score.witness_facts && score.witness_facts.length > 0 && (
          <div class="fw-only mt-2" style="display:none;">
            <div class="text-[10px] text-green-400 uppercase tracking-wider font-bold mb-1">Observable Facts</div>
            <ul class="text-sm text-gray-300 leading-relaxed list-disc list-inside space-y-0.5">
              {score.witness_facts.map((fact) => (
                <li>{fact}</li>
              ))}
            </ul>
          </div>
        )}
        {score.witness_inferences && score.witness_inferences.length > 0 && (
          <div class="fw-only mt-2" style="display:none;">
            <div class="text-[10px] text-purple-400 uppercase tracking-wider font-bold mb-1">Inferences</div>
            <ul class="text-sm text-gray-400 leading-relaxed list-disc list-inside space-y-0.5 italic">
              {score.witness_inferences.map((inf) => (
                <li>{inf}</li>
              ))}
            </ul>
          </div>
        )}
      </>
    )}
  </div>
</details>
