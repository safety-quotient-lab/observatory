---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'HN HRCB — Hacker News stories scored against the UN Universal Declaration of Human Rights',
  ogTitle,
  ogDescription,
  ogUrl,
  canonicalUrl,
} = Astro.props;

const triggerSecret = Astro.locals.runtime?.env?.TRIGGER_SECRET || '';

// Last evaluation timestamp for footer
let lastEvaluatedAt: string | null = null;
try {
  const db = Astro.locals.runtime?.env?.DB;
  if (db) {
    const row = await db
      .prepare(`SELECT MAX(evaluated_at) as last_eval FROM stories WHERE eval_status = 'done'`)
      .first<{ last_eval: string | null }>();
    lastEvaluatedAt = row?.last_eval ?? null;
  }
} catch { /* graceful fallback */ }
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | HN HRCB</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="alternate" type="application/atom+xml" title="HN HRCB Feed" href="/feed.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="HN HRCB" />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
  </head>
  <body data-ts={triggerSecret}>
    <center>
      <table id="hnmain" width="85%" cellpadding="0" cellspacing="0" style="background-color: #002d38; max-width: 1280px;">
        <tr>
          <td>
            <Nav />
          </td>
        </tr>
        <tr style="height: 10px;"></tr>
        <tr>
          <td>
            <slot />
          </td>
        </tr>
        <tr>
          <td>
            <Footer lastEvaluatedAt={lastEvaluatedAt} />
          </td>
        </tr>
      </table>
    </center>
    {/* Donate modal */}
    <div id="donate-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.7); align-items:center; justify-content:center;">
      <div style="background:#093946; border:1px solid #1a5568; border-radius:8px; padding:24px; max-width:400px; width:90%; text-align:center;">
        <div style="color:#98a8a8; font-size:14pt; margin-bottom:12px;">Support HN HRCB</div>
        <div style="color:#5b7279; font-size:10pt; line-height:1.6; margin-bottom:20px;">
          Evaluations use Claude API credits. Please consider donating to keep the service running.
        </div>
        <form action="https://www.paypal.com/donate" method="post" target="_blank" id="donate-form">
          <input type="hidden" name="hosted_button_id" value="56GCFHDZHB7AJ" />
          <button type="submit" style="background:rgba(234,179,8,0.2); border:1px solid rgba(234,179,8,0.4); color:#eab308; cursor:pointer; padding:10px 28px; font-size:11pt; border-radius:6px; font-weight:bold;">
            Donate via PayPal
          </button>
        </form>
        <div style="margin-top:16px;">
          <a href="#" id="already-donated" style="color:#5b7279; font-size:9pt; text-decoration:underline;">I've already donated</a>
        </div>
      </div>
    </div>

    <script>
      function scoreColor(score: number): string {
        if (score > 0) {
          const t = Math.min(score, 1);
          return `rgb(${Math.round(0xea+(0x16-0xea)*t)},${Math.round(0xb3+(0xa3-0xb3)*t)},${Math.round(0x08+(0x4a-0x08)*t)})`;
        } else if (score < 0) {
          const t = Math.min(Math.abs(score), 1);
          return `rgb(${Math.round(0xea+(0xdc-0xea)*t)},${Math.round(0xb3+(0x26-0xb3)*t)},${Math.round(0x08+(0x26-0x08)*t)})`;
        }
        return '#eab308';
      }

      function makeRetryBtn(hnId: string, title: string): HTMLButtonElement {
        const btn = document.createElement('button');
        btn.className = 'trigger-btn';
        btn.dataset.hnId = hnId;
        btn.title = title;
        btn.style.cssText = 'background:none;border:none;cursor:pointer;padding:2px 4px;font-size:10pt;color:#dc2626;';
        btn.textContent = '\u25B6';
        return btn;
      }

      // Donate modal logic
      const donateModal = document.getElementById('donate-modal')!;
      const donateForm = document.getElementById('donate-form')!;
      const alreadyDonated = document.getElementById('already-donated')!;
      let pendingTriggerBtn: HTMLElement | null = null;

      function showDonateModal(btn: HTMLElement) {
        pendingTriggerBtn = btn;
        donateModal.style.display = 'flex';
      }

      function hideDonateModal() {
        donateModal.style.display = 'none';
      }

      function markDonated() {
        localStorage.setItem('hrcb_donated', new Date().toISOString());
      }

      function hasDonated(): boolean {
        return !!localStorage.getItem('hrcb_donated');
      }

      function onDonationConfirmed() {
        markDonated();
        hideDonateModal();
        if (pendingTriggerBtn) {
          pendingTriggerBtn.click();
          pendingTriggerBtn = null;
        }
        // Handle batch eval button (set by [username].astro)
        if ((window as any).__pendingEvalAll) {
          delete (window as any).__pendingEvalAll;
          const evalBtn = document.getElementById('eval-all-btn') as HTMLButtonElement | null;
          if (evalBtn) evalBtn.click();
        }
        // Handle retry button (set by [id].astro)
        if ((window as any).__pendingRetryBtn) {
          const retryBtn = (window as any).__pendingRetryBtn;
          delete (window as any).__pendingRetryBtn;
          retryBtn.click();
        }
      }

      donateForm.addEventListener('submit', () => {
        onDonationConfirmed();
      });

      alreadyDonated.addEventListener('click', (e) => {
        e.preventDefault();
        onDonationConfirmed();
      });

      // Close modal on overlay click
      donateModal.addEventListener('click', (e) => {
        if (e.target === donateModal) {
          hideDonateModal();
          pendingTriggerBtn = null;
        }
      });

      document.addEventListener('click', async (e) => {
        const btn = (e.target as HTMLElement).closest('.trigger-btn') as HTMLButtonElement | null;
        if (!btn) return;

        const hnId = btn.dataset.hnId;
        if (!hnId) return;

        // Gate: require donation
        if (!hasDonated()) {
          showDonateModal(btn);
          return;
        }

        // Replace button with spinning gear
        const spinner = document.createElement('span');
        spinner.className = 'eval-spinner';
        spinner.style.color = '#60a5fa';
        spinner.style.fontSize = '8pt';
        spinner.style.display = 'inline-block';
        spinner.title = 'Starting...';
        spinner.textContent = '\u2699';
        btn.replaceWith(spinner);

        // Find subtext elements
        const row = spinner.closest('tr');
        const subtextRow = row?.nextElementSibling;
        const subtextTd = subtextRow?.querySelector('.subtext');

        // Ensure status span exists in subtext
        let statusEl = subtextTd?.querySelector('.eval-status') as HTMLElement | null;
        if (!statusEl && subtextTd) {
          statusEl = document.createElement('span');
          statusEl.className = 'eval-status';
          subtextTd.appendChild(statusEl);
        }

        function setStatus(text: string, color: string = '#60a5fa') {
          if (!statusEl) return;
          statusEl.textContent = '';
          const sep = document.createTextNode(' | ');
          const span = document.createElement('span');
          span.style.cssText = `color: ${color}; font-size: 8pt;`;
          span.textContent = text;
          statusEl.appendChild(sep);
          statusEl.appendChild(span);
        }

        setStatus('connecting...', '#60a5fa');

        try {
          const ts = document.body.dataset.ts;
          const headers: Record<string, string> = {};
          if (ts) headers['Authorization'] = `Bearer ${ts}`;
          const res = await fetch(`/api/trigger/${hnId}`, { method: 'POST', headers });

          // Check if we got an SSE stream or a plain JSON error
          const contentType = res.headers.get('content-type') || '';

          if (contentType.includes('text/event-stream')) {
            // Read SSE stream
            const reader = res.body!.getReader();
            const decoder = new TextDecoder();
            let buffer = '';

            while (true) {
              const { done, value } = await reader.read();
              if (done) break;

              buffer += decoder.decode(value, { stream: true });

              // Parse complete SSE messages from buffer
              const parts = buffer.split('\n\n');
              buffer = parts.pop() || '';

              for (const part of parts) {
                if (!part.trim()) continue;
                let event = 'message';
                let data = '';
                for (const line of part.split('\n')) {
                  if (line.startsWith('event: ')) event = line.slice(7);
                  else if (line.startsWith('data: ')) data = line.slice(6);
                }
                if (!data) continue;

                const parsed = JSON.parse(data);

                if (event === 'status') {
                  spinner.title = parsed.message;
                  if (parsed.step === 'fetching') {
                    setStatus('fetching page...', '#60a5fa');
                  } else if (parsed.step === 'evaluating') {
                    setStatus('calling Claude...', '#60a5fa');
                  } else if (parsed.step === 'writing') {
                    setStatus('saving results...', '#60a5fa');
                  }
                } else if (event === 'done') {
                  const score = parsed.score as number;
                  const sign = score > 0 ? '+' : '';
                  const formatted = `${sign}${score.toFixed(2)}`;

                  const link = document.createElement('a');
                  link.href = `/item/${hnId}`;
                  link.title = `HRCB: ${formatted}`;
                  const scoreEl = document.createElement('span');
                  scoreEl.className = 'score-font';
                  scoreEl.style.color = scoreColor(score);
                  scoreEl.style.fontSize = '9pt';
                  scoreEl.style.fontWeight = 'bold';
                  scoreEl.textContent = formatted;
                  link.appendChild(scoreEl);
                  spinner.replaceWith(link);

                  if (statusEl) {
                    statusEl.textContent = '';
                    const sep = document.createTextNode(' | ');
                    const link = document.createElement('a');
                    link.href = `/item/${hnId}`;
                    link.style.color = '#d56500';
                    link.textContent = 'hrcb';
                    statusEl.appendChild(sep);
                    statusEl.appendChild(link);
                  }
                } else if (event === 'error') {
                  spinner.replaceWith(makeRetryBtn(hnId, parsed.error || 'Failed — click to retry'));
                  setStatus('failed', '#dc2626');
                }
              }
            }
          } else {
            // Plain JSON error response (409, 404, etc.)
            const data = await res.json();
            spinner.replaceWith(makeRetryBtn(hnId, data.error || 'Failed — click to retry'));
            setStatus(data.error || 'error', '#dc2626');
          }
        } catch (err) {
          spinner.replaceWith(makeRetryBtn(hnId, 'Network error — click to retry'));
          setStatus('network error', '#dc2626');
        }
      });
    </script>
  </body>
</html>
