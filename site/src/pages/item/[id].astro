---
import Base from '../../layouts/Base.astro';
import HeatMap from '../../components/HeatMap.astro';
import RadarChart from '../../components/RadarChart.astro';
import DcpTable from '../../components/DcpTable.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, evidenceColor, computeSetl, formatSetl, setlToColor } from '../../lib/colors';
import { getStory } from '../../lib/db';
import { CONTENT_TYPE_LABELS } from '../../lib/types';
import type { Evaluation } from '../../lib/types';

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const hnId = parseInt(id!, 10);
if (isNaN(hnId)) {
  return Astro.redirect('/');
}

const storyData = await getStory(db, hnId);
if (!storyData || storyData.eval_status !== 'done' || !storyData.hcb_json) {
  return Astro.redirect('/');
}

let evalData: Evaluation;
try {
  evalData = JSON.parse(storyData.hcb_json) as Evaluation;
} catch {
  return Astro.redirect('/');
}
const { evaluation, domain_context_profile, aggregates } = evalData;
const scores = storyData.scores.length > 0 ? storyData.scores : evalData.scores;

const classColor = classificationColor(aggregates.classification);
const classText = classificationTextColor(aggregates.classification);

// Compute aggregate SETL from scores
const setlValues = scores
  .map(s => computeSetl(s.structural, s.editorial))
  .filter((v): v is number => v !== null);
const aggSetl = setlValues.length > 0
  ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
  : null;

const siteUrl = Astro.url.origin;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: `HRCB Evaluation: ${storyData.title}`,
  description: `Human Rights Compatibility Bias evaluation of "${storyData.title}" against the UN Universal Declaration of Human Rights. Classification: ${aggregates.classification}. Score: ${formatScore(aggregates.weighted_mean)}.`,
  url: `${siteUrl}/item/${storyData.hn_id}`,
  datePublished: storyData.evaluated_at || undefined,
  author: {
    '@type': 'Organization',
    name: 'HN HRCB',
    url: siteUrl,
  },
  itemReviewed: {
    '@type': 'CreativeWork',
    name: storyData.title,
    url: storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`,
    ...(storyData.domain && { publisher: { '@type': 'Organization', name: storyData.domain } }),
    ...(storyData.hn_by && { author: { '@type': 'Person', name: storyData.hn_by } }),
    datePublished: new Date(storyData.hn_time * 1000).toISOString(),
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: aggregates.weighted_mean,
    bestRating: 1.0,
    worstRating: -1.0,
    ratingExplanation: `HRCB ${aggregates.classification} — evaluated against ${aggregates.signal_sections} of 31 UDHR provisions using methodology v${evaluation.methodology}`,
  },
  reviewBody: `Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}. ${aggregates.signal_sections} sections scored, ${aggregates.nd_count} with no data. Volatility: ${aggregates.volatility.label} (${aggregates.volatility.value.toFixed(2)}).`,
  about: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
};

const EVIDENCE_LABELS: Record<string, string> = {H: 'High', M: 'Medium', L: 'Low', ND: 'No Data'};

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

<Base
  title={`${storyData.title} — HRCB`}
  ogTitle={`${formatScore(aggregates.weighted_mean)} ${storyData.title}`}
  ogDescription={`HRCB: ${aggregates.classification} (${formatScore(aggregates.weighted_mean)}) — ${aggregates.signal_sections} of 31 UDHR provisions scored. ${storyData.domain || 'self-post'}`}
  ogUrl={`${siteUrl}/item/${storyData.hn_id}`}
  canonicalUrl={`${siteUrl}/item/${storyData.hn_id}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
  {/* Story header - HN style */}
  <table cellpadding="0" cellspacing="0" width="100%">
    <tr class="athing">
      <td valign="top" style="padding: 5px 10px 0 0; text-align: center; width: 44px;">
        <span
          class="score-font"
          style={`color: ${scoreToColor(aggregates.weighted_mean)}; font-size: 14pt; font-weight: bold;`}
        >
          {formatScore(aggregates.weighted_mean)}
        </span>
      </td>
      <td>
        <span class="titleline" style="font-size: 12pt;">
          <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
             target="_blank" rel="noopener"
          >
            {storyData.title}
          </a>
        </span>
        {storyData.domain && (
          <span class="sitebit" style="font-size: 8pt; margin-left: 5px;">
            (<a href={`https://${storyData.domain}`} target="_blank" rel="noopener">{storyData.domain}</a>)
          </span>
        )}
      </td>
    </tr>
    <tr>
      <td></td>
      <td class="subtext" style="padding-bottom: 8px;">
        {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
        {storyData.hn_by && <span> by <a href={`https://news.ycombinator.com/user?id=${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
        <span> {timeAgo(storyData.hn_time)}</span>
        <span> | </span>
        <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
          {storyData.hn_comments ?? 0} comments on HN
        </a>
        <span> | </span>
        <span
          class="badge"
          style={`background: ${classColor}; color: ${classText}; font-size: 7pt;`}
        >
          {aggregates.classification}
        </span>
        <span style="color: #828282; margin-left: 4px;">
          <span title={`Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}`} style="cursor: help;">
            {CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}
          </span>
          · v{evaluation.methodology} · {evaluation.date}
        </span>
      </td>
    </tr>
  </table>

  <tr style="height: 10px;"></tr>

  {/* Heatmap */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Article Heatmap</div>
        <HeatMap scores={scores} compact={false} showLabels={true} />
        <div style="display: flex; gap: 12px; margin-top: 8px; font-size: 7pt; color: #666;">
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #dc2626; border-radius: 2px;"></span> Negative</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #555; border-radius: 2px;"></span> Neutral</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #16a34a; border-radius: 2px;"></span> Positive</span>
          <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: #2a2a35; border-radius: 2px;"></span> No Data</span>
        </div>
      </td>
    </tr>
  </table>

  {/* Stats + Radar */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Aggregates</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: 8pt;">
            <tr>
              <td style="color: #666;">Weighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>{formatScore(aggregates.weighted_mean)}</td>
              <td style="color: #666;">Unweighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.unweighted_mean)}`}>{formatScore(aggregates.unweighted_mean)}</td>
            </tr>
            <tr>
              <td style="color: #666;">Max</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.max.value)}`}>{formatScore(aggregates.max.value)} <span style="color: #555;">{aggregates.max.section}</span></td>
              <td style="color: #666;">Min</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.min.value)}`}>{formatScore(aggregates.min.value)} <span style="color: #555;">{aggregates.min.section}</span></td>
            </tr>
            <tr>
              <td style="color: #666;">Signal</td>
              <td class="score-font" style="color: #ccc;">{aggregates.signal_sections}</td>
              <td style="color: #666;" title="Articles with insufficient evidence to score">No Data</td>
              <td class="score-font" style="color: #666;">{aggregates.nd_count}</td>
            </tr>
            <tr>
              <td style="color: #666;">Negative</td>
              <td class="score-font" style="color: #ef4444;">{aggregates.negative_count}</td>
              <td style="color: #666;">Volatility</td>
              <td class="score-font" style="color: #ccc;">{aggregates.volatility.value.toFixed(2)} ({aggregates.volatility.label})</td>
            </tr>
            <tr>
              <td style="color: #666;">Channels</td>
              <td colspan="3" class="score-font">
                <span style="color: #60a5fa;" title="What the content says">Editorial: {evaluation.channel_weights.editorial}</span>
                <span style="color: #22d3ee; margin-left: 6px;" title="What the site does">Structural: {evaluation.channel_weights.structural}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Structural-Editorial Tension Level: normalized difference between S and E channels">SETL</td>
              <td class="score-font" style={`color: ${setlToColor(aggSetl)};`}>{formatSetl(aggSetl)}</td>
              <td style="color: #555; font-size: 7pt;" colspan="2">{aggSetl !== null ? (aggSetl > 0 ? 'Editorial-dominant' : aggSetl < 0 ? 'Structural-dominant' : 'Balanced') : ''}</td>
            </tr>
          </table>
          <div style="margin-top: 6px;">
            <span style="color: #666; font-size: 7pt;">Evidence: </span>
            {Object.entries(aggregates.evidence_profile).map(([key, count]) => {
              const label = EVIDENCE_LABELS[key] || key;
              return (
                <span
                  class="badge"
                  style={`background: ${evidenceColor(key === 'ND' ? null : key)}30; color: ${evidenceColor(key === 'ND' ? null : key)}; font-size: 7pt; margin-right: 3px;`}
                >
                  {label}: {count}
                </span>
              );
            })}
          </div>
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Theme Radar</div>
          <RadarChart scores={scores} size={300} />
        </div>
      </td>
    </tr>
  </table>

  {/* DCP */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Domain Context Profile</div>
        <DcpTable elements={domain_context_profile.elements} />
      </td>
    </tr>
  </table>

  {/* Score breakdown */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 20px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Score Breakdown</div>
        {scores.map((score, i) => (
          <ArticleDetail score={score} index={i} />
        ))}
      </td>
    </tr>
  </table>
</Base>
