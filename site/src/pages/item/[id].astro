---
import Base from '../../layouts/Base.astro';
import HeatMap from '../../components/HeatMap.astro';
import RadarChart from '../../components/RadarChart.astro';
import DcpTable from '../../components/DcpTable.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import ModelCompareTable from '../../components/ModelCompareTable.astro';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, evidenceColor, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence, fwRatioColor, formatFwRatio } from '../../lib/colors';
import { getStory, getStoryComments, getDomainDcp, getEventsForStory, getRaterEvalsForStory, getRaterScores } from '../../lib/db';
import { CONTENT_TYPE_LABELS } from '../../lib/types';
import type { Evaluation } from '../../lib/types';
import { modelDisplayName, PRIMARY_MODEL_ID, isLightMode } from '../../lib/shared-eval';
import { sanitizeHtml } from '../../lib/sanitize';

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const url = new URL(Astro.request.url);
const modelParam = url.searchParams.get('model');
const viewParam = url.searchParams.get('view');

const hnId = parseInt(id!, 10);
if (isNaN(hnId)) {
  return Astro.redirect('/');
}

const storyData = await getStory(db, hnId);
if (!storyData) {
  return Astro.redirect('/');
}

// Fetch multi-model evals for tabs
let raterEvals: Awaited<ReturnType<typeof getRaterEvalsForStory>> = [];
try {
  raterEvals = await getRaterEvalsForStory(db, hnId);
} catch { /* table may not exist yet */ }
const hasMultipleModels = raterEvals.length > 1;

// If viewing a non-primary model, load its scores
let altModelScores: Awaited<ReturnType<typeof getRaterScores>> = [];
let altModelEval = modelParam ? raterEvals.find(e => e.eval_model === modelParam) : null;
if (modelParam && altModelEval) {
  try {
    altModelScores = await getRaterScores(db, hnId, modelParam);
  } catch { /* table may not exist yet */ }
}

// For compare view, load scores for all models
const compareScoresByModel: Record<string, Awaited<ReturnType<typeof getRaterScores>>> = {};
if (viewParam === 'compare' && raterEvals.length >= 2) {
  for (const re of raterEvals) {
    try {
      compareScoresByModel[re.eval_model] = await getRaterScores(db, hnId, re.eval_model);
    } catch { /* ignore */ }
  }
}

// Handle statuses
const isFailed = storyData.eval_status === 'failed';
const isDone = storyData.eval_status === 'done' && !!storyData.hcb_json;
const isPending = storyData.eval_status === 'pending' || storyData.eval_status === 'evaluating';
// Light-only: done status but no full hcb_json — has rater_evals with lite models
const isLightOnlyEval = !isDone && storyData.eval_status === 'done' && raterEvals.some(re => isLightMode(re.prompt_mode));
const lightEval = isLightOnlyEval ? (raterEvals.find(re => isLightMode(re.prompt_mode)) ?? null) : null;

let evalData: Evaluation | null = null;
let cachedDcp: string | null = null;
if (isDone) {
  try {
    evalData = JSON.parse(storyData.hcb_json!) as Evaluation;
  } catch (_e) {
    return Astro.redirect('/');
  }
}
let cachedDcpElements: any[] | null = null;
if (isFailed && storyData.domain) {
  cachedDcp = await getDomainDcp(db, storyData.domain);
  if (cachedDcp) {
    try {
      const dcpData = JSON.parse(cachedDcp);
      cachedDcpElements = dcpData.elements || dcpData;
    } catch (_e) { /* ignore parse errors */ }
  }
}
const evaluation = evalData?.evaluation;
const domain_context_profile = evalData?.domain_context_profile;
const aggregates = evalData?.aggregates;
const scores = isDone ? (storyData.scores.length > 0 ? storyData.scores : evalData!.scores) : [];

const classColor = aggregates ? classificationColor(aggregates.classification) : '#5b7279';
const classText = aggregates ? classificationTextColor(aggregates.classification) : '#98a8a8';

// Fair Witness: detect if any score has FW data (from evalData JSON, not DB scores)
const fwScores = evalData?.scores ?? [];
const hasFairWitness = fwScores.some(s =>
  (s.witness_facts && s.witness_facts.length > 0) || (s.witness_inferences && s.witness_inferences.length > 0)
);
// Merge FW data + split notes from evalData into display scores
const displayScores = isDone ? scores.map(s => {
  const fwMatch = fwScores.find(fs => fs.section === s.section);
  const merged: typeof s = { ...s };
  if (fwMatch) {
    merged.witness_facts = fwMatch.witness_facts;
    merged.witness_inferences = fwMatch.witness_inferences;
    merged.witness_ratio = fwMatch.witness_ratio;
    // Merge split notes from evalData JSON if not already in DB row
    if (!merged.editorial_note && (fwMatch as any).editorial_note) {
      merged.editorial_note = (fwMatch as any).editorial_note;
    }
    if (!merged.structural_note && (fwMatch as any).structural_note) {
      merged.structural_note = (fwMatch as any).structural_note;
    }
  }
  return merged;
}) : [];
// Power-ranked: sort by channel score descending, ND articles last
const editorialRanked = [...displayScores].sort((a, b) => {
  if (a.editorial === null && b.editorial === null) return 0;
  if (a.editorial === null) return 1;
  if (b.editorial === null) return -1;
  return b.editorial - a.editorial;
});
const structuralRanked = [...displayScores].sort((a, b) => {
  if (a.structural === null && b.structural === null) return 0;
  if (a.structural === null) return 1;
  if (b.structural === null) return -1;
  return b.structural - a.structural;
});
// FW aggregate metrics
const fwRatio = storyData.fw_ratio ?? (hasFairWitness ? (() => {
  let facts = 0, inferences = 0;
  for (const s of fwScores) {
    facts += s.witness_facts?.length ?? 0;
    inferences += s.witness_inferences?.length ?? 0;
  }
  const total = facts + inferences;
  return total > 0 ? facts / total : null;
})() : null);
const fwObservableCount = storyData.fw_observable_count ?? fwScores.reduce((n, s) => n + (s.witness_facts?.length ?? 0), 0);
const fwInferenceCount = storyData.fw_inference_count ?? fwScores.reduce((n, s) => n + (s.witness_inferences?.length ?? 0), 0);

// Compute aggregate SETL from scores
const setlValues = scores
  .map(s => computeSetl(s.structural, s.editorial))
  .filter((v): v is number => v !== null);
const aggSetl = setlValues.length > 0
  ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
  : null;

// Confidence (evidence-weighted)
const confidence = computeConfidence(storyData.hcb_evidence_h, storyData.hcb_evidence_m, storyData.hcb_evidence_l, storyData.hcb_nd_count);

// Story-level labels (v3.6+)
const themeTag = evalData?.theme_tag || storyData.hcb_theme_tag || null;
const sentimentTag = evalData?.sentiment_tag || storyData.hcb_sentiment_tag || null;
const executiveSummary = evalData?.executive_summary || storyData.hcb_executive_summary || null;

// Supplementary signals (from evalData JSON with fallback to materialized columns)
const eqData = evalData?.epistemic_quality ?? null;
const eqScore = eqData?.eq_score ?? storyData.eq_score ?? null;
const ptFlags = evalData?.propaganda_flags ?? (storyData.pt_flags_json ? JSON.parse(storyData.pt_flags_json) : null);
const ptFlagCount = ptFlags?.length ?? storyData.pt_flag_count ?? 0;
const soData = evalData?.solution_orientation ?? null;
const etData = evalData?.emotional_tone ?? null;
const srData = evalData?.stakeholder_representation ?? null;
const tfData = evalData?.temporal_framing ?? null;
const gsData = evalData?.geographic_scope ?? null;
const clData = evalData?.complexity_level ?? null;
const tdData = evalData?.transparency_disclosure ?? null;
const hasSignals = eqScore !== null || ptFlagCount > 0 || soData !== null || etData !== null || srData !== null || tfData !== null || gsData !== null || clData !== null || tdData !== null;

let comments: Awaited<ReturnType<typeof getStoryComments>> = [];
try {
  comments = await getStoryComments(db, hnId);
} catch {
  // story_comments table may not exist yet — graceful fallback
}

let storyEvents: Awaited<ReturnType<typeof getEventsForStory>> = [];
try {
  storyEvents = await getEventsForStory(db, hnId, 20);
} catch {
  // events table may not exist yet — graceful fallback
}

const siteUrl = Astro.url.origin;

const jsonLd = isDone && aggregates && evaluation ? {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: `HRCB Evaluation: ${storyData.title}`,
  description: `Human Rights Compatibility Bias evaluation of "${storyData.title}" against the UN Universal Declaration of Human Rights. Classification: ${aggregates.classification}. HRCB: ${formatScore(aggregates.weighted_mean)}.`,
  url: `${siteUrl}/item/${storyData.hn_id}`,
  datePublished: storyData.evaluated_at || undefined,
  author: {
    '@type': 'Organization',
    name: 'HN HRCB',
    url: siteUrl,
  },
  itemReviewed: {
    '@type': 'CreativeWork',
    name: storyData.title,
    url: storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`,
    ...(storyData.domain && { publisher: { '@type': 'Organization', name: storyData.domain } }),
    ...(storyData.hn_by && { author: { '@type': 'Person', name: storyData.hn_by } }),
    datePublished: new Date(storyData.hn_time * 1000).toISOString(),
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: aggregates.weighted_mean,
    bestRating: 1.0,
    worstRating: -1.0,
    ratingExplanation: `HRCB ${aggregates.classification} — evaluated against ${aggregates.signal_sections} of 31 UDHR provisions using methodology v${evaluation.methodology}`,
  },
  reviewBody: executiveSummary || `Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}. ${aggregates.signal_sections} sections scored, ${aggregates.nd_count} with no data. Volatility: ${aggregates.volatility.label} (${aggregates.volatility.value.toFixed(2)}).`,
  about: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;

const EVIDENCE_LABELS: Record<string, string> = {H: 'High', M: 'Medium', L: 'Low', ND: 'No Data'};

const EVENT_TYPE_COLORS: Record<string, string> = {
  eval_failure: '#dc2626', eval_retry: '#f97316', eval_skip: '#6b7280',
  eval_success: '#16a34a', rate_limit: '#eab308', fetch_error: '#dc2626',
  parse_error: '#dc2626', trigger: '#60a5fa', r2_error: '#f97316',
};

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

<Base
  title={`${storyData.title} — ${isFailed ? 'Failed' : isPending ? 'Pending' : isLightOnlyEval ? 'HRCB~lite' : 'HRCB'}`}
  ogTitle={isDone && aggregates ? `${formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)} ${storyData.title}` : storyData.title}
  ogDescription={isDone && aggregates ? (executiveSummary || `HRCB: ${aggregates.classification} (${formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}) — ${aggregates.signal_sections} of 31 UDHR provisions scored. ${storyData.domain || 'self-post'}`) : isPending ? `Evaluation pending for ${storyData.title}` : `Evaluation failed for ${storyData.title}`}
  ogUrl={`${siteUrl}/item/${storyData.hn_id}`}
  canonicalUrl={`${siteUrl}/item/${storyData.hn_id}`}
>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}

  {/* Breadcrumb */}
  <div style="padding: 4px 0; font-size: var(--font-xs); color: #5b7279;">
    <a href="/" style="color: #5b7279;">home</a>
    {storyData.domain && (
      <>
        <span style="color: #0d4655;"> / </span>
        <a href={`/domain/${storyData.domain}`} style="color: #5b7279;">{storyData.domain}</a>
      </>
    )}
    <span style="color: #0d4655;"> / </span>
    <span style="color: #5b7279;">item {storyData.hn_id}</span>
  </div>

  {/* Model tab bar (shown when multiple models have evaluated) */}
  {(isDone || isLightOnlyEval) && hasMultipleModels && (
    <div style="padding: 6px 0; margin-bottom: 4px; display: flex; gap: 4px; flex-wrap: wrap; align-items: center;">
      <span style="color: #5b7279; font-size: var(--font-xs); margin-right: 4px;">Model:</span>
      {raterEvals.map(re => {
        const isActive = modelParam ? modelParam === re.eval_model : re.eval_model === PRIMARY_MODEL_ID;
        const isPrimary = re.eval_model === PRIMARY_MODEL_ID;
        return (
          <a href={isPrimary ? `/item/${hnId}` : `/item/${hnId}?model=${re.eval_model}`}
             style={`padding: 2px 8px; font-size: var(--font-xs); border-radius: 3px; text-decoration: none; ${isActive ? 'background: #0d4655; color: #98a8a8; border: 1px solid #1a5568;' : 'background: #093946; color: #5b7279; border: 1px solid #0d4655;'}`}>
            {modelDisplayName(re.eval_model)}
            {isLightMode(re.prompt_mode) && <span style="color: #d56500; margin-left: 3px;" title="Light evaluation — editorial only, no per-section scores">lite</span>}
            <span style={`margin-left: 4px; color: ${scoreToColor(re.hcb_editorial_mean ?? re.hcb_weighted_mean)};`}>
              {formatScore(re.hcb_editorial_mean ?? re.hcb_weighted_mean)}
            </span>
          </a>
        );
      })}
      <a href={`/item/${hnId}?view=compare`}
         style={`padding: 2px 8px; font-size: var(--font-xs); border-radius: 3px; text-decoration: none; ${viewParam === 'compare' ? 'background: #0d4655; color: #98a8a8; border: 1px solid #1a5568;' : 'background: #093946; color: #5b7279; border: 1px solid #0d4655;'}`}>
        Compare
      </a>
    </div>
  )}

  {/* Compare view */}
  {viewParam === 'compare' && raterEvals.length >= 2 && (
    <ModelCompareTable evals={raterEvals} scoresByModel={compareScoresByModel} />
  )}

  {isFailed ? (
    <>
      {/* Failed evaluation page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            <span style="color: #dc2626; font-size: var(--font-lg);">&#10007;</span>
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
            <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Evaluation Failed</div>
            <div style="color: #dc2626; font-size: var(--font-base); padding: 8px 0; line-height: 1.5;">
              {storyData.eval_error || 'Unknown error'}
            </div>
            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm); margin-top: 8px;">
              {storyData.domain && (
                <tr>
                  <td style="color: #5b7279; width: 100px;">Domain</td>
                  <td><a href={`/domain/${storyData.domain}`} style="color: #98a8a8;">{storyData.domain}</a></td>
                </tr>
              )}
              {storyData.content_type && (
                <tr>
                  <td style="color: #5b7279;">Content Type</td>
                  <td style="color: #5b7279;">{CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}</td>
                </tr>
              )}
              <tr>
                <td style="color: #5b7279;">Created</td>
                <td style="color: #5b7279;">{storyData.created_at}</td>
              </tr>
            </table>
            <div style="margin-top: 12px;">
              <button
                class="trigger-btn"
                data-hn-id={storyData.hn_id}
                title="Retry evaluation"
                style="background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.3); cursor: pointer; padding: 4px 12px; font-size: var(--font-sm); color: #dc2626; border-radius: 4px;"
              >
                &#9654; Retry Evaluation
              </button>
            </div>
          </td>
        </tr>
      </table>

      {cachedDcpElements && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
          <tr>
            <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
              <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Cached Domain Context Profile
                <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">from previous evaluation</span>
              </div>
              <DcpTable elements={cachedDcpElements} />
            </td>
          </tr>
        </table>
      )}
    </>
  ) : isDone && aggregates && evaluation ? (
    <>
  {/* Story header - HN style */}
  <table cellpadding="0" cellspacing="0" width="100%">
    <tr class="athing">
      <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
        <span
          class="score-font"
          style={`color: ${scoreToColor(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}; font-size: var(--font-lg); font-weight: bold;`}
          title={`Editorial: ${formatScore(storyData.hcb_editorial_mean)} | Weighted mean: ${formatScore(aggregates.weighted_mean)}`}
        >
          {formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}
        </span>
      </td>
      <td>
        <span class="titleline" style="font-size: var(--font-md);">
          <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
             target="_blank" rel="noopener"
          >
            {storyData.title}
          </a>
        </span>
        {storyData.domain && (
          <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
            (<a href={`https://${storyData.domain}`} target="_blank" rel="noopener">{storyData.domain}</a>{storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? (
              <span style={`color: ${scoreToColor(storyData.hcb_structural_mean)}; margin-left: 4px;`}
                    title={`Structural: ${formatScore(storyData.hcb_structural_mean)} (privacy, access, tracking)`}>
                S:{formatScore(storyData.hcb_structural_mean)}
              </span>
            ) : isDone ? (
              <span style="color: #5b7279; margin-left: 4px;" title="Structural: no data">S:ND</span>
            ) : null})
          </span>
        )}
      </td>
    </tr>
    <tr>
      <td></td>
      <td class="subtext" style="padding-bottom: 8px;">
        {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
        {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
        <span> {timeAgo(storyData.hn_time)}</span>
        <span> | </span>
        <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
          {storyData.hn_comments ?? 0} comments on HN
        </a>
        <span> | </span>
        <span
          class="badge"
          style={`background: ${classColor}; color: ${classText}; font-size: var(--font-xs);`}
        >
          {aggregates.classification}
        </span>
        <span style="color: #5b7279; margin-left: 4px;">
          <span title={`Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}`} style="cursor: help;">
            {CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}
          </span>
          · {storyData.schema_version ? `v${storyData.schema_version}` : evaluation.methodology} · {evaluation.date}
        </span>
        {hasFairWitness && (
          <button
            id="fw-toggle"
            style="margin-left: 8px; background: rgba(168,85,247,0.15); border: 1px solid rgba(168,85,247,0.3); cursor: pointer; padding: 2px 8px; font-size: var(--font-xs); color: #a855f7; border-radius: 4px;"
            title="Toggle Fair Witness mode: show only observable facts vs interpretive inferences"
          >
            Fair Witness: OFF
          </button>
        )}
      </td>
    </tr>
  </table>

  <div style="height: 10px;"></div>

  {/* Summary card (v3.6+ story-level labels) */}
  {(executiveSummary || themeTag || sentimentTag) && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">Summary</span>
            {themeTag && (
              <span class="badge" style="background: rgba(43,144,216,0.15); color: #7d80d1; font-size: var(--font-xs);">
                {themeTag}
              </span>
            )}
            {sentimentTag && (
              <span class="badge" style="background: rgba(34,211,238,0.15); color: #22d3ee; font-size: var(--font-xs);">
                {sentimentTag}
              </span>
            )}
          </div>
          {executiveSummary && (
            <div style="color: #98a8a8; font-size: var(--font-sm); line-height: 1.6;">
              {executiveSummary}
            </div>
          )}
        </td>
      </tr>
    </table>
  )}

  {/* Heatmap */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Article Heatmap</div>
        <HeatMap scores={scores} compact={false} showLabels={true} />
        <div style="display: flex; gap: 12px; margin-top: 8px; font-size: var(--font-xs); color: #5b7279;">
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #dc2626; border-radius: 2px;"></span> Negative</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #eab308; border-radius: 2px;"></span> Neutral</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #16a34a; border-radius: 2px;"></span> Positive</span>
          <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: #6b7280; border-radius: 2px;"></span> No Data</span>
        </div>
      </td>
    </tr>
  </table>

  {/* Stats + Radar */}
  <div class="two-col" style="padding: 5px 0; gap: 10px;">
    <div>
      <div style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Aggregates</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr>
              <td style="color: #5b7279;" title="Average editorial channel score across all UDHR sections">Editorial Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(storyData.hcb_editorial_mean)}`}>{storyData.hcb_editorial_mean !== null && storyData.hcb_editorial_mean !== undefined ? formatScore(storyData.hcb_editorial_mean) : 'ND'}</td>
              <td style="color: #5b7279;" title="Average structural channel score across all UDHR sections">Structural Mean</td>
              <td class="score-font" style={`color: ${storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? scoreToColor(storyData.hcb_structural_mean) : '#5b7279'}`}>{storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? formatScore(storyData.hcb_structural_mean) : 'ND'}</td>
            </tr>
            <tr>
              <td style="color: #5b7279;" title="Evidence-weighted average of combined E+S+DCP final scores">Weighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>{formatScore(aggregates.weighted_mean)}</td>
              <td style="color: #5b7279;">Unweighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.unweighted_mean)}`}>{formatScore(aggregates.unweighted_mean)}</td>
            </tr>
            <tr>
              <td style="color: #5b7279;">Max</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.max.value)}`}>{formatScore(aggregates.max.value)} <span style="color: #5b7279;">{aggregates.max.section}</span></td>
              <td style="color: #5b7279;">Min</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.min.value)}`}>{formatScore(aggregates.min.value)} <span style="color: #5b7279;">{aggregates.min.section}</span></td>
            </tr>
            <tr>
              <td style="color: #5b7279;">Signal</td>
              <td class="score-font" style="color: #98a8a8;">{aggregates.signal_sections}</td>
              <td style="color: #5b7279;" title="Articles with insufficient evidence to score">No Data</td>
              <td class="score-font" style="color: #5b7279;">{aggregates.nd_count}</td>
            </tr>
            <tr>
              <td style="color: #5b7279;">Confidence</td>
              <td class="score-font" style={`color: ${confidenceToColor(confidence)};`} title={`${aggregates.signal_sections}/${aggregates.signal_sections + aggregates.nd_count} articles scored`}>{formatConfidence(confidence)}</td>
              <td style="color: #5b7279;">Volatility</td>
              <td class="score-font" style="color: #98a8a8;">{aggregates.volatility.value.toFixed(2)} ({aggregates.volatility.label})</td>
            </tr>
            <tr>
              <td style="color: #5b7279;">Negative</td>
              <td class="score-font" style="color: #ef4444;">{aggregates.negative_count}</td>
              <td style="color: #5b7279;">Channels</td>
              <td class="score-font">
                <span style="color: #60a5fa;" title="What the content says">E: {evaluation.channel_weights.editorial}</span>
                <span style="color: #22d3ee; margin-left: 6px;" title="What the site does">S: {evaluation.channel_weights.structural}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #5b7279;" title="Structural-Editorial Tension Level: normalized difference between S and E channels">SETL</td>
              <td class="score-font" style={`color: ${setlToColor(aggSetl)};`}>{formatSetl(aggSetl)}</td>
              <td style="color: #5b7279; font-size: var(--font-xs);" colspan="2">{aggSetl !== null ? (aggSetl > 0 ? 'Editorial-dominant' : aggSetl < 0 ? 'Structural-dominant' : 'Balanced') : ''}</td>
            </tr>
            {hasFairWitness && (
              <tr>
                <td style="color: #5b7279;" title="Fair Witness ratio: proportion of observable facts to total evidence items">FW Ratio</td>
                <td class="score-font" style={`color: ${fwRatioColor(fwRatio)};`}>{formatFwRatio(fwRatio)}</td>
                <td style="color: #5b7279; font-size: var(--font-xs);" title="Observable facts / Inferences" colspan="2">
                  <span style="color: #22c55e;">{fwObservableCount} facts</span> · <span style="color: #a855f7;">{fwInferenceCount} inferences</span>
                </td>
              </tr>
            )}
          </table>
          <div style="margin-top: 6px;">
            <span style="color: #5b7279; font-size: var(--font-xs);">Evidence: </span>
            {Object.entries(aggregates.evidence_profile).map(([key, count]) => {
              const label = EVIDENCE_LABELS[key] || key;
              return (
                <span
                  class="badge"
                  style={`background: ${evidenceColor(key === 'ND' ? null : key)}30; color: ${evidenceColor(key === 'ND' ? null : key)}; font-size: var(--font-xs); margin-right: 3px;`}
                >
                  {label}: {count}
                </span>
              );
            })}
          </div>
        </div>
    </div>
    <div>
      <div style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Theme Radar</div>
        <RadarChart scores={scores} size={300} />
      </div>
    </div>
  </div>

  {/* HN Comments */}
  {comments.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            HN Discussion
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
              {comments.filter(c => c.depth === 0).length} top-level · {comments.filter(c => c.depth > 0).length} replies
            </span>
          </div>
          {comments.map((c) => (
            <div style={`border-top: 1px solid #0d4655; padding: 8px 0; margin-left: ${c.depth * 20}px;`}>
              <div style="font-size: var(--font-xs); color: #5b7279; margin-bottom: 4px;">
                <a href={`/user/${c.author}`}
                   style="color: #5b7279;">{c.author}</a>
                {c.time && (
                  <span style="margin-left: 6px;">
                    {new Date(c.time * 1000).toISOString().slice(0, 16).replace('T', ' ')} UTC
                  </span>
                )}
                <a href={`https://news.ycombinator.com/item?id=${c.comment_id}`}
                   target="_blank" rel="noopener"
                   style="color: #5b7279; margin-left: 6px;">link</a>
              </div>
              <div style="color: #8faaab; font-size: var(--font-sm); line-height: 1.5;" set:html={sanitizeHtml(c.text)} />
            </div>
          ))}
        </td>
      </tr>
    </table>
  )}

  {/* Editorial Channel */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px; border-top: 3px solid #a78bfa;">
        <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;">
          <div style="color: #a78bfa; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold;">Editorial Channel</div>
          <div style="color: #5b7279; font-size: var(--font-xs);">What the content says</div>
        </div>
        {editorialRanked.map((score, i) => (
          <ArticleDetail score={score} index={i} channel="editorial" />
        ))}
      </td>
    </tr>
  </table>

  {/* Structural Channel */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px; border-top: 3px solid #22d3ee;">
        <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;">
          <div style="color: #22d3ee; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold;">Structural Channel</div>
          <div style="color: #5b7279; font-size: var(--font-xs);">What the site does</div>
        </div>
        {domain_context_profile && (
          <div style="margin-bottom: 12px; padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Domain Context Profile</div>
            <DcpTable elements={domain_context_profile.elements} />
          </div>
        )}
        {structuralRanked.map((score, i) => (
          <ArticleDetail score={score} index={i} channel="structural" />
        ))}
      </td>
    </tr>
  </table>

  {/* Supplementary Signals */}
  {hasSignals && (
    <div style="padding: 5px 0 20px 0;">
      <div style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px; border-top: 3px solid #f59e0b;">
        <div style="color: #f59e0b; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold; margin-bottom: 12px;">Supplementary Signals</div>

        <div class="insight-grid">
          {/* Epistemic Quality */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Epistemic Quality</div>
                  {eqData ? (
                    <>
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 6px;">
                        <span class="score-font" style={`color: ${eqData.eq_score >= 0.7 ? '#16a34a' : eqData.eq_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-md);`}>{eqData.eq_score.toFixed(2)}</span>
                        <span class="badge" style={`background: ${eqData.claim_density === 'low' ? 'rgba(22,163,106,0.15)' : eqData.claim_density === 'medium' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${eqData.claim_density === 'low' ? '#16a34a' : eqData.claim_density === 'medium' ? '#eab308' : '#dc2626'}; font-size: var(--font-xs);`}>{eqData.claim_density} claims</span>
                      </div>
                      <table cellpadding="2" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                        <tr><td style="color: #5b7279; width: 55%;">Sources</td><td><div style={`height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;`}><div style={`width: ${eqData.source_quality * 100}%; height: 100%; background: #60a5fa;`}></div></div></td><td style="color: #5b7279; text-align: right; width: 30px;">{eqData.source_quality.toFixed(1)}</td></tr>
                        <tr><td style="color: #5b7279;">Evidence</td><td><div style={`height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;`}><div style={`width: ${eqData.evidence_reasoning * 100}%; height: 100%; background: #60a5fa;`}></div></div></td><td style="color: #5b7279; text-align: right;">{eqData.evidence_reasoning.toFixed(1)}</td></tr>
                        <tr><td style="color: #5b7279;">Uncertainty</td><td><div style={`height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;`}><div style={`width: ${eqData.uncertainty_handling * 100}%; height: 100%; background: #60a5fa;`}></div></div></td><td style="color: #5b7279; text-align: right;">{eqData.uncertainty_handling.toFixed(1)}</td></tr>
                        <tr><td style="color: #5b7279;">Purpose</td><td><div style={`height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;`}><div style={`width: ${eqData.purpose_transparency * 100}%; height: 100%; background: #60a5fa;`}></div></div></td><td style="color: #5b7279; text-align: right;">{eqData.purpose_transparency.toFixed(1)}</td></tr>
                      </table>
                    </>
                  ) : eqScore !== null ? (
                    <span class="score-font" style={`color: ${eqScore >= 0.7 ? '#16a34a' : eqScore >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-md);`}>{eqScore.toFixed(2)}</span>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Propaganda Flags */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Propaganda Flags</div>
                  <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 6px;">
                    <span class="badge" style={`background: ${ptFlagCount === 0 ? 'rgba(22,163,106,0.15)' : ptFlagCount <= 2 ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${ptFlagCount === 0 ? '#16a34a' : ptFlagCount <= 2 ? '#eab308' : '#dc2626'}; font-size: var(--font-sm);`}>{ptFlagCount}</span>
                    <span style="color: #5b7279; font-size: var(--font-xs);">techniques detected</span>
                  </div>
                  {ptFlags && ptFlags.length > 0 && (
                    <div style="font-size: var(--font-xs);">
                      {ptFlags.map((f: any) => (
                        <div style="padding: 3px 0; border-top: 1px solid #0d4655;">
                          <span class="badge" style={`background: ${f.severity === 'high' ? 'rgba(220,38,38,0.15)' : f.severity === 'medium' ? 'rgba(234,179,8,0.15)' : 'rgba(107,114,128,0.15)'}; color: ${f.severity === 'high' ? '#dc2626' : f.severity === 'medium' ? '#eab308' : '#6b7280'}; font-size: var(--font-xs);`}>{f.technique.replace(/_/g, ' ')}</span>
                          <div style="color: #5b7279; font-size: var(--font-xs); margin-top: 2px; font-style: italic;">{f.evidence}</div>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
          </div>

          {/* Solution Orientation */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Solution Orientation</div>
                  {soData ? (
                    <>
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 6px;">
                        <span class="score-font" style={`color: ${soData.so_score >= 0.7 ? '#16a34a' : soData.so_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-md);`}>{soData.so_score.toFixed(2)}</span>
                        <span class="badge" style={`background: ${soData.framing === 'solution_oriented' ? 'rgba(22,163,106,0.15)' : soData.framing === 'mixed' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${soData.framing === 'solution_oriented' ? '#16a34a' : soData.framing === 'mixed' ? '#eab308' : '#dc2626'}; font-size: var(--font-xs);`}>{soData.framing.replace(/_/g, ' ')}</span>
                      </div>
                      <table cellpadding="2" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                        <tr><td style="color: #5b7279;">Reader Agency</td><td><div style="height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;"><div style={`width: ${soData.reader_agency * 100}%; height: 100%; background: #60a5fa;`}></div></div></td><td style="color: #5b7279; text-align: right; width: 30px;">{soData.reader_agency.toFixed(1)}</td></tr>
                      </table>
                    </>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Emotional Tone */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Emotional Tone</div>
                  {etData ? (
                    <>
                      <div style="margin-bottom: 6px;">
                        <span class="badge" style="background: rgba(168,85,247,0.15); color: #a855f7; font-size: var(--font-sm);">{etData.primary_tone}</span>
                      </div>
                      <table cellpadding="2" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                        <tr><td style="color: #5b7279; width: 55%;">Valence</td><td><div style="height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden; position: relative;"><div style={`position: absolute; left: 50%; width: ${Math.abs(etData.valence) * 50}%; height: 100%; background: ${etData.valence >= 0 ? '#16a34a' : '#dc2626'}; ${etData.valence >= 0 ? '' : 'transform: translateX(-100%);'}`}></div></div></td><td style="color: #5b7279; text-align: right; width: 35px;">{etData.valence > 0 ? '+' : ''}{etData.valence.toFixed(1)}</td></tr>
                        <tr><td style="color: #5b7279;">Arousal</td><td><div style="height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;"><div style={`width: ${etData.arousal * 100}%; height: 100%; background: #f59e0b;`}></div></div></td><td style="color: #5b7279; text-align: right;">{etData.arousal.toFixed(1)}</td></tr>
                        <tr><td style="color: #5b7279;">Dominance</td><td><div style="height: 4px; background: #0d4655; border-radius: 2px; overflow: hidden;"><div style={`width: ${etData.dominance * 100}%; height: 100%; background: #22d3ee;`}></div></div></td><td style="color: #5b7279; text-align: right;">{etData.dominance.toFixed(1)}</td></tr>
                      </table>
                    </>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Stakeholder Representation */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Stakeholder Voice</div>
                  {srData ? (
                    <>
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 6px;">
                        <span class="score-font" style={`color: ${srData.sr_score >= 0.7 ? '#16a34a' : srData.sr_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-md);`}>{srData.sr_score.toFixed(2)}</span>
                        <span style="color: #5b7279; font-size: var(--font-xs);">{srData.perspective_count} perspective{srData.perspective_count !== 1 ? 's' : ''}</span>
                      </div>
                      {srData.who_speaks && srData.who_speaks.length > 0 && (
                        <div style="font-size: var(--font-xs); margin-bottom: 3px;">
                          <span style="color: #5b7279;">Speaks: </span>
                          {srData.who_speaks.map((s: string) => (
                            <span class="badge" style="background: rgba(22,163,106,0.15); color: #16a34a; font-size: var(--font-xs); margin-right: 2px;">{s}</span>
                          ))}
                        </div>
                      )}
                      {srData.who_is_spoken_about && srData.who_is_spoken_about.length > 0 && (
                        <div style="font-size: var(--font-xs);">
                          <span style="color: #5b7279;">About: </span>
                          {srData.who_is_spoken_about.map((s: string) => (
                            <span class="badge" style="background: rgba(107,114,128,0.15); color: #6b7280; font-size: var(--font-xs); margin-right: 2px;">{s}</span>
                          ))}
                        </div>
                      )}
                    </>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Temporal Framing */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Temporal Framing</div>
                  {tfData ? (
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                      <span class="badge" style="background: rgba(96,165,250,0.15); color: #60a5fa; font-size: var(--font-xs);">{tfData.primary_focus}</span>
                      <span class="badge" style="background: rgba(107,114,128,0.15); color: #5b7279; font-size: var(--font-xs);">{tfData.time_horizon.replace(/_/g, ' ')}</span>
                    </div>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Geographic Scope */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Geographic Scope</div>
                  {gsData ? (
                    <>
                      <span class="badge" style="background: rgba(96,165,250,0.15); color: #60a5fa; font-size: var(--font-xs); margin-bottom: 4px;">{gsData.scope}</span>
                      {gsData.regions_mentioned && gsData.regions_mentioned.length > 0 && (
                        <div style="font-size: var(--font-xs); color: #5b7279; margin-top: 4px;">
                          {gsData.regions_mentioned.join(', ')}
                        </div>
                      )}
                    </>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Complexity Level */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Complexity</div>
                  {clData ? (
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                      <span class="badge" style={`background: ${clData.reading_level === 'accessible' ? 'rgba(22,163,106,0.15)' : clData.reading_level === 'moderate' ? 'rgba(96,165,250,0.15)' : clData.reading_level === 'technical' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${clData.reading_level === 'accessible' ? '#16a34a' : clData.reading_level === 'moderate' ? '#60a5fa' : clData.reading_level === 'technical' ? '#eab308' : '#dc2626'}; font-size: var(--font-xs);`}>{clData.reading_level}</span>
                      <span class="badge" style={`background: ${clData.jargon_density === 'low' ? 'rgba(22,163,106,0.15)' : clData.jargon_density === 'medium' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${clData.jargon_density === 'low' ? '#16a34a' : clData.jargon_density === 'medium' ? '#eab308' : '#dc2626'}; font-size: var(--font-xs);`}>{clData.jargon_density} jargon</span>
                      <span class="badge" style="background: rgba(107,114,128,0.15); color: #5b7279; font-size: var(--font-xs);">{clData.assumed_knowledge.replace(/_/g, ' ')}</span>
                    </div>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>

          {/* Transparency & Disclosure */}
          <div>
                <div style="padding: 8px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; height: 100%;">
                  <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Transparency</div>
                  {tdData ? (
                    <>
                      <div style="margin-bottom: 6px;">
                        <span class="score-font" style={`color: ${tdData.td_score >= 0.7 ? '#16a34a' : tdData.td_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-md);`}>{tdData.td_score.toFixed(2)}</span>
                      </div>
                      <div style="font-size: var(--font-xs); display: flex; flex-wrap: wrap; gap: 4px;">
                        <span style={`color: ${tdData.author_identified ? '#16a34a' : '#dc2626'};`}>{tdData.author_identified ? '\u2713' : '\u2717'} Author</span>
                        {tdData.conflicts_disclosed !== null && (
                          <span style={`color: ${tdData.conflicts_disclosed ? '#16a34a' : '#dc2626'};`}>{tdData.conflicts_disclosed ? '\u2713' : '\u2717'} Conflicts</span>
                        )}
                        {tdData.funding_disclosed !== null && (
                          <span style={`color: ${tdData.funding_disclosed ? '#16a34a' : '#dc2626'};`}>{tdData.funding_disclosed ? '\u2713' : '\u2717'} Funding</span>
                        )}
                      </div>
                    </>
                  ) : (
                    <span style="color: #1a5568; font-size: var(--font-xs);">No data</span>
                  )}
                </div>
          </div>
        </div>
      </div>
    </div>
  )}
    </>
  ) : isLightOnlyEval && lightEval ? (
    <>
      {/* Light-only eval page — editorial score, no per-section breakdown */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            <span
              class="score-font"
              style={`color: ${scoreToColor(lightEval.hcb_editorial_mean ?? lightEval.hcb_weighted_mean)}; font-size: var(--font-lg); font-weight: bold;`}
              title={`Light eval — editorial only: ${formatScore(lightEval.hcb_editorial_mean ?? lightEval.hcb_weighted_mean)}`}
            >
              {formatScore(lightEval.hcb_editorial_mean ?? lightEval.hcb_weighted_mean)}
            </span>
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
            {lightEval.hcb_classification && (
              <>
                <span> | </span>
                <span class="badge" style={`background: ${classificationColor(lightEval.hcb_classification)}; color: ${classificationTextColor(lightEval.hcb_classification)}; font-size: var(--font-xs);`}>
                  {lightEval.hcb_classification}
                </span>
              </>
            )}
            <span style="color: #d56500; font-size: var(--font-xs); margin-left: 6px;" title="Light evaluation — editorial channel only, no per-section breakdown">~lite</span>
            <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 4px;">{lightEval.schema_version ? `v${lightEval.schema_version}` : ''}</span>
          </td>
        </tr>
      </table>

      <div style="height: 10px;"></div>

      {/* Light eval summary card */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
        <tr>
          <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <span style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">Summary</span>
              <span style="color: #d56500; font-size: var(--font-xs); border: 1px solid rgba(213,101,0,0.4); padding: 1px 5px; border-radius: 3px;" title="Light evaluation — editorial channel only, no per-section heatmap">~lite</span>
              {lightEval.hcb_theme_tag && (
                <span class="badge" style="background: rgba(43,144,216,0.15); color: #7d80d1; font-size: var(--font-xs);">
                  {lightEval.hcb_theme_tag}
                </span>
              )}
              {lightEval.hcb_sentiment_tag && (
                <span class="badge" style="background: rgba(34,211,238,0.15); color: #22d3ee; font-size: var(--font-xs);">
                  {lightEval.hcb_sentiment_tag}
                </span>
              )}
            </div>
            {lightEval.hcb_executive_summary && (
              <div style="color: #98a8a8; font-size: var(--font-sm); line-height: 1.6; margin-bottom: 10px;">
                {lightEval.hcb_executive_summary}
              </div>
            )}
            {(lightEval.eq_score !== null || lightEval.so_score !== null || lightEval.td_score !== null) && (
              <div style="display: flex; gap: 16px; flex-wrap: wrap; border-top: 1px solid #0d4655; padding-top: 8px; margin-top: 4px;">
                {lightEval.eq_score !== null && (
                  <div>
                    <span style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">EQ</span>
                    <span class="score-font" style={`color: ${lightEval.eq_score >= 0.7 ? '#16a34a' : lightEval.eq_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-sm); margin-left: 4px;`} title="Epistemic Quality">{lightEval.eq_score.toFixed(2)}</span>
                  </div>
                )}
                {lightEval.so_score !== null && (
                  <div>
                    <span style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">SO</span>
                    <span class="score-font" style={`color: ${lightEval.so_score >= 0.6 ? '#16a34a' : '#5b7279'}; font-size: var(--font-sm); margin-left: 4px;`} title="Solution Orientation">{lightEval.so_score.toFixed(2)}</span>
                  </div>
                )}
                {lightEval.td_score !== null && (
                  <div>
                    <span style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">TD</span>
                    <span class="score-font" style={`color: ${lightEval.td_score >= 0.7 ? '#16a34a' : lightEval.td_score >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-sm); margin-left: 4px;`} title="Transparency & Disclosure">{lightEval.td_score.toFixed(2)}</span>
                  </div>
                )}
              </div>
            )}
            <div style="color: #1a5568; font-size: var(--font-xs); margin-top: 10px;">
              Light evaluation by {lightEval.eval_model} · editorial channel only · no per-section breakdown available
            </div>
          </td>
        </tr>
      </table>
    </>
  ) : isPending ? (
    <>
      {/* Pending/evaluating page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            {storyData.eval_status === 'evaluating' ? (
              <span class="eval-spinner" style="display: inline-block; color: #60a5fa; font-size: var(--font-lg);">&#9696;</span>
            ) : (
              <span style="color: #eab308; font-size: var(--font-lg);">&#9679;</span>
            )}
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 15px; background: #093946; border: 1px solid #1a5568; border-radius: 6px; text-align: center;">
            <div style={`color: ${storyData.eval_status === 'evaluating' ? '#60a5fa' : '#eab308'}; font-size: var(--font-md); margin-bottom: 6px;`}>
              {storyData.eval_status === 'evaluating' ? 'Evaluating...' : 'Pending Evaluation'}
            </div>
            <div style="color: #5b7279; font-size: var(--font-sm);">
              {storyData.eval_status === 'evaluating'
                ? 'This story is currently being evaluated against the UDHR. Results will appear shortly.'
                : 'This story is queued for evaluation. It will be processed in an upcoming batch.'}
            </div>
            <div style="color: #1a5568; font-size: var(--font-xs); margin-top: 8px;">
              Queued: {storyData.created_at}
            </div>
          </td>
        </tr>
      </table>
    </>
  ) : null}

  {/* Event Timeline — shown for all statuses when events exist */}
  {storyEvents.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            Event Timeline
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">{storyEvents.length} events</span>
          </div>
          <div class="table-wrap">
          <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
            {storyEvents.map((ev) => {
              const sevColor = ev.severity === 'error' ? '#dc2626' : ev.severity === 'warn' ? '#eab308' : '#5b7279';
              const typeColor = EVENT_TYPE_COLORS[ev.event_type] || '#5b7279';
              return (
                <tr style={`border-top: 1px solid #0d4655;`}>
                  <td style="color: #5b7279; white-space: nowrap; width: 140px;">{ev.created_at.slice(0, 16)}</td>
                  <td style="width: 90px;">
                    <span class="badge" style={`background: ${typeColor}20; color: ${typeColor}; font-size: var(--font-xs);`}>
                      {ev.event_type}
                    </span>
                  </td>
                  <td style={`color: ${sevColor};`}>{ev.message}</td>
                  <td style="width: 60px; text-align: center; white-space: nowrap;">
                    {ev.investigated === 1
                      ? <span style="color: #3b82f6;" title="Investigated">INV</span>
                      : ev.investigated === 0
                        ? <span style="color: #5b7279;" title="Not investigated">--</span>
                        : <span style="color: #0d4655;" title="Not triaged">-</span>
                    }
                    {' '}
                    {ev.resolved === 1
                      ? <span style="color: #22c55e;" title="Resolved">RES</span>
                      : ev.resolved === 0
                        ? <span style="color: #5b7279;" title="Not resolved">--</span>
                        : <span style="color: #0d4655;" title="Not triaged">-</span>
                    }
                  </td>
                </tr>
              );
            })}
          </table>
          </div>
        </td>
      </tr>
    </table>
  )}

  {isFailed && (
    <script is:inline>
    document.querySelectorAll('.trigger-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Gate: require donation
        if (!localStorage.getItem('hrcb_donated')) {
          var modal = document.getElementById('donate-modal');
          if (modal) {
            window.__pendingRetryBtn = btn;
            modal.style.display = 'flex';
          }
          return;
        }

        var hnId = this.getAttribute('data-hn-id');
        this.disabled = true;
        this.textContent = 'Retrying...';
        fetch('/api/trigger/' + hnId, {
          method: 'POST'
        }).then(function(r) {
          var ct = r.headers.get('content-type') || '';
          if (ct.indexOf('text/event-stream') !== -1) {
            // SSE stream — read until done/error
            var reader = r.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';
            function read() {
              reader.read().then(function(chunk) {
                if (chunk.done) return;
                buffer += decoder.decode(chunk.value, { stream: true });
                var parts = buffer.split('\n\n');
                buffer = parts.pop() || '';
                for (var i = 0; i < parts.length; i++) {
                  var lines = parts[i].split('\n');
                  var evType = '', evData = '';
                  for (var l = 0; l < lines.length; l++) {
                    if (lines[l].indexOf('event: ') === 0) evType = lines[l].slice(7);
                    if (lines[l].indexOf('data: ') === 0) evData = lines[l].slice(6);
                  }
                  if (!evData) continue;
                  try {
                    var d = JSON.parse(evData);
                    if (evType === 'status') {
                      btn.textContent = d.message.slice(0, 30) + '...';
                    } else if (evType === 'done') {
                      btn.textContent = 'Done: ' + (d.score !== undefined ? d.score.toFixed(2) : '?');
                      btn.style.color = '#16a34a';
                      btn.style.borderColor = 'rgba(22,163,106,0.3)';
                      btn.style.background = 'rgba(22,163,106,0.15)';
                      setTimeout(function() { location.reload(); }, 1500);
                    } else if (evType === 'error') {
                      btn.textContent = 'Error: ' + (d.error || 'unknown');
                      btn.disabled = false;
                    }
                  } catch(e) {}
                }
                read();
              });
            }
            read();
          } else {
            return r.json().then(function(d) {
              btn.textContent = 'Error: ' + (d.error || 'unknown');
              btn.disabled = false;
            });
          }
        }).catch(function() { btn.textContent = 'Network error'; btn.disabled = false; });
      });
    });
    </script>
  )}

  <script is:inline>
  (function() {
    var toggle = document.getElementById('fw-toggle');
    if (!toggle) return;
    var fwOn = false;
    toggle.addEventListener('click', function() {
      fwOn = !fwOn;
      toggle.textContent = 'Fair Witness: ' + (fwOn ? 'ON' : 'OFF');
      toggle.style.background = fwOn ? 'rgba(168,85,247,0.3)' : 'rgba(168,85,247,0.15)';

      // Show/hide FW-only elements
      var fwOnly = document.querySelectorAll('.fw-only');
      for (var i = 0; i < fwOnly.length; i++) {
        fwOnly[i].style.display = fwOn ? '' : 'none';
      }

      // Show/hide standard elements
      var fwHide = document.querySelectorAll('.fw-hide');
      for (var j = 0; j < fwHide.length; j++) {
        fwHide[j].style.display = fwOn ? 'none' : '';
      }
    });
  })();
  </script>
</Base>
