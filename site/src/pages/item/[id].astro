                    {tdData.conflicts_disclosed !== null && (
                      <span style={`color: ${tdData.conflicts_disclosed ? 'var(--color-positive)' : 'var(--color-negative)'};`}>{tdData.conflicts_disclosed ? '\u2713' : '\u2717'} Conflicts</span>
                    )}
                    {tdData.funding_disclosed !== null && (
