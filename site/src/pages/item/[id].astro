---
import Base from '../../layouts/Base.astro';
import HeatMap from '../../components/HeatMap.astro';
import RadarChart from '../../components/RadarChart.astro';
import DcpTable from '../../components/DcpTable.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, evidenceColor, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence } from '../../lib/colors';
import { getStory, getStoryComments, getDomainDcp } from '../../lib/db';
import { CONTENT_TYPE_LABELS } from '../../lib/types';
import type { Evaluation } from '../../lib/types';

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const hnId = parseInt(id!, 10);
if (isNaN(hnId)) {
  return Astro.redirect('/');
}

const storyData = await getStory(db, hnId);
if (!storyData) {
  return Astro.redirect('/');
}

// Handle statuses
const isFailed = storyData.eval_status === 'failed';
const isDone = storyData.eval_status === 'done' && !!storyData.hcb_json;
const isPending = storyData.eval_status === 'pending' || storyData.eval_status === 'evaluating';

let evalData: Evaluation | null = null;
let cachedDcp: string | null = null;
if (isDone) {
  try {
    evalData = JSON.parse(storyData.hcb_json!) as Evaluation;
  } catch (_e) {
    return Astro.redirect('/');
  }
}
let cachedDcpElements: any[] | null = null;
if (isFailed && storyData.domain) {
  cachedDcp = await getDomainDcp(db, storyData.domain);
  if (cachedDcp) {
    try {
      const dcpData = JSON.parse(cachedDcp);
      cachedDcpElements = dcpData.elements || dcpData;
    } catch (_e) { /* ignore parse errors */ }
  }
}
const evaluation = evalData?.evaluation;
const domain_context_profile = evalData?.domain_context_profile;
const aggregates = evalData?.aggregates;
const scores = isDone ? (storyData.scores.length > 0 ? storyData.scores : evalData!.scores) : [];

const classColor = aggregates ? classificationColor(aggregates.classification) : '#555';
const classText = aggregates ? classificationTextColor(aggregates.classification) : '#ccc';

// Compute aggregate SETL from scores
const setlValues = scores
  .map(s => computeSetl(s.structural, s.editorial))
  .filter((v): v is number => v !== null);
const aggSetl = setlValues.length > 0
  ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
  : null;

// Confidence (evidence-weighted)
const confidence = computeConfidence(storyData.hcb_evidence_h, storyData.hcb_evidence_m, storyData.hcb_evidence_l, storyData.hcb_nd_count);

let comments: Awaited<ReturnType<typeof getStoryComments>> = [];
try {
  comments = await getStoryComments(db, hnId);
} catch {
  // story_comments table may not exist yet — graceful fallback
}

const siteUrl = Astro.url.origin;

const jsonLd = isDone && aggregates && evaluation ? {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: `HRCB Evaluation: ${storyData.title}`,
  description: `Human Rights Compatibility Bias evaluation of "${storyData.title}" against the UN Universal Declaration of Human Rights. Classification: ${aggregates.classification}. Score: ${formatScore(aggregates.weighted_mean)}.`,
  url: `${siteUrl}/item/${storyData.hn_id}`,
  datePublished: storyData.evaluated_at || undefined,
  author: {
    '@type': 'Organization',
    name: 'HN HRCB',
    url: siteUrl,
  },
  itemReviewed: {
    '@type': 'CreativeWork',
    name: storyData.title,
    url: storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`,
    ...(storyData.domain && { publisher: { '@type': 'Organization', name: storyData.domain } }),
    ...(storyData.hn_by && { author: { '@type': 'Person', name: storyData.hn_by } }),
    datePublished: new Date(storyData.hn_time * 1000).toISOString(),
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: aggregates.weighted_mean,
    bestRating: 1.0,
    worstRating: -1.0,
    ratingExplanation: `HRCB ${aggregates.classification} — evaluated against ${aggregates.signal_sections} of 31 UDHR provisions using methodology v${evaluation.methodology}`,
  },
  reviewBody: `Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}. ${aggregates.signal_sections} sections scored, ${aggregates.nd_count} with no data. Volatility: ${aggregates.volatility.label} (${aggregates.volatility.value.toFixed(2)}).`,
  about: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;

const EVIDENCE_LABELS: Record<string, string> = {H: 'High', M: 'Medium', L: 'Low', ND: 'No Data'};

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

<Base
  title={`${storyData.title} — ${isFailed ? 'Failed' : isPending ? 'Pending' : 'HRCB'}`}
  ogTitle={isDone && aggregates ? `${formatScore(aggregates.weighted_mean)} ${storyData.title}` : storyData.title}
  ogDescription={isDone && aggregates ? `HRCB: ${aggregates.classification} (${formatScore(aggregates.weighted_mean)}) — ${aggregates.signal_sections} of 31 UDHR provisions scored. ${storyData.domain || 'self-post'}` : isPending ? `Evaluation pending for ${storyData.title}` : `Evaluation failed for ${storyData.title}`}
  ogUrl={`${siteUrl}/item/${storyData.hn_id}`}
  canonicalUrl={`${siteUrl}/item/${storyData.hn_id}`}
>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}

  {/* Breadcrumb */}
  <div style="padding: 4px 0; font-size: var(--font-xs); color: #555;">
    <a href="/" style="color: #555;">home</a>
    {storyData.domain && (
      <>
        <span style="color: #333;"> / </span>
        <a href={`/domain/${storyData.domain}`} style="color: #555;">{storyData.domain}</a>
      </>
    )}
    <span style="color: #333;"> / </span>
    <span style="color: #888;">item {storyData.hn_id}</span>
  </div>

  {isFailed ? (
    <>
      {/* Failed evaluation page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            <span style="color: #dc2626; font-size: var(--font-lg);">&#10007;</span>
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`https://news.ycombinator.com/user?id=${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Evaluation Failed</div>
            <div style="color: #dc2626; font-size: var(--font-base); padding: 8px 0; line-height: 1.5;">
              {storyData.eval_error || 'Unknown error'}
            </div>
            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm); margin-top: 8px;">
              {storyData.domain && (
                <tr>
                  <td style="color: #666; width: 100px;">Domain</td>
                  <td><a href={`/domain/${storyData.domain}`} style="color: #c9c9c9;">{storyData.domain}</a></td>
                </tr>
              )}
              {storyData.content_type && (
                <tr>
                  <td style="color: #666;">Content Type</td>
                  <td style="color: #888;">{CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}</td>
                </tr>
              )}
              <tr>
                <td style="color: #666;">Created</td>
                <td style="color: #555;">{storyData.created_at}</td>
              </tr>
            </table>
            <div style="margin-top: 12px;">
              <button
                class="trigger-btn"
                data-hn-id={storyData.hn_id}
                title="Retry evaluation"
                style="background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.3); cursor: pointer; padding: 4px 12px; font-size: var(--font-sm); color: #dc2626; border-radius: 4px;"
              >
                &#9654; Retry Evaluation
              </button>
            </div>
          </td>
        </tr>
      </table>

      {cachedDcpElements && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
          <tr>
            <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Cached Domain Context Profile
                <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">from previous evaluation</span>
              </div>
              <DcpTable elements={cachedDcpElements} />
            </td>
          </tr>
        </table>
      )}
    </>
  ) : isDone && aggregates && evaluation ? (
    <>
  {/* Story header - HN style */}
  <table cellpadding="0" cellspacing="0" width="100%">
    <tr class="athing">
      <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
        <span
          class="score-font"
          style={`color: ${scoreToColor(aggregates.weighted_mean)}; font-size: var(--font-lg); font-weight: bold;`}
        >
          {formatScore(aggregates.weighted_mean)}
        </span>
      </td>
      <td>
        <span class="titleline" style="font-size: var(--font-md);">
          <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
             target="_blank" rel="noopener"
          >
            {storyData.title}
          </a>
        </span>
        {storyData.domain && (
          <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
            (<a href={`https://${storyData.domain}`} target="_blank" rel="noopener">{storyData.domain}</a>)
          </span>
        )}
      </td>
    </tr>
    <tr>
      <td></td>
      <td class="subtext" style="padding-bottom: 8px;">
        {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
        {storyData.hn_by && <span> by <a href={`https://news.ycombinator.com/user?id=${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
        <span> {timeAgo(storyData.hn_time)}</span>
        <span> | </span>
        <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
          {storyData.hn_comments ?? 0} comments on HN
        </a>
        <span> | </span>
        <span
          class="badge"
          style={`background: ${classColor}; color: ${classText}; font-size: var(--font-xs);`}
        >
          {aggregates.classification}
        </span>
        <span style="color: #828282; margin-left: 4px;">
          <span title={`Content type: ${CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}`} style="cursor: help;">
            {CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}
          </span>
          · v{evaluation.methodology} · {evaluation.date}
        </span>
      </td>
    </tr>
  </table>

  <div style="height: 10px;"></div>

  {/* Heatmap */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Article Heatmap</div>
        <HeatMap scores={scores} compact={false} showLabels={true} />
        <div style="display: flex; gap: 12px; margin-top: 8px; font-size: var(--font-xs); color: #666;">
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #dc2626; border-radius: 2px;"></span> Negative</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #eab308; border-radius: 2px;"></span> Neutral</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: #16a34a; border-radius: 2px;"></span> Positive</span>
          <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: #6b7280; border-radius: 2px;"></span> No Data</span>
        </div>
      </td>
    </tr>
  </table>

  {/* Stats + Radar */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Aggregates</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr>
              <td style="color: #666;">Weighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>{formatScore(aggregates.weighted_mean)}</td>
              <td style="color: #666;">Unweighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.unweighted_mean)}`}>{formatScore(aggregates.unweighted_mean)}</td>
            </tr>
            <tr>
              <td style="color: #666;">Max</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.max.value)}`}>{formatScore(aggregates.max.value)} <span style="color: #555;">{aggregates.max.section}</span></td>
              <td style="color: #666;">Min</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.min.value)}`}>{formatScore(aggregates.min.value)} <span style="color: #555;">{aggregates.min.section}</span></td>
            </tr>
            <tr>
              <td style="color: #666;">Signal</td>
              <td class="score-font" style="color: #ccc;">{aggregates.signal_sections}</td>
              <td style="color: #666;" title="Articles with insufficient evidence to score">No Data</td>
              <td class="score-font" style="color: #666;">{aggregates.nd_count}</td>
            </tr>
            <tr>
              <td style="color: #666;">Confidence</td>
              <td class="score-font" style={`color: ${confidenceToColor(confidence)};`} title={`${aggregates.signal_sections}/${aggregates.signal_sections + aggregates.nd_count} articles scored`}>{formatConfidence(confidence)}</td>
              <td style="color: #666;">Volatility</td>
              <td class="score-font" style="color: #ccc;">{aggregates.volatility.value.toFixed(2)} ({aggregates.volatility.label})</td>
            </tr>
            <tr>
              <td style="color: #666;">Negative</td>
              <td class="score-font" style="color: #ef4444;">{aggregates.negative_count}</td>
              <td style="color: #666;">Channels</td>
              <td class="score-font">
                <span style="color: #60a5fa;" title="What the content says">E: {evaluation.channel_weights.editorial}</span>
                <span style="color: #22d3ee; margin-left: 6px;" title="What the site does">S: {evaluation.channel_weights.structural}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Structural-Editorial Tension Level: normalized difference between S and E channels">SETL</td>
              <td class="score-font" style={`color: ${setlToColor(aggSetl)};`}>{formatSetl(aggSetl)}</td>
              <td style="color: #555; font-size: var(--font-xs);" colspan="2">{aggSetl !== null ? (aggSetl > 0 ? 'Editorial-dominant' : aggSetl < 0 ? 'Structural-dominant' : 'Balanced') : ''}</td>
            </tr>
          </table>
          <div style="margin-top: 6px;">
            <span style="color: #666; font-size: var(--font-xs);">Evidence: </span>
            {Object.entries(aggregates.evidence_profile).map(([key, count]) => {
              const label = EVIDENCE_LABELS[key] || key;
              return (
                <span
                  class="badge"
                  style={`background: ${evidenceColor(key === 'ND' ? null : key)}30; color: ${evidenceColor(key === 'ND' ? null : key)}; font-size: var(--font-xs); margin-right: 3px;`}
                >
                  {label}: {count}
                </span>
              );
            })}
          </div>
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Theme Radar</div>
          <RadarChart scores={scores} size={300} />
        </div>
      </td>
    </tr>
  </table>

  {/* DCP */}
  {domain_context_profile && (
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Domain Context Profile</div>
        <DcpTable elements={domain_context_profile.elements} />
      </td>
    </tr>
  </table>
  )}

  {/* HN Comments */}
  {comments.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            HN Discussion
            <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
              {comments.length} top-level comments
            </span>
          </div>
          {comments.map((c) => (
            <div style="border-top: 1px solid #1a1a25; padding: 8px 0;">
              <div style="font-size: var(--font-xs); color: #555; margin-bottom: 4px;">
                <a href={`https://news.ycombinator.com/user?id=${c.author}`}
                   target="_blank" rel="noopener"
                   style="color: #888;">{c.author}</a>
                {c.time && (
                  <span style="margin-left: 6px;">
                    {new Date(c.time * 1000).toISOString().slice(0, 16).replace('T', ' ')} UTC
                  </span>
                )}
                <a href={`https://news.ycombinator.com/item?id=${c.comment_id}`}
                   target="_blank" rel="noopener"
                   style="color: #555; margin-left: 6px;">link</a>
              </div>
              <div style="color: #aaa; font-size: var(--font-sm); line-height: 1.5;" set:html={c.text} />
            </div>
          ))}
        </td>
      </tr>
    </table>
  )}

  {/* Score breakdown */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 20px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Score Breakdown</div>
        {scores.map((score, i) => (
          <ArticleDetail score={score} index={i} />
        ))}
      </td>
    </tr>
  </table>
    </>
  ) : isPending ? (
    <>
      {/* Pending/evaluating page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            {storyData.eval_status === 'evaluating' ? (
              <span class="eval-spinner" style="display: inline-block; color: #60a5fa; font-size: var(--font-lg);">&#9696;</span>
            ) : (
              <span style="color: #eab308; font-size: var(--font-lg);">&#9679;</span>
            )}
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`https://news.ycombinator.com/user?id=${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 15px; background: #12121a; border: 1px solid #222230; border-radius: 6px; text-align: center;">
            <div style={`color: ${storyData.eval_status === 'evaluating' ? '#60a5fa' : '#eab308'}; font-size: var(--font-md); margin-bottom: 6px;`}>
              {storyData.eval_status === 'evaluating' ? 'Evaluating...' : 'Pending Evaluation'}
            </div>
            <div style="color: #555; font-size: var(--font-sm);">
              {storyData.eval_status === 'evaluating'
                ? 'This story is currently being evaluated against the UDHR. Results will appear shortly.'
                : 'This story is queued for evaluation. It will be processed in an upcoming batch.'}
            </div>
            <div style="color: #444; font-size: var(--font-xs); margin-top: 8px;">
              Queued: {storyData.created_at}
            </div>
          </td>
        </tr>
      </table>
    </>
  ) : null}

  {isFailed && (
    <script is:inline>
    document.querySelectorAll('.trigger-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var hnId = this.getAttribute('data-hn-id');
        this.disabled = true;
        this.textContent = 'Submitting...';
        fetch('/api/trigger', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ hn_id: parseInt(hnId) })
        }).then(function(r) { return r.json(); }).then(function(d) {
          if (d.ok) {
            btn.textContent = 'Queued';
            btn.style.color = '#eab308';
            btn.style.borderColor = 'rgba(234,179,8,0.3)';
            btn.style.background = 'rgba(234,179,8,0.15)';
          } else {
            btn.textContent = 'Error: ' + (d.error || 'unknown');
            btn.disabled = false;
          }
        }).catch(function() { btn.textContent = 'Network error'; btn.disabled = false; });
      });
    });
    </script>
  )}
</Base>
