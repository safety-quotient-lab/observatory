                    <span class="score-font" style={`color: ${soData.so_score >= 0.7 ? 'var(--color-positive)' : soData.so_score >= 0.4 ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-md);`}>{soData.so_score.toFixed(2)}</span>
                    <span class="badge" style={`background: ${soData.framing === 'solution_oriented' ? 'rgba(22,163,106,0.15)' : soData.framing === 'mixed' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${soData.framing === 'solution_oriented' ? 'var(--color-positive)' : soData.framing === 'mixed' ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-xs);`}>{soData.framing.replace(/_/g, ' ')}</span>
