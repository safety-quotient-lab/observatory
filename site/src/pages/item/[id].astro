            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 4px;">{liteEval.schema_version ? `v${liteEval.schema_version}` : ''}</span>
          </td>
        </tr>
      </table>

      <div style="height: 10px;"></div>

      {/* Lite eval summary card */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
        <tr>
          <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <span style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">Summary</span>
              <span style="color: var(--color-orange); font-size: var(--font-xs); border: 1px solid rgba(213,101,0,0.4); padding: 1px 5px; border-radius: 3px;" title="Lite evaluation — editorial channel only, no per-section heatmap">~lite</span>
              {liteEval.hcb_theme_tag && (
                <span class="badge" style="background: rgba(43,144,216,0.15); color: var(--color-violet); font-size: var(--font-xs);">
                  {liteEval.hcb_theme_tag}
                </span>
              )}
              {liteEval.hcb_sentiment_tag && (
                <span class="badge" style="background: rgba(34,211,238,0.15); color: var(--color-sentiment); font-size: var(--font-xs);">
                  {liteEval.hcb_sentiment_tag}
                </span>
              )}
            </div>
            {liteEval.hcb_executive_summary && (
              <div style="color: var(--fg-primary); font-size: var(--font-sm); line-height: 1.6; margin-bottom: 10px;">
                {liteEval.hcb_executive_summary}
              </div>
            )}
            {(liteEval.eq_score !== null || liteEval.so_score !== null || liteEval.td_score !== null) && (
              <div style="display: flex; gap: 16px; flex-wrap: wrap; border-top: 1px solid var(--bg-surface); padding-top: 8px; margin-top: 4px;">
                {liteEval.eq_score !== null && (
                  <div>
                    <abbr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none;" title="Epistemic Quality: source credibility, evidence reasoning, and uncertainty handling">EQ</abbr>
                    <span class="score-font" style={`color: ${liteEval.eq_score >= 0.7 ? 'var(--color-positive)' : liteEval.eq_score >= 0.4 ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-sm); margin-left: 4px;`}>{liteEval.eq_score.toFixed(2)}</span>
                  </div>
                )}
                {liteEval.so_score !== null && (
                  <div>
                    <abbr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none;" title="Solution Orientation: degree to which content frames problems constructively and offers reader agency">SO</abbr>
                    <span class="score-font" style={`color: ${liteEval.so_score >= 0.6 ? 'var(--color-positive)' : 'var(--fg-secondary)'}; font-size: var(--font-sm); margin-left: 4px;`}>{liteEval.so_score.toFixed(2)}</span>
                  </div>
                )}
                {liteEval.td_score !== null && (
                  <div>
                    <abbr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none;" title="Transparency & Disclosure: author identification and conflict-of-interest disclosure">TD</abbr>
                    <span class="score-font" style={`color: ${liteEval.td_score >= 0.7 ? 'var(--color-positive)' : liteEval.td_score >= 0.4 ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-sm); margin-left: 4px;`}>{liteEval.td_score.toFixed(2)}</span>
                  </div>
                )}
              </div>
            )}
            <div style="color: var(--color-border); font-size: var(--font-xs); margin-top: 10px;">
              Lite evaluation by {liteEval.eval_model} · editorial channel only · no per-section breakdown available
            </div>
          </td>
        </tr>
      </table>
    </>
  ) : isPending ? (
    <>
      {/* Pending/evaluating page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            {storyData.eval_status === 'evaluating' ? (
              <span class="eval-spinner" style="display: inline-block; color: var(--channel-editorial); font-size: var(--font-lg);">&#9696;</span>
            ) : (
              <span style="color: var(--color-warning); font-size: var(--font-lg);">&#9679;</span>
            )}
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 15px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; text-align: center;">
            <div style={`color: ${storyData.eval_status === 'evaluating' ? 'var(--channel-editorial)' : 'var(--color-warning)'}; font-size: var(--font-md); margin-bottom: 6px;`}>
              {storyData.eval_status === 'evaluating' ? 'Evaluating...' : 'Pending Evaluation'}
            </div>
            <div style="color: var(--fg-secondary); font-size: var(--font-sm);">
              {storyData.eval_status === 'evaluating'
                ? 'This story is currently being evaluated against the UDHR. Results will appear shortly.'
                : 'This story is queued for evaluation. It will be processed in an upcoming batch.'}
            </div>
            <div style="color: var(--color-border); font-size: var(--font-xs); margin-top: 8px;">
              Queued: {storyData.created_at}
            </div>
          </td>
        </tr>
      </table>
    </>
  ) : null}

  {/* Longitudinal sparkline (shown when ≥2 eval entries or ≥5 HN snapshots) */}
  {showSparkline && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 0 0;">
      <tr>
        <td style="padding: 8px 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
            Longitudinal
            {storyTimeline.length > 0 && <span style="text-transform: none; letter-spacing: 0; margin-left: 6px;">{storyTimeline.length} HN snapshots</span>}
            {evalHistory.length > 0 && <span style="text-transform: none; letter-spacing: 0; margin-left: 6px;">· {evalHistory.length} evals</span>}
          </div>
          <div style="overflow-x: auto;">
            <svg width={SPARK_W} height={SPARK_H} style="display: block; overflow: visible;">
              {/* HRCB band labels */}
              <text x="2" y={hrcbY0 + 2} fill="var(--fg-secondary)" font-size="8" dominant-baseline="hanging">+1</text>
              <text x="2" y={(hrcbY0 + hrcbY1) / 2} fill="var(--fg-secondary)" font-size="8" dominant-baseline="middle">0</text>
              <text x="2" y={hrcbY1 - 1} fill="var(--fg-secondary)" font-size="8" dominant-baseline="auto">−1</text>
              {/* HRCB zero line */}
              <line x1={SPARK_PAD_X + 14} y1={(hrcbY0 + hrcbY1) / 2} x2={SPARK_W - SPARK_PAD_X} y2={(hrcbY0 + hrcbY1) / 2} stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2,3" />
              {/* Divider */}
              <line x1={SPARK_PAD_X} y1={SPARK_HRCB_H + SPARK_PAD_Y / 2} x2={SPARK_W} y2={SPARK_HRCB_H + SPARK_PAD_Y / 2} stroke="var(--color-border)" stroke-width="0.5" />
              {/* HN score label */}
              <text x="2" y={hnY0 + 2} fill="var(--fg-secondary)" font-size="8" dominant-baseline="hanging">HN</text>
              {/* HN score area */}
              {hnPath && <path d={hnPath} fill="#3b82f620" stroke="var(--color-blue)" stroke-width="1" />}
              {/* HRCB eval dots */}
              {hrcbDots.map((dot, i) => (
                <circle key={i} cx={dot.x} cy={dot.y} r="3"
                  fill={scoreToColor(dot.score)}
                  stroke="var(--bg-highlight)" stroke-width="1"
                  title={`${dot.model}: ${formatScore(dot.score)}`} />
              ))}
            </svg>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* Audit Trail — merged eval_history + events, sorted by timestamp */}
  {auditTrail.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 6px; margin-bottom: 8px;">
            <span style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">
              Audit Trail
            </span>
            <span id="trail-count" style="color: var(--fg-secondary); font-size: var(--font-xs);">{auditTrail.length} entries</span>
            {/* Type filter chips */}
            <span style="display: flex; gap: 4px; margin-left: 4px; flex-wrap: wrap;">
              <button class="trail-filter" data-filter="all" style="padding: 1px 8px; font-size: var(--font-xs); border-radius: 10px; border: 1px solid var(--color-border); background: var(--bg-surface); color: var(--fg-primary); cursor: pointer;">all</button>
              <button class="trail-filter" data-filter="eval" style="padding: 1px 8px; font-size: var(--font-xs); border-radius: 10px; border: 1px solid var(--color-border); background: none; color: var(--fg-secondary); cursor: pointer;">eval</button>
              <button class="trail-filter" data-filter="pipeline" style="padding: 1px 8px; font-size: var(--font-xs); border-radius: 10px; border: 1px solid var(--color-border); background: none; color: var(--fg-secondary); cursor: pointer;">pipeline</button>
              {auditTrail.some(e => e.trailCategory === 'content_drift') && (
                <button class="trail-filter" data-filter="content_drift" style="padding: 1px 8px; font-size: var(--font-xs); border-radius: 10px; border: 1px solid var(--color-border); background: none; color: var(--fg-secondary); cursor: pointer;">drift</button>
              )}
            </span>
            {/* Model filter */}
            {distinctAuditModels.length > 1 && (
              <select id="trail-model-filter" style="font-size: var(--font-xs); background: var(--bg-surface); color: var(--fg-secondary); border: 1px solid var(--color-border); border-radius: 4px; padding: 1px 4px; cursor: pointer;">
                <option value="">all models</option>
                {distinctAuditModels.map(m => <option value={m}>{m}</option>)}
              </select>
            )}
            {/* Sort toggle */}
            <button id="trail-sort-toggle" style="padding: 1px 8px; font-size: var(--font-xs); border-radius: 4px; border: 1px solid var(--color-border); background: none; color: var(--fg-secondary); cursor: pointer; margin-left: auto;">
              newest first
            </button>
          </div>
          <div class="table-wrap">
          <table id="audit-trail-table" cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
            {auditTrail.map((entry) => {
              if (entry.type === 'eval') {
                const drift = entry.eval_model && entry.hcb_weighted_mean != null
                  ? getDriftForEval(entry.eval_model, entry.hcb_weighted_mean)
                  : null;
                const scoreStr = entry.hcb_weighted_mean != null ? formatScore(entry.hcb_weighted_mean) : '?';
                const driftStr = drift != null ? (drift > 0 ? `+${drift.toFixed(2)}` : drift.toFixed(2)) : '';
                const driftColor = drift != null ? (drift > 0 ? 'var(--color-positive)' : drift < 0 ? 'var(--color-negative)' : 'var(--fg-secondary)') : '';
                const reasoning = entry.eval_model ? reasoningByModel.get(entry.eval_model) : null;
                return (
                  <>
                  <tr style="border-top: 1px solid var(--bg-surface);" data-category="eval" data-model={entry.eval_model || ''} data-ts={entry.timestamp}>
                    <td style="color: var(--fg-secondary); white-space: nowrap; width: 140px;">{entry.timestamp.slice(0, 16)}</td>
                    <td style="width: 90px;">
                      <span class="badge" style="background: var(--color-positive)20; color: var(--color-positive); font-size: var(--font-xs);">
                        eval
                      </span>
                    </td>
                    <td style="color: var(--fg-primary);">
                      Evaluated by <strong>{entry.eval_model}</strong>: {scoreStr}
                      {entry.hcb_classification ? ` (${entry.hcb_classification})` : ''}
                      {entry.total_tokens ? <span style="color: var(--fg-secondary); margin-left: 6px;">{entry.total_tokens.toLocaleString()} tokens</span> : null}
                      {driftStr ? <span style={`margin-left: 6px; color: ${driftColor}; font-weight: bold;`}>{driftStr}</span> : null}
                    </td>
                    <td style="width: 60px;"></td>
                  </tr>
                  {reasoning && (
                    <tr data-category="eval" data-model={entry.eval_model || ''} data-ts={entry.timestamp}>
                      <td></td>
                      <td colspan="3" style="padding: 2px 0 6px 0;">
                        <details style="font-size: var(--font-xs);">
                          <summary style="color: var(--fg-secondary); cursor: pointer;">reasoning</summary>
                          <div style="margin-top: 4px; padding: 6px 8px; background: var(--bg-surface); border-radius: 4px; color: var(--fg-secondary); white-space: pre-wrap; line-height: 1.4;">{reasoning}</div>
                        </details>
                      </td>
                    </tr>
                  )}
                  </>
                );
              }
              // Event entry
              const sevColor = entry.severity === 'error' ? 'var(--color-negative)' : entry.severity === 'warn' ? 'var(--color-warning)' : 'var(--fg-secondary)';
              const typeColor = EVENT_TYPE_COLORS[entry.event_type || ''] || 'var(--fg-secondary)';
              return (
                <tr style="border-top: 1px solid var(--bg-surface);" data-category={entry.trailCategory} data-model="" data-ts={entry.timestamp}>
                  <td style="color: var(--fg-secondary); white-space: nowrap; width: 140px;">{entry.timestamp.slice(0, 16)}</td>
                  <td style="width: 90px;">
                    <span class="badge" style={`background: ${typeColor}20; color: ${typeColor}; font-size: var(--font-xs);`}>
                      {entry.event_type}
                    </span>
                  </td>
                  <td style={`color: ${sevColor};`}>{entry.message}</td>
                  <td style="width: 60px; text-align: center; white-space: nowrap;">
                    {entry.investigated === 1
                      ? <span style="color: var(--color-blue);" title="Investigated">INV</span>
                      : entry.investigated === 0
                        ? <span style="color: var(--fg-secondary);" title="Not investigated">--</span>
                        : <span style="color: var(--bg-surface);" title="Not triaged">-</span>
                    }
                    {' '}
                    {entry.resolved === 1
                      ? <span style="color: var(--color-positive-vivid);" title="Resolved">RES</span>
                      : entry.resolved === 0
                        ? <span style="color: var(--fg-secondary);" title="Not resolved">--</span>
                        : <span style="color: var(--bg-surface);" title="Not triaged">-</span>
                    }
                  </td>
                </tr>
              );
            })}
          </table>
          </div>
        </td>
      </tr>
    </table>
  )}

  {isFailed && (
    <script is:inline>
    document.querySelectorAll('.trigger-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Gate: require donation (7-day TTL)
        var _dt = localStorage.getItem('hrcb_donated');
        if (!_dt || (Date.now() - new Date(_dt).getTime()) >= 604800000) {
          var modal = document.getElementById('donate-modal');
          if (modal) {
            window.__pendingRetryBtn = btn;
            modal.style.display = 'flex';
          }
          return;
        }

        var hnId = this.getAttribute('data-hn-id');
        this.disabled = true;
        this.textContent = 'Retrying...';
        fetch('/api/trigger/' + hnId, {
          method: 'POST'
        }).then(function(r) {
          var ct = r.headers.get('content-type') || '';
          if (ct.indexOf('text/event-stream') !== -1) {
            // SSE stream — read until done/error
            var reader = r.body.getReader();
            var decoder = new TextDecoder();
            var buffer = '';
            function read() {
              reader.read().then(function(chunk) {
                if (chunk.done) return;
                buffer += decoder.decode(chunk.value, { stream: true });
                var parts = buffer.split('\n\n');
                buffer = parts.pop() || '';
                for (var i = 0; i < parts.length; i++) {
                  var lines = parts[i].split('\n');
                  var evType = '', evData = '';
                  for (var l = 0; l < lines.length; l++) {
                    if (lines[l].indexOf('event: ') === 0) evType = lines[l].slice(7);
                    if (lines[l].indexOf('data: ') === 0) evData = lines[l].slice(6);
                  }
                  if (!evData) continue;
                  try {
                    var d = JSON.parse(evData);
                    if (evType === 'status') {
                      btn.textContent = d.message.slice(0, 30) + '...';
                    } else if (evType === 'done') {
                      btn.textContent = 'Done: ' + (d.score !== undefined ? d.score.toFixed(2) : '?');
                      btn.style.color = 'var(--color-positive)';
                      btn.style.borderColor = 'rgba(22,163,106,0.3)';
                      btn.style.background = 'rgba(22,163,106,0.15)';
                      setTimeout(function() { location.reload(); }, 1500);
                    } else if (evType === 'error') {
                      btn.textContent = 'Error: ' + (d.error || 'unknown');
                      btn.disabled = false;
                    }
                  } catch(e) {}
                }
                read();
              });
            }
            read();
          } else {
            return r.json().then(function(d) {
              btn.textContent = 'Error: ' + (d.error || 'unknown');
              btn.disabled = false;
            });
          }
        }).catch(function() { btn.textContent = 'Network error'; btn.disabled = false; });
      });
    });
    </script>
  )}

  <script is:inline>
  (function() {
    var toggle = document.getElementById('fw-toggle');
    if (!toggle) return;
    var fwOn = false;
    toggle.addEventListener('click', function() {
      fwOn = !fwOn;
      toggle.textContent = 'Fair Witness (Evidence): ' + (fwOn ? 'ON' : 'OFF');
      toggle.style.background = fwOn ? 'rgba(168,85,247,0.3)' : 'rgba(168,85,247,0.15)';

      // Show/hide FW-only elements
      var fwOnly = document.querySelectorAll('.fw-only');
      for (var i = 0; i < fwOnly.length; i++) {
        fwOnly[i].style.display = fwOn ? '' : 'none';
      }

      // Show/hide standard elements
      var fwHide = document.querySelectorAll('.fw-hide');
      for (var j = 0; j < fwHide.length; j++) {
        fwHide[j].style.display = fwOn ? 'none' : '';
      }
    });
  })();
  </script>

  <script is:inline>
  // Audit trail filter + sort
  (function() {
    var table = document.getElementById('audit-trail-table');
    if (!table) return;
    var countEl = document.getElementById('trail-count');
    var modelSel = document.getElementById('trail-model-filter');
    var sortBtn = document.getElementById('trail-sort-toggle');
    var filterBtns = document.querySelectorAll('.trail-filter');
    var activeFilter = 'all';
    var activeModel = '';
    var sortDesc = true; // newest first

    function applyFilters() {
      var rows = table.querySelectorAll('tr[data-category]');
      var visible = 0;
      // Collect and sort
      var arr = Array.prototype.slice.call(rows);
      arr.sort(function(a, b) {
        var ta = a.getAttribute('data-ts') || '';
        var tb = b.getAttribute('data-ts') || '';
        return sortDesc ? tb.localeCompare(ta) : ta.localeCompare(tb);
      });
      arr.forEach(function(row) {
        table.appendChild(row);
      });
      rows = table.querySelectorAll('tr[data-category]');
      rows.forEach(function(row) {
        var cat = row.getAttribute('data-category') || '';
        var model = row.getAttribute('data-model') || '';
        var show = (activeFilter === 'all' || cat === activeFilter)
                && (activeModel === '' || model === activeModel);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = visible + ' of ' + rows.length + ' entries';
    }

    filterBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeFilter = this.getAttribute('data-filter') || 'all';
        filterBtns.forEach(function(b) {
          b.style.background = 'none';
          b.style.color = 'var(--fg-secondary)';
        });
        this.style.background = 'var(--bg-surface)';
        this.style.color = 'var(--fg-primary)';
        applyFilters();
      });
    });

    if (modelSel) {
      modelSel.addEventListener('change', function() {
        activeModel = this.value;
        applyFilters();
      });
    }

    if (sortBtn) {
      sortBtn.addEventListener('click', function() {
        sortDesc = !sortDesc;
        this.textContent = sortDesc ? 'newest first' : 'oldest first';
        applyFilters();
      });
    }
  })();
  </script>
</Base>
