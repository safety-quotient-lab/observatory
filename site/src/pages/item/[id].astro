                  <div style="display: flex; align-items: center; gap: 4px; margin-bottom: 2px;">
                    <span style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">Complexity</span>
                    <a href="/about#cl" style="color: var(--channel-hrcb); font-size: var(--font-xs); text-decoration: none;" title="Reading level, jargon density, assumed knowledge">&#8505;</a>
                  </div>
                  <div style="color: var(--fg-secondary); font-size: 7px; margin-bottom: 6px;">How accessible is this content to a general audience?</div>
                  <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                    <span class="badge" style={`background: ${clData.reading_level === 'accessible' ? 'rgba(22,163,106,0.15)' : clData.reading_level === 'moderate' ? 'rgba(96,165,250,0.15)' : clData.reading_level === 'technical' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${clData.reading_level === 'accessible' ? 'var(--color-positive)' : clData.reading_level === 'moderate' ? 'var(--channel-editorial)' : clData.reading_level === 'technical' ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-xs);`}>{clData.reading_level}</span>
                    <span class="badge" style={`background: ${clData.jargon_density === 'low' ? 'rgba(22,163,106,0.15)' : clData.jargon_density === 'medium' ? 'rgba(234,179,8,0.15)' : 'rgba(220,38,38,0.15)'}; color: ${clData.jargon_density === 'low' ? 'var(--color-positive)' : clData.jargon_density === 'medium' ? 'var(--color-warning)' : 'var(--color-negative)'}; font-size: var(--font-xs);`}>{clData.jargon_density} jargon</span>
