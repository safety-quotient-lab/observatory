                    <tr><td style="color: var(--fg-secondary);">Dominance</td><td><div style="height: 4px; background: var(--bg-surface); border-radius: 2px; overflow: hidden;"><div style={`width: ${etData.dominance * 100}%; height: 100%; background: var(--color-sentiment);`}></div></div></td><td style="color: var(--fg-secondary); text-align: right;">{etData.dominance.toFixed(1)}</td></tr>
                  </table>
