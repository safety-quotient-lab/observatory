                    <span class="badge" style="background: rgba(107,114,128,0.15); color: var(--fg-secondary); font-size: var(--font-xs);">{tfData.time_horizon.replace(/_/g, ' ')}</span>
                  </div>
                </div>
              </div>
              )}

              {/* Geographic Scope */}
              {gsData && (
