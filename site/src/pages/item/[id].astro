---
import Base from '../../layouts/Base.astro';
import HeatMap from '../../components/HeatMap.astro';
import RadarChart from '../../components/RadarChart.astro';
import ScoreBar from '../../components/ScoreBar.astro';
import DcpTable from '../../components/DcpTable.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, evidenceColor } from '../../lib/colors';
import { getStory } from '../../lib/db';
import type { Evaluation } from '../../lib/types';

const { id } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const hnId = parseInt(id!, 10);
if (isNaN(hnId)) {
  return Astro.redirect('/');
}

const storyData = await getStory(db, hnId);
if (!storyData || storyData.eval_status !== 'done' || !storyData.hcb_json) {
  return Astro.redirect('/');
}

// Parse the full evaluation JSON for DCP and aggregates
const evalData = JSON.parse(storyData.hcb_json) as Evaluation;
const { evaluation, domain_context_profile, aggregates } = evalData;

// Use scores from DB (or from eval JSON as fallback)
const scores = storyData.scores.length > 0 ? storyData.scores : evalData.scores;

const classColor = classificationColor(aggregates.classification);
const classText = classificationTextColor(aggregates.classification);

const CONTENT_TYPE_LABELS: Record<string, string> = {
  ED: 'Editorial',
  CO: 'Commentary',
  HR: 'Human Rights',
  PO: 'Policy',
  MI: 'Mixed',
  ME: 'Media',
  LP: 'Landing Page',
  PR: 'Product',
  AD: 'Advertising',
  AC: 'Academic',
  MX: 'Mixed',
};

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds}s ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}
---

<Base title={`${storyData.title} — HRCB`}>
  <!-- Header -->
  <section class="border-b border-surface-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <a href="/" class="text-gray-500 hover:text-gray-300 text-sm">&larr; Feed</a>
          </div>
          <h1 class="text-xl sm:text-2xl font-bold text-white mb-2">{storyData.title}</h1>
          <p class="text-sm text-gray-400 break-all">
            <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener" class="hover:text-indigo-400 transition-colors">
              {(storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`).replace(/^https?:\/\//, '').slice(0, 80)}
            </a>
          </p>
          <div class="flex items-center flex-wrap gap-2 mt-3">
            <span
              class="badge"
              style={`background: ${classColor}; color: ${classText}`}
            >
              {aggregates.classification}
            </span>
            <span class="badge bg-surface-3 text-gray-400">
              {CONTENT_TYPE_LABELS[evaluation.content_type.primary] || evaluation.content_type.primary}
            </span>
            <span class="badge bg-surface-3 text-gray-400">
              v{evaluation.methodology}
            </span>
            <span class="badge bg-surface-3 text-gray-400">
              {evaluation.date}
            </span>
          </div>
          <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span>by {storyData.hn_by}</span>}
            <span>{timeAgo(storyData.hn_time)}</span>
            {storyData.hn_comments !== null && (
              <a
                href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                class="hover:text-gray-300 transition-colors"
                target="_blank"
                rel="noopener"
              >
                {storyData.hn_comments} comments on HN
              </a>
            )}
          </div>
        </div>
        <div class="text-right">
          <div class="text-[10px] uppercase tracking-wider text-gray-500 mb-1">Weighted Mean</div>
          <div class="score-font text-4xl font-bold" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>
            {formatScore(aggregates.weighted_mean)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    <!-- Article Heatmap -->
    <section class="card p-6">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Article Heatmap</h2>
      <HeatMap scores={scores} compact={false} showLabels={true} />
      <div class="flex items-center gap-4 mt-4 text-xs text-gray-500">
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded" style="background: #dc2626"></div>
          <span>Negative</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded" style="background: #555"></div>
          <span>Neutral</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded" style="background: #16a34a"></div>
          <span>Positive</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded" style="background: repeating-linear-gradient(45deg, #1a1a25, #1a1a25 2px, #2a2a35 2px, #2a2a35 4px)"></div>
          <span>ND</span>
        </div>
      </div>
    </section>

    <!-- Stats + Radar side by side -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Aggregate stats -->
      <section class="card p-6">
        <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Aggregates</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-surface-2 rounded-lg p-3">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Weighted Mean</div>
            <div class="score-font text-xl font-bold" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>
              {formatScore(aggregates.weighted_mean)}
            </div>
          </div>
          <div class="bg-surface-2 rounded-lg p-3">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Unweighted Mean</div>
            <div class="score-font text-xl font-bold" style={`color: ${scoreToColor(aggregates.unweighted_mean)}`}>
              {formatScore(aggregates.unweighted_mean)}
            </div>
          </div>
          <div class="bg-surface-2 rounded-lg p-3">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Max</div>
            <div class="score-font text-lg font-bold" style={`color: ${scoreToColor(aggregates.max.value)}`}>
              {formatScore(aggregates.max.value)}
            </div>
            <div class="text-[10px] text-gray-500 score-font">{aggregates.max.section}</div>
          </div>
          <div class="bg-surface-2 rounded-lg p-3">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Min</div>
            <div class="score-font text-lg font-bold" style={`color: ${scoreToColor(aggregates.min.value)}`}>
              {formatScore(aggregates.min.value)}
            </div>
            <div class="text-[10px] text-gray-500 score-font">{aggregates.min.section}</div>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="bg-surface-2 rounded-lg p-3 text-center">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Signal</div>
            <div class="score-font text-lg font-bold text-white">{aggregates.signal_sections}</div>
          </div>
          <div class="bg-surface-2 rounded-lg p-3 text-center">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">ND</div>
            <div class="score-font text-lg font-bold text-gray-500">{aggregates.nd_count}</div>
          </div>
          <div class="bg-surface-2 rounded-lg p-3 text-center">
            <div class="text-[10px] text-gray-500 uppercase tracking-wider">Negative</div>
            <div class="score-font text-lg font-bold text-red-400">{aggregates.negative_count}</div>
          </div>
        </div>

        <!-- Evidence profile -->
        <div class="mt-4">
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Evidence Profile</div>
          <div class="flex gap-2">
            {Object.entries(aggregates.evidence_profile).map(([key, count]) => (
              <div class="flex items-center gap-1">
                <span class="badge text-[10px]" style={`background: ${evidenceColor(key === 'ND' ? null : key)}30; color: ${evidenceColor(key === 'ND' ? null : key)}`}>
                  {key}: {count}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Channel balance -->
        <div class="mt-3">
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-2">Channel Balance</div>
          <div class="flex gap-2">
            <span class="badge bg-blue-500/20 text-blue-400 text-[10px]">E: {aggregates.channel_balance.E_only}</span>
            <span class="badge bg-cyan-500/20 text-cyan-400 text-[10px]">S: {aggregates.channel_balance.S_only}</span>
            <span class="badge bg-purple-500/20 text-purple-400 text-[10px]">Both: {aggregates.channel_balance.both}</span>
          </div>
        </div>

        <!-- Volatility -->
        <div class="mt-3">
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Volatility</div>
          <span class="score-font text-sm text-gray-300">
            {aggregates.volatility.value.toFixed(2)} ({aggregates.volatility.label})
          </span>
        </div>

        <!-- Channel weights -->
        <div class="mt-3">
          <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-1">Channel Weights</div>
          <div class="flex gap-4 score-font text-sm text-gray-300">
            <span>E: {evaluation.channel_weights.editorial}</span>
            <span>S: {evaluation.channel_weights.structural}</span>
          </div>
        </div>
      </section>

      <!-- Radar chart -->
      <section class="card p-6">
        <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Theme Radar</h2>
        <RadarChart scores={scores} size={340} />
        <p class="text-xs text-gray-500 text-center mt-2">
          Average score per article group. Dashed line = 0.0 (neutral).
        </p>
      </section>
    </div>

    <!-- Domain Context Profile -->
    <section class="card p-6">
      <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Domain Context Profile</h2>
      <DcpTable elements={domain_context_profile.elements} />
    </section>

    <!-- Article detail accordion -->
    <section class="card overflow-hidden">
      <div class="px-6 py-4 border-b border-surface-3">
        <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider">Score Breakdown</h2>
      </div>
      {scores.map((score, i) => (
        <ArticleDetail score={score} index={i} />
      ))}
    </section>
  </div>
</Base>
