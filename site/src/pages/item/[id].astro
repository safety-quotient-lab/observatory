---
import Base from '../../layouts/Base.astro';
import HeatMap from '../../components/HeatMap.astro';
import RadarChart from '../../components/RadarChart.astro';
import DcpTable from '../../components/DcpTable.astro';
import ArticleDetail from '../../components/ArticleDetail.astro';
import ModelCompareTable from '../../components/ModelCompareTable.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, evidenceColor, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence, fwRatioColor, formatFwRatio } from '../../lib/colors';
import { getStory, getStoryComments, getDomainDcp, getEventsForStory, getEvalHistoryForStory, getRaterEvalsForStory, getRaterScores, getFairWitnessForStory, getStoryTimeline } from '../../lib/db';
import { CONTENT_TYPE_LABELS } from '../../lib/types';
import { computeAggregates, type Aggregates } from '../../lib/compute-aggregates';
import { modelDisplayName, isLiteMode } from '../../lib/shared-eval';
import { sanitizeHtml } from '../../lib/sanitize';
import { readDb } from '../../lib/db-utils';

const { id } = Astro.params;
const rawDb = Astro.locals.runtime.env.DB;
const db = readDb(rawDb);
const url = new URL(Astro.request.url);
const modelParam = url.searchParams.get('model');
const viewParam = url.searchParams.get('view');

const hnId = parseInt(id!, 10);
if (isNaN(hnId)) {
  return Astro.redirect('/');
}

const storyData = await getStory(rawDb, hnId);
if (!storyData) {
  return Astro.redirect('/');
}

// Batch fetch: single D1 round-trip for all independent queries to stay within CPU budget.
// Uses rawDb (not session-wrapped db) because batch() may not be available on session proxy.
const batchStatements: D1PreparedStatement[] = [
  rawDb.prepare(`SELECT * FROM rater_evals WHERE hn_id = ? ORDER BY evaluated_at DESC`).bind(hnId),
  rawDb.prepare(`SELECT comment_id, parent_id, author, text, time, depth, hn_score FROM story_comments WHERE hn_id = ? ORDER BY depth ASC, time ASC LIMIT 50`).bind(hnId),
  rawDb.prepare(`SELECT event_type, severity, message, created_at, investigated, resolved FROM events WHERE hn_id = ? ORDER BY created_at DESC LIMIT 20`).bind(hnId),
  rawDb.prepare(`SELECT eval_model, hcb_weighted_mean, hcb_classification, input_tokens, output_tokens, evaluated_at FROM eval_history WHERE hn_id = ? ORDER BY evaluated_at DESC`).bind(hnId),
  rawDb.prepare(`SELECT hn_score, hn_comments, hn_rank, snapshot_at, ROUND((julianday(snapshot_at) - julianday((SELECT MIN(snapshot_at) FROM story_snapshots WHERE hn_id = ?))) * 24 * 60, 0) as minutes_elapsed FROM story_snapshots WHERE hn_id = ? ORDER BY snapshot_at`).bind(hnId, hnId),
];
// DCP query only if domain exists
if (storyData.domain) {
  batchStatements.push(
    rawDb.prepare(`SELECT dcp_json FROM domain_dcp WHERE domain = ?`).bind(storyData.domain)
  );
}

let raterEvals: Awaited<ReturnType<typeof getRaterEvalsForStory>> = [];
let comments: Awaited<ReturnType<typeof getStoryComments>> = [];
let storyEvents: Awaited<ReturnType<typeof getEventsForStory>> = [];
let evalHistory: Awaited<ReturnType<typeof getEvalHistoryForStory>> = [];
let storyTimeline: Awaited<ReturnType<typeof getStoryTimeline>> = [];
let _dcpJson: string | null = null;

try {
  const batchResults = await rawDb.batch(batchStatements);
  raterEvals = (batchResults[0]?.results ?? []) as typeof raterEvals;
  comments = (batchResults[1]?.results ?? []) as typeof comments;
  storyEvents = (batchResults[2]?.results ?? []) as typeof storyEvents;
  evalHistory = (batchResults[3]?.results ?? []) as typeof evalHistory;
  storyTimeline = (batchResults[4]?.results ?? []) as typeof storyTimeline;
  if (storyData.domain && batchResults[5]) {
    const dcpRow = batchResults[5].results?.[0] as { dcp_json: string } | undefined;
    _dcpJson = dcpRow?.dcp_json ?? null;
  }
} catch {
  // Batch failed — queries may not exist yet, fall back gracefully
}

const hasMultipleModels = raterEvals.length > 1;

// If viewing a non-primary model, load its scores
let altModelScores: Awaited<ReturnType<typeof getRaterScores>> = [];
let altModelEval = modelParam ? raterEvals.find(e => e.eval_model === modelParam) : null;
if (modelParam && altModelEval) {
  try {
    altModelScores = await getRaterScores(rawDb, hnId, modelParam);
  } catch { /* table may not exist yet */ }
}

// For compare view, load scores for all models
const compareScoresByModel: Record<string, Awaited<ReturnType<typeof getRaterScores>>> = {};
if (viewParam === 'compare' && raterEvals.length >= 2) {
  for (const re of raterEvals) {
    try {
      compareScoresByModel[re.eval_model] = await getRaterScores(rawDb, hnId, re.eval_model);
    } catch { /* ignore */ }
  }
}

// Handle statuses
const isFailed = storyData.eval_status === 'failed';
const isDone = storyData.eval_status === 'done' && storyData.hcb_weighted_mean !== null;
const isPending = storyData.eval_status === 'pending' || storyData.eval_status === 'evaluating';
// Lite-only: has editorial scores but no full weighted_mean — lite eval filled COALESCE
// fields but didn't promote eval_status (story stays pending/queued until full eval)
const isLiteOnlyEval = !isDone && storyData.hcb_editorial_mean !== null && storyData.hcb_weighted_mean === null && raterEvals.some(re => isLiteMode(re.prompt_mode));
const liteEval = isLiteOnlyEval ? (raterEvals.find(re => isLiteMode(re.prompt_mode)) ?? null) : null;

// DCP: parse from parallel-fetched result
let dcpElements: any[] | null = null;
if (_dcpJson) {
  try {
    const dcpData = JSON.parse(_dcpJson);
    dcpElements = dcpData.elements || dcpData;
  } catch { /* ignore parse errors */ }
}

// Scores from the scores table (already fetched by getStory)
const scores = isDone ? storyData.scores : [];

// Compute aggregates from scores (replaces hcb_json parsing)
const channelWeights = { editorial: 0.6, structural: 0.4 }; // default ED weights
let aggregates: Aggregates | null = null;
if (isDone && scores.length > 0) {
  aggregates = computeAggregates(scores, channelWeights);
}

const classColor = storyData.hcb_classification ? classificationColor(storyData.hcb_classification) : 'var(--fg-secondary)';
const classText = storyData.hcb_classification ? classificationTextColor(storyData.hcb_classification) : 'var(--fg-primary)';

// Fair Witness: fetch from rater_witness table (depends on raterEvals for model name)
const fwEvalModel = storyData.eval_model || raterEvals.find(re => re.prompt_mode === 'full')?.eval_model || null;
const fwFacts = isDone ? await getFairWitnessForStory(rawDb, hnId, fwEvalModel) : [];
const hasFairWitness = fwFacts.length > 0;

// Group FW facts by section and merge into display scores
const fwBySection = new Map<string, { facts: string[]; inferences: string[] }>();
for (const fw of fwFacts) {
  let entry = fwBySection.get(fw.section);
  if (!entry) {
    entry = { facts: [], inferences: [] };
    fwBySection.set(fw.section, entry);
  }
  if (fw.fact_type === 'observable') entry.facts.push(fw.fact_text);
  else entry.inferences.push(fw.fact_text);
}

const displayScores = isDone ? scores.map(s => {
  const fw = fwBySection.get(s.section);
  return {
    ...s,
    witness_facts: fw?.facts,
    witness_inferences: fw?.inferences,
    witness_ratio: fw ? (fw.facts.length / (fw.facts.length + fw.inferences.length)) : undefined,
  };
}) : [];

// Power-ranked: sort by channel score descending, ND articles last
const editorialRanked = [...displayScores].sort((a, b) => {
  if (a.editorial == null && b.editorial == null) return 0;
  if (a.editorial == null) return 1;
  if (b.editorial == null) return -1;
  return b.editorial - a.editorial;
});
const structuralRanked = [...displayScores].sort((a, b) => {
  if (a.structural == null && b.structural == null) return 0;
  if (a.structural == null) return 1;
  if (b.structural == null) return -1;
  return b.structural - a.structural;
});
// FW aggregate metrics
const fwRatio = storyData.fw_ratio ?? (hasFairWitness ? (() => {
  let facts = 0, inferences = 0;
  for (const [, fw] of fwBySection) {
    facts += fw.facts.length;
    inferences += fw.inferences.length;
  }
  const total = facts + inferences;
  return total > 0 ? facts / total : null;
})() : null);
const fwObservableCount = storyData.fw_observable_count ?? Array.from(fwBySection.values()).reduce((n, fw) => n + fw.facts.length, 0);
const fwInferenceCount = storyData.fw_inference_count ?? Array.from(fwBySection.values()).reduce((n, fw) => n + fw.inferences.length, 0);

// Compute aggregate SETL from scores
const setlValues = scores
  .map(s => computeSetl(s.structural, s.editorial))
  .filter((v): v is number => v !== null);
const aggSetl = storyData.hcb_setl ?? (setlValues.length > 0
  ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
  : null);

// Confidence (evidence-weighted)
const confidence = computeConfidence(storyData.hcb_evidence_h, storyData.hcb_evidence_m, storyData.hcb_evidence_l, storyData.hcb_nd_count);
const _evTotal = (storyData.hcb_evidence_h ?? 0) + (storyData.hcb_evidence_m ?? 0) + (storyData.hcb_evidence_l ?? 0) + (storyData.hcb_nd_count ?? 0);
const _evH = _evTotal > 0 ? Math.round((storyData.hcb_evidence_h ?? 0) / _evTotal * 100) : 0;
const _evM = _evTotal > 0 ? Math.round((storyData.hcb_evidence_m ?? 0) / _evTotal * 100) : 0;
const _evL = _evTotal > 0 ? Math.round((storyData.hcb_evidence_l ?? 0) / _evTotal * 100) : 0;
const _evND = _evTotal > 0 ? (100 - _evH - _evM - _evL) : 0; // remainder avoids rounding gap

// Story-level labels
const themeTag = storyData.hcb_theme_tag || null;
const sentimentTag = storyData.hcb_sentiment_tag || null;
const executiveSummary = storyData.hcb_executive_summary || null;

// Supplementary signals (from materialized columns — source of truth)
const eqData = storyData.eq_score != null ? {
  eq_score: storyData.eq_score,
  source_quality: storyData.eq_source_quality ?? 0,
  evidence_reasoning: storyData.eq_evidence_reasoning ?? 0,
  uncertainty_handling: storyData.eq_uncertainty_handling ?? 0,
  purpose_transparency: storyData.eq_purpose_transparency ?? 0,
  claim_density: storyData.eq_claim_density ?? 'medium',
} : null;
const eqScore = storyData.eq_score ?? null;
const ptFlags = storyData.pt_flags_json ? (() => { try { return JSON.parse(storyData.pt_flags_json); } catch { return null; } })() : null;
const ptFlagCount = ptFlags?.length ?? storyData.pt_flag_count ?? 0;
const soData = storyData.so_score != null ? {
  so_score: storyData.so_score,
  framing: storyData.so_framing ?? 'mixed',
  reader_agency: storyData.so_reader_agency ?? 0,
} : null;
const etData = storyData.et_primary_tone != null ? {
  primary_tone: storyData.et_primary_tone,
  valence: storyData.et_valence ?? 0,
  arousal: storyData.et_arousal ?? 0,
  dominance: storyData.et_dominance ?? 0.5,
} : null;
const srData = storyData.sr_score != null ? {
  sr_score: storyData.sr_score,
  perspective_count: storyData.sr_perspective_count ?? 0,
  voice_balance: storyData.sr_voice_balance ?? 0,
  who_speaks: storyData.sr_who_speaks ? (() => { try { return JSON.parse(storyData.sr_who_speaks); } catch { return []; } })() : [],
  who_is_spoken_about: storyData.sr_who_spoken_about ? (() => { try { return JSON.parse(storyData.sr_who_spoken_about); } catch { return []; } })() : [],
} : null;
const tfData = storyData.tf_primary_focus != null ? {
  primary_focus: storyData.tf_primary_focus,
  time_horizon: storyData.tf_time_horizon ?? 'unspecified',
} : null;
const gsData = storyData.gs_scope != null ? {
  scope: storyData.gs_scope,
  regions_mentioned: storyData.gs_regions_json ? (() => { try { return JSON.parse(storyData.gs_regions_json); } catch { return []; } })() : [],
} : null;
const clData = storyData.cl_reading_level != null ? {
  reading_level: storyData.cl_reading_level,
  jargon_density: storyData.cl_jargon_density ?? 'low',
  assumed_knowledge: storyData.cl_assumed_knowledge ?? 'general_audience',
} : null;
const tdData = storyData.td_score != null ? {
  td_score: storyData.td_score,
  author_identified: !!storyData.td_author_identified,
  conflicts_disclosed: storyData.td_conflicts_disclosed != null ? !!storyData.td_conflicts_disclosed : null,
  funding_disclosed: storyData.td_funding_disclosed != null ? !!storyData.td_funding_disclosed : null,
} : null;
const hasSignals = eqScore !== null || ptFlagCount > 0 || soData !== null || etData !== null || srData !== null || tfData !== null || gsData !== null || clData !== null || tdData !== null;

// comments, storyEvents, evalHistory, storyTimeline fetched in parallel above

// Merge events and eval_history into a unified audit trail, sorted newest first
interface AuditEntry {
  timestamp: string;
  type: 'event' | 'eval';
  trailCategory: 'eval' | 'pipeline' | 'content_drift';
  // event fields
  event_type?: string;
  severity?: string;
  message?: string;
  investigated?: number | null;
  resolved?: number | null;
  // eval fields
  eval_model?: string;
  hcb_weighted_mean?: number | null;
  hcb_classification?: string | null;
  total_tokens?: number | null;
}

const CONTENT_DRIFT_EVENT_TYPES = new Set(['content_drift']);

function trailCategory(type: 'event' | 'eval', event_type?: string): 'eval' | 'pipeline' | 'content_drift' {
  if (type === 'eval') return 'eval';
  if (event_type && CONTENT_DRIFT_EVENT_TYPES.has(event_type)) return 'content_drift';
  return 'pipeline';
}

const auditTrail: AuditEntry[] = [
  ...storyEvents.map(ev => ({
    timestamp: ev.created_at,
    type: 'event' as const,
    trailCategory: trailCategory('event', ev.event_type),
    event_type: ev.event_type,
    severity: ev.severity,
    message: ev.message,
    investigated: ev.investigated,
    resolved: ev.resolved,
  })),
  ...evalHistory.map(eh => ({
    timestamp: eh.evaluated_at,
    type: 'eval' as const,
    trailCategory: trailCategory('eval'),
    eval_model: eh.eval_model,
    hcb_weighted_mean: eh.hcb_weighted_mean,
    hcb_classification: eh.hcb_classification,
    total_tokens: (eh.input_tokens ?? 0) + (eh.output_tokens ?? 0) || null,
  })),
].sort((a, b) => b.timestamp.localeCompare(a.timestamp));

// Compute score drift for re-evaluations by same model
const evalsByModel = new Map<string, number[]>();
for (const entry of auditTrail) {
  if (entry.type === 'eval' && entry.eval_model && entry.hcb_weighted_mean != null) {
    const existing = evalsByModel.get(entry.eval_model);
    if (existing) existing.push(entry.hcb_weighted_mean);
    else evalsByModel.set(entry.eval_model, [entry.hcb_weighted_mean]);
  }
}
const modelEvalIndex = new Map<string, number>();
function getDriftForEval(model: string, score: number): number | null {
  const scores = evalsByModel.get(model);
  if (!scores || scores.length < 2) return null;
  const idx = modelEvalIndex.get(model) ?? 0;
  modelEvalIndex.set(model, idx + 1);
  // scores are newest-first, so drift = current - next (older)
  if (idx + 1 < scores.length) return score - scores[idx + 1];
  return null;
}

// Build reasoning lookup from rater_evals (lite evals have pre-commit reasoning text)
const reasoningByModel = new Map<string, string>();
for (const re of raterEvals) {
  if (re.reasoning) reasoningByModel.set(re.eval_model, re.reasoning);
}

// Longitudinal sparkline: show when ≥2 eval_history entries OR ≥5 story_snapshots
const showSparkline = evalHistory.length >= 2 || storyTimeline.length >= 5;

// Compute sparkline geometry (server-side SVG)
const SPARK_W = 560, SPARK_H = 64, SPARK_PAD_X = 2, SPARK_PAD_Y = 4;
const SPARK_HN_H = 28, SPARK_HRCB_H = 28; // heights of each sub-chart area
// Gather all timestamps to establish shared time axis
const allTimestamps: number[] = [
  ...storyTimeline.map(p => new Date(p.snapshot_at).getTime()),
  ...evalHistory.map(eh => new Date(eh.evaluated_at).getTime()),
].filter(t => !isNaN(t));
const tMin = allTimestamps.length > 0 ? Math.min(...allTimestamps) : 0;
const tMax = allTimestamps.length > 0 ? Math.max(...allTimestamps) : 1;
const tRange = tMax - tMin || 1;

function txToX(ts: number): number {
  return SPARK_PAD_X + ((ts - tMin) / tRange) * (SPARK_W - SPARK_PAD_X * 2);
}

// HN score area path (bottom sub-chart: y from SPARK_HRCB_H+SPARK_PAD_Y to SPARK_H-SPARK_PAD_Y)
const hnScores = storyTimeline.map(p => p.hn_score ?? 0).filter(s => s > 0);
const hnMax = hnScores.length > 0 ? Math.max(...hnScores) : 1;
const hnY0 = SPARK_HRCB_H + SPARK_PAD_Y;
const hnY1 = SPARK_H - SPARK_PAD_Y;
function hnScoreToY(s: number): number {
  return hnY1 - ((s / hnMax) * (hnY1 - hnY0));
}
const hnPoints = storyTimeline
  .filter(p => p.hn_score != null && p.hn_score > 0)
  .map(p => ({ x: txToX(new Date(p.snapshot_at).getTime()), y: hnScoreToY(p.hn_score!) }));
let hnPath = '';
if (hnPoints.length >= 2) {
  hnPath = hnPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  const firstX = hnPoints[0].x.toFixed(1);
  const lastX = hnPoints[hnPoints.length - 1].x.toFixed(1);
  hnPath += ` L${lastX},${hnY1} L${firstX},${hnY1} Z`;
}

// HRCB dots (top sub-chart: y from SPARK_PAD_Y to SPARK_HRCB_H)
const hrcbY0 = SPARK_PAD_Y, hrcbY1 = SPARK_HRCB_H;
function hrcbScoreToY(score: number): number {
  // [-1, 1] → [hrcbY1, hrcbY0] (high score = top)
  return hrcbY1 - ((score + 1) / 2) * (hrcbY1 - hrcbY0);
}
const hrcbDots = evalHistory
  .filter(eh => eh.hcb_weighted_mean != null)
  .map(eh => ({
    x: txToX(new Date(eh.evaluated_at).getTime()),
    y: hrcbScoreToY(eh.hrcb_weighted_mean!),
    score: eh.hrcb_weighted_mean!,
    model: eh.eval_model,
  }));

const siteUrl = Astro.url.origin;

const jsonLd = isDone && aggregates ? {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: `HRCB Evaluation: ${storyData.title}`,
  description: `Human Rights Compatibility Bias evaluation of "${storyData.title}" against the UN Universal Declaration of Human Rights. Classification: ${aggregates.classification}. HRCB: ${formatScore(aggregates.weighted_mean)}.`,
  url: `${siteUrl}/item/${storyData.hn_id}`,
  datePublished: storyData.evaluated_at || undefined,
  author: {
    '@type': 'Organization',
    name: 'HN HRCB',
    url: siteUrl,
  },
  itemReviewed: {
    '@type': 'CreativeWork',
    name: storyData.title,
    url: storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`,
    ...(storyData.domain && { publisher: { '@type': 'Organization', name: storyData.domain } }),
    ...(storyData.hn_by && { author: { '@type': 'Person', name: storyData.hn_by } }),
    datePublished: new Date(storyData.hn_time * 1000).toISOString(),
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: aggregates.weighted_mean,
    bestRating: 1.0,
    worstRating: -1.0,
    ratingExplanation: `HRCB ${aggregates.classification} — evaluated against ${aggregates.signal_sections} of 31 UDHR provisions${storyData.schema_version ? ` using schema v${storyData.schema_version}` : ''}`,
  },
  reviewBody: executiveSummary || `Content type: ${CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}. ${aggregates.signal_sections} sections scored, ${aggregates.nd_count} with no data. Volatility: ${aggregates.volatility.label} (${aggregates.volatility.value.toFixed(2)}).`,
  about: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;

const distinctAuditModels = [...new Set(
  auditTrail.filter(e => e.type === 'eval' && e.eval_model).map(e => e.eval_model!)
)];

const EVIDENCE_LABELS: Record<string, string> = {H: 'High', M: 'Medium', L: 'Low', ND: 'No Data'};

const EVENT_TYPE_COLORS: Record<string, string> = {
  eval_failure: 'var(--color-negative)', eval_retry: 'var(--color-orange)', eval_skip: 'var(--color-muted)',
  eval_success: 'var(--color-positive)', rate_limit: 'var(--color-warning)', fetch_error: 'var(--color-negative)',
  parse_error: 'var(--color-negative)', trigger: 'var(--channel-editorial)', r2_error: 'var(--color-orange)',
};

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds} seconds ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}
---

<Base
  title={`${storyData.title} — ${isFailed ? 'Failed' : isPending ? 'Pending' : isLiteOnlyEval ? 'HRCB~lite' : 'HRCB'}`}
  ogTitle={isDone && aggregates ? `${formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)} ${storyData.title}` : storyData.title}
  ogDescription={isDone && aggregates ? (executiveSummary || `HRCB: ${aggregates.classification} (${formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}) — ${aggregates.signal_sections} of 31 UDHR provisions scored. ${storyData.domain || 'self-post'}`) : isPending ? `Evaluation pending for ${storyData.title}` : `Evaluation failed for ${storyData.title}`}
  ogUrl={`${siteUrl}/item/${storyData.hn_id}`}
  canonicalUrl={`${siteUrl}/item/${storyData.hn_id}`}
>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}

  <Breadcrumb crumbs={[
    { label: 'home', href: '/' },
    ...(storyData.domain ? [{ label: storyData.domain, href: `/domain/${storyData.domain}` }] : []),
    { label: `item ${storyData.hn_id}` },
  ]} />

  {/* Model tab bar (shown when multiple models have evaluated) */}
  {(isDone || isLiteOnlyEval) && hasMultipleModels && (
    <div style="padding: 6px 0; margin-bottom: 4px; display: flex; gap: 4px; flex-wrap: wrap; align-items: center;">
      <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-right: 4px;">Model:</span>
      {raterEvals.map(re => {
        const isActive = modelParam ? modelParam === re.eval_model : re.eval_model === storyData.eval_model;
        const isDefault = re.eval_model === storyData.eval_model;
        return (
          <a href={isDefault ? `/item/${hnId}` : `/item/${hnId}?model=${re.eval_model}`}
             style={`padding: 2px 8px; font-size: var(--font-xs); border-radius: 3px; text-decoration: none; ${isActive ? 'background: var(--bg-surface); color: var(--fg-primary); border: 1px solid var(--color-border);' : 'background: var(--bg-highlight); color: var(--fg-secondary); border: 1px solid var(--bg-surface);'}`}>
            {modelDisplayName(re.eval_model)}
            {isLiteMode(re.prompt_mode) && <span style="color: var(--color-orange); margin-left: 3px;" title="Lite evaluation — editorial only, no per-section scores">lite</span>}
            <span style={`margin-left: 4px; color: ${scoreToColor(re.hcb_editorial_mean ?? re.hcb_weighted_mean)};`}>
              {formatScore(re.hcb_editorial_mean ?? re.hcb_weighted_mean)}
            </span>
          </a>
        );
      })}
      <a href={`/item/${hnId}?view=compare`}
         style={`padding: 2px 8px; font-size: var(--font-xs); border-radius: 3px; text-decoration: none; ${viewParam === 'compare' ? 'background: var(--bg-surface); color: var(--fg-primary); border: 1px solid var(--color-border);' : 'background: var(--bg-highlight); color: var(--fg-secondary); border: 1px solid var(--bg-surface);'}`}>
        Compare
      </a>
    </div>
  )}

  {/* Compare view */}
  {viewParam === 'compare' && raterEvals.length >= 2 && (
    <ModelCompareTable evals={raterEvals} scoresByModel={compareScoresByModel} />
  )}

  {isFailed ? (
    <>
      {/* Failed evaluation page */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
          <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
            <span style="color: var(--color-negative); font-size: var(--font-lg);">&#10007;</span>
          </td>
          <td>
            <span class="titleline" style="font-size: var(--font-md);">
              <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
                 target="_blank" rel="noopener"
              >
                {storyData.title}
              </a>
            </span>
            {storyData.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${storyData.domain}`}>{storyData.domain}</a>)
              </span>
            )}
          </td>
        </tr>
        <tr>
          <td></td>
          <td class="subtext" style="padding-bottom: 8px;">
            {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
            {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
            <span> {timeAgo(storyData.hn_time)}</span>
            <span> | </span>
            <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
              {storyData.hn_comments ?? 0} comments on HN
            </a>
          </td>
        </tr>
      </table>

      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
        <tr>
          <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
            <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Evaluation Failed</div>
            <div style="color: var(--color-negative); font-size: var(--font-base); padding: 8px 0; line-height: 1.5;">
              {storyData.eval_error || 'Unknown error'}
            </div>
            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm); margin-top: 8px;">
              {storyData.domain && (
                <tr>
                  <td style="color: var(--fg-secondary); width: 100px;">Domain</td>
                  <td><a href={`/domain/${storyData.domain}`} style="color: var(--fg-primary);">{storyData.domain}</a></td>
                </tr>
              )}
              {storyData.content_type && (
                <tr>
                  <td style="color: var(--fg-secondary);">Content Type</td>
                  <td style="color: var(--fg-secondary);">{CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}</td>
                </tr>
              )}
              <tr>
                <td style="color: var(--fg-secondary);">Created</td>
                <td style="color: var(--fg-secondary);">{storyData.created_at}</td>
              </tr>
            </table>
            <div style="margin-top: 12px;">
              <button
                class="trigger-btn"
                data-hn-id={storyData.hn_id}
                title="Retry evaluation"
                style="background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.3); cursor: pointer; padding: 4px 12px; font-size: var(--font-sm); color: var(--color-negative); border-radius: 4px;"
              >
                &#9654; Retry Evaluation
              </button>
            </div>
          </td>
        </tr>
      </table>

      {dcpElements && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
          <tr>
            <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
              <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Cached Domain Context Profile
                <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">from previous evaluation</span>
              </div>
              <DcpTable elements={dcpElements} />
            </td>
          </tr>
        </table>
      )}
    </>
  ) : isDone && aggregates ? (
    <>
  {/* Story header - HN style */}
  <table cellpadding="0" cellspacing="0" width="100%">
    <tr class="athing">
      <td valign="top" style="padding: 5px var(--space-lg) 0 0; text-align: center; width: 44px;">
        <span
          class="score-font"
          style={`color: ${scoreToColor(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}; font-size: var(--font-lg); font-weight: bold;`}
          title={`Editorial: ${formatScore(storyData.hcb_editorial_mean)} | Weighted mean: ${formatScore(aggregates.weighted_mean)}`}
        >
          {formatScore(storyData.hcb_editorial_mean ?? aggregates.weighted_mean)}
        </span>
      </td>
      <td>
        <span class="titleline" style="font-size: var(--font-md);">
          <a href={storyData.url || `https://news.ycombinator.com/item?id=${storyData.hn_id}`}
             target="_blank" rel="noopener"
          >
            {storyData.title}
          </a>
        </span>
        {storyData.domain && (
          <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
            (<a href={`https://${storyData.domain}`} target="_blank" rel="noopener">{storyData.domain}</a>{storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? (
              <span style={`color: ${scoreToColor(storyData.hcb_structural_mean)}; margin-left: 4px;`}
                    title={`Structural: ${formatScore(storyData.hcb_structural_mean)} (privacy, access, tracking)`}>
                S:{formatScore(storyData.hcb_structural_mean)}
              </span>
            ) : isDone ? (
              <span style="color: var(--fg-secondary); margin-left: 4px;" title="Structural: no data">S:ND</span>
            ) : null})
          </span>
        )}
        {storyData.archive_url && <a href={storyData.archive_url} style="color: var(--color-muted, var(--fg-secondary)); font-size: var(--font-xs); margin-left: 8px;" target="_blank" rel="noopener">archived</a>}
      </td>
    </tr>
    <tr>
      <td></td>
      <td class="subtext" style="padding-bottom: 8px;">
        {storyData.hn_score !== null && <span>{storyData.hn_score} points</span>}
        {storyData.hn_by && <span> by <a href={`/user/${storyData.hn_by}`}>{storyData.hn_by}</a></span>}
        <span> {timeAgo(storyData.hn_time)}</span>
        <span> | </span>
        <a href={`https://news.ycombinator.com/item?id=${storyData.hn_id}`} target="_blank" rel="noopener">
          {storyData.hn_comments ?? 0} comments on HN
        </a>
        <span> | </span>
        <span
          class="badge"
          style={`background: ${classColor}; color: ${classText}; font-size: var(--font-xs);`}
        >
          {aggregates.classification}
        </span>
        {storyData.consensus_model_count != null && storyData.consensus_model_count >= 2 && storyData.consensus_spread != null && storyData.consensus_spread > 0.3 && (
          <span
            class="badge"
            style="background: rgba(217,119,6,0.15); color: var(--color-warning); font-size: var(--font-xs); margin-left: 4px;"
            title={`Cross-model spread: ${storyData.consensus_spread.toFixed(2)} across ${storyData.consensus_model_count} models`}
          >
            Contested
          </span>
        )}
        <span style="color: var(--fg-secondary); margin-left: 4px;">
          <span title={`Content type: ${CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}`} style="cursor: help;">
            {CONTENT_TYPE_LABELS[storyData.content_type] || storyData.content_type}
          </span>
          {storyData.schema_version && <span>· v{storyData.schema_version}</span>}
          {storyData.evaluated_at && <span>· {storyData.evaluated_at.split('T')[0]}</span>}
          {storyData.archive_used && <span style="color: var(--color-inference);">· from archive</span>}
        </span>
        {hasFairWitness && (
          <button
            id="fw-toggle"
            style="margin-left: 8px; background: rgba(168,85,247,0.15); border: 1px solid rgba(168,85,247,0.3); cursor: pointer; padding: 2px 8px; font-size: var(--font-xs); color: var(--color-inference); border-radius: 4px;"
            title="Toggle Fair Witness mode: show only observable facts vs interpretive inferences"
            aria-label="Toggle Fair Witness (evidence breakdown) mode: show only observable facts vs interpretive inferences"
          >
            Fair Witness (Evidence): OFF
          </button>
        )}
      </td>
    </tr>
  </table>

  <div style="height: 10px;"></div>

  {/* Summary card (v3.6+ story-level labels) */}
  {(executiveSummary || themeTag || sentimentTag) && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
            <span style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">Summary</span>
            {themeTag && (
              <span class="badge" style="background: rgba(43,144,216,0.15); color: var(--color-violet); font-size: var(--font-xs);">
                {themeTag}
              </span>
            )}
            {sentimentTag && (
              <span class="badge" style="background: rgba(34,211,238,0.15); color: var(--color-sentiment); font-size: var(--font-xs);">
                {sentimentTag}
              </span>
            )}
          </div>
          {executiveSummary && (
            <div style="color: var(--fg-primary); font-size: var(--font-sm); line-height: 1.6;">
              {executiveSummary}
            </div>
          )}
        </td>
      </tr>
    </table>
  )}

  {/* Heatmap */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Article Heatmap</div>
        <HeatMap scores={scores} compact={false} showLabels={true} />
        <div style="display: flex; gap: 12px; margin-top: 8px; font-size: var(--font-xs); color: var(--fg-secondary);">
          <span><span style="display: inline-block; width: 8px; height: 8px; background: var(--color-negative); border-radius: 2px;"></span> Negative</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: var(--color-neutral); border-radius: 2px;"></span> Neutral</span>
          <span><span style="display: inline-block; width: 8px; height: 8px; background: var(--color-positive); border-radius: 2px;"></span> Positive</span>
          <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: var(--color-muted); border-radius: 2px;"></span> No Data</span>
        </div>
      </td>
    </tr>
  </table>

  {/* Stats + Radar */}
  <div class="two-col" style="padding: 5px 0; gap: 10px;">
    <div>
      <div style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Aggregates</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr>
              <td style="color: var(--fg-secondary);" title="Average editorial channel score across all UDHR sections">Editorial Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(storyData.hcb_editorial_mean)}`}>{storyData.hcb_editorial_mean !== null && storyData.hcb_editorial_mean !== undefined ? formatScore(storyData.hcb_editorial_mean) : 'ND'}</td>
              <td style="color: var(--fg-secondary);" title="Average structural channel score across all UDHR sections">Structural Mean</td>
              <td class="score-font" style={`color: ${storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? scoreToColor(storyData.hcb_structural_mean) : 'var(--fg-secondary)'}`}>{storyData.hcb_structural_mean !== null && storyData.hcb_structural_mean !== undefined ? formatScore(storyData.hcb_structural_mean) : 'ND'}</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);" title="Evidence-weighted average of combined E+S+DCP final scores">Weighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.weighted_mean)}`}>{formatScore(aggregates.weighted_mean)}</td>
              <td style="color: var(--fg-secondary);">Unweighted Mean</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.unweighted_mean)}`}>{formatScore(aggregates.unweighted_mean)}</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);">Max</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.max.value)}`}>{formatScore(aggregates.max.value)} <span style="color: var(--fg-secondary);">{aggregates.max.section}</span></td>
              <td style="color: var(--fg-secondary);">Min</td>
              <td class="score-font" style={`color: ${scoreToColor(aggregates.min.value)}`}>{formatScore(aggregates.min.value)} <span style="color: var(--fg-secondary);">{aggregates.min.section}</span></td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);">Signal</td>
              <td class="score-font" style="color: var(--fg-primary);">{aggregates.signal_sections}</td>
              <td style="color: var(--fg-secondary);" title="Articles with insufficient evidence to score">No Data</td>
              <td class="score-font" style="color: var(--fg-secondary);">{aggregates.nd_count}</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);">Volatility</td>
              <td class="score-font" style="color: var(--fg-primary);" colspan="3">{aggregates.volatility.value.toFixed(2)} ({aggregates.volatility.label})</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);">Negative</td>
              <td class="score-font" style="color: var(--color-negative);">{aggregates.negative_count}</td>
              <td style="color: var(--fg-secondary);">Channels</td>
              <td class="score-font">
                <span style="color: var(--channel-editorial);" title="What the content says">E: {channelWeights.editorial}</span>
                <span style="color: var(--color-sentiment); margin-left: 6px;" title="What the site does">S: {channelWeights.structural}</span>
              </td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);"><abbr title="Structural-Editorial Tension Level: how much a site's actions (S channel) diverge from what its content says (E channel)">SETL</abbr> <a href="/about#setl" style="color: var(--fg-secondary); text-decoration: none; font-size: var(--font-xs);" title="About SETL">ℹ</a></td>
              <td class="score-font" style={`color: ${setlToColor(aggSetl)};`}>{formatSetl(aggSetl)}</td>
              <td style="color: var(--fg-secondary); font-size: var(--font-xs);" colspan="2">{aggSetl !== null ? (aggSetl > 0 ? 'Editorial-dominant' : aggSetl < 0 ? 'Structural-dominant' : 'Balanced') : ''}</td>
            </tr>
            {hasFairWitness && (
              <tr>
                <td style="color: var(--fg-secondary);"><abbr title="Fair Witness ratio: share of evidence items that are directly observable facts vs. inferences">FW Ratio</abbr> <a href="/about#fair-witness" style="color: var(--fg-secondary); text-decoration: none; font-size: var(--font-xs);" title="About Fair Witness">ℹ</a></td>
                <td class="score-font" style={`color: ${fwRatioColor(fwRatio)};`}>{formatFwRatio(fwRatio)}</td>
                <td style="color: var(--fg-secondary); font-size: var(--font-xs);" title="Observable facts / Inferences" colspan="2">
                  <span style="color: var(--color-positive-vivid);">{fwObservableCount} facts</span> · <span style="color: var(--color-inference);">{fwInferenceCount} inferences</span>
                </td>
              </tr>
            )}
          </table>
          {/* Confidence + Evidence merged visualization */}
          <div style="margin-top: 8px;">
            <div style="display: flex; align-items: center; gap: 5px; margin-bottom: 3px;">
              <span style="color: var(--fg-secondary); font-size: var(--font-xs);">Evidence</span>
              <span class="score-font" style={`color: ${confidenceToColor(confidence)}; font-size: var(--font-xs);`} title={`${aggregates.signal_sections}/${aggregates.signal_sections + aggregates.nd_count} articles scored`}>{formatConfidence(confidence)}</span>
              <span style="color: var(--fg-secondary); font-size: var(--font-xs);">coverage</span>
              <a href="/about#confidence" style="color: var(--fg-secondary); text-decoration: none; font-size: var(--font-xs);" title="About Confidence">ℹ</a>
            </div>
            <div style="display: flex; height: 7px; border-radius: 3px; overflow: hidden; background: var(--bg-surface); gap: 1px;">
              {_evH > 0 && <div style={`width: ${_evH}%; background: ${evidenceColor('H')}; flex-shrink: 0;`} title={`High evidence: ${storyData.hcb_evidence_h} sections`} />}
              {_evM > 0 && <div style={`width: ${_evM}%; background: ${evidenceColor('M')}; flex-shrink: 0;`} title={`Medium evidence: ${storyData.hcb_evidence_m} sections`} />}
              {_evL > 0 && <div style={`width: ${_evL}%; background: ${evidenceColor('L')}; flex-shrink: 0;`} title={`Low evidence: ${storyData.hcb_evidence_l} sections`} />}
              {_evND > 0 && <div style={`width: ${_evND}%; background: ${evidenceColor(null)}; flex-shrink: 0;`} title={`No data: ${storyData.hcb_nd_count} sections`} />}
            </div>
            <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-top: 2px; font-family: monospace;">
              {(storyData.hcb_evidence_h ?? 0) > 0 && <span style={`color: ${evidenceColor('H')};`}>{storyData.hcb_evidence_h}H </span>}
              {(storyData.hcb_evidence_m ?? 0) > 0 && <span style={`color: ${evidenceColor('M')};`}>{storyData.hcb_evidence_m}M </span>}
              {(storyData.hcb_evidence_l ?? 0) > 0 && <span style={`color: ${evidenceColor('L')};`}>{storyData.hcb_evidence_l}L </span>}
              {(storyData.hcb_nd_count ?? 0) > 0 && <span style={`color: ${evidenceColor(null)};`}>{storyData.hcb_nd_count} ND</span>}
            </div>
          </div>
        </div>
    </div>
    <div>
      <div style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Theme Radar</div>
        <RadarChart scores={scores} size={300} />
      </div>
    </div>
  </div>

  {/* HN Comments */}
  {comments.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            HN Discussion
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
              {comments.filter(c => c.depth === 0).length} top-level · {comments.filter(c => c.depth > 0).length} replies
            </span>
          </div>
          {comments.map((c) => (
            <div style={`border-top: 1px solid var(--bg-surface); padding: 8px 0; margin-left: ${c.depth * 20}px;`}>
              <div style="font-size: var(--font-xs); color: var(--fg-secondary); margin-bottom: 4px;">
                <a href={`/user/${c.author}`}
                   style="color: var(--fg-secondary);">{c.author}</a>
                {c.time && (
                  <span style="margin-left: 6px;">
                    {new Date(c.time * 1000).toISOString().slice(0, 16).replace('T', ' ')} UTC
                  </span>
                )}
                <a href={`https://news.ycombinator.com/item?id=${c.comment_id}`}
                   target="_blank" rel="noopener"
                   style="color: var(--fg-secondary); margin-left: 6px;">link</a>
              </div>
              <div style="color: var(--fg-emphasis); font-size: var(--font-sm); line-height: 1.5;" set:html={sanitizeHtml(c.text)} />
            </div>
          ))}
        </td>
      </tr>
    </table>
  )}

  {/* Editorial Channel */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; border-top: 3px solid var(--channel-structural);">
        <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;">
          <div style="color: var(--channel-structural); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold;">Editorial Channel</div>
          <div style="color: var(--fg-secondary); font-size: var(--font-xs);">What the content says</div>
        </div>
        {editorialRanked.map((score, i) => (
          <ArticleDetail score={score} index={i} channel="editorial" />
        ))}
      </td>
    </tr>
  </table>

  {/* Structural Channel */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; border-top: 3px solid var(--color-sentiment);">
        <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;">
          <div style="color: var(--color-sentiment); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; font-weight: bold;">Structural Channel</div>
          <div style="color: var(--fg-secondary); font-size: var(--font-xs);">What the site does</div>
        </div>
        {dcpElements && (
          <div style="margin-bottom: 12px; padding: 8px; background: var(--bg-surface); border: 1px solid var(--color-border); border-radius: 4px;">
            <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;"><a href="/about#dcp" style="color: var(--fg-secondary); text-decoration: none;" title="Domain-level modifiers inherited from site policies (privacy, ToS, accessibility, ownership)">Domain Context Profile</a></div>
            <DcpTable elements={dcpElements} />
          </div>
        )}
        {structuralRanked.map((score, i) => (
          <ArticleDetail score={score} index={i} channel="structural" />
        ))}
      </td>
    </tr>
  </table>

  {/* Supplementary Signals */}
  {hasSignals && (
    <div style="padding: 5px 0 20px 0;">
      <div style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; border-top: 3px solid var(--color-amber);">
