          </details>
        )}
      </div>
    </div>
  )}
    </>
  ) : isLiteOnlyEval && liteEval ? (
    <>
      {/* Lite-only eval page — editorial score, no per-section breakdown */}
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr class="athing">
