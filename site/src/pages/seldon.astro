---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SubNav from '../components/SubNav.astro';
import { getDailyHrcb, getDailyContentTypeHrcb, getFeedDailyHrcb, getGlobalSetlHistory } from '../lib/db';
import { scoreToColor, formatScore } from '../lib/colors';
import { CONTENT_TYPE_LABELS } from '../lib/types';
import { readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);

const [dailyHrcb, dailyContentType, dailyFeed, globalSetl] = await Promise.all([
  getDailyHrcb(db, 90),
  getDailyContentTypeHrcb(db, 90),
  getFeedDailyHrcb(db, 90),
  getGlobalSetlHistory(db, 90),
]);

// Compute rolling averages (7-day, 30-day)
function rollingAvg(data: { day: string; avg: number }[], window: number): { day: string; avg: number }[] {
  const result: { day: string; avg: number }[] = [];
  for (let i = 0; i < data.length; i++) {
    const start = Math.max(0, i - window + 1);
    const slice = data.slice(start, i + 1);
    const avg = slice.reduce((s, d) => s + d.avg, 0) / slice.length;
    result.push({ day: data[i].day, avg });
  }
  return result;
}

const rolling7 = rollingAvg(dailyHrcb, 7);
const rolling30 = rollingAvg(dailyHrcb, 30);

// Regime change detection: find days where 7-day rolling crosses the 30-day rolling
interface RegimeChange {
  day: string;
  direction: 'up' | 'down';
  rolling7: number;
  rolling30: number;
}

const regimeChanges: RegimeChange[] = [];
for (let i = 1; i < Math.min(rolling7.length, rolling30.length); i++) {
  const prev7 = rolling7[i - 1].avg, curr7 = rolling7[i].avg;
  const prev30 = rolling30[i - 1].avg, curr30 = rolling30[i].avg;
  const prevAbove = prev7 > prev30;
  const currAbove = curr7 > curr30;
  if (prevAbove !== currAbove) {
    regimeChanges.push({
      day: rolling7[i].day,
      direction: currAbove ? 'up' : 'down',
      rolling7: curr7,
      rolling30: curr30,
    });
  }
}

// Group content type daily data
const ctDays = new Map<string, Map<string, number>>();
for (const r of dailyContentType) {
  let dayMap = ctDays.get(r.content_type);
  if (!dayMap) { dayMap = new Map(); ctDays.set(r.content_type, dayMap); }
  dayMap.set(r.day, r.avg_score);
}
const ctTypes = [...ctDays.keys()].slice(0, 6);
const ctColors: Record<string, string> = {
  ED: 'var(--channel-editorial)', PO: 'var(--color-negative-light)', LP: 'var(--color-warning-light)', PR: 'var(--color-positive-medium)', AC: 'var(--channel-structural)', MI: 'var(--color-sentiment)',
  AD: 'var(--color-amber-light)', HR: 'var(--color-violet)', CO: '#c084fc', ME: '#38bdf8', MX: 'var(--color-muted)',
};

// Group feed daily data
const feedDays = new Map<string, Map<string, number>>();
for (const r of dailyFeed) {
  let dayMap = feedDays.get(r.feed);
  if (!dayMap) { dayMap = new Map(); feedDays.set(r.feed, dayMap); }
  dayMap.set(r.day, r.avg_score);
}
const feeds = [...feedDays.keys()];
const feedColors: Record<string, string> = {
  top: 'var(--color-orange)', new: 'var(--channel-editorial)', best: 'var(--color-positive-medium)', ask: 'var(--color-warning-light)', show: 'var(--color-amber-light)', job: 'var(--channel-structural)',
};

// Chart helpers
const allDays = dailyHrcb.map(d => d.day);
const chartW = Math.max(allDays.length * 12, 300);
const chartH = 120;

function yPos(score: number): number {
  return chartH / 2 - (score * chartH * 0.4);
}

function makeLine(points: { day: string; avg: number }[]): string {
  return points.map((p, i) => {
    const x = (allDays.indexOf(p.day) / Math.max(allDays.length - 1, 1)) * chartW;
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${yPos(p.avg).toFixed(1)}`;
  }).join(' ');
}

// Serialized data for regime change rendering
const regimeData = JSON.stringify(regimeChanges);
---

<Base title="Seldon Dashboard — HN HRCB">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'trends', href: '/trends' }, { label: 'seldon' }]} />
  <SubNav items={[{ label: 'Seldon', href: '/seldon' }, { label: 'Velocity', href: '/velocity' }, { label: 'Dynamics', href: '/dynamics' }]} current="/seldon" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Seldon Dashboard</span>
        <span style="color: var(--fg-secondary); margin-left: 8px; font-size: var(--font-sm);">
          Macro-trend forecasting of collective rights alignment
        </span>
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-top: 4px; line-height: 1.5;">
          Named after Hari Seldon from Asimov's <em>Foundation</em> — tracking whether HN's collective discourse is trending toward or away from human rights alignment.
          Bullish = trending rights-positive, Bearish = trending rights-negative.
          Regime change detection compares 7-day and 30-day rolling HRCB averages.
          When the short-term trend crosses the long-term trend, it signals a shift
          in overall alignment. Upward crossovers mean recent content is more HR-aligned
          than the longer trend; downward means the opposite. SETL drift tracks
          structural-editorial tension over time.
        </div>
      </td>
    </tr>
  </table>

  {/* Overall HRCB with rolling averages */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
          Overall HRCB Trajectory
          <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">{allDays.length} days</span>
        </div>
        <div style="display: flex; gap: 12px; font-size: var(--font-xs); margin-bottom: 4px;">
          <span style="color: var(--fg-secondary);">Daily</span>
          <span style="color: var(--channel-editorial);">7-day rolling</span>
          <span style="color: var(--color-orange);">30-day rolling</span>
        </div>
        <div style="overflow-x: auto;">
          <svg width={chartW} height={chartH} viewBox={`0 0 ${chartW} ${chartH}`} style="min-width: 300px;">
            <line x1="0" y1={chartH / 2} x2={chartW} y2={chartH / 2} stroke="var(--color-border)" stroke-width="0.5" />
            {/* Daily points */}
            <polyline fill="none" stroke="var(--bg-surface)" stroke-width="1"
              points={dailyHrcb.map((d, i) => `${(i / Math.max(allDays.length - 1, 1)) * chartW},${yPos(d.avg)}`).join(' ')} />
            {/* 7-day rolling */}
            {rolling7.length > 1 && <path d={makeLine(rolling7)} fill="none" stroke="var(--channel-editorial)" stroke-width="2" />}
            {/* 30-day rolling */}
            {rolling30.length > 1 && <path d={makeLine(rolling30)} fill="none" stroke="var(--color-orange)" stroke-width="2" />}
            {/* Regime change markers */}
            {regimeChanges.map(rc => {
              const x = (allDays.indexOf(rc.day) / Math.max(allDays.length - 1, 1)) * chartW;
              return (
                <g>
                  <line x1={x} y1="0" x2={x} y2={chartH} stroke={rc.direction === 'up' ? 'var(--color-positive-medium)' : 'var(--color-negative-light)'} stroke-width="1" stroke-dasharray="3,3" />
                  <circle cx={x} cy={yPos(rc.rolling7)} r="3" fill={rc.direction === 'up' ? 'var(--color-positive-medium)' : 'var(--color-negative-light)'} />
                </g>
              );
            })}
          </svg>
        </div>
      </td>
    </tr>
  </table>

  {/* Regime changes list */}
  {regimeChanges.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            Regime Changes
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
              7-day/30-day crossovers · {regimeChanges.length} detected
            </span>
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: var(--fg-secondary);"><td>Date</td><td>Direction</td><td style="text-align: right;">7-day</td><td style="text-align: right;">30-day</td></tr>
            {regimeChanges.map(rc => (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="color: var(--fg-emphasis);">{rc.day}</td>
                <td style={`color: ${rc.direction === 'up' ? 'var(--color-positive-medium)' : 'var(--color-negative-light)'};`}>
                  {rc.direction === 'up' ? 'Bullish' : 'Bearish'}
                </td>
                <td style={`text-align: right; color: ${scoreToColor(rc.rolling7)};`} class="score-font">{formatScore(rc.rolling7)}</td>
                <td style={`text-align: right; color: ${scoreToColor(rc.rolling30)};`} class="score-font">{formatScore(rc.rolling30)}</td>
              </tr>
            ))}
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Per-feed HRCB */}
  {feeds.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            Per-Feed HRCB
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">does community voting amplify or suppress rights alignment?</span>
          </div>
          <div style="display: flex; gap: 12px; font-size: var(--font-xs); margin-bottom: 4px;">
            {feeds.map(f => (
              <span style={`color: ${feedColors[f] || 'var(--fg-secondary)'};`}>{f}</span>
            ))}
          </div>
          <div style="overflow-x: auto;">
            <svg width={chartW} height={chartH} viewBox={`0 0 ${chartW} ${chartH}`} style="min-width: 300px;">
              <line x1="0" y1={chartH / 2} x2={chartW} y2={chartH / 2} stroke="var(--color-border)" stroke-width="0.5" />
              {feeds.map(feed => {
                const dayMap = feedDays.get(feed);
                if (!dayMap) return null;
                const points = allDays
                  .map((day, i) => {
                    const val = dayMap.get(day);
                    if (val === undefined) return null;
                    return `${(i / Math.max(allDays.length - 1, 1)) * chartW},${yPos(val)}`;
                  })
                  .filter(Boolean);
                if (points.length < 2) return null;
                return <polyline fill="none" stroke={feedColors[feed] || 'var(--fg-secondary)'} stroke-width="1.5" points={points.join(' ')} />;
              })}
            </svg>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* Global SETL Trend (Chapel Perilous) */}
  {globalSetl.length > 1 && (() => {
    const setlW = Math.max(globalSetl.length * 12, 300);
    const setlH = 120;
    function setlY(v: number): number { return setlH / 2 - (v * setlH * 0.4); }
    // Compute 7-day rolling SETL
    const rollingSetl7: { day: string; avg: number }[] = [];
    for (let i = 0; i < globalSetl.length; i++) {
      const start = Math.max(0, i - 6);
      const slice = globalSetl.slice(start, i + 1);
      rollingSetl7.push({ day: globalSetl[i].day, avg: slice.reduce((s, d) => s + d.avg_setl, 0) / slice.length });
    }
    return (
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
        <tr>
          <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
            <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
              Global SETL Trend
              <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
                structural-editorial tension across all content · {globalSetl.length} days
              </span>
            </div>
            <div style="display: flex; gap: 12px; font-size: var(--font-xs); margin-bottom: 4px;">
              <span style="color: var(--channel-structural);">Editorial</span>
              <span style="color: var(--color-sentiment);">Structural</span>
              <span style="color: var(--fg-secondary);">SETL (daily)</span>
              <span style="color: var(--color-warning-light);">SETL (7-day rolling)</span>
            </div>
            <div style="overflow-x: auto;">
              <svg width={setlW} height={setlH} viewBox={`0 0 ${setlW} ${setlH}`} style="min-width: 300px;">
                <line x1="0" y1={setlH / 2} x2={setlW} y2={setlH / 2} stroke="var(--color-border)" stroke-width="0.5" />
                {/* Editorial line */}
                <polyline
                  fill="none"
                  stroke="var(--channel-structural)"
                  stroke-width="1.5"
                  points={globalSetl.map((p, i) => `${(i / Math.max(globalSetl.length - 1, 1)) * setlW},${setlY(p.avg_editorial)}`).join(' ')}
                />
                {/* Structural line */}
                <polyline
                  fill="none"
                  stroke="var(--color-sentiment)"
                  stroke-width="1.5"
                  points={globalSetl.map((p, i) => `${(i / Math.max(globalSetl.length - 1, 1)) * setlW},${setlY(p.avg_structural)}`).join(' ')}
                />
                {/* Daily SETL */}
                <polyline
                  fill="none"
                  stroke="var(--bg-surface)"
                  stroke-width="1"
                  points={globalSetl.map((p, i) => `${(i / Math.max(globalSetl.length - 1, 1)) * setlW},${setlY(p.avg_setl)}`).join(' ')}
                />
                {/* 7-day rolling SETL */}
                <polyline
                  fill="none"
                  stroke="var(--color-warning-light)"
                  stroke-width="2"
                  points={rollingSetl7.map((p, i) => `${(i / Math.max(rollingSetl7.length - 1, 1)) * setlW},${setlY(p.avg)}`).join(' ')}
                />
              </svg>
            </div>
          </td>
        </tr>
      </table>
    );
  })()}

  {/* Per-content-type HRCB */}
  {ctTypes.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 20px 0;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            Per-Content-Type HRCB
          </div>
          <div style="display: flex; gap: 12px; font-size: var(--font-xs); margin-bottom: 4px; flex-wrap: wrap;">
            {ctTypes.map(ct => (
              <span style={`color: ${ctColors[ct] || 'var(--fg-secondary)'};`}>{CONTENT_TYPE_LABELS[ct] || ct}</span>
            ))}
          </div>
          <div style="overflow-x: auto;">
            <svg width={chartW} height={chartH} viewBox={`0 0 ${chartW} ${chartH}`} style="min-width: 300px;">
              <line x1="0" y1={chartH / 2} x2={chartW} y2={chartH / 2} stroke="var(--color-border)" stroke-width="0.5" />
              {ctTypes.map(ct => {
                const dayMap = ctDays.get(ct);
                if (!dayMap) return null;
                const points = allDays
                  .map((day, i) => {
                    const val = dayMap.get(day);
                    if (val === undefined) return null;
                    return `${(i / Math.max(allDays.length - 1, 1)) * chartW},${yPos(val)}`;
                  })
                  .filter(Boolean);
                if (points.length < 2) return null;
                return <polyline fill="none" stroke={ctColors[ct] || 'var(--fg-secondary)'} stroke-width="1.5" points={points.join(' ')} />;
              })}
            </svg>
          </div>
        </td>
      </tr>
    </table>
  )}

</Base>
