---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export const prerender = true;

const siteUrl = Astro.site?.origin ?? 'https://observatory.unratified.org';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Human Rights Observatory Evaluation Dataset',
  description: 'Automated LLM evaluations of Hacker News stories against the 30 articles and Preamble of the UN Universal Declaration of Human Rights. Each story receives editorial and structural channel scores, supplementary signals (transparency, accessibility, persuasion techniques, temporal framing), and a composite HRCB score.',
  url: `${siteUrl}/data`,
  license: 'https://creativecommons.org/licenses/by-sa/4.0/',
  creator: {
    '@type': 'Organization',
    name: 'Safety Quotient Lab',
    url: 'https://github.com/safety-quotient-lab',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Human Rights Observatory',
    url: siteUrl,
  },
  measurementTechnique: 'Multi-model LLM ensemble (Claude + Llama) evaluated against 31 UDHR provisions using HRCB methodology v3.7',
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'HRCB Score', description: 'Human Rights Compatibility Bias — directional lean of content relative to UDHR provisions, range [-1.0, +1.0]' },
    { '@type': 'PropertyValue', name: 'SETL', description: 'Structural-Editorial Tension Level — divergence between what content says vs what the site does' },
    { '@type': 'PropertyValue', name: 'Epistemic Quality', description: 'Source quality, evidence use, and uncertainty handling' },
    { '@type': 'PropertyValue', name: 'Propaganda Technique Score', description: 'PTC-18 based propaganda technique detection, cumulative weighted score' },
    { '@type': 'PropertyValue', name: 'Fair Witness Ratio', description: 'Ratio of observable facts to interpretive inferences in evaluation evidence' },
  ],
  distribution: [
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: `${siteUrl}/api/v1/stories`, name: 'Stories API (paginated)' },
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: `${siteUrl}/api/v1/domains`, name: 'Domain Aggregates API' },
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: `${siteUrl}/api/v1/articles`, name: 'Per-UDHR-Provision Article Scores API' },
    { '@type': 'DataDownload', encodingFormat: 'application/json', contentUrl: `${siteUrl}/api/v1/signals`, name: 'Corpus Signal Aggregates API' },
  ],
  temporalCoverage: '2026-02/..',
  spatialCoverage: { '@type': 'Place', name: 'Global (Hacker News English-language content)' },
  isAccessibleForFree: true,
};
const sourceCodeLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: 'Human Rights Observatory',
  description: 'Evaluation pipeline scoring tech news against 31 UDHR provisions using multi-model LLM ensemble with Fair Witness evidence transparency.',
  codeRepository: 'https://github.com/safety-quotient-lab/observatory',
  programmingLanguage: ['TypeScript', 'Astro', 'Svelte'],
  runtimePlatform: 'Cloudflare Workers',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  author: {
    '@type': 'Organization',
    name: 'Safety Quotient Lab',
    url: 'https://github.com/safety-quotient-lab',
  },
  about: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
  },
};
---

<Base title="Data — HRO" canonicalUrl={`${siteUrl}/data`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
  <script type="application/ld+json" set:html={JSON.stringify(sourceCodeLd).replace(/</g, '\\u003c')} />
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'data' }]} />

  <table cellpadding="0" cellspacing="0" width="100%" style="max-width: 680px; padding: 10px 0;">
    <tr>
      <td>
        <h1 style="font-size: var(--font-md); margin-bottom: 10px;">Dataset &amp; Exports</h1>

        <p style="color: var(--fg-secondary); font-size: var(--font-sm); line-height: 1.6; margin-bottom: 20px;">
          The HRO evaluation dataset — story scores, domain profiles, and rater evaluations — will be available for bulk download here. Dataset exports and bulk snapshots are in progress.
        </p>

        {/* API access (available now) */}
        <p style="color: var(--fg-primary); font-size: var(--font-base); font-weight: bold; margin: 20px 0 8px 0;">API Access (available now)</p>

        <table cellpadding="3" cellspacing="0" style="font-size: var(--font-sm); margin-bottom: 20px; background: var(--bg-surface); border: 1px solid var(--color-border); border-radius: 4px;" width="100%">
          <tr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 4px 8px;">Endpoint</td>
            <td style="padding: 4px 8px;">Description</td>
          </tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v1/stories" style="color: var(--color-orange);">/api/v1/stories</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">Paginated evaluated story feed with HRCB scores</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font">/api/v1/story/{'{id}'}</td><td style="color: var(--fg-secondary); padding: 2px 8px;">Single story with per-model rater evaluations</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v1/articles" style="color: var(--color-orange);">/api/v1/articles</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">Per-UDHR-provision aggregate scores: editorial/structural averages, story counts, trigger counts, evidence distribution, SETL tension</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v1/signals" style="color: var(--color-orange);">/api/v1/signals</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">Corpus-wide signal aggregates: transparency disclosure rates, accessibility metrics, temporal framing, tone/scope distributions. Includes <code>generated_at</code> timestamp for build-time consumers.</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v1/domains" style="color: var(--color-orange);">/api/v1/domains</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">Domain signal aggregates (HRCB, EQ, SO, TD, valence, arousal)</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font">/api/v1/domain/{'{domain}'}</td><td style="color: var(--fg-secondary); padding: 2px 8px;">Domain profile with recent evaluated stories</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font">/api/v1/domain/{'{domain}'}/history</td><td style="color: var(--fg-secondary); padding: 2px 8px;">Daily HRCB profile snapshots (?days=30, max 365)</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v0/topstories.json" style="color: var(--color-orange);">/api/v0/topstories.json</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">HN-compatible: top 500 story IDs by HN score</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font"><a href="/api/v0/beststories.json" style="color: var(--color-orange);">/api/v0/beststories.json</a></td><td style="color: var(--fg-secondary); padding: 2px 8px;">HN-compatible: top 500 story IDs by HRCB score</td></tr>
          <tr><td style="color: var(--color-orange); padding: 2px 8px;" class="score-font">/api/v0/item/{'{id}'}.json</td><td style="color: var(--fg-secondary); padding: 2px 8px;">HN-compatible item + <span class="score-font">hcb</span> extension object</td></tr>
        </table>

        <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 20px;">
          All endpoints are public, CORS-enabled, and rate-limited to 200 requests/hour per IP.
          <a href="/api/v1/openapi.json" style="color: var(--color-orange);">OpenAPI 3.1 spec</a> ·
          <a href="/about#technical" style="color: var(--fg-secondary);">Methodology reference →</a>
        </p>

        {/* Bulk exports (coming soon) */}
        <p style="color: var(--fg-primary); font-size: var(--font-base); font-weight: bold; margin: 20px 0 8px 0;">Bulk Exports <span style="color: var(--color-border); font-size: var(--font-xs); font-weight: normal;">(coming soon)</span></p>

        <table cellpadding="3" cellspacing="0" style="font-size: var(--font-sm); margin-bottom: 15px; background: #0a3040; border: 1px solid #0f3d50; border-radius: 4px; opacity: 0.7;" width="100%">
          <tr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 4px 8px;">File</td>
            <td style="padding: 4px 8px;">Format</td>
            <td style="padding: 4px 8px;">Contents</td>
          </tr>
          <tr><td style="color: var(--color-disabled); padding: 2px 8px;" class="score-font">/api/v1/export/stories.csv</td><td style="color: var(--color-disabled); padding: 2px 8px;">CSV</td><td style="color: var(--color-disabled); padding: 2px 8px;">All evaluated stories with full signal data</td></tr>
          <tr><td style="color: var(--color-disabled); padding: 2px 8px;" class="score-font">/api/v1/export/stories.jsonl</td><td style="color: var(--color-disabled); padding: 2px 8px;">JSONL</td><td style="color: var(--color-disabled); padding: 2px 8px;">Same as CSV, newline-delimited JSON</td></tr>
          <tr><td style="color: var(--color-disabled); padding: 2px 8px;" class="score-font">/api/v1/export/domains.csv</td><td style="color: var(--color-disabled); padding: 2px 8px;">CSV</td><td style="color: var(--color-disabled); padding: 2px 8px;">All domain signal profiles</td></tr>
          <tr><td style="color: var(--color-disabled); padding: 2px 8px;" class="score-font">/api/v1/export/rater-evals.jsonl</td><td style="color: var(--color-disabled); padding: 2px 8px;">JSONL</td><td style="color: var(--color-disabled); padding: 2px 8px;">Per-model evaluation records (ML research)</td></tr>
        </table>

        <p style="color: var(--color-disabled); font-size: var(--font-xs);">
          License and citation information will be published here when bulk exports are available.
        </p>
      </td>
    </tr>
  </table>
</Base>
