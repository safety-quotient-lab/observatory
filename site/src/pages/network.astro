---
import Base from '../layouts/Base.astro';
import { SECTIONS } from '../lib/udhr';
import { getArticlePairStats, getArticleDetailedStats } from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [pairStats, articleStats] = await Promise.all([
  getArticlePairStats(db),
  getArticleDetailedStats(db),
]);

// Build nodes: one per UDHR section
const statsMap = new Map(articleStats.map(a => [a.section, a]));

const groupColors: Record<string, string> = {
  'Foundation': '#a78bfa',
  'Security': '#f87171',
  'Legal': '#22d3ee',
  'Personal': '#34d399',
  'Political': '#fbbf24',
  'Economic': '#fb923c',
  'Limits': '#818cf8',
};

function getGroupColor(group: string): string {
  for (const [key, color] of Object.entries(groupColors)) {
    if (group.toLowerCase().includes(key.toLowerCase())) return color;
  }
  return '#888';
}

const nodes = SECTIONS.map(s => {
  const stat = statsMap.get(s.id);
  return {
    id: s.id,
    label: s.id === 'Preamble' ? 'P' : String(s.number),
    title: s.shortTitle,
    group: s.group,
    color: getGroupColor(s.group),
    avgScore: stat?.avg_final ?? null,
    signalCount: stat?.signal_count ?? 0,
  };
});

// Build edges: only where |correlation| > threshold
const edges: { source: string; target: string; r: number; n: number }[] = [];
for (const [key, r] of pairStats.correlation) {
  const [a, b] = key.split('|');
  if (a === b) continue; // skip self-correlation
  if (Math.abs(r) < 0.15) continue; // threshold
  const n = pairStats.cooccurrence.get(key) || 0;
  edges.push({ source: a, target: b, r, n });
}

// Serialize for client
const graphData = JSON.stringify({ nodes, edges });
---

<Base title="Rights Network — HN HRCB">
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">Rights Correlation Network</span>
        <span style="color: #828282; margin-left: 8px; font-size: var(--font-sm);">
          Stephenson Rights Graph — force-directed by Pearson correlation
        </span>
      </td>
    </tr>
  </table>

  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 8px;">
          {Object.entries(groupColors).map(([group, color]) => (
            <span style={`color: ${color}; font-size: var(--font-xs);`}>{group}</span>
          ))}
        </div>
        <div style="color: #555; font-size: var(--font-xs); margin-bottom: 8px;">
          Green edges = positive correlation · Red edges = negative correlation · Thickness = strength · Drag nodes to explore
        </div>
        <canvas id="network-canvas" width="900" height="600" style="width: 100%; max-width: 900px; height: auto; aspect-ratio: 3/2; background: #0a0a12; border-radius: 4px; cursor: grab;"></canvas>
      </td>
    </tr>
  </table>

  {/* Edge list table */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 20px 0;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
          Strongest Correlations
          <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
            {edges.length} pairs above threshold
          </span>
        </div>
        <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <tr style="color: #555;">
            <td>Article A</td><td>Article B</td><td style="text-align: right;">r</td><td style="text-align: right;">n</td>
          </tr>
          {edges.sort((a, b) => Math.abs(b.r) - Math.abs(a.r)).slice(0, 30).map(e => (
            <tr style="border-top: 1px solid #1a1a25;">
              <td style="color: #aaa;">
                <a href={`/article/${SECTIONS.find(s => s.id === e.source)?.number ?? 0}`} style="color: #aaa;">{e.source}</a>
              </td>
              <td style="color: #aaa;">
                <a href={`/article/${SECTIONS.find(s => s.id === e.target)?.number ?? 0}`} style="color: #aaa;">{e.target}</a>
              </td>
              <td style={`text-align: right; color: ${e.r > 0 ? '#34d399' : '#f87171'};`} class="score-font">
                {e.r > 0 ? '+' : ''}{e.r.toFixed(3)}
              </td>
              <td style="text-align: right; color: #555;" class="score-font">{e.n}</td>
            </tr>
          ))}
        </table>
      </td>
    </tr>
  </table>

  <script define:vars={{ graphData }}>
    const { nodes, edges } = JSON.parse(graphData);
    const canvas = document.getElementById('network-canvas');
    const ctx = canvas.getContext('2d');
    const W = canvas.width;
    const H = canvas.height;

    // Initialize positions in a circle
    nodes.forEach((n, i) => {
      const angle = (2 * Math.PI * i) / nodes.length;
      n.x = W / 2 + (W * 0.35) * Math.cos(angle);
      n.y = H / 2 + (H * 0.35) * Math.sin(angle);
      n.vx = 0;
      n.vy = 0;
    });

    const nodeMap = new Map(nodes.map(n => [n.id, n]));

    // Force simulation parameters
    const REPULSION = 8000;
    const SPRING_LENGTH = 120;
    const SPRING_K = 0.03;
    const DAMPING = 0.85;
    const CENTER_PULL = 0.005;

    let dragging = null;
    let mx = 0, my = 0;

    function getScale() {
      return canvas.clientWidth / W;
    }

    canvas.addEventListener('mousedown', (e) => {
      const rect = canvas.getBoundingClientRect();
      const scale = getScale();
      mx = (e.clientX - rect.left) / scale;
      my = (e.clientY - rect.top) / scale;
      for (const n of nodes) {
        if (Math.hypot(n.x - mx, n.y - my) < 18) {
          dragging = n;
          canvas.style.cursor = 'grabbing';
          break;
        }
      }
    });

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const scale = getScale();
      mx = (e.clientX - rect.left) / scale;
      my = (e.clientY - rect.top) / scale;
      if (dragging) {
        dragging.x = mx;
        dragging.y = my;
        dragging.vx = 0;
        dragging.vy = 0;
      }
    });

    canvas.addEventListener('mouseup', () => {
      dragging = null;
      canvas.style.cursor = 'grab';
    });

    function simulate() {
      // Repulsion between all pairs
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const dist = Math.max(Math.hypot(dx, dy), 1);
          const force = REPULSION / (dist * dist);
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          a.vx -= fx; a.vy -= fy;
          b.vx += fx; b.vy += fy;
        }
      }

      // Spring forces along edges
      for (const e of edges) {
        const a = nodeMap.get(e.source);
        const b = nodeMap.get(e.target);
        if (!a || !b) continue;
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist = Math.max(Math.hypot(dx, dy), 1);
        // Correlated articles attract, anti-correlated repel
        const targetLen = SPRING_LENGTH * (1 - Math.abs(e.r) * 0.5);
        const displacement = dist - targetLen;
        const force = SPRING_K * displacement * (e.r > 0 ? 1 : -0.3);
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.vx += fx; a.vy += fy;
        b.vx -= fx; b.vy -= fy;
      }

      // Center pull
      for (const n of nodes) {
        n.vx += (W / 2 - n.x) * CENTER_PULL;
        n.vy += (H / 2 - n.y) * CENTER_PULL;
      }

      // Update positions
      for (const n of nodes) {
        if (n === dragging) continue;
        n.vx *= DAMPING;
        n.vy *= DAMPING;
        n.x += n.vx;
        n.y += n.vy;
        // Bounds
        n.x = Math.max(20, Math.min(W - 20, n.x));
        n.y = Math.max(20, Math.min(H - 20, n.y));
      }
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // Draw edges
      for (const e of edges) {
        const a = nodeMap.get(e.source);
        const b = nodeMap.get(e.target);
        if (!a || !b) continue;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        const absR = Math.abs(e.r);
        ctx.strokeStyle = e.r > 0
          ? `rgba(52, 211, 153, ${absR * 0.6})`
          : `rgba(248, 113, 113, ${absR * 0.6})`;
        ctx.lineWidth = absR * 4;
        ctx.stroke();
      }

      // Draw nodes
      for (const n of nodes) {
        const radius = Math.max(10, 6 + n.signalCount * 0.1);
        ctx.beginPath();
        ctx.arc(n.x, n.y, radius, 0, 2 * Math.PI);
        ctx.fillStyle = n.color;
        ctx.fill();
        ctx.strokeStyle = '#0d0d14';
        ctx.lineWidth = 2;
        ctx.stroke();

        // Label
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 9px monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(n.label, n.x, n.y);

        // Title below
        ctx.fillStyle = '#666';
        ctx.font = '8px sans-serif';
        ctx.fillText(n.title, n.x, n.y + radius + 10);
      }
    }

    function loop() {
      simulate();
      draw();
      requestAnimationFrame(loop);
    }

    loop();
  </script>
</Base>
