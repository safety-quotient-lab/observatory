---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import EvalCard from '../components/EvalCard.astro';
import { getFilteredStoriesWithScores } from '../lib/db';
import { readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const url = new URL(Astro.request.url);

// Default to yesterday
const today = new Date();
const yesterday = new Date(today);
yesterday.setUTCDate(yesterday.getUTCDate() - 1);
const defaultDay = yesterday.toISOString().slice(0, 10);

const day = url.searchParams.get('day') || defaultDay;
// Validate format
const validDay = /^\d{4}-\d{2}-\d{2}$/.test(day) && !isNaN(new Date(day + 'T00:00:00Z').getTime());
const safeDay = validDay ? day : defaultDay;

const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));
const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

const stories = await getFilteredStoriesWithScores(db, 'hn_points', 'all', 'all', PER_PAGE + 1, offset, safeDay);
const hasMore = stories.length > PER_PAGE;
const displayStories = hasMore ? stories.slice(0, PER_PAGE) : stories;

// Navigation: prev/next day
const dayDate = new Date(safeDay + 'T00:00:00Z');
const prevDate = new Date(dayDate);
prevDate.setUTCDate(prevDate.getUTCDate() - 1);
const nextDate = new Date(dayDate);
nextDate.setUTCDate(nextDate.getUTCDate() + 1);
const prevDay = prevDate.toISOString().slice(0, 10);
const nextDay = nextDate.toISOString().slice(0, 10);
const isToday = safeDay === today.toISOString().slice(0, 10);
const isFuture = dayDate >= today;

// Format date for display
const displayDate = dayDate.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Base title={`${displayDate} — HN HRCB`}>
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'past' }]} />
  <div class="filter-bar">
    <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">{displayDate}</span>
    <div class="subtext" style="margin-top: 4px;">
      <div class="filter-row">
        <a href={`/past?day=${prevDay}`} class="filter-link">&larr; {prevDay}</a>
        {!isFuture && !isToday && (
          <>
            <span class="filter-sep"> | </span>
            <a href={`/past?day=${nextDay}`} class="filter-link">{nextDay} &rarr;</a>
          </>
        )}
        <span class="filter-sep"> | </span>
        <a href="/past" class="filter-link">yesterday</a>
        <span class="filter-sep"> | </span>
        <span class="filter-stats">{displayStories.length}{hasMore ? '+' : ''} stories</span>
        <span class="filter-stats"> · page {page}{hasMore ? '' : ' (last)'}</span>
      </div>
    </div>
  </div>

  <table cellpadding="0" cellspacing="0" class="itemlist" width="100%">
    {displayStories.map((story, i) => (
      <EvalCard
        story={story}
        rank={offset + i + 1}
      />
    ))}
  </table>

  {displayStories.length === 0 && (
    <table width="100%">
      <tr>
        <td style="padding: 40px 20px; text-align: center; color: var(--fg-secondary);">
          No stories from {safeDay}.
        </td>
      </tr>
    </table>
  )}

  {hasMore && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0 20px 0;">
      <tr>
        <td style="padding-left: 40px;">
          <a href={`/past?day=${safeDay}&p=${page + 1}`} class="morelink" style="color: var(--fg-secondary); font-size: var(--font-base);">
            Next → <span style="color: var(--color-border); font-size: var(--font-sm);">(page {page + 1})</span>
          </a>
        </td>
      </tr>
    </table>
  )}
</Base>
