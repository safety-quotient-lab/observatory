---
import Base from '../layouts/Base.astro';
import { scoreToColor, formatScore, confidenceToColor, formatConfidence } from '../lib/colors';
import { modelDisplayName, MODEL_REGISTRY, isLightMode, getModelDef } from '../lib/shared-eval';
import {
  getStatusCounts,
  getFailedStories,
  getQueueStories,
  getModelStats,
  getModelComparisonStats,
  getCostStats,
  getVelocityStats,
  getEventStats,
  getRecentEvents,
  getCronRuns,
  getDailyErrorCounts,
  getEvalsPerCycle,
  getLatestRateLimitSnapshot,
  getDlqStats,
  getDlqMessages,
  getMethodologyDistribution,
  getModelDriftStats,
  getLatestCalibrationRun,
  getLatestLightCalibrationRun,
  getRaterSummaryStats,
  getRaterStatusBreakdown,
  getGlobalGateStats,
  getProviderStats,
  getModelQueueStats,
  getDlqTrend,
  getSelfThrottleImpact,
  getEvalLatencyStats,
  getSignalCompleteness,
} from '../lib/db';
import { cachedQuery } from '../lib/db-utils';
import { CALIBRATION_SET, LIGHT_CALIBRATION_SET } from '../lib/calibration';

const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

// Only real dependency: velocity needs pending count from status
const status = await getStatusCounts(db);

// Everything else in parallel — individual .catch() prevents cascade failures
const emptyEventStats = { total: 0, by_type: {}, by_severity: {}, last_24h: 0, last_7d: 0, error_count_7d: 0 };
const [
  failed, queue, models, velocity,
  modelComparison, costStats,
  eventStats, recentPipelineEvents, cronRuns, dailyErrors, cycleStats,
  rateLimitSnapshot, dlqStats, dlqMessages,
  methodologyDist, driftStats, lastCalibration, lastLightCalibration, globalGate,
  raterSummary, raterStatus, providerStats, modelQueueStats,
  dlqTrend, throttleImpact, latencyStats, signalCompleteness,
] = await Promise.all([
  // Ops-critical (fresh)
  getFailedStories(db, 5),
  getQueueStories(db),
  getModelStats(db),
  getVelocityStats(db, status.pending),
  // Historical aggregates (cached — eval_history full scans)
  cachedQuery(kv, 'sys:modelComparison', () => getModelComparisonStats(db), 300),
  cachedQuery(kv, 'sys:costStats', () => getCostStats(db), 120),
  // Events (mix of cached + fresh)
  cachedQuery(kv, 'sys:eventStats', () => getEventStats(db, 7), 60).catch(() => emptyEventStats),
  getRecentEvents(db, 15).catch(() => [] as Awaited<ReturnType<typeof getRecentEvents>>),
  getCronRuns(db, 5).catch(() => [] as Awaited<ReturnType<typeof getCronRuns>>),
  cachedQuery(kv, 'sys:dailyErrors', () => getDailyErrorCounts(db, 7), 300).catch(() => [] as Awaited<ReturnType<typeof getDailyErrorCounts>>),
  cachedQuery(kv, 'sys:evalsPerCycle', () => getEvalsPerCycle(db, 10), 120).catch(() => [] as Awaited<ReturnType<typeof getEvalsPerCycle>>),
  // Rate limit + integrity (mix)
  getLatestRateLimitSnapshot(db),
  getDlqStats(db),
  getDlqMessages(db, 'pending', 10),
  cachedQuery(kv, 'sys:methDist', () => getMethodologyDistribution(db), 600),
  cachedQuery(kv, 'sys:modelDrift', () => getModelDriftStats(db), 300),
  cachedQuery(kv, 'sys:lastCal', () => getLatestCalibrationRun(db), 600),
  cachedQuery(kv, 'sys:lastLightCal', () => getLatestLightCalibrationRun(db), 600),
  cachedQuery(kv, 'sys:globalGate', () => getGlobalGateStats(db), 600),
  // Rater stats (mix of cached + fresh)
  cachedQuery(kv, 'sys:raterSummary', () => getRaterSummaryStats(db), 120).catch(() => [] as Awaited<ReturnType<typeof getRaterSummaryStats>>),
  cachedQuery(kv, 'sys:raterStatus', () => getRaterStatusBreakdown(db), 120).catch(() => [] as Awaited<ReturnType<typeof getRaterStatusBreakdown>>),
  getProviderStats(db).catch(() => [] as Awaited<ReturnType<typeof getProviderStats>>),
  getModelQueueStats(db).catch(() => [] as Awaited<ReturnType<typeof getModelQueueStats>>),
  // Observability (mostly cached)
  cachedQuery(kv, 'sys:dlqTrend', () => getDlqTrend(db), 300).catch(() => null as Awaited<ReturnType<typeof getDlqTrend>> | null),
  cachedQuery(kv, 'sys:throttle', () => getSelfThrottleImpact(db), 300).catch(() => [] as Awaited<ReturnType<typeof getSelfThrottleImpact>>),
  getEvalLatencyStats(db).catch(() => [] as Awaited<ReturnType<typeof getEvalLatencyStats>>),
  cachedQuery(kv, 'sys:signalComplete', () => getSignalCompleteness(db), 300).catch(() => [] as Awaited<ReturnType<typeof getSignalCompleteness>>),
]);

// Format token counts for display
function formatTokens(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return String(n);
}

// Event type color map for Pipeline Events panel
const EVENT_TYPE_COLORS: Record<string, string> = {
  eval_failure: '#dc2626', eval_retry: '#f97316', eval_skip: '#6b7280',
  eval_success: '#16a34a', rate_limit: '#eab308', self_throttle: '#7d80d1',
  credit_exhausted: '#ef4444', fetch_error: '#dc2626',
  parse_error: '#dc2626', cron_run: '#60a5fa', cron_error: '#f97316',
  crawl_error: '#f97316', r2_error: '#f97316', dlq: '#dc2626', dlq_replay: '#34d399',
  calibration: '#8b5cf6', trigger: '#a78bfa',
  rater_validation_warn: '#f97316', rater_validation_fail: '#dc2626',
  rater_auto_disable: '#ef4444', rater_auto_enable: '#34d399',
};

// Worker health helpers
function relativeTime(ts: string | null | undefined): string {
  if (!ts) return 'never';
  const s = Math.floor((Date.now() - new Date(ts).getTime()) / 1000);
  if (s < 60) return `${s}s ago`;
  if (s < 3600) return `${Math.floor(s / 60)}m ago`;
  if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
  return `${Math.floor(s / 86400)}d ago`;
}
function workerDot(ts: string | null | undefined): { color: string; title: string } {
  if (!ts) return { color: '#1a5568', title: 'never active' };
  const s = Math.floor((Date.now() - new Date(ts).getTime()) / 1000);
  if (s < 600) return { color: '#16a34a', title: 'active (<10m)' };
  if (s < 3600) return { color: '#eab308', title: 'idle (<1h)' };
  if (s < 86400) return { color: '#5b7279', title: 'sleeping (<24h)' };
  return { color: '#1a5568', title: 'inactive (>24h)' };
}

// Map eval_provider values to display names
const PROVIDER_META: Record<string, { name: string; role: string }> = {
  'anthropic':             { name: 'consumer-anthropic',  role: 'evaluate · Anthropic API' },
  'openrouter':            { name: 'consumer-openrouter', role: 'evaluate · OpenRouter' },
  'workers-ai':            { name: 'consumer-workers-ai', role: 'evaluate · Workers AI (~lite)' },
  'claude-code-standalone':{ name: 'standalone',          role: 'evaluate · local CLI' },
};

// Static queue → model → consumer mapping (mirrors wrangler configs + MODEL_QUEUE_BINDINGS)
const QUEUE_CONFIG = [
  { queue: 'hrcb-eval-queue',      model: 'claude-haiku-4-5-20251001', consumer: 'consumer-anthropic',  provider: 'anthropic'  },
  { queue: 'hrcb-eval-deepseek',   model: 'deepseek-v3.2',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-trinity',    model: 'trinity-large',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-nemotron',   model: 'nemotron-nano-30b',         consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-step',       model: 'step-3.5-flash',            consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-qwen',       model: 'qwen3-next-80b',            consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-llama',      model: 'llama-3.3-70b',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-mistral',    model: 'mistral-small-3.1',         consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-hermes',     model: 'hermes-3-405b',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-workers-ai', model: 'llama-4-scout-wai',         consumer: 'consumer-workers-ai', provider: 'workers-ai' },
  { queue: 'hrcb-eval-workers-ai', model: 'llama-3.3-70b-wai',         consumer: 'consumer-workers-ai', provider: 'workers-ai' },
];

const pctDone = status.total > 0 ? Math.round((status.done / status.total) * 100) : 0;
const pctPending = status.total > 0 ? Math.round((status.pending / status.total) * 100) : 0;
const pctFailed = status.total > 0 ? Math.round((status.failed / status.total) * 100) : 0;
const pctSkipped = status.total > 0 ? Math.round((status.skipped / status.total) * 100) : 0;
---

<Base title="System">
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">System</span>
        <span style="color: #5b7279; margin-left: var(--space-lg);">Pipeline operations and system health.</span>
        <span id="live-indicator" style="margin-left: var(--space-lg); font-size: var(--font-xs); color: #5b7279;">connecting...</span>
      </td>
    </tr>
  </table>

  {/* Pipeline Status */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Pipeline</div>

        {/* Progress bar */}
        <div style="width: 100%; height: 8px; background: #0d4655; border-radius: 4px; overflow: hidden; display: flex; margin-bottom: 10px;">
          {status.done > 0 && <div style={`width: ${pctDone}%; background: #16a34a;`}></div>}
          {status.skipped > 0 && <div style={`width: ${pctSkipped}%; background: #5b7279;`}></div>}
          {status.failed > 0 && <div style={`width: ${pctFailed}%; background: #dc2626;`}></div>}
          {status.pending > 0 && <div style={`width: ${pctPending}%; background: #0d4655;`}></div>}
        </div>

        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-base);">
          <tr>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #16a34a; font-weight: bold;">{status.done}</div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">Done</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #eab308; font-weight: bold;">{status.pending}</div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">Pending</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #60a5fa; font-weight: bold;">{status.evaluating}</div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">Evaluating</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #dc2626; font-weight: bold;">{status.failed}</div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">Failed</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #5b7279; font-weight: bold;">{status.skipped}</div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">Skipped</div>
            </td>
          </tr>
        </table>
        {velocity.evalsPerDay > 0 && (
          <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #0d4655; display: flex; gap: 16px; font-size: var(--font-sm); color: #5b7279;">
            <span>
              <span class="score-font" style="color: #5b7279;">{velocity.evalsPerDay.toFixed(1)}</span> evals/day
            </span>
            <span>
              <span class="score-font" style="color: #5b7279;">{velocity.daysActive}</span> days active
            </span>
            {velocity.daysToClearing !== null && status.pending > 0 && (
              <span>
                est. <span class="score-font" style="color: #eab308;">{velocity.daysToClearing < 1 ? '<1' : Math.ceil(velocity.daysToClearing)}</span> {velocity.daysToClearing < 1.5 ? 'day' : 'days'} to clear backlog
              </span>
            )}
          </div>
        )}
      </td>
    </tr>
  </table>

  {/* Workers Health */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Workers</div>
        <div class="table-wrap">
        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 2px 6px; width: 12px;"></td>
            <td style="padding: 2px 6px;">Worker</td>
            <td style="padding: 2px 6px;">Role</td>
            <td style="padding: 2px 6px; text-align: right;">Last Active</td>
            <td style="padding: 2px 6px; text-align: right; width: 50px;">24h</td>
            <td style="padding: 2px 6px; text-align: right; width: 50px;">7d</td>
            <td style="padding: 2px 6px; text-align: right; width: 50px;">Errs 24h</td>
          </tr>

          {/* Cron worker */}
          {(() => {
            const lastActive = cronRuns[0]?.cycle_start ?? null;
            const dot = workerDot(lastActive);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: #98a8a8; font-weight: bold;">hn-hrcb-cron</td>
                <td style="padding: 4px 6px; color: #5b7279;">crawl HN · dispatch to queues</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279; white-space: nowrap;">{relativeTime(lastActive)}</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279;">—</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279;">—</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279;">—</td>
              </tr>
            );
          })()}

          {/* Consumer workers (from rater_evals eval_provider) */}
          {providerStats.map(ps => {
            const meta = PROVIDER_META[ps.eval_provider] ?? { name: ps.eval_provider, role: 'evaluate' };
            const dot = workerDot(ps.last_eval);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: #98a8a8; font-weight: bold;">{meta.name}</td>
                <td style="padding: 4px 6px; color: #5b7279;">{meta.role}</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279; white-space: nowrap;">{relativeTime(ps.last_eval)}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.evals_24h > 0 ? '#60a5fa' : '#5b7279'};`}>{ps.evals_24h > 0 ? ps.evals_24h : '—'}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.evals_7d > 0 ? '#5b7279' : '#1a5568'};`}>{ps.evals_7d > 0 ? ps.evals_7d : '—'}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.failed_24h > 0 ? '#dc2626' : '#5b7279'};`}>{ps.failed_24h > 0 ? ps.failed_24h : '—'}</td>
              </tr>
            );
          })}

          {/* DLQ worker */}
          {(() => {
            const lastDlqEvent = recentPipelineEvents.find(e => e.event_type === 'dlq' || e.event_type === 'dlq_replay');
            const lastActive = lastDlqEvent?.created_at ?? null;
            const dot = workerDot(lastActive);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: #98a8a8; font-weight: bold;">hn-hrcb-dlq</td>
                <td style="padding: 4px 6px; color: #5b7279;">dead letter handler</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279; white-space: nowrap;">{relativeTime(lastActive)}</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279;">—</td>
                <td style="padding: 4px 6px; text-align: right; color: #5b7279;">—</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${dlqStats.pending > 0 ? '#dc2626' : '#5b7279'};`}>
                  {dlqStats.pending > 0 ? `${dlqStats.pending}p` : '—'}
                </td>
              </tr>
            );
          })()}
        </table>
        </div>
      </td>
    </tr>
  </table>

  {/* Queue Breakdown */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
          Queues
          <span style="text-transform: none; letter-spacing: 0; color: #1a5568; margin-left: 6px; font-size: var(--font-xs);">{QUEUE_CONFIG.length} queues + hrcb-eval-dlq</span>
        </div>
        <div class="table-wrap">
        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 2px 6px; width: 12px;"></td>
            <td style="padding: 2px 6px;">Queue</td>
            <td style="padding: 2px 6px;">Model</td>
            <td style="padding: 2px 6px;">Consumer</td>
            <td style="padding: 2px 6px; text-align: right;">Last Eval</td>
            <td style="padding: 2px 6px; text-align: right; width: 55px;" title="Items in rater_evals with queued/evaluating status">In-flight</td>
            <td style="padding: 2px 6px; text-align: right; width: 40px;">24h</td>
            <td style="padding: 2px 6px; text-align: right; width: 40px;">7d</td>
          </tr>

          {QUEUE_CONFIG.map(qc => {
            const stat = modelQueueStats.find(s => s.eval_model === qc.model);
            const dot = workerDot(stat?.last_eval ?? null);
            const isEnabled = MODEL_REGISTRY.find(r => r.id === qc.model)?.enabled ?? false;
            return (
              <tr style={`border-top: 1px solid #0d4655; ${!isEnabled ? 'opacity: 0.5;' : ''}`}>
                <td style="padding: 3px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 3px 6px; color: #5b7279; font-family: monospace; white-space: nowrap;" title={qc.queue}>
                  {qc.queue.replace('hrcb-eval-', '')}
                </td>
                <td style="padding: 3px 6px; color: #98a8a8; white-space: nowrap;">
                  {modelDisplayName(qc.model)}
                  {isLightMode(getModelDef(qc.model)?.prompt_mode ?? null) && <span style="color: #d56500; margin-left: 3px; font-size: 8px;">~lite</span>}
                  {!isEnabled && <span style="color: #1a5568; margin-left: 4px; font-size: 8px;">off</span>}
                </td>
                <td style="padding: 3px 6px; color: #5b7279; font-size: 9px;">{qc.consumer}</td>
                <td style="padding: 3px 6px; text-align: right; color: #5b7279; white-space: nowrap;">{relativeTime(stat?.last_eval ?? null)}</td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.in_flight ?? 0) > 0 ? '#eab308' : '#1a5568'};`}>
                  {(stat?.in_flight ?? 0) > 0 ? stat!.in_flight : '—'}
                </td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.evals_24h ?? 0) > 0 ? '#60a5fa' : '#1a5568'};`}>
                  {(stat?.evals_24h ?? 0) > 0 ? stat!.evals_24h : '—'}
                </td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.evals_7d ?? 0) > 0 ? '#5b7279' : '#1a5568'};`}>
                  {(stat?.evals_7d ?? 0) > 0 ? stat!.evals_7d : '—'}
                </td>
              </tr>
            );
          })}

          {/* DLQ row */}
          {(() => {
            const lastDlqEvent = recentPipelineEvents.find(e => e.event_type === 'dlq' || e.event_type === 'dlq_replay');
            const dot = workerDot(lastDlqEvent?.created_at ?? null);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 3px 6px; text-align: center;">
                  <span style={`color: ${dlqStats.pending > 0 ? '#dc2626' : dot.color}; font-size: 8px;`} title={dlqStats.pending > 0 ? `${dlqStats.pending} pending` : dot.title}>●</span>
                </td>
                <td style="padding: 3px 6px; color: #5b7279; font-family: monospace;">eval-dlq</td>
                <td style="padding: 3px 6px; color: #5b7279; font-size: 9px;">dead letters</td>
                <td style="padding: 3px 6px; color: #5b7279; font-size: 9px;">hn-hrcb-dlq</td>
                <td style="padding: 3px 6px; text-align: right; color: #5b7279; white-space: nowrap;">{relativeTime(lastDlqEvent?.created_at ?? null)}</td>
                <td style={`padding: 3px 6px; text-align: right; color: ${dlqStats.pending > 0 ? '#dc2626' : '#1a5568'};`}>
                  {dlqStats.pending > 0 ? `${dlqStats.pending}` : '—'}
                </td>
                <td style="padding: 3px 6px; text-align: right; color: #1a5568;">—</td>
                <td style="padding: 3px 6px; text-align: right; color: #5b7279;">
                  {dlqStats.total > 0 ? dlqStats.total : '—'}
                </td>
              </tr>
            );
          })()}
        </table>
        </div>
      </td>
    </tr>
  </table>

  {/* ═══ SECONDARY — Expanded by default, collapsible ═══ */}
  {raterStatus.length > 0 && (
    <details open class="collapsible-section">
      <summary>Multi-Model Raters</summary>
    <div class="table-wrap">
          <table cellpadding="0" cellspacing="0" width="100%">
            <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td style="padding: 4px 8px;">Model</td>
              <td style="padding: 4px 8px; text-align: center;">Avg Score</td>
              <td style="padding: 4px 8px; text-align: center;">Conf</td>
              <td style="padding: 4px 8px; text-align: center;">Done</td>
              <td style="padding: 4px 8px; text-align: center;">Queued</td>
              <td style="padding: 4px 8px; text-align: center;">Failed</td>
              <td style="padding: 4px 8px; text-align: center;">Coverage</td>
            </tr>
            {raterStatus.map(rs => {
              const summary = raterSummary.find(s => s.model === rs.model);
              const coveragePct = rs.total_primary > 0 ? Math.round((rs.done / rs.total_primary) * 100) : 0;
              const coverageColor = coveragePct >= 95 ? '#34d399' : coveragePct >= 50 ? '#eab308' : '#dc2626';
              const inFlight = rs.queued + rs.pending + rs.evaluating;
              return (
                <tr style="border-top: 1px solid #0d4655;">
                  <td style="padding: 6px 8px; color: #98a8a8; font-size: var(--font-sm); font-weight: bold;">
                    {modelDisplayName(rs.model)}
                    {isLightMode(getModelDef(rs.model)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 4px; font-weight: normal;" title="Light evaluation — editorial only">lite</span>}
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style={`color: ${summary?.avg_score != null ? scoreToColor(summary.avg_score) : '#5b7279'}; font-weight: bold;`}>
                      {summary?.avg_score != null ? summary.avg_score.toFixed(3) : '---'}
                    </span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style={`color: ${summary?.avg_confidence != null ? confidenceToColor(summary.avg_confidence) : '#5b7279'};`}>
                      {summary?.avg_confidence != null ? summary.avg_confidence.toFixed(2) : '---'}
                    </span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style="color: #34d399;">{rs.done}</span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    {inFlight > 0
                      ? <span class="score-font" style="color: #eab308;">{inFlight}</span>
                      : <span style="color: #5b7279;">0</span>
                    }
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    {rs.failed > 0
                      ? <span class="score-font" style="color: #dc2626;">{rs.failed}</span>
                      : <span style="color: #5b7279;">0</span>
                    }
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <div style="display: inline-flex; align-items: center; gap: 4px;">
                      <div style="width: 50px; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                        <div style={`width: ${coveragePct}%; height: 100%; background: ${coverageColor}; border-radius: 3px;`}></div>
                      </div>
                      <span class="score-font" style={`color: ${coverageColor}; font-size: var(--font-xs);`}>{coveragePct}%</span>
                    </div>
                  </td>
                </tr>
              );
            })}
          </table>
    </div>
    </details>
  )}

  {/* Eval Model */}
  {models.length > 0 && (
    <details open class="collapsible-section">
      <summary>
            Evaluation Models
            {modelComparison.length > 1 && (
              <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                {modelComparison.length} models in history
              </span>
            )}
      </summary>
          <div class="table-wrap">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #5b7279; font-size: var(--font-xs);">
              <td>Model</td>
              <td width="60" align="center">Status</td>
              <td width="70" align="center">Provider</td>
              <td width="70" align="center">Evals</td>
              <td width="70" align="center">Avg HRCB</td>
              <td width="50" align="center">Min</td>
              <td width="50" align="center">Max</td>
            </tr>
            {MODEL_REGISTRY.map((reg) => {
              const active = models.find(m => m.eval_model === reg.id);
              const hist = modelComparison.find(mc => mc.eval_model === reg.id);
              const evalCount = active?.count ?? hist?.count ?? 0;
              const avgScore = active?.avg_score ?? hist?.avg_score ?? null;
              return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style={`color: ${reg.enabled ? '#98a8a8' : '#5b7279'};`} class="score-font">
                  {reg.api_model_id}
                </td>
                <td align="center" class="score-font">
                  {reg.enabled
                    ? <span style="color: #4ade80;">on</span>
                    : <span style="color: #5b7279;">off</span>
                  }
                </td>
                <td align="center" class="score-font" style={`color: ${reg.provider === 'anthropic' ? '#c084fc' : reg.provider === 'workers-ai' ? '#f59e0b' : '#60a5fa'};`}>
                  {reg.provider === 'anthropic' ? 'anth' : reg.provider === 'workers-ai' ? 'CF' : 'OR'}{reg.is_free ? '' : ''}
                </td>
                <td align="center" class="score-font" style="color: #5b7279;">
                  {evalCount > 0 ? evalCount : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(avgScore)}; white-space: nowrap;`}>
                  {avgScore != null ? formatScore(avgScore) : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.min_score ?? null)}; white-space: nowrap;`}>
                  {hist ? formatScore(hist.min_score) : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.max_score ?? null)}; white-space: nowrap;`}>
                  {hist ? formatScore(hist.max_score) : '---'}
                </td>
              </tr>
              );
            })}
          </table>
          </div>
    </details>
  )}

  {/* ═══ TERTIARY — Collapsed by default ═══ */}

  {/* API & Rate Limits */}
  {(eventStats.total > 0 || recentPipelineEvents.length > 0) && (
    <details class="collapsible-section">
      <summary>
            API & Rate Limits
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
              {eventStats.error_count_7d > 0 ? `${eventStats.error_count_7d} errors 7d` : 'no errors'}
            </span>
      </summary>

          {/* Error sparkline (last 7 days) */}
          {dailyErrors.length > 0 && (
            <div style="margin-bottom: 10px;">
              <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 4px;">Errors/warnings (7d)</div>
              <div style="display: flex; align-items: flex-end; gap: 2px; height: 24px;">
                {dailyErrors.map((d) => {
                  const maxCount = Math.max(...dailyErrors.map(x => x.count), 1);
                  const h = Math.max(2, Math.round((d.count / maxCount) * 24));
                  return (
                    <div
                      title={`${d.day}: ${d.count}`}
                      style={`width: ${Math.floor(100 / Math.max(dailyErrors.length, 1))}%; height: ${h}px; background: ${d.count > 5 ? '#dc2626' : d.count > 0 ? '#eab308' : '#0d4655'}; border-radius: 1px;`}
                    ></div>
                  );
                })}
              </div>
            </div>
          )}

          {/* API Headroom */}
          {rateLimitSnapshot && (
            <div style="margin-bottom: 10px; padding: 8px; background: #0d4655; border: 1px solid #0d4655; border-radius: 4px;">
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 6px;">
                API Headroom
                <span style="text-transform: none; color: #1a5568; margin-left: 6px;">
                  {rateLimitSnapshot.model} · {rateLimitSnapshot.created_at.slice(0, 16)}
                </span>
              </div>
              <div style="display: flex; flex-wrap: wrap; gap: 8px; font-size: var(--font-xs);">
                {/* Requests */}
                <div style="flex: 1; min-width: 100px;">
                  <div style="color: #5b7279; margin-bottom: 2px;">Requests</div>
                  <div style="display: flex; align-items: center; gap: 4px;">
                    <div style="flex: 1; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      {rateLimitSnapshot.requests_remaining != null && rateLimitSnapshot.requests_limit != null && rateLimitSnapshot.requests_limit > 0 && (
                        <div style={`width: ${Math.round((rateLimitSnapshot.requests_remaining / rateLimitSnapshot.requests_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.1 ? '#dc2626' : rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.3 ? '#eab308' : '#16a34a'}; border-radius: 3px;`}></div>
                      )}
                    </div>
                    <span style={`color: ${rateLimitSnapshot.requests_remaining != null && rateLimitSnapshot.requests_limit != null && rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.1 ? '#dc2626' : '#5b7279'};`}>
                      {rateLimitSnapshot.requests_remaining ?? '?'}/{rateLimitSnapshot.requests_limit ?? '?'}
                    </span>
                  </div>
                </div>
                {/* Input tokens */}
                <div style="flex: 1; min-width: 100px;">
                  <div style="color: #5b7279; margin-bottom: 2px;">Input Tokens</div>
                  <div style="display: flex; align-items: center; gap: 4px;">
                    <div style="flex: 1; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      {rateLimitSnapshot.input_tokens_remaining != null && rateLimitSnapshot.input_tokens_limit != null && rateLimitSnapshot.input_tokens_limit > 0 && (
                        <div style={`width: ${Math.round((rateLimitSnapshot.input_tokens_remaining / rateLimitSnapshot.input_tokens_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.1 ? '#dc2626' : rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.3 ? '#eab308' : '#16a34a'}; border-radius: 3px;`}></div>
                      )}
                    </div>
                    <span style={`color: ${rateLimitSnapshot.input_tokens_remaining != null && rateLimitSnapshot.input_tokens_limit != null && rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.1 ? '#dc2626' : '#5b7279'}; white-space: nowrap;`}>
                      {rateLimitSnapshot.input_tokens_remaining != null ? (rateLimitSnapshot.input_tokens_remaining > 999999 ? `${(rateLimitSnapshot.input_tokens_remaining / 1000000).toFixed(1)}M` : rateLimitSnapshot.input_tokens_remaining > 999 ? `${(rateLimitSnapshot.input_tokens_remaining / 1000).toFixed(0)}k` : rateLimitSnapshot.input_tokens_remaining) : '?'}
                    </span>
                  </div>
                </div>
                {/* Output tokens */}
                <div style="flex: 1; min-width: 100px;">
                  <div style="color: #5b7279; margin-bottom: 2px;">Output Tokens</div>
                  <div style="display: flex; align-items: center; gap: 4px;">
                    <div style="flex: 1; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      {rateLimitSnapshot.output_tokens_remaining != null && rateLimitSnapshot.output_tokens_limit != null && rateLimitSnapshot.output_tokens_limit > 0 && (
                        <div style={`width: ${Math.round((rateLimitSnapshot.output_tokens_remaining / rateLimitSnapshot.output_tokens_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.1 ? '#dc2626' : rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.3 ? '#eab308' : '#16a34a'}; border-radius: 3px;`}></div>
                      )}
                    </div>
                    <span style={`color: ${rateLimitSnapshot.output_tokens_remaining != null && rateLimitSnapshot.output_tokens_limit != null && rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.1 ? '#dc2626' : '#5b7279'}; white-space: nowrap;`}>
                      {rateLimitSnapshot.output_tokens_remaining != null ? (rateLimitSnapshot.output_tokens_remaining > 999999 ? `${(rateLimitSnapshot.output_tokens_remaining / 1000000).toFixed(1)}M` : rateLimitSnapshot.output_tokens_remaining > 999 ? `${(rateLimitSnapshot.output_tokens_remaining / 1000).toFixed(0)}k` : rateLimitSnapshot.output_tokens_remaining) : '?'}
                    </span>
                  </div>
                </div>
              </div>
              <div style="display: flex; gap: 12px; margin-top: 6px; font-size: var(--font-xs);">
                {rateLimitSnapshot.cache_hit_rate != null && (
                  <span style="color: #5b7279;">
                    Cache: <span style={`color: ${rateLimitSnapshot.cache_hit_rate > 0.5 ? '#16a34a' : rateLimitSnapshot.cache_hit_rate > 0.2 ? '#eab308' : '#5b7279'};`}>{(rateLimitSnapshot.cache_hit_rate * 100).toFixed(0)}%</span>
                  </span>
                )}
                <span style={`color: ${rateLimitSnapshot.consecutive_429s === 0 ? '#16a34a' : rateLimitSnapshot.consecutive_429s <= 2 ? '#eab308' : '#dc2626'};`}>
                  429s: {rateLimitSnapshot.consecutive_429s}{rateLimitSnapshot.consecutive_429s >= 3 ? ' (circuit open)' : ''}
                </span>
              </div>
            </div>
          )}
    </details>
  )}

  {/* Cycle Performance */}
  {cycleStats.length > 0 && (
    <details class="collapsible-section">
      <summary>Cycle Performance</summary>

              <div class="table-wrap">
              <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase;">
                  <td width="130">Cycle Start</td>
                  <td width="50" align="center">Crawl</td>
                  <td width="40" align="center" title="Stories found by cron">Found</td>
                  <td width="35" align="center" title="New stories queued">New</td>
                  <td width="45" align="center" title="Evaluations completed">Evals</td>
                  <td width="35" align="center" title="Failed evaluations">Fail</td>
                  <td title="Time until next cycle">Cycle Time</td>
                </tr>
                {cycleStats.map((c) => {
                  const cycleDuration = c.cycle_end
                    ? Math.round((new Date(c.cycle_end).getTime() - new Date(c.cycle_start).getTime()) / 1000)
                    : null;
                  const cycleMins = cycleDuration !== null ? Math.floor(cycleDuration / 60) : null;
                  const cycleSecs = cycleDuration !== null ? cycleDuration % 60 : null;
                  return (
                    <tr style="border-top: 1px solid #0d4655;">
                      <td style="color: #5b7279; white-space: nowrap;">{c.cycle_start.slice(0, 16)}</td>
                      <td align="center" style="color: #5b7279; white-space: nowrap;">
                        {c.duration_ms !== null ? `${(c.duration_ms / 1000).toFixed(1)}s` : '---'}
                      </td>
                      <td align="center" style="color: #5b7279;">{c.stories_found ?? '---'}</td>
                      <td align="center" style={`color: ${(c.stories_new ?? 0) > 0 ? '#16a34a' : '#5b7279'};`}>{c.stories_new ?? '---'}</td>
                      <td align="center" style={`color: ${c.evals_completed > 0 ? '#60a5fa' : '#5b7279'}; font-weight: ${c.evals_completed > 0 ? 'bold' : 'normal'};`}>{c.evals_completed}</td>
                      <td align="center" style={`color: ${c.evals_failed > 0 ? '#dc2626' : '#5b7279'};`}>{c.evals_failed || '---'}</td>
                      <td style="color: #5b7279;">
                        {cycleMins !== null ? `${cycleMins}m ${cycleSecs}s` : <span style="color: #0d4655;">current</span>}
                      </td>
                    </tr>
                  );
                })}
              </table>
              </div>
              {cycleStats.length >= 2 && (() => {
                const withDurations = cycleStats.filter(c => c.cycle_end !== null);
                if (withDurations.length === 0) return null;
                const totalEvals = withDurations.reduce((sum, c) => sum + c.evals_completed, 0);
                const avgEvals = totalEvals / withDurations.length;
                const cycleDurations = withDurations.map(c =>
                  (new Date(c.cycle_end!).getTime() - new Date(c.cycle_start).getTime()) / 1000
                );
                const avgCycle = cycleDurations.reduce((a, b) => a + b, 0) / cycleDurations.length;
                const avgCycleMins = Math.floor(avgCycle / 60);
                const avgCycleSecs = Math.round(avgCycle % 60);
                return (
                  <div style="margin-top: 6px; font-size: var(--font-xs); color: #5b7279;">
                    Avg: <span style="color: #60a5fa;">{avgEvals.toFixed(1)}</span> evals/cycle
                    <span style="color: #0d4655;"> · </span>
                    <span style="color: #5b7279;">{avgCycleMins}m {avgCycleSecs}s</span> cycle time
                  </div>
                );
              })()}
    </details>
  )}

  {/* Throttle Impact */}
  {throttleImpact.length > 0 && (
    <details class="collapsible-section">
      <summary>
        Throttle Impact
        <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
          {Math.round(throttleImpact.reduce((s, r) => s + r.total_delay_sec, 0) / 60)}m wasted 7d
        </span>
      </summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">Events</td>
          <td style="padding: 2px 6px; text-align: right; width: 80px;">Wasted (7d)</td>
        </tr>
        {throttleImpact.map(row => (
          <tr style="border-top: 1px solid #0d4655;">
            <td style="padding: 3px 6px; color: #98a8a8;">{row.model}</td>
            <td style="padding: 3px 6px; text-align: right; color: #5b7279;">{row.event_count}</td>
            <td style={`padding: 3px 6px; text-align: right; color: ${row.total_delay_sec > 600 ? '#eab308' : '#5b7279'};`}>
              {row.total_delay_sec >= 60
                ? `${Math.round(row.total_delay_sec / 60)}m ${Math.round(row.total_delay_sec % 60)}s`
                : `${Math.round(row.total_delay_sec)}s`}
            </td>
          </tr>
        ))}
      </table>
      </div>
    </details>
  )}

  {/* Eval Latency */}
  {latencyStats.length > 0 && (
    <details class="collapsible-section">
      <summary>Eval Latency</summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;" title="Median latency (story crawled → eval done)">P50</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">P95</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">P99</td>
          <td style="padding: 2px 6px; text-align: right; width: 50px;">N</td>
        </tr>
        {latencyStats.map(row => {
          const fmt = (s: number | null) => s == null ? '—' : s < 3600 ? `${Math.round(s / 60)}m` : `${(s / 3600).toFixed(1)}h`;
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 3px 6px; color: #98a8a8;">{row.eval_model}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${row.p50_sec != null && row.p50_sec > 3600 ? '#eab308' : '#5b7279'};`}>{fmt(row.p50_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: #5b7279;">{fmt(row.p95_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: #5b7279;">{fmt(row.p99_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: #1a5568;">{row.sample_count}</td>
            </tr>
          );
        })}
      </table>
      </div>
    </details>
  )}

  {/* Signal Completeness */}
  {signalCompleteness.length > 0 && (
    <details class="collapsible-section">
      <summary>
        Signal Completeness
        {signalCompleteness.some(r => r.any_below_80) && (
          <span style="text-transform: none; letter-spacing: 0; color: #eab308; margin-left: 6px;">gaps detected</span>
        )}
      </summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Epistemic quality">EQ</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Solution orientation">SO</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Temporal dimension">TD</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Propaganda flags">PT</td>
          <td style="padding: 2px 6px; text-align: right; width: 50px;" title="Primary tone">Tone</td>
        </tr>
        {signalCompleteness.map(row => {
          const pct = (v: number | null) => v == null ? '—' : `${Math.round(v)}%`;
          const col = (v: number | null) => v == null ? '#1a5568' : v < 80 ? '#dc2626' : v < 95 ? '#eab308' : '#5b7279';
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 3px 6px; color: #98a8a8;">{row.eval_model}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.eq_pct)};`}>{pct(row.eq_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.so_pct)};`}>{pct(row.so_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.td_pct)};`}>{pct(row.td_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.pt_pct)};`}>{pct(row.pt_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.tone_pct)};`}>{pct(row.tone_pct)}</td>
            </tr>
          );
        })}
      </table>
      </div>
    </details>
  )}

  {/* Measurement Integrity */}
  <details class="collapsible-section">
    <summary>Measurement Integrity</summary>
          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px;">
            {/* DLQ Status */}
            <div style={`flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid ${dlqStats.pending > 0 ? '#dc262640' : '#0d4655'}; border-radius: 4px;`}>
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">
                Dead Letter Queue
                {dlqTrend?.backlog_growing && <span style="color: #dc2626; margin-left: 4px;" title="Backlog growing over last 7 days">↑</span>}
                {dlqTrend && !dlqTrend.backlog_growing && dlqStats.pending > 0 && <span style="color: #16a34a; margin-left: 4px;" title="Backlog stable or shrinking">→</span>}
              </div>
              {dlqStats.total === 0 ? (
                <div style="color: #5b7279; font-size: var(--font-xs);">Empty</div>
              ) : (
                <div style="font-size: var(--font-xs);">
                  <span style={`color: ${dlqStats.pending > 0 ? '#dc2626' : '#16a34a'}; font-weight: bold;`}>{dlqStats.pending}</span>
                  <span style="color: #5b7279;"> pending</span>
                  {dlqStats.replayed > 0 && <span style="color: #5b7279;"> · {dlqStats.replayed} replayed</span>}
                  {dlqStats.discarded > 0 && <span style="color: #1a5568;"> · {dlqStats.discarded} discarded</span>}
                </div>
              )}
              {dlqTrend && dlqTrend.days.length > 0 && (
                <div style="margin-top: 4px; display: flex; align-items: flex-end; gap: 1px; height: 16px;" title="14-day DLQ new entries">
                  {dlqTrend.days.map(d => {
                    const maxNew = Math.max(...dlqTrend!.days.map(x => x.new_count), 1);
                    const h = Math.max(2, Math.round((d.new_count / maxNew) * 16));
                    return (
                      <div style={`width: 6px; height: ${h}px; background: ${d.new_count > 0 ? '#dc262680' : '#0d4655'}; border-radius: 1px;`} title={`${d.day}: ${d.new_count} new`}></div>
                    );
                  })}
                </div>
              )}
              {dlqMessages.length > 0 && (
                <div style="margin-top: 4px; font-size: 9px;">
                  {dlqMessages.slice(0, 3).map((m) => (
                    <div style="color: #5b7279; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;" title={`hn_id=${m.hn_id}: ${m.title}`}>
                      <a href={`/item/${m.hn_id}`} style="color: #dc2626;">{m.hn_id}</a> {m.title.slice(0, 30)}...
                    </div>
                  ))}
                </div>
              )}
            </div>

            {/* Methodology Versions */}
            <div style="flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid #0d4655; border-radius: 4px;">
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Methodology Versions</div>
              {methodologyDist.length === 0 ? (
                <div style="color: #5b7279; font-size: var(--font-xs);">No data</div>
              ) : (
                <div style="font-size: var(--font-xs);">
                  {methodologyDist.map((m, i) => {
                    const hashDisplay = m.methodology_hash ? m.methodology_hash.slice(0, 8) : 'pre-v';
                    const isLatest = i === 0 && m.methodology_hash !== null;
                    return (
                      <div style={`color: ${isLatest ? '#16a34a' : m.methodology_hash === null ? '#eab308' : '#5b7279'};`}>
                        <span style="font-family: monospace;">{hashDisplay}</span>
                        <span style="color: #5b7279;"> · {m.count} evals</span>
                        {m.methodology_hash === null && <span style="color: #eab308;"> (stale)</span>}
                      </div>
                    );
                  })}
                  {methodologyDist.some(m => m.methodology_hash === null) && (
                    <div style="color: #eab308; font-size: 9px; margin-top: 2px;">
                      {methodologyDist.find(m => m.methodology_hash === null)?.count ?? 0} evals need reprocessing
                    </div>
                  )}
                </div>
              )}
            </div>

            {/* Model Drift */}
            <div style="flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid #0d4655; border-radius: 4px;">
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Model Drift</div>
              {driftStats.models.length === 0 ? (
                <div style="color: #5b7279; font-size: var(--font-xs);">No data</div>
              ) : (
                <div style="font-size: var(--font-xs);">
                  {driftStats.models.map((m) => (
                    <div style="color: #5b7279;">
                      <span style="color: #60a5fa;">{m.eval_model}</span>
                      <span style="color: #5b7279;"> · {m.count} evals · avg </span>
                      <span style={`color: ${m.avg_score > 0.05 ? '#16a34a' : m.avg_score < -0.05 ? '#dc2626' : '#5b7279'};`}>{m.avg_score?.toFixed(3)}</span>
                      <span style="color: #1a5568;"> ±{m.stddev?.toFixed(3)}</span>
                    </div>
                  ))}
                  {driftStats.overlapping > 0 && (
                    <div style="margin-top: 2px; color: #5b7279; font-size: 9px;">
                      {driftStats.overlapping} overlapping
                      {driftStats.meanDelta !== null && (
                        <span> · mean |Δ| = <span style={`color: ${driftStats.meanDelta > 0.1 ? '#eab308' : '#5b7279'};`}>{driftStats.meanDelta.toFixed(3)}</span></span>
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>

            {/* Calibration Status (full model) */}
            <div style={`flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid ${lastCalibration?.status === 'fail' ? '#dc262640' : '#0d4655'}; border-radius: 4px;`}>
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Calibration</div>
              {!lastCalibration ? (
                <div style="font-size: var(--font-xs);">
                  <div style="color: #eab308;">No runs yet</div>
                  <div style="color: #1a5568; font-size: 9px;">{CALIBRATION_SET.length} URLs defined</div>
                </div>
              ) : (
                <div style="font-size: var(--font-xs);">
                  <span style={`color: ${lastCalibration.status === 'pass' ? '#16a34a' : lastCalibration.status === 'fail' ? '#dc2626' : '#eab308'}; font-weight: bold; text-transform: uppercase;`}>{lastCalibration.status}</span>
                  <span style="color: #5b7279;"> · {lastCalibration.passed}/{lastCalibration.total_urls} passed</span>
                  {lastCalibration.failed > 0 && <span style="color: #dc2626;"> · {lastCalibration.failed} failed</span>}
                  <div style="color: #1a5568; font-size: 9px; margin-top: 2px;">
                    {lastCalibration.model.replace('claude-', '').replace('-20251001', '')} · {lastCalibration.created_at.slice(0, 10)}
                  </div>
                </div>
              )}
            </div>

            {/* Light Calibration Status (light-1.3 model) */}
            <div style={`flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid ${lastLightCalibration?.status === 'fail' ? '#dc262640' : '#0d4655'}; border-radius: 4px;`}>
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Light Cal</div>
              {!lastLightCalibration ? (
                <div style="font-size: var(--font-xs);">
                  <div style="color: #eab308;">No runs yet</div>
                  <div style="color: #1a5568; font-size: 9px;">{LIGHT_CALIBRATION_SET.length} URLs defined</div>
                </div>
              ) : (
                <div style="font-size: var(--font-xs);">
                  <span style={`color: ${lastLightCalibration.status === 'pass' ? '#16a34a' : lastLightCalibration.status === 'fail' ? '#dc2626' : '#eab308'}; font-weight: bold; text-transform: uppercase;`}>{lastLightCalibration.status}</span>
                  <span style="color: #5b7279;"> · {lastLightCalibration.passed}/{lastLightCalibration.total_urls} passed</span>
                  {lastLightCalibration.failed > 0 && <span style="color: #dc2626;"> · {lastLightCalibration.failed} failed</span>}
                  <div style="color: #1a5568; font-size: 9px; margin-top: 2px;">
                    light-1.3 · {lastLightCalibration.created_at.slice(0, 10)}
                  </div>
                </div>
              )}
            </div>

            {/* Content Gates */}
            <div style={`flex: 1; min-width: 120px; padding: 6px 8px; background: #0d4655; border: 1px solid ${globalGate.gate_pct > 20 ? '#eab30840' : '#0d4655'}; border-radius: 4px;`}>
              <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Content Gates</div>
              <div style="font-size: var(--font-xs);">
                <span style={`color: ${globalGate.gate_pct > 20 ? '#eab308' : '#5b7279'}; font-weight: bold;`}>{globalGate.gate_pct}%</span>
                <span style="color: #5b7279;"> gated ({globalGate.gated}/{globalGate.total})</span>
              </div>
              {globalGate.breakdown.length > 0 && (
                <div style="margin-top: 3px; font-size: 9px;">
                  {globalGate.breakdown.slice(0, 4).map(b => (
                    <div style="color: #5b7279;">
                      <span style={`color: ${b.gate_category === 'paywall' ? '#d56500' : b.gate_category === 'bot_protection' ? '#dc2626' : b.gate_category === 'error_page' ? '#5b7279' : '#eab308'};`}>
                        {b.gate_category.replace(/_/g, ' ')}
                      </span>
                      <span style="color: #1a5568;"> · {b.cnt}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
  </details>

  {/* Pipeline Events */}
  {(eventStats.total > 0 || recentPipelineEvents.length > 0) && (
    <details class="collapsible-section">
      <summary>
            Pipeline Events
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
              {eventStats.last_24h} last 24h · {eventStats.last_7d} last 7d
            </span>
      </summary>

          {/* Event type breakdown */}
          {Object.keys(eventStats.by_type).length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;">
              {Object.entries(eventStats.by_type).sort((a, b) => b[1] - a[1]).map(([type, count]) => {
                const color = EVENT_TYPE_COLORS[type] || '#5b7279';
                return (
                  <span class="badge" style={`background: ${color}20; color: ${color}; font-size: var(--font-xs);`}>
                    {type}: {count}
                  </span>
                );
              })}
            </div>
          )}

          {/* Recent events table */}
          {recentPipelineEvents.length > 0 && (
            <div>
              <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 4px;">Recent Events</div>
              <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                {recentPipelineEvents.map((ev) => {
                  const sevColor = ev.severity === 'error' ? '#dc2626' : ev.severity === 'warn' ? '#eab308' : '#5b7279';
                  const typeColor = EVENT_TYPE_COLORS[ev.event_type] || '#5b7279';
                  return (
                    <tr style="border-top: 1px solid #0d4655;">
                      <td style="color: #5b7279; white-space: nowrap; width: 140px;">{ev.created_at.slice(0, 16)}</td>
                      <td style="width: 90px;">
                        <span class="badge" style={`background: ${typeColor}20; color: ${typeColor}; font-size: var(--font-xs);`}>
                          {ev.event_type}
                        </span>
                      </td>
                      <td style={`color: ${sevColor};`}>
                        {ev.hn_id ? (
                          <a href={`/item/${ev.hn_id}`} style={`color: ${sevColor};`}>{ev.message}</a>
                        ) : (
                          ev.message
                        )}
                      </td>
                      <td style="width: 60px; text-align: center; white-space: nowrap;">
                        {ev.investigated === 1
                          ? <span style="color: #3b82f6;" title="Investigated">INV</span>
                          : ev.investigated === 0
                            ? <span style="color: #5b7279;" title="Not investigated">--</span>
                            : <span style="color: #0d4655;" title="Not triaged">-</span>
                        }
                        {' '}
                        {ev.resolved === 1
                          ? <span style="color: #22c55e;" title="Resolved">RES</span>
                          : ev.resolved === 0
                            ? <span style="color: #5b7279;" title="Not resolved">--</span>
                            : <span style="color: #0d4655;" title="Not triaged">-</span>
                        }
                      </td>
                    </tr>
                  );
                })}
              </table>
            </div>
          )}
    </details>
  )}

  {/* Recent Failures */}
  {failed.length > 0 && (
    <details class="collapsible-section">
      <summary>Recent Failures <span style="text-transform: none; letter-spacing: 0; color: #dc2626; margin-left: 6px;">{failed.length}</span></summary>
          <div class="table-wrap">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            {failed.map((s) => (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="color: #98a8a8;">
                  {s.title}
                  {s.domain && <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td style="color: #dc2626; font-size: var(--font-xs); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.eval_error?.slice(0, 80) || 'Unknown error'}
                </td>
              </tr>
            ))}
          </table>
          </div>
    </details>
  )}

  {/* Evaluation Queue */}
  {queue.length > 0 && (
    <details class="collapsible-section">
      <summary>
            Evaluation Queue
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
              {queue.length} stories waiting
            </span>
      </summary>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #5b7279; font-size: var(--font-xs);">
              <td width="24">#</td>
              <td width="70">Status</td>
              <td>Story</td>
              <td width="140">Domain</td>
            </tr>
            {queue.map((s, i) => (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="color: #5b7279;" class="score-font">{i + 1}</td>
                <td>
                  {s.eval_status === 'evaluating' ? (
                    <span class="badge" style="background: rgba(96,165,250,0.2); color: #60a5fa; font-size: var(--font-xs);">evaluating</span>
                  ) : (
                    <span class="badge" style="background: rgba(234,179,8,0.15); color: #eab308; font-size: var(--font-xs);">pending</span>
                  )}
                </td>
                <td>
                  <a href={s.url || `https://news.ycombinator.com/item?id=${s.hn_id}`}
                     target="_blank" rel="noopener" style="color: #98a8a8;">
                    {s.title}
                  </a>
                </td>
                <td style="color: #5b7279; font-size: var(--font-xs);">{s.domain || 'self'}</td>
              </tr>
            ))}
          </table>
    </details>
  )}

  {/* Operations */}
  <details class="collapsible-section">
    <summary>Operations</summary>
        <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <tr>
            <td style="color: #5b7279; width: 140px;">Cron interval</td>
            <td style="color: #98a8a8;">Every 5 minutes</td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Score refresh</td>
            <td style="color: #98a8a8;">Every 5 min (updates) · 48h sweep every 10 min</td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Eval today</td>
            <td>
              <span class="score-font" style="color: #eab308;">{costStats.today_evals}</span>
              <span style="color: #5b7279;"> evals · </span>
              <span class="score-font" style="color: #5b7279;">{formatTokens(costStats.today_input_tokens)}</span>
              <span style="color: #5b7279;"> in · </span>
              <span class="score-font" style="color: #5b7279;">{formatTokens(costStats.today_output_tokens)}</span>
              <span style="color: #5b7279;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Total usage</td>
            <td>
              <span class="score-font" style="color: #16a34a;">{costStats.total_evals}</span>
              <span style="color: #5b7279;"> evals · </span>
              <span class="score-font" style="color: #5b7279;">{formatTokens(costStats.total_input_tokens)}</span>
              <span style="color: #5b7279;"> in · </span>
              <span class="score-font" style="color: #5b7279;">{formatTokens(costStats.total_output_tokens)}</span>
              <span style="color: #5b7279;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Queue</td>
            <td>
              <span class="score-font" style="color: #60a5fa;">{status.evaluating}</span>
              <span style="color: #5b7279;"> evaluating · </span>
              <span class="score-font" style="color: #eab308;">{queue.length}</span>
              <span style="color: #5b7279;"> queued/pending</span>
            </td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Crawl surface</td>
            <td style="color: #98a8a8;">top · new · best · ask · show (5 lists)</td>
          </tr>
          <tr>
            <td style="color: #5b7279;">Architecture</td>
            <td style="color: #5b7279; font-size: var(--font-xs);">Cron v5 → Queue → Consumer (fan-out) · KV content cache · KV DCP cache</td>
          </tr>
        </table>
  </details>

  {/* Link card: Models */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <a href="/models" style="color: #98a8a8; text-decoration: none; display: block;">
          <div style="font-size: var(--font-sm); font-weight: bold;">Models</div>
          <div style="color: #5b7279; font-size: var(--font-xs); margin-top: 2px;">Multi-model comparison, agreement analysis, and score distributions.</div>
        </a>
      </td>
    </tr>
  </table>

  {/* Live feed toast area */}
  <div id="live-feed" style="position: fixed; bottom: 10px; right: 10px; z-index: 100; display: flex; flex-direction: column; gap: 4px; max-width: 320px;"></div>

  <script is:inline>
  (function() {
    const indicator = document.getElementById('live-indicator');
    const feed = document.getElementById('live-feed');
    let es;

    function connect() {
      es = new EventSource('/api/events');

      es.addEventListener('connected', function() {
        if (indicator) {
          indicator.style.color = '#16a34a';
          indicator.textContent = 'live';
        }
      });

      es.addEventListener('evaluation', function(e) {
        const d = JSON.parse(e.data);
        const score = d.hcb_weighted_mean !== null ? d.hcb_weighted_mean.toFixed(2) : '?';
        const toast = document.createElement('div');
        toast.style.cssText = 'background:#093946;border:1px solid #1a5568;border-radius:4px;padding:6px 10px;font-size:8pt;color:#8faaab;';
        const link = document.createElement('a');
        link.href = '/item/' + d.hn_id;
        link.style.color = '#98a8a8';
        link.textContent = (d.title || '').slice(0, 40);
        const scoreSpan = document.createElement('span');
        scoreSpan.style.cssText = 'color:' + (d.hcb_weighted_mean > 0.05 ? '#16a34a' : d.hcb_weighted_mean < -0.05 ? '#dc2626' : '#eab308') + ';font-family:monospace;';
        scoreSpan.textContent = ' ' + score;
        toast.appendChild(link);
        toast.appendChild(scoreSpan);
        if (feed) {
          feed.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 15000);
          // Keep max 3 toasts
          while (feed.children.length > 3) feed.removeChild(feed.firstChild);
        }
      });

      es.addEventListener('timeout', function() {
        es.close();
        if (indicator) { indicator.style.color = '#5b7279'; indicator.textContent = 'reconnecting...'; }
        setTimeout(connect, 2000);
      });

      es.onerror = function() {
        es.close();
        if (indicator) { indicator.style.color = '#5b7279'; indicator.textContent = 'offline'; }
        setTimeout(connect, 30000);
      };
    }

    connect();
  })();
  </script>
</Base>
