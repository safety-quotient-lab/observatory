---
import Base from '../layouts/Base.astro';
import { scoreToColor, formatScore, confidenceToColor, formatConfidence } from '../lib/colors';
import { ARTICLE_TITLES, ARTICLE_GROUPS, SECTIONS } from '../lib/udhr';
import { getArticleDetailedStats, getArticleSparklines } from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [articleStats, sparklines] = await Promise.all([
  getArticleDetailedStats(db),
  getArticleSparklines(db, 30),
]);

const statsMap = new Map(articleStats.map(a => [a.section, a]));
const totalEvaluated = Math.max(...articleStats.map(a => a.signal_count + a.nd_count), 0);

// Group sections by UDHR group
const groupedSections = new Map<string, typeof SECTIONS>();
for (const s of SECTIONS) {
  const arr = groupedSections.get(s.group) || [];
  arr.push(s);
  groupedSections.set(s.group, arr);
}

const groupColors: Record<string, string> = {
  'Foundation & Dignity': '#a78bfa',
  'Civil & Political Rights': '#60a5fa',
  'Legal Rights': '#22d3ee',
  'Personal Freedoms': '#34d399',
  'Political & Community Rights': '#fbbf24',
  'Economic, Social & Cultural Rights': '#fb923c',
  'Order & Limitations': '#f87171',
};
---

<Base title="UDHR Articles — HN HRCB">
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">UDHR Articles</span>
        <span style="color: #828282; margin-left: 8px; font-size: var(--font-base);">
          31 provisions · {articleStats.filter(a => a.signal_count > 0).length} with scores
        </span>
      </td>
    </tr>
  </table>

  {[...groupedSections.entries()].map(([group, sections]) => {
    const color = groupColors[group] || '#888';
    return (
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
              <span style={`color: ${color}; font-size: var(--font-sm); font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;`}>{group}</span>
              <span style="color: #444; font-size: var(--font-xs);">{sections.length} articles</span>
            </div>

            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base);">
              {sections.map(s => {
                const stat = statsMap.get(s.id);
                const hasData = stat && stat.signal_count > 0;
                const covPct = stat && totalEvaluated > 0 ? Math.round((stat.signal_count / totalEvaluated) * 100) : 0;
                const spark = sparklines.get(s.id) || [];
                let sparkPath = '';
                if (spark.length > 1) {
                  const w = 60, h = 14;
                  const step = w / (spark.length - 1);
                  sparkPath = spark.map((v, i) => {
                    const x = i * step;
                    const y = h / 2 - (v * h / 2);
                    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
                  }).join(' ');
                }
                return (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td style="width: 24px; color: #555;" class="score-font">
                      <a href={`/article/${s.number}`} style={`color: ${hasData ? color : '#333'}; font-weight: bold;`}>
                        {s.id === 'Preamble' ? 'P' : s.number}
                      </a>
                    </td>
                    <td>
                      <a href={`/article/${s.number}`} style={`color: ${hasData ? '#c9c9c9' : '#555'};`}>
                        {s.title}
                      </a>
                      <div style="color: #444; font-size: var(--font-xs); margin-top: 1px; max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        {s.text.slice(0, 120)}{s.text.length > 120 ? '...' : ''}
                      </div>
                    </td>
                    <td style="width: 70px; text-align: right;" class="score-font">
                      {hasData ? (
                        <span style={`color: ${scoreToColor(stat.avg_final)};`}>{formatScore(stat.avg_final)}</span>
                      ) : (
                        <span style="color: #333;">—</span>
                      )}
                    </td>
                    <td style="width: 60px; text-align: right; color: #555; font-size: var(--font-xs);" class="score-font">
                      {hasData ? `${stat.signal_count} (${covPct}%)` : ''}
                    </td>
                    <td style="width: 65px; text-align: center;">
                      {spark.length > 1 ? (
                        <svg width="60" height="14" viewBox="0 0 60 14">
                          <line x1="0" y1="7" x2="60" y2="7" stroke="#1a1a25" stroke-width="0.5" />
                          <path d={sparkPath} fill="none" stroke={color} stroke-width="1" />
                        </svg>
                      ) : (
                        <span style="color: #333;">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </table>
          </td>
        </tr>
      </table>
    );
  })}
</Base>
