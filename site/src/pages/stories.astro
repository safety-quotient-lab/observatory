---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import MiniBar from '../components/MiniBar.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getFilteredStoriesWithScores, getEvaluatedCount, getDistinctModels, getTdSignalAggregates, getComplexityAggregates, getTemporalFramingAggregates, getSignalOverview } from '../lib/db';
import type { SortOption, FilterOption, TypeOption, ContentTypeOption, ModelOption } from '../lib/db';
import { modelDisplayName, getModelDef } from '../lib/shared-eval';
import { scoreToColor, formatScore, classificationColor, classificationTextColor, computeSetl, formatSetl, normalizePsq, formatPsqScore } from '../lib/colors';
import { readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'top') as SortOption;
const filter = (url.searchParams.get('filter') || 'all') as FilterOption;
const type = (url.searchParams.get('type') || 'all') as TypeOption;
const ctype = (url.searchParams.get('ctype') || 'all') as ContentTypeOption;
const model = (url.searchParams.get('model') || 'any') as ModelOption;
const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));

// Supplemental signal filters (drill-through from /signals chart rows)
const ptRaw = url.searchParams.get('pt') || '';
const jargonRaw = url.searchParams.get('jargon') || '';
const temporalRaw = url.searchParams.get('temporal') || '';
const validJargon = ['low', 'medium', 'high'];
const validTemporal = ['retrospective', 'present', 'prospective', 'mixed'];
const safePt = /^[\w\s\-]{1,60}$/.test(ptRaw) ? ptRaw : '';
const safeJargon = validJargon.includes(jargonRaw) ? jargonRaw : '';
const safeTemporal = validTemporal.includes(temporalRaw) ? temporalRaw : '';
const hasSupplFilter = !!(safePt || safeJargon || safeTemporal);

const validSorts: SortOption[] = ['top', 'time', 'score_desc', 'score_asc', 'hn_points', 'conf_desc', 'conf_asc', 'velocity', 'psq_desc', 'psq_asc', 'editorial_desc', 'editorial_asc', 'structural_desc', 'structural_asc'];
const validFilters: FilterOption[] = ['all', 'evaluated', 'positive', 'negative', 'neutral', 'pending', 'failed'];
const validTypes: TypeOption[] = ['all', 'ask', 'show', 'job'];
const validCtypes: ContentTypeOption[] = ['all', 'ED', 'PO', 'LP', 'PR', 'AC', 'MI'];
const safeSort = validSorts.includes(sort) ? sort : 'top';
const safeFilter = validFilters.includes(filter) ? filter : 'all';
const safeType = validTypes.includes(type) ? type : 'all';
const safeCtype = validCtypes.includes(ctype) ? ctype : 'all';

// Fetch distinct models for the selector — only show enabled models with evaluations
const allDistinctModels = await getDistinctModels(db);
const distinctModels = allDistinctModels.filter(m => {
  const def = getModelDef(m);
  return def ? def.enabled : false;
});
const safeModel = model === 'all' || model === 'any' || allDistinctModels.includes(model) ? model : 'any';

const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

// Single JOIN query: stories + scores in one round-trip
const stories = await getFilteredStoriesWithScores(db, safeSort, safeFilter, safeType, PER_PAGE + 1, offset, undefined, safeModel, safeCtype, safePt || undefined, safeJargon || undefined, safeTemporal || undefined);
const hasMore = stories.length > PER_PAGE;
const displayStories = hasMore ? stories.slice(0, PER_PAGE) : stories;

const evaluatedCount = await getEvaluatedCount(db);

// Interstitial insight data (lightweight queries, graceful fallback)
let tdData: Awaited<ReturnType<typeof getTdSignalAggregates>> | null = null;
let complexityData: Awaited<ReturnType<typeof getComplexityAggregates>> | null = null;
let temporalData: Awaited<ReturnType<typeof getTemporalFramingAggregates>> | null = null;
let signalData: Awaited<ReturnType<typeof getSignalOverview>> | null = null;
try {
  [tdData, complexityData, temporalData, signalData] = await Promise.all([
    getTdSignalAggregates(db),
    getComplexityAggregates(db),
    getTemporalFramingAggregates(db),
    getSignalOverview(db),
  ]);
} catch { /* interstitials degrade to no-show */ }

// Build interstitial pool — each: { text, context, articleNum, articleLabel }
const insightPool: { text: string; context: string; articleNum: number; articleLabel: string }[] = [];
if (tdData) {
  if (tdData.funding_disclosed_pct != null) insightPool.push({ text: `Only ${Math.round(tdData.funding_disclosed_pct)}% of stories disclose their funding source.`, context: 'Transparency enables informed reading.', articleNum: 19, articleLabel: 'Art. 19' });
  if (tdData.author_identified_pct != null) insightPool.push({ text: `${Math.round(tdData.author_identified_pct)}% of stories identify their author.`, context: 'Accountability starts with attribution.', articleNum: 19, articleLabel: 'Art. 19' });
}
if (complexityData) {
  const expertShare = complexityData.total_measured > 0 ? Math.round(((complexityData.knowledge_domain_specific + complexityData.knowledge_expert) / complexityData.total_measured) * 100) : null;
  if (expertShare !== null) insightPool.push({ text: `${expertShare}% of stories assume domain-specific or expert knowledge.`, context: 'Jargon creates invisible barriers to understanding.', articleNum: 26, articleLabel: 'Art. 26' });
  if (complexityData.accessible_pct != null) insightPool.push({ text: `${Math.round(complexityData.accessible_pct)}% of stories are fully accessible — plain language, self-contained.`, context: 'Education is a human right.', articleNum: 26, articleLabel: 'Art. 26' });
}
if (temporalData) {
  if (temporalData.present_pct != null && temporalData.prospective_pct != null) insightPool.push({ text: `${Math.round(temporalData.present_pct)}% of tech coverage is present-focused — only ${Math.round(temporalData.prospective_pct)}% looks forward.`, context: 'How we frame time shapes how we address rights.', articleNum: 0, articleLabel: 'Preamble' });
}
if (signalData?.technique_distribution) {
  const totalFlagged = Object.values(signalData.technique_distribution).reduce((a, b) => a + b, 0);
  if (totalFlagged > 0) insightPool.push({ text: `${totalFlagged} propaganda technique flags detected across evaluated stories.`, context: '18 persuasion techniques tracked.', articleNum: 19, articleLabel: 'Art. 19' });
}
insightPool.push({ text: `${evaluatedCount.toLocaleString()} stories evaluated against 31 UDHR provisions.`, context: 'Every evaluation separates observable facts from inferences.', articleNum: -1, articleLabel: '' });

// Deterministic selection: pick 2 insights per page based on page number
const insightA = insightPool.length > 0 ? insightPool[(page * 3) % insightPool.length] : null;
const insightB = insightPool.length > 1 ? insightPool[(page * 3 + 1) % insightPool.length] : null;
// Ensure they're different
const selectedInsights = insightA ? (insightB && insightB !== insightA ? [insightA, insightB] : [insightA]) : [];

function buildUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const s = params.sort ?? safeSort;
  const f = params.filter ?? safeFilter;
  const t = params.type ?? safeType;
  const ct = params.ctype ?? safeCtype;
  const m = params.model ?? safeModel;
  const pg = params.p ?? '1';
  if (s !== 'top') p.set('sort', s);
  if (f !== 'all') p.set('filter', f);
  if (t !== 'all') p.set('type', t);
  if (ct !== 'all') p.set('ctype', ct);
  if (m !== 'any') p.set('model', m);
  if (pg !== '1') p.set('p', pg);
  // Preserve supplemental signal filters across pagination/sort changes
  if (safePt) p.set('pt', safePt);
  if (safeJargon) p.set('jargon', safeJargon);
  if (safeTemporal) p.set('temporal', safeTemporal);
  const qs = p.toString();
  return qs ? `/stories?${qs}` : '/stories';
}

// Build URL preserving all current params except suppl signal filters
function buildClearSupplUrl(): string {
  const p = new URLSearchParams();
  if (safeSort !== 'top') p.set('sort', safeSort);
  if (safeFilter !== 'all') p.set('filter', safeFilter);
  if (safeType !== 'all') p.set('type', safeType);
  if (safeCtype !== 'all') p.set('ctype', safeCtype);
  if (safeModel !== 'any') p.set('model', safeModel);
  const qs = p.toString();
  return qs ? `/stories?${qs}` : '/stories';
}

const pageTitle = safeType === 'ask' ? 'Ask HN' : safeType === 'show' ? 'Show HN' : safeType === 'job' ? 'Jobs' : 'Stories';

// JSON-LD: ItemList of evaluated stories (first page, default view only)
const jsonLd = (safeSort === 'top' && safeFilter === 'all' && safeType === 'all' && safeModel === 'any' && page === 1) ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Human Rights Observatory — Latest Evaluated Stories',
  description: `Hacker News stories evaluated for human rights compatibility bias. ${evaluatedCount} stories evaluated.`,
  url: `${url.origin}/stories`,
  numberOfItems: evaluatedCount,
  itemListElement: displayStories
    .filter(s => s.eval_status === 'done')
    .slice(0, 10)
    .map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${url.origin}/item/${s.hn_id}`,
      name: s.title,
    })),
} : null;

// Canonical URL: include sort/filter/type/model but exclude pagination
const canonicalParams = new URLSearchParams();
if (safeSort !== 'top') canonicalParams.set('sort', safeSort);
if (safeFilter !== 'all') canonicalParams.set('filter', safeFilter);
if (safeType !== 'all') canonicalParams.set('type', safeType);
if (safeCtype !== 'all') canonicalParams.set('ctype', safeCtype);
if (safeModel !== 'any') canonicalParams.set('model', safeModel);
const canonicalQs = canonicalParams.toString();
const canonicalUrl = `${url.origin}${canonicalQs ? `/stories?${canonicalQs}` : '/stories'}`;

const SORT_OPTIONS = [
  { value: 'top', label: 'top' },
  { value: 'time', label: 'new' },
  { value: 'score_desc', label: 'top hrcb' },
  { value: 'score_asc', label: 'bottom hrcb' },
  { value: 'psq_desc', label: 'top psq' },
  { value: 'editorial_desc', label: 'top E' },
  { value: 'structural_desc', label: 'top S' },
  { value: 'hn_points', label: 'points' },
  { value: 'conf_desc', label: 'top conf' },
  { value: 'conf_asc', label: 'bottom conf' },
  { value: 'velocity', label: 'velocity' },
] as const;

// Column header sort helpers (following users.astro pattern)
function sortUrl(key: string): string {
  return buildUrl({ sort: key, p: '1' });
}
function thStyle(col: string): string {
  return safeSort === col
    ? 'color: var(--color-orange); font-weight: bold; text-decoration: none;'
    : 'color: var(--fg-secondary); text-decoration: none;';
}

function timeAgo(unixTime: number): string {
  const seconds = Math.floor(Date.now() / 1000 - unixTime);
  if (seconds < 60) return `${seconds}s`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h`;
  const days = Math.floor(hours / 24);
  return `${days}d`;
}

const FILTER_OPTIONS = [
  { value: 'all', label: 'all' },
  { value: 'evaluated', label: 'evaluated' },
  { value: 'positive', label: 'positive' },
  { value: 'negative', label: 'negative' },
  { value: 'neutral', label: 'neutral' },
  { value: 'pending', label: 'pending' },
  { value: 'failed', label: 'failed' },
] as const;

const CTYPE_OPTIONS: { value: ContentTypeOption; label: string }[] = [
  { value: 'all', label: 'all' },
  { value: 'ED', label: 'editorial' },
  { value: 'PO', label: 'opinion' },
  { value: 'LP', label: 'legal' },
  { value: 'PR', label: 'press' },
  { value: 'AC', label: 'academic' },
  { value: 'MI', label: 'misc' },
];

// Short display label for model IDs
function modelLabel(id: string): string {
  return modelDisplayName(id);
}
function isLiteModel(id: string): boolean {
  return getModelDef(id)?.prompt_mode === 'lite';
}
---

<Base title={pageTitle} canonicalUrl={canonicalUrl}>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'stories' }]} />
  {/* Filter/sort bar — primary (always visible) + advanced (collapsed) */}
  <div class="filter-bar subtext">
    <div class="filter-row">
      <span class="filter-label">sort:</span>
      {([
        { value: 'top', label: 'top' },
        { value: 'time', label: 'new' },
        { value: 'score_desc', label: 'score' },
        { value: 'hn_points', label: 'points' },
      ] as const).map((opt, i) => (
        <>
          {i > 0 && <span class="filter-sep"> | </span>}
          {safeSort === opt.value
            ? <span class="filter-active" aria-current="true">{opt.label}</span>
            : <a href={buildUrl({ sort: opt.value, p: '1' })} class="filter-link">{opt.label}</a>
          }
        </>
      ))}
    </div>
    <div class="filter-row">
      <span class="filter-label">show:</span>
      {([
        { value: 'all', label: 'all' },
        { value: 'evaluated', label: 'evaluated' },
        { value: 'positive', label: 'positive' },
        { value: 'negative', label: 'negative' },
        { value: 'neutral', label: 'neutral' },
      ] as const).map((opt, i) => (
        <>
          {i > 0 && <span class="filter-sep"> | </span>}
          {safeFilter === opt.value
            ? <span class="filter-active" aria-current="true">{opt.label}</span>
            : <a href={buildUrl({ filter: opt.value, p: '1' })} class="filter-link">{opt.label}</a>
          }
        </>
      ))}
      <span class="filter-sep"> | </span>
      <a href="#" id="toggle-advanced-filters" class="filter-link" style="color: var(--fg-secondary);">more ▾</a>
    </div>
    {/* Advanced filters — collapsed by default, auto-open if non-default params active */}
    <div id="advanced-filters" style={`display: ${safeType !== 'all' || safeCtype !== 'all' || safeModel !== 'any' || safeFilter === 'pending' || safeFilter === 'failed' || !['top', 'time', 'score_desc', 'hn_points', 'psq_desc', 'editorial_desc', 'structural_desc'].includes(safeSort) ? 'block' : 'none'};`}>
      <div class="filter-row">
        <span class="filter-label">sort:</span>
        {SORT_OPTIONS.map((opt, i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {safeSort === opt.value
              ? <span class="filter-active" aria-current="true">{opt.label}</span>
              : <a href={buildUrl({ sort: opt.value, p: '1' })} class="filter-link">{opt.label}</a>
            }
          </>
        ))}
      </div>
      <div class="filter-row">
        <span class="filter-label">show:</span>
        {FILTER_OPTIONS.map((opt, i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {safeFilter === opt.value
              ? <span class="filter-active" aria-current="true">{opt.label}</span>
              : <a href={buildUrl({ filter: opt.value, p: '1' })} class="filter-link">{opt.label}</a>
            }
          </>
        ))}
      </div>
      <div class="filter-row">
        <span class="filter-label">type:</span>
        {(['all', 'ask', 'show', 'job'] as const).map((t, i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {safeType === t
              ? <span class="filter-active" aria-current="true">{t}</span>
              : <a href={buildUrl({ type: t, p: '1' })} class="filter-link">{t}</a>
            }
          </>
        ))}
        <span class="filter-sep"> · </span>
        <span class="filter-label">content:</span>
        {CTYPE_OPTIONS.map((opt, i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {safeCtype === opt.value
              ? <span class="filter-active" aria-current="true">{opt.label}</span>
              : <a href={buildUrl({ ctype: opt.value, p: '1' })} class="filter-link">{opt.label}</a>
            }
          </>
        ))}
      </div>
      {distinctModels.length > 1 && (
        <div class="filter-row">
          <span class="filter-label">model:</span>
          {safeModel === 'any'
            ? <span class="filter-active" aria-current="true"> any</span>
            : <a href={buildUrl({ model: 'any', p: '1' })} class="filter-link"> any</a>
          }
          <span class="filter-sep"> | </span>
          {safeModel === 'all'
            ? <span class="filter-active" aria-current="true">all</span>
            : <a href={buildUrl({ model: 'all', p: '1' })} class="filter-link">all</a>
          }
          {distinctModels.map((m) => (
            <>
              <span class="filter-sep"> | </span>
              {safeModel === m
                ? <span class="filter-active" aria-current="true">{modelLabel(m)}{isLiteModel(m) && <a href="/about#eval-modes" class="lite-icon" style="margin-left: 3px; text-decoration: none; color: var(--color-orange);" title="Lite eval — click for details">L</a>}</span>
                : <a href={buildUrl({ model: m, p: '1' })} class="filter-link">{modelLabel(m)}{isLiteModel(m) && <span class="lite-icon" style="margin-left: 3px;" title="Lite eval — click for details" onclick="event.preventDefault();event.stopPropagation();window.location.href='/about#eval-modes'" role="link">L</span>}</a>
              }
            </>
          ))}
        </div>
      )}
    </div>
    <div class="filter-row">
      <span class="filter-stats">{displayStories.length}{hasMore ? '+' : ''} stories</span>
      {evaluatedCount > 0 && <span class="filter-stats"> ({evaluatedCount} evaluated)</span>}
      <span class="filter-stats"> · page {page}{hasMore ? '' : ' (last)'}</span>
      <span class="filter-stats"> · </span>
      <a href="/past" class="filter-link">past</a>
      <span class="filter-stats"> · </span>
      <a href="/velocity" class="filter-link">velocity</a>
      <span class="filter-stats"> · </span>
      <a href="/dynamics" class="filter-link">dynamics</a>
    </div>
    {hasSupplFilter && (
      <div class="filter-row" style="margin-top: 2px;">
        <span class="filter-label">signal filter:</span>
        {safePt && <span class="filter-active" style="margin-right: 4px;">technique: {safePt}</span>}
        {safeJargon && <span class="filter-active" style="margin-right: 4px;">jargon: {safeJargon}</span>}
        {safeTemporal && <span class="filter-active" style="margin-right: 4px;">temporal: {safeTemporal}</span>}
        <a href={buildClearSupplUrl()} class="filter-link" style="color: var(--fg-secondary);">× clear</a>
      </div>
    )}
  </div>

  <div class="table-wrap">
  <table cellpadding="0" cellspacing="0" class="itemlist stories-table" width="100%">
    <thead>
    <tr style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
      <th style="width: 28px; text-align: right; padding-right: 5px; font-weight: normal;">#</th>
      <th style="text-align: left; font-weight: normal;">Title</th>
      <th width="55" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('score_desc')} style={thStyle('score_desc')} title="Human Rights Compatibility Bias score">HRCB</a>
      </th>
      <th width="55" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('psq_desc')} style={thStyle('psq_desc')} title="Psychological Safety Quotient">PSQ</a>
      </th>
      <th width="55" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('editorial_desc')} style={thStyle('editorial_desc')} title="Editorial: what the content says">E</a>
      </th>
      <th width="55" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('structural_desc')} style={thStyle('structural_desc')} title="Structural: what the site does">S</a>
      </th>
      <th width="45" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('hn_points')} style={thStyle('hn_points')} title="HN score">Pts</a>
      </th>
      <th width="55" style="text-align: center; font-weight: normal;">
        <a href={sortUrl('time')} style={thStyle('time')} title="Time posted">Age</a>
      </th>
    </tr>
    </thead>
    <tbody>
    {displayStories.map((story, i) => {
      const hasEval = story.hcb_weighted_mean != null || story.hcb_editorial_mean != null;
      const isLiteOnly = hasEval && (story.hcb_weighted_mean == null || story.hcb_structural_mean == null);
      const displayScore = story.hcb_weighted_mean ?? story.hcb_editorial_mean;
      const isZero = hasEval && displayScore === 0;
      const classLabel = story.hcb_classification?.split(' — ')[0] || story.hcb_classification;
      const miniScores = 'miniScores' in story ? story.miniScores : [];
      const hnTextPreview = 'hn_text_preview' in story ? (story as any).hn_text_preview : null;
      const setlValues = miniScores
        .map(s => computeSetl(s.structural, s.editorial))
        .filter((v): v is number => v !== null);
      const aggSetl = setlValues.length > 0
        ? setlValues.reduce((a, b) => a + b, 0) / setlValues.length
        : null;
      const rightsWashing = !isLiteOnly && aggSetl != null && aggSetl >= 0.25 && story.hcb_editorial_mean != null && story.hcb_structural_mean != null && story.hcb_editorial_mean > 0.1 && story.hcb_structural_mean < -0.1;
      const hasPsq = story.psq_score != null;
      const psqNorm = normalizePsq(story.psq_score);
      return (
        <>
        <tr style="border-top: 1px solid var(--bg-surface);">
          <td align="right" class="score-font" style="color: var(--fg-secondary); padding-right: 5px; vertical-align: top; padding-top: 4px;">{offset + i + 1}.</td>
          <td style="vertical-align: top; padding: 4px 5px 2px 0;">
            <span class="titleline">
              <a href={story.url || `https://news.ycombinator.com/item?id=${story.hn_id}`}
                 target={story.url ? '_blank' : undefined}
                 rel={story.url ? 'noopener' : undefined}
              >{story.title}</a>
            </span>
            {story.domain && (
              <span class="sitebit" style="font-size: var(--font-sm); margin-left: 5px;">
                (<a href={`/domain/${story.domain}`}>{story.domain}</a>)
              </span>
            )}
            {!story.url && hnTextPreview && (
              <div style="color: var(--fg-secondary); font-size: var(--font-sm); font-style: italic; margin-top: 1px;">
                {hnTextPreview.length >= 100 ? hnTextPreview + '...' : hnTextPreview}
              </div>
            )}
            <div class="subtext">
              {story.hn_by && <span>by <a href={`/user/${story.hn_by}`}>{story.hn_by}</a></span>}
              {story.hn_comments != null && (
                <>
                  <span> | </span>
                  <a href={`https://news.ycombinator.com/item?id=${story.hn_id}`} target="_blank" rel="noopener">
                    {story.hn_comments} comments
                  </a>
                </>
              )}
              {hasEval ? (
                <>
                  <span> | </span>
                  <a href={`/item/${story.hn_id}`} style="color: var(--color-orange);">hrcb</a>
                  {isLiteOnly && (
                    <a href="/about#eval-modes" class="badge" style="background: rgba(213,101,0,0.15); color: var(--color-orange); font-size: var(--font-xs); margin-left: 3px; text-decoration: none;" title="Lite eval — editorial only, no structural analysis">L</a>
                  )}
                  {story.schema_version && (
                    <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 4px;"
                          title={`Schema version ${story.schema_version}`}>
                      v{story.schema_version}
                    </span>
                  )}
                  {story.hcb_theme_tag && (
                    <span class="badge" style="background: rgba(43,144,216,0.15); color: var(--color-violet); font-size: var(--font-xs); margin-left: 4px;"
                          title={`Theme: ${story.hcb_theme_tag}`}>
                      {story.hcb_theme_tag}
                    </span>
                  )}
                  {story.hcb_classification && !isLiteOnly && (
                    <span class="badge" style={`background: ${classificationColor(story.hcb_classification)}; color: ${classificationTextColor(story.hcb_classification)}; font-size: var(--font-xs); margin-left: 4px;`}
                          title={story.hcb_classification}>
                      {classLabel}
                    </span>
                  )}
                  {(story.consensus_model_count ?? 0) >= 2 && story.consensus_score != null && (
                    <span
                      class="badge"
                      style={`background: ${(story.consensus_spread ?? 0) > 0.3 ? 'rgba(217,119,6,0.15)' : 'rgba(43,144,216,0.10)'}; color: ${(story.consensus_spread ?? 0) > 0.3 ? 'var(--color-warning)' : 'var(--fg-emphasis)'}; font-size: var(--font-xs); margin-left: 3px;`}
                      title={`Consensus across ${story.consensus_model_count} models: ${story.consensus_score > 0 ? '+' : ''}${story.consensus_score.toFixed(3)}${story.consensus_spread != null ? ` (spread ±${(story.consensus_spread / 2).toFixed(3)})` : ''}`}
                    >&times;{story.consensus_model_count}{story.consensus_spread != null ? ` ±${(story.consensus_spread / 2).toFixed(2)}` : ''}</span>
                  )}
                  {rightsWashing && (
                    <span
                      class="badge"
                      style="background: rgba(217,119,6,0.15); color: var(--color-warning); font-size: var(--font-xs); margin-left: 3px;"
                      title={`Rights-washing: editorial says positive (E:${formatScore(story.hcb_editorial_mean)}) but structural behavior is negative (S:${formatScore(story.hcb_structural_mean)}). SETL: ${formatSetl(aggSetl)}`}
                    >&#9888; says≠does</span>
                  )}
                </>
              ) : story.eval_status === 'evaluating' ? (
                <span> | <span style="color: var(--channel-editorial); font-size: var(--font-sm);">evaluating</span></span>
              ) : story.eval_status === 'pending' || story.eval_status === 'queued' ? (
                <span> | <span style="color: var(--color-warning); font-size: var(--font-sm);">queued</span></span>
              ) : story.eval_status === 'failed' ? (
                <span> | <a href={`/item/${story.hn_id}`} style="color: var(--color-negative); font-size: var(--font-sm);">failed</a></span>
              ) : story.eval_status === 'skipped' ? (
                <span> | <span style="color: var(--fg-secondary); font-size: var(--font-sm);">skipped</span></span>
              ) : null}
            </div>
            {hasEval && miniScores.length > 0 && (
              <div style="margin-top: 2px;">
                <a href={`/item/${story.hn_id}`} style="text-decoration: none;">
                  <MiniBar scores={miniScores} />
                </a>
              </div>
            )}
          </td>
          <td align="center" class="score-font" style={`vertical-align: top; padding-top: 4px; color: ${isZero ? 'var(--color-nd)' : hasEval ? scoreToColor(displayScore) : 'var(--fg-secondary)'};`}>
            {isZero ? 'ND' : hasEval ? <a href={`/item/${story.hn_id}`} style={`color: inherit; text-decoration: none;`}>{formatScore(displayScore)}</a> : '—'}
          </td>
          <td align="center" class="score-font" style={`vertical-align: top; padding-top: 4px; color: ${hasPsq ? scoreToColor(psqNorm) : 'var(--fg-secondary)'};`}>
            {hasPsq ? formatPsqScore(story.psq_score) : '—'}
          </td>
          <td align="center" class="score-font" style={`vertical-align: top; padding-top: 4px; color: ${story.hcb_editorial_mean != null ? scoreToColor(story.hcb_editorial_mean) : 'var(--fg-secondary)'};`}>
            {story.hcb_editorial_mean != null ? formatScore(story.hcb_editorial_mean) : '—'}
          </td>
          <td align="center" class="score-font" style={`vertical-align: top; padding-top: 4px; color: ${story.hcb_structural_mean != null ? scoreToColor(story.hcb_structural_mean) : 'var(--fg-secondary)'};`}>
            {story.hcb_structural_mean != null ? formatScore(story.hcb_structural_mean) : '—'}
          </td>
          <td align="center" class="score-font" style="vertical-align: top; padding-top: 4px; color: var(--fg-secondary);">
            {story.hn_score ?? '—'}
          </td>
          <td align="center" class="score-font" style="vertical-align: top; padding-top: 4px; color: var(--fg-secondary); white-space: nowrap;">
            {timeAgo(story.hn_time)}
          </td>
        </tr>
        {/* Pedagogical interstitial after stories 10 and 20 */}
        {i === 9 && selectedInsights[0] && (
          <tr>
            <td colspan="8" style="padding: 8px 0;">
              <div style="border-top: 1px dashed var(--color-border); border-bottom: 1px dashed var(--color-border); padding: 8px 10px; color: var(--fg-secondary); font-size: var(--font-xs); line-height: 1.6;">
                <span style="color: var(--color-orange);">&#9670;</span>
                {' '}{selectedInsights[0].text}
                <br />
                <span style="margin-left: 16px;">{selectedInsights[0].context}</span>
                {selectedInsights[0].articleNum >= 0 && (
                  <a href={`/article/${selectedInsights[0].articleNum}`} style="color: var(--channel-hrcb); margin-left: 6px;">&rarr; {selectedInsights[0].articleLabel}</a>
                )}
                {selectedInsights[0].articleNum < 0 && (
                  <a href="/about" style="color: var(--channel-hrcb); margin-left: 6px;">&rarr; About</a>
                )}
              </div>
            </td>
          </tr>
        )}
        {i === 19 && selectedInsights[1] && (
          <tr>
            <td colspan="8" style="padding: 8px 0;">
              <div style="border-top: 1px dashed var(--color-border); border-bottom: 1px dashed var(--color-border); padding: 8px 10px; color: var(--fg-secondary); font-size: var(--font-xs); line-height: 1.6;">
                <span style="color: var(--color-orange);">&#9670;</span>
                {' '}{selectedInsights[1].text}
                <br />
                <span style="margin-left: 16px;">{selectedInsights[1].context}</span>
                {selectedInsights[1].articleNum >= 0 && (
                  <a href={`/article/${selectedInsights[1].articleNum}`} style="color: var(--channel-hrcb); margin-left: 6px;">&rarr; {selectedInsights[1].articleLabel}</a>
                )}
                {selectedInsights[1].articleNum < 0 && (
                  <a href="/about" style="color: var(--channel-hrcb); margin-left: 6px;">&rarr; About</a>
                )}
              </div>
            </td>
          </tr>
        )}
        </>
      );
    })}
    </tbody>
  </table>
  </div>

  {displayStories.length === 0 && (
    <div style="padding: 40px 20px; text-align: center;">
      <div style="color: var(--fg-secondary); margin-bottom: 12px;">
        {safeFilter !== 'all' || safeType !== 'all'
          ? `No stories match the current filters.`
          : 'No stories yet.'}
      </div>
      {safeFilter !== 'all' || safeType !== 'all' ? (
        <a href="/stories" style="color: var(--color-orange);">clear filters</a>
      ) : (
        <span style="color: var(--fg-secondary); font-size: var(--font-sm);">No stories yet. The cron worker will populate them shortly.</span>
      )}
    </div>
  )}

  {/* Pagination */}
  {(page > 1 || hasMore) && (
    <div style="padding: 10px 0 20px 40px; font-size: var(--font-base);">
      {page > 1 && (
        <a href={buildUrl({ p: String(page - 1) })} style="color: var(--fg-secondary); margin-right: 16px;">
          ← Prev
        </a>
      )}
      {hasMore && (
        <a href={buildUrl({ p: String(page + 1) })} style="color: var(--fg-secondary);">
          Next → <span style="color: var(--color-border); font-size: var(--font-sm);">(page {page + 1})</span>
        </a>
      )}
    </div>
  )}

  <script is:inline>
    (function() {
      var toggle = document.getElementById('toggle-advanced-filters');
      var panel = document.getElementById('advanced-filters');
      if (!toggle || !panel) return;
      var stored = localStorage.getItem('hrcb_advanced_filters');
      if (stored === 'open' && panel.style.display === 'none') {
        panel.style.display = 'block';
        toggle.textContent = 'less ▴';
      }
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        var open = panel.style.display !== 'none';
        panel.style.display = open ? 'none' : 'block';
        toggle.textContent = open ? 'more ▾' : 'less ▴';
        localStorage.setItem('hrcb_advanced_filters', open ? 'closed' : 'open');
      });
    })();
  </script>
</Base>
