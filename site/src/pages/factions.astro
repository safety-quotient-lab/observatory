---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getDomainSignalProfiles, getDomainKarmaMap } from '../lib/db';
import type { DomainSignalProfile } from '../lib/db';
import { cachedQuery, readDb } from '../lib/db-utils';
import SignalSpace from '../components/SignalSpace.astro';
import FactionSignalLandscape from '../components/FactionSignalLandscape.astro';
import FactionParallelCoords from '../components/FactionParallelCoords.astro';
import FactionDifferentiation from '../components/FactionDifferentiation.astro';
import FactionClusterCard from '../components/FactionClusterCard.astro';
import FactionAffinityMatrix from '../components/FactionAffinityMatrix.astro';
import FactionInterestingPairs from '../components/FactionInterestingPairs.astro';
import FactionOutliers from '../components/FactionOutliers.astro';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

// --- 1. Parallel fetch ---
// Signal profiles already contain avg_hrcb — no need for separate getAllDomainStats query
const [signalProfilesArr, karmaMapArr] = await Promise.all([
  cachedQuery<DomainSignalProfile[]>(kv, 'domainSignalProfiles', async () => {
    const m = await getDomainSignalProfiles(db);
    return [...m.values()];
  }),
  cachedQuery<{domain: string; avg_karma: number; user_count: number}[]>(kv, 'domainKarmaMap', async () => {
    const m = await getDomainKarmaMap(db);
    return [...m.values()];
  }, 600),
]);
const karmaMap = new Map(karmaMapArr.map(k => [k.domain, k]));

// Derive domainScoreMap from signal profiles (avg_hrcb) — eliminates redundant GROUP BY scan
const domainScoreMap = new Map(signalProfilesArr.map(p => [p.domain, p.avg_hrcb ?? null]));

// --- Signal dimension definitions (used by both computation and template) ---
type SignalDimDef = { code: string; fullLabel: string; label: string; color: string };
const SIGNAL_DIMS: (SignalDimDef & { extract: (p: DomainSignalProfile) => number | null })[] = [
  { code: 'EQ', fullLabel: 'Epistemic Quality', label: 'epistemic quality', color: 'var(--channel-editorial)', extract: p => p.avg_eq },
  { code: 'SO', fullLabel: 'Solution Orientation', label: 'solution orientation', color: 'var(--color-positive-light)', extract: p => p.avg_so },
  { code: 'SR', fullLabel: 'Stakeholder Rep', label: 'stakeholder rep', color: 'var(--channel-structural)', extract: p => p.avg_sr },
  { code: 'TD', fullLabel: 'Transparency', label: 'transparency', color: 'var(--color-positive-medium)', extract: p => p.avg_td },
  { code: 'PT', fullLabel: 'Propaganda (inv)', label: 'propaganda (inv)', color: 'var(--color-negative-light)', extract: p => p.avg_pt_score !== null ? 1 - Math.min(p.avg_pt_score / 12, 1) : null },
  { code: 'AR', fullLabel: 'Arousal', label: 'arousal', color: 'var(--color-amber-light)', extract: p => p.avg_arousal },
  { code: 'VA', fullLabel: 'Valence', label: 'valence', color: 'var(--color-warning-light)', extract: p => p.avg_valence },
  { code: 'FW', fullLabel: 'Fair Witness', label: 'fair witness', color: 'var(--color-sentiment)', extract: p => p.avg_fw_ratio },
];

// --- FactionsData: all computed results for template rendering ---
interface EnrichedCluster {
  id: number;
  members: string[];
  centroid: number[];
  rawCentroid: number[];
  avgScore: number | null;
  name: string;
  archetype: string;
  description: string;
  icon: string;
  color: string;
  insight: string;
  dominantTone: string | null;
  dominantScope: string | null;
  dominantReadingLevel: string | null;
  dominantSentiment: string | null;
  avgSetl: number | null;
  avgHnScore: number;
  avgHnComments: number;
  avgKarma: number | null;
  storyCount: number;
  hrcbPositive: number;
  hrcbNeutral: number;
  hrcbNegative: number;
  liminalMembers: { domain: string; secondCluster: string; similarity: number }[];
}

interface SignalHistogram {
  code: string;
  fullLabel: string;
  color: string;
  bins: { x0: number; x1: number; count: number }[];
  min: number;
  max: number;
  maxCount: number;
  clusterMarkers: { name: string; value: number; color: string }[];
}

interface PcLine {
  domain: string;
  color: string;
  opacity: number;
  points: string;
  clusterName: string | null;
}

interface OutlierEntry {
  domain: string;
  score: number | null;
  outlierScore: number;
  nearestCluster: string;
  nearestSim: number;
  keySignal: string;
  tone: string | null;
}

interface FactionsData {
  enrichedClusters: EnrichedCluster[];
  loneWolfDomains: string[];
  histograms: SignalHistogram[];
  coreHistograms: SignalHistogram[];
  crossClusterPairs: { a: string; b: string; similarity: number; clusterA: string; clusterB: string }[];
  sameClusterDivergent: { a: string; b: string; similarity: number; cluster: string }[];
  outlierEntries: OutlierEntry[];
  pcLines: PcLine[];
  pcCentroidLines: { name: string; color: string; points: string }[];
  interClusterVar: { code: string; label: string; color: string; variance: number }[];
  affinityMatrix: number[][];
  signalSpacePoints: { domain: string; zVector: number[]; hcbScore: number | null; storyCount: number; clusterName: string | null; clusterColor: string }[];
  totalDomains: number;
  totalClusters: number;
  unalignedCount: number;
  loneWolfRatio: number;
  mostDiff: { code: string; label: string; color: string; variance: number } | null;
  leastDiff: { code: string; label: string; color: string; variance: number } | null;
  maxVar: number;
  nClusters: number;
  profileCount: number;
  pcDimMins: number[];
  pcDimMaxs: number[];
  populationMedian: number[];
  dimValues: number[][];
  // Domain score lookup for template member rendering
  domainScores: Record<string, number | null>;
}

// Wrap all CPU-heavy computation in cachedQuery (25-35ms CPU without cache)
function computeFactionsData(
  signalProfilesArr: DomainSignalProfile[],
  domainScoreMapIn: Map<string, number | null>,
  karmaMapIn: Map<string, { domain: string; avg_karma: number; user_count: number }>,
): FactionsData {
  const signalProfilesLocal = new Map(signalProfilesArr.map(p => [p.domain, p]));

// --- 3. Build 8D signal vectors per domain + z-normalize ---
const profileEntries = [...signalProfilesLocal.entries()];
const domainNames = profileEntries.map(([d]) => d);
const rawVectors = new Map<string, number[]>();

for (const [domain, profile] of profileEntries) {
  const vec = SIGNAL_DIMS.map(dim => dim.extract(profile) ?? NaN);
  rawVectors.set(domain, vec);
}

// Compute per-dimension mean and stddev for z-normalization
const nDims = SIGNAL_DIMS.length;
const means = new Array(nDims).fill(0);
const stddevs = new Array(nDims).fill(0);
const counts = new Array(nDims).fill(0);

for (const vec of rawVectors.values()) {
  for (let i = 0; i < nDims; i++) {
    if (!isNaN(vec[i])) {
      means[i] += vec[i];
      counts[i]++;
    }
  }
}
for (let i = 0; i < nDims; i++) {
  means[i] = counts[i] > 0 ? means[i] / counts[i] : 0;
}
for (const vec of rawVectors.values()) {
  for (let i = 0; i < nDims; i++) {
    if (!isNaN(vec[i])) {
      stddevs[i] += (vec[i] - means[i]) ** 2;
    }
  }
}
for (let i = 0; i < nDims; i++) {
  stddevs[i] = counts[i] > 1 ? Math.sqrt(stddevs[i] / (counts[i] - 1)) : 1;
  if (stddevs[i] === 0) stddevs[i] = 1;
}

// Z-normalize: missing → 0 (population mean)
const zVectors = new Map<string, number[]>();
const missingDimCounts = new Map<string, number>();
for (const [domain, vec] of rawVectors) {
  let missing = 0;
  const zVec = vec.map((v, i) => {
    if (isNaN(v)) { missing++; return 0; }
    return (v - means[i]) / stddevs[i];
  });
  zVectors.set(domain, zVec);
  missingDimCounts.set(domain, missing);
}

// --- 4. Cosine similarity on z-normalized vectors ---
function cosineSim(va: number[], vb: number[]): number {
  let dot = 0, magA = 0, magB = 0;
  for (let i = 0; i < va.length; i++) {
    dot += va[i] * vb[i];
    magA += va[i] * va[i];
    magB += vb[i] * vb[i];
  }
  if (magA === 0 || magB === 0) return 0;
  return dot / (Math.sqrt(magA) * Math.sqrt(magB));
}

interface SimPair { a: string; b: string; similarity: number }
const allPairs: SimPair[] = [];
for (let i = 0; i < domainNames.length; i++) {
  for (let j = i + 1; j < domainNames.length; j++) {
    const a = domainNames[i], b = domainNames[j];
    const va = zVectors.get(a), vb = zVectors.get(b);
    if (!va || !vb) continue;
    allPairs.push({ a, b, similarity: cosineSim(va, vb) });
  }
}

// --- 5. Agglomerative hierarchical clustering ---
const PHI = (1 + Math.sqrt(5)) / 2;
const factionThreshold = 1 / PHI;           // ~0.618
const allianceThreshold = 1 / (PHI * PHI);  // ~0.382
const acquaintanceThreshold = 1 / (PHI * PHI * PHI); // ~0.236

interface Cluster {
  id: number;
  members: string[];
}

let nextClusterId = 0;
const clusterList: Cluster[] = [];
const domainToCluster = new Map<string, Cluster>();

// Sort pairs descending by similarity
const sortedPairs = [...allPairs].sort((a, b) => b.similarity - a.similarity);

for (const pair of sortedPairs) {
  if (pair.similarity < factionThreshold) break;
  const ca = domainToCluster.get(pair.a);
  const cb = domainToCluster.get(pair.b);

  if (ca && cb && ca !== cb) {
    // Merge: check average linkage between clusters
    let simSum = 0, simCount = 0;
    for (const ma of ca.members) {
      for (const mb of cb.members) {
        const va = zVectors.get(ma), vb = zVectors.get(mb);
        if (va && vb) { simSum += cosineSim(va, vb); simCount++; }
      }
    }
    const avgLinkage = simCount > 0 ? simSum / simCount : 0;
    if (avgLinkage >= factionThreshold) {
      ca.members.push(...cb.members);
      for (const m of cb.members) domainToCluster.set(m, ca);
      clusterList.splice(clusterList.indexOf(cb), 1);
    }
  } else if (ca && !cb) {
    ca.members.push(pair.b);
    domainToCluster.set(pair.b, ca);
  } else if (!ca && cb) {
    cb.members.push(pair.a);
    domainToCluster.set(pair.a, cb);
  } else if (!ca && !cb) {
    const newC: Cluster = { id: nextClusterId++, members: [pair.a, pair.b] };
    clusterList.push(newC);
    domainToCluster.set(pair.a, newC);
    domainToCluster.set(pair.b, newC);
  }
}

// If we got 1 giant cluster and no others, try alliance threshold as fallback
if (clusterList.length === 1 && clusterList[0].members.length > 3) {
  // Reset and try alliance threshold
  clusterList.length = 0;
  domainToCluster.clear();
  nextClusterId = 0;
  for (const pair of sortedPairs) {
    if (pair.similarity < allianceThreshold) break;
    const ca = domainToCluster.get(pair.a);
    const cb = domainToCluster.get(pair.b);
    if (ca && cb && ca !== cb) {
      let simSum = 0, simCount = 0;
      for (const ma of ca.members) {
        for (const mb of cb.members) {
          const va = zVectors.get(ma), vb = zVectors.get(mb);
          if (va && vb) { simSum += cosineSim(va, vb); simCount++; }
        }
      }
      const avgLinkage = simCount > 0 ? simSum / simCount : 0;
      if (avgLinkage >= allianceThreshold) {
        ca.members.push(...cb.members);
        for (const m of cb.members) domainToCluster.set(m, ca);
        clusterList.splice(clusterList.indexOf(cb), 1);
      }
    } else if (ca && !cb) {
      ca.members.push(pair.b);
      domainToCluster.set(pair.b, ca);
    } else if (!ca && cb) {
      cb.members.push(pair.a);
      domainToCluster.set(pair.a, cb);
    } else if (!ca && !cb) {
      const newC: Cluster = { id: nextClusterId++, members: [pair.a, pair.b] };
      clusterList.push(newC);
      domainToCluster.set(pair.a, newC);
      domainToCluster.set(pair.b, newC);
    }
  }
}

// Lone wolves: domains not in any cluster
const loneWolfDomains = domainNames.filter(d => !domainToCluster.has(d));

// Sort clusters by size descending
clusterList.sort((a, b) => b.members.length - a.members.length);

// --- 6. Cluster centroids (mean of z-vectors) ---
function computeCentroid(members: string[]): number[] {
  const centroid = new Array(nDims).fill(0);
  let count = 0;
  for (const m of members) {
    const v = zVectors.get(m);
    if (v) { for (let i = 0; i < nDims; i++) centroid[i] += v[i]; count++; }
  }
  if (count > 0) for (let i = 0; i < nDims; i++) centroid[i] /= count;
  return centroid;
}

// --- 7. Archetype naming ---
const ARCHETYPE_RULES: { name: string; desc: string; icon: string; test: (hi: Set<string>, lo: Set<string>) => boolean }[] = [
  { name: 'Rigorous Analysts', desc: 'High epistemic quality and transparency with minimal propaganda techniques. Evidence-driven coverage that prioritizes verifiable claims.', icon: '\u{1F9EA}', test: (hi, lo) => hi.has('EQ') && hi.has('TD') && lo.has('PT') },
  { name: 'Solution Builders', desc: 'Content oriented toward actionable outcomes, combining strong epistemic standards with a focus on constructive approaches.', icon: '\u{1F6E0}', test: (hi, lo) => hi.has('SO') && hi.has('EQ') },
  { name: 'Watchdog Press', desc: 'Fact-heavy reporting that favors observable evidence over positive framing. Investigative style that surfaces structural issues.', icon: '\u{1F4F0}', test: (hi, lo) => hi.has('EQ') && hi.has('FW') && lo.has('VA') },
  { name: 'Advocacy Amplifiers', desc: 'Stakeholder-centered content with strong positive valence but lower transparency. Platforms that elevate voices and perspectives.', icon: '\u{1F4E2}', test: (hi, lo) => hi.has('SR') && hi.has('VA') && lo.has('TD') },
  { name: 'Calm Observers', desc: 'Measured, low-arousal coverage with strong epistemic grounding. Analytical rather than emotional in editorial character.', icon: '\u{1F30A}', test: (hi, lo) => lo.has('AR') && hi.has('EQ') },
  { name: 'Emotional Narrators', desc: 'High-arousal storytelling with strong affective elements. Content that engages through narrative energy and emotional resonance.', icon: '\u{1F525}', test: (hi, lo) => hi.has('AR') && hi.has('VA') },
  { name: 'Transparent Reporters', desc: 'High disclosure and observable-fact orientation. Content that shows its work and distinguishes clearly between fact and inference.', icon: '\u{1F50D}', test: (hi, lo) => hi.has('TD') && hi.has('FW') },
  { name: 'Stakeholder Champions', desc: 'Diverse representation combined with solution orientation. Content that centers affected communities while seeking constructive paths.', icon: '\u{1F91D}', test: (hi, lo) => hi.has('SR') && hi.has('SO') },
  { name: 'Persuasion Engines', desc: 'Elevated use of propaganda techniques including emotional appeals, framing devices, and rhetorical strategies.', icon: '\u{26A0}', test: (hi) => hi.has('PT') },
  { name: 'Optimistic Voices', desc: 'Positive-valence content paired with solution-seeking orientation. Constructive framing that emphasizes possibilities.', icon: '\u{2600}', test: (hi) => hi.has('VA') && hi.has('SO') },
  { name: 'Evidence Anchors', desc: 'Grounded in observable facts with strong epistemic standards. Content where claims are closely tied to verifiable evidence.', icon: '\u{2693}', test: (hi) => hi.has('FW') && hi.has('EQ') },
  { name: 'Broad Spectrum', desc: 'Wide stakeholder representation across perspectives. Content that draws from diverse sources and viewpoints.', icon: '\u{1F308}', test: (hi) => hi.has('SR') },
  // Low-signal patterns
  { name: 'Minimalist Wire', desc: 'Sparse editorial signals across most dimensions. Stripped-down, wire-service-style content with minimal editorial fingerprint.', icon: '\u{1F4CB}', test: (_hi, lo) => lo.size >= 5 },
  { name: 'Understated Coverage', desc: 'Below-average signal strength in multiple dimensions. Restrained editorial voice with limited use of rhetorical devices.', icon: '\u{1F4C9}', test: (_hi, lo) => lo.size >= 3 },
  // High-signal patterns
  { name: 'Signal-Rich Sources', desc: 'Strong signals across many dimensions simultaneously. Editorially rich content with distinct fingerprints.', icon: '\u{1F4CA}', test: (hi) => hi.size >= 4 },
  { name: 'Quality Anchors', desc: 'Above-average epistemic quality. Content that demonstrates careful sourcing and claim substantiation.', icon: '\u{2693}', test: (hi) => hi.has('EQ') },
  { name: 'Solution-Focused', desc: 'Elevated orientation toward proposed solutions and constructive outcomes.', icon: '\u{1F4A1}', test: (hi) => hi.has('SO') },
  { name: 'Engaged Voices', desc: 'High-arousal editorial character. Content with strong emotional or motivational energy.', icon: '\u{1F3A4}', test: (hi) => hi.has('AR') },
  { name: 'Positive Framing', desc: 'Above-average positive valence in editorial tone. Content that leans toward affirmative and constructive framing.', icon: '\u{2600}', test: (hi) => hi.has('VA') },
  { name: 'Fact Witnesses', desc: 'High ratio of observable facts to editorial inference. Content grounded in direct evidence.', icon: '\u{1F441}', test: (hi) => hi.has('FW') },
  { name: 'Open Books', desc: 'High transparency and disclosure. Content that surfaces methodology, limitations, and sourcing.', icon: '\u{1F4D6}', test: (hi) => hi.has('TD') },
  { name: 'Low-Propaganda', desc: 'Below-average use of propaganda techniques. Content that avoids rhetorical manipulation.', icon: '\u{1F6E1}', test: (_hi, lo) => lo.has('PT') },
  { name: 'Measured Tone', desc: 'Low arousal and restrained editorial energy. Calm, analytical coverage.', icon: '\u{1F30A}', test: (_hi, lo) => lo.has('AR') },
];

// Population medians (for radar overlay)
const populationMedian = new Array(nDims).fill(0);
{
  const dimVals: number[][] = Array.from({ length: nDims }, () => []);
  for (const vec of rawVectors.values()) {
    for (let i = 0; i < nDims; i++) {
      if (!isNaN(vec[i])) dimVals[i].push(vec[i]);
    }
  }
  for (let i = 0; i < nDims; i++) {
    const sorted = dimVals[i].sort((a, b) => a - b);
    populationMedian[i] = sorted.length > 0 ? sorted[Math.floor(sorted.length / 2)] : 0;
  }
}

// Compute p33/p66 for marker assignment
function percentile(arr: number[], p: number): number {
  const sorted = [...arr].sort((a, b) => a - b);
  if (sorted.length === 0) return 0;
  const idx = (p / 100) * (sorted.length - 1);
  const lo = Math.floor(idx), hi = Math.ceil(idx);
  if (lo === hi) return sorted[lo];
  return sorted[lo] + (sorted[hi] - sorted[lo]) * (idx - lo);
}

const dimValues: number[][] = Array.from({ length: nDims }, () => []);
for (const vec of rawVectors.values()) {
  for (let i = 0; i < nDims; i++) {
    if (!isNaN(vec[i])) dimValues[i].push(vec[i]);
  }
}
const p33s = dimValues.map(v => percentile(v, 33));
const p66s = dimValues.map(v => percentile(v, 66));

function assignArchetype(centroidRaw: number[]): { name: string; archetype: string; description: string; icon: string; color: string } {
  const hiSet = new Set<string>();
  const loSet = new Set<string>();
  for (let i = 0; i < nDims; i++) {
    if (centroidRaw[i] >= p66s[i]) hiSet.add(SIGNAL_DIMS[i].code);
    else if (centroidRaw[i] <= p33s[i]) loSet.add(SIGNAL_DIMS[i].code);
  }

  // Build signal profile name (always used as primary name)
  const hiMarkers = [...hiSet];
  const loMarkers = [...loSet];
  let profileName: string;
  if (hiMarkers.length > 0 && loMarkers.length > 0) {
    profileName = `High ${hiMarkers.slice(0, 2).join('/')} · Low ${loMarkers.slice(0, 2).join('/')}`;
  } else if (hiMarkers.length > 0) {
    profileName = `High ${hiMarkers.slice(0, 3).join('/')}`;
  } else if (loMarkers.length > 0) {
    profileName = `Low ${loMarkers.slice(0, 3).join('/')}`;
  } else {
    profileName = 'Centrist Profile';
  }

  // Find archetype (used as subtitle) and description
  let archetype = '';
  let description = '';
  let icon = '\u{1F3F7}';
  for (const rule of ARCHETYPE_RULES) {
    if (rule.test(hiSet, loSet)) {
      archetype = rule.name;
      description = rule.desc;
      icon = rule.icon;
      break;
    }
  }

  const primaryCode = hiMarkers[0] || loMarkers[0] || null;
  const dim = primaryCode ? SIGNAL_DIMS.find(d => d.code === primaryCode) : null;
  return { name: profileName, archetype, description, icon, color: dim?.color || 'var(--color-violet)' };
}

function generateInsight(centroidRaw: number[], archName: string): string {
  const parts: string[] = [];
  // Find strongest dimension
  let maxDev = 0, maxDim = '';
  for (let i = 0; i < nDims; i++) {
    const dev = Math.abs(centroidRaw[i] - populationMedian[i]);
    if (dev > maxDev) { maxDev = dev; maxDim = SIGNAL_DIMS[i].fullLabel; }
  }
  if (maxDim) {
    const idx = SIGNAL_DIMS.findIndex(d => d.fullLabel === maxDim);
    const dir = centroidRaw[idx] > populationMedian[idx] ? 'above' : 'below';
    parts.push(`Most distinctive in ${maxDim} (${dir} population median).`);
  }
  // Check for tension signals
  const ptIdx = SIGNAL_DIMS.findIndex(d => d.code === 'PT');
  const eqIdx = SIGNAL_DIMS.findIndex(d => d.code === 'EQ');
  if (centroidRaw[ptIdx] < p33s[ptIdx] && centroidRaw[eqIdx] > p66s[eqIdx]) {
    parts.push('Low propaganda with high epistemic rigor suggests evidence-driven coverage.');
  } else if (centroidRaw[ptIdx] > p66s[ptIdx]) {
    parts.push('Elevated propaganda techniques may indicate persuasion-oriented content.');
  }
  return parts.join(' ') || `Cluster shows a ${archName.toLowerCase()} editorial character.`;
}

function mode(values: (string | null)[]): string | null {
  const strs = values.filter((s): s is string => s !== null);
  if (strs.length === 0) return null;
  const counts = new Map<string, number>();
  for (const s of strs) counts.set(s, (counts.get(s) || 0) + 1);
  let best = strs[0], bestCount = 0;
  for (const [k, v] of counts) { if (v > bestCount) { best = k; bestCount = v; } }
  return best;
}

const enrichedClusters: EnrichedCluster[] = [];

for (const cl of clusterList) {
  const centroid = computeCentroid(cl.members);

  // Raw centroid (un-normalized, for display)
  const rawCentroid = new Array(nDims).fill(0);
  let rc = 0;
  for (const m of cl.members) {
    const v = rawVectors.get(m);
    if (v) {
      for (let i = 0; i < nDims; i++) { if (!isNaN(v[i])) rawCentroid[i] += v[i]; }
      rc++;
    }
  }
  if (rc > 0) for (let i = 0; i < nDims; i++) rawCentroid[i] /= rc;

  const scores = cl.members.map(m => domainScoreMapIn.get(m)).filter((s): s is number => s != null);
  const avgScore = scores.length > 0 ? scores.reduce((a, b) => a + b, 0) / scores.length : null;

  const arch = assignArchetype(rawCentroid);
  const insight = generateInsight(rawCentroid, arch.name);

  // Aggregate metadata
  const profiles = cl.members.map(m => signalProfilesLocal.get(m)).filter(Boolean) as DomainSignalProfile[];
  const dominantTone = mode(profiles.map(p => p.dominant_tone));
  const dominantScope = mode(profiles.map(p => p.dominant_scope));
  const dominantReadingLevel = mode(profiles.map(p => p.dominant_reading_level));
  const dominantSentiment = mode(profiles.map(p => p.dominant_sentiment));
  const setlVals = profiles.map(p => p.avg_setl).filter((v): v is number => v !== null);
  const avgSetl = setlVals.length > 0 ? setlVals.reduce((a, b) => a + b, 0) / setlVals.length : null;
  const hnScores = profiles.map(p => p.avg_hn_score).filter((v): v is number => v !== null);
  const avgHnScore = hnScores.length > 0 ? hnScores.reduce((a, b) => a + b, 0) / hnScores.length : 0;
  const hnComments = profiles.map(p => p.avg_hn_comments).filter((v): v is number => v !== null);
  const avgHnComments = hnComments.length > 0 ? hnComments.reduce((a, b) => a + b, 0) / hnComments.length : 0;

  // Karma per cluster
  const karmaVals = cl.members.map(m => karmaMapIn.get(m)?.avg_karma).filter((v): v is number => v != null);
  const avgKarma = karmaVals.length > 0 ? Math.round(karmaVals.reduce((a, b) => a + b, 0) / karmaVals.length) : null;

  // Story count per cluster
  const storyCount = profiles.reduce((s, p) => s + p.count, 0);

  // HRCB distribution per cluster
  const hrcbPositive = scores.filter(s => s > 0.05).length;
  const hrcbNegative = scores.filter(s => s < -0.05).length;
  const hrcbNeutral = scores.length - hrcbPositive - hrcbNegative;

  enrichedClusters.push({
    id: cl.id,
    members: cl.members,
    centroid,
    rawCentroid,
    avgScore,
    name: arch.name,
    archetype: arch.archetype,
    description: arch.description,
    icon: arch.icon,
    color: arch.color,
    insight,
    dominantTone,
    dominantScope,
    dominantReadingLevel,
    dominantSentiment,
    avgSetl,
    avgHnScore,
    avgHnComments,
    avgKarma,
    storyCount,
    hrcbPositive,
    hrcbNeutral,
    hrcbNegative,
    liminalMembers: [],
  });
}

// --- 8. Liminal members ---
for (const cl of enrichedClusters) {
  for (const m of cl.members) {
    const mv = zVectors.get(m);
    if (!mv) continue;
    let bestOtherSim = -Infinity;
    let bestOtherName = '';
    for (const other of enrichedClusters) {
      if (other.id === cl.id) continue;
      const sim = cosineSim(mv, other.centroid);
      if (sim > bestOtherSim) { bestOtherSim = sim; bestOtherName = other.name; }
    }
    if (bestOtherSim >= allianceThreshold) {
      cl.liminalMembers.push({ domain: m, secondCluster: bestOtherName, similarity: bestOtherSim });
    }
  }
}

// --- 9. Parallel coordinates data ---
// Cluster color map (assign distinct colors)
const CLUSTER_COLORS = ['var(--channel-structural)', 'var(--color-positive-medium)', 'var(--channel-editorial)', 'var(--color-amber-light)', 'var(--color-negative-light)', 'var(--color-warning-light)', 'var(--color-sentiment)', '#e879f9', 'var(--color-violet)', 'var(--color-positive-light)'];

for (let i = 0; i < enrichedClusters.length; i++) {
  enrichedClusters[i].color = CLUSTER_COLORS[i % CLUSTER_COLORS.length];
}

// Domain-to-color mapping
const domainClusterColor = new Map<string, string>();
for (const cl of enrichedClusters) {
  for (const m of cl.members) domainClusterColor.set(m, cl.color);
}

// Parallel coordinates: use raw (non-z) values, normalize each dim to [0,1] for chart
const pcDimMins = new Array(nDims).fill(Infinity);
const pcDimMaxs = new Array(nDims).fill(-Infinity);
for (const vec of rawVectors.values()) {
  for (let i = 0; i < nDims; i++) {
    if (!isNaN(vec[i])) {
      if (vec[i] < pcDimMins[i]) pcDimMins[i] = vec[i];
      if (vec[i] > pcDimMaxs[i]) pcDimMaxs[i] = vec[i];
    }
  }
}
const pcDimRanges = pcDimMins.map((mn, i) => pcDimMaxs[i] - mn || 1);

// Chart dimensions
const pcW = 700, pcH = 300, pcPadL = 30, pcPadR = 30, pcPadT = 30, pcPadB = 40;
const pcInnerW = pcW - pcPadL - pcPadR;
const pcInnerH = pcH - pcPadT - pcPadB;
const axisSpacing = pcInnerW / (nDims - 1);

function pcAxisX(dim: number): number { return pcPadL + dim * axisSpacing; }
function pcValY(val: number, dim: number): number {
  const norm = (val - pcDimMins[dim]) / pcDimRanges[dim];
  return pcPadT + pcInnerH * (1 - norm); // inverted: high values at top
}

// Build polylines per domain
const pcLines: PcLine[] = [];

// Draw unaligned domains first (behind), then cluster members
for (const domain of loneWolfDomains) {
  const vec = rawVectors.get(domain);
  if (!vec) continue;
  const pts = vec.map((v, i) => `${pcAxisX(i)},${pcValY(isNaN(v) ? means[i] : v, i)}`).join(' ');
  pcLines.push({ domain, color: 'var(--fg-secondary)', opacity: 0.25, points: pts, clusterName: null });
}
for (const cl of enrichedClusters) {
  for (const m of cl.members) {
    const vec = rawVectors.get(m);
    if (!vec) continue;
    const pts = vec.map((v, i) => `${pcAxisX(i)},${pcValY(isNaN(v) ? means[i] : v, i)}`).join(' ');
    pcLines.push({ domain: m, color: cl.color, opacity: 0.6, points: pts, clusterName: cl.name });
  }
}

// Cluster centroid polylines (thick, for overlay)
const pcCentroidLines: { name: string; color: string; points: string }[] = [];
for (const cl of enrichedClusters) {
  const pts = cl.rawCentroid.map((v, i) => `${pcAxisX(i)},${pcValY(v, i)}`).join(' ');
  pcCentroidLines.push({ name: cl.name, color: cl.color, points: pts });
}

// --- 11. Inter-cluster variance per signal (differentiation) ---
const clusterCentroids = enrichedClusters.map(cl => cl.centroid);
const globalCentroid = new Array(nDims).fill(0);
for (const c of clusterCentroids) {
  for (let i = 0; i < nDims; i++) globalCentroid[i] += c[i];
}
for (let i = 0; i < nDims; i++) globalCentroid[i] /= Math.max(clusterCentroids.length, 1);

const interClusterVar: { code: string; label: string; color: string; variance: number }[] = [];
for (let d = 0; d < nDims; d++) {
  let variance = 0;
  for (const c of clusterCentroids) {
    variance += (c[d] - globalCentroid[d]) ** 2;
  }
  variance /= Math.max(clusterCentroids.length - 1, 1);
  interClusterVar.push({ code: SIGNAL_DIMS[d].code, label: SIGNAL_DIMS[d].fullLabel, color: SIGNAL_DIMS[d].color, variance });
}
interClusterVar.sort((a, b) => b.variance - a.variance);
const maxVar = Math.max(...interClusterVar.map(v => v.variance), 0.01);

// --- 12. Affinity matrix ---
const nClusters = enrichedClusters.length;
const affinityMatrix: number[][] = Array.from({ length: nClusters }, () => new Array(nClusters).fill(0));
for (let i = 0; i < nClusters; i++) {
  for (let j = 0; j < nClusters; j++) {
    affinityMatrix[i][j] = i === j ? 1 : cosineSim(enrichedClusters[i].centroid, enrichedClusters[j].centroid);
  }
}

// --- 13. Signal distribution histograms with cluster overlays ---
function buildHistogramFromValues(code: string, fullLabel: string, color: string, raw: number[], markers: { name: string; value: number; color: string }[]): SignalHistogram {
  if (raw.length === 0) return { code, fullLabel, color, bins: [], min: 0, max: 0, maxCount: 0, clusterMarkers: [] };
  const min = Math.min(...raw);
  const max = Math.max(...raw);
  const numBins = 12;
  const range = max - min || 1;
  const binWidth = range / numBins;
  const bins: { x0: number; x1: number; count: number }[] = [];
  for (let i = 0; i < numBins; i++) {
    bins.push({ x0: min + i * binWidth, x1: min + (i + 1) * binWidth, count: 0 });
  }
  for (const v of raw) {
    const idx = Math.min(Math.floor((v - min) / binWidth), numBins - 1);
    bins[idx].count++;
  }
  const maxCount = Math.max(...bins.map(b => b.count), 1);
  return { code, fullLabel, color, bins, min, max, maxCount, clusterMarkers: markers };
}

function buildHistograms(): SignalHistogram[] {
  const vals = [...signalProfilesLocal.values()];
  const extractors: { code: string; fullLabel: string; color: string; fn: (p: DomainSignalProfile) => number | null }[] = [
    { code: 'EQ', fullLabel: 'Epistemic Quality (EQ)', color: 'var(--channel-editorial)', fn: p => p.avg_eq },
    { code: 'SO', fullLabel: 'Solution Orientation (SO)', color: 'var(--color-positive-light)', fn: p => p.avg_so },
    { code: 'SR', fullLabel: 'Stakeholder Rep (SR)', color: 'var(--channel-structural)', fn: p => p.avg_sr },
    { code: 'TD', fullLabel: 'Transparency (TD)', color: 'var(--color-positive-medium)', fn: p => p.avg_td },
    { code: 'PT', fullLabel: 'Propaganda Techniques (PT)', color: 'var(--color-negative-light)', fn: p => p.avg_pt_score },
    { code: 'AR', fullLabel: 'Arousal (AR)', color: 'var(--color-amber-light)', fn: p => p.avg_arousal },
    { code: 'VA', fullLabel: 'Valence (VA)', color: 'var(--color-warning-light)', fn: p => p.avg_valence },
    { code: 'FW', fullLabel: 'Fair Witness (FW)', color: 'var(--color-sentiment)', fn: p => p.avg_fw_ratio },
  ];

  return extractors.map((ext, dimIdx) => {
    const raw = vals.map(ext.fn).filter((n): n is number => n !== null);
    const markers = enrichedClusters.map(cl => ({
      name: cl.name,
      value: cl.rawCentroid[dimIdx],
      color: cl.color,
    }));
    return buildHistogramFromValues(ext.code, ext.fullLabel, ext.color, raw, markers);
  });
}

const histograms = buildHistograms();

// --- 13b. Core signal histograms (HRCB, Editorial, Structural, Confidence, SETL) ---
function buildCoreHistograms(): SignalHistogram[] {
  const vals = [...signalProfilesLocal.values()];
  const coreExtractors: { code: string; fullLabel: string; color: string; fn: (p: DomainSignalProfile) => number | null }[] = [
    { code: 'HRCB', fullLabel: 'HRCB Score', color: '#e879f9', fn: p => p.avg_hrcb },
    { code: 'E', fullLabel: 'Editorial Channel', color: 'var(--color-violet)', fn: p => p.avg_editorial },
    { code: 'S', fullLabel: 'Structural Channel', color: '#38bdf8', fn: p => p.avg_structural },
    { code: 'CONF', fullLabel: 'Confidence', color: '#a3e635', fn: p => p.avg_confidence },
    { code: 'SETL', fullLabel: 'Structural-Editorial Tension', color: '#fb7185', fn: p => p.avg_setl },
  ];

  return coreExtractors.map(ext => {
    const raw = vals.map(ext.fn).filter((n): n is number => n !== null);
    // Compute cluster averages for markers
    const markers = enrichedClusters.map(cl => {
      const memberVals = cl.members
        .map(m => signalProfilesLocal.get(m))
        .filter(Boolean)
        .map(p => ext.fn(p!))
        .filter((v): v is number => v !== null);
      const avg = memberVals.length > 0 ? memberVals.reduce((a, b) => a + b, 0) / memberVals.length : 0;
      return { name: cl.name, value: avg, color: cl.color };
    });
    return buildHistogramFromValues(ext.code, ext.fullLabel, ext.color, raw, markers);
  });
}

const coreHistograms = buildCoreHistograms();

// --- 14. Interesting pairs ---
// Cross-cluster closest pairs
const crossClusterPairs: { a: string; b: string; similarity: number; clusterA: string; clusterB: string }[] = [];
for (const pair of sortedPairs.slice(0, 500)) {
  const ca = domainToCluster.get(pair.a);
  const cb = domainToCluster.get(pair.b);
  if (ca && cb && ca !== cb) {
    const clA = enrichedClusters.find(c => c.id === ca.id);
    const clB = enrichedClusters.find(c => c.id === cb.id);
    if (clA && clB) {
      crossClusterPairs.push({ a: pair.a, b: pair.b, similarity: pair.similarity, clusterA: clA.name, clusterB: clB.name });
    }
  }
  if (crossClusterPairs.length >= 10) break;
}

// Most divergent same-cluster pairs
const sameClusterDivergent: { a: string; b: string; similarity: number; cluster: string }[] = [];
const reverseSorted = [...allPairs].sort((a, b) => a.similarity - b.similarity);
for (const pair of reverseSorted) {
  const ca = domainToCluster.get(pair.a);
  const cb = domainToCluster.get(pair.b);
  if (ca && cb && ca === cb) {
    const cl = enrichedClusters.find(c => c.id === ca.id);
    if (cl) {
      sameClusterDivergent.push({ a: pair.a, b: pair.b, similarity: pair.similarity, cluster: cl.name });
    }
  }
  if (sameClusterDivergent.length >= 10) break;
}

// --- 15. Outlier scoring ---
const outlierEntries: OutlierEntry[] = [];
for (const domain of loneWolfDomains) {
  const dv = zVectors.get(domain);
  if (!dv) continue;

  // Avg distance to all cluster centroids
  let distSum = 0;
  let nearestSim = -Infinity, nearestName = 'None';
  for (const cl of enrichedClusters) {
    const sim = cosineSim(dv, cl.centroid);
    distSum += (1 - sim);
    if (sim > nearestSim) { nearestSim = sim; nearestName = cl.name; }
  }
  const outlierScore = enrichedClusters.length > 0 ? distSum / enrichedClusters.length : 1;

  // Key distinguishing signal: dimension with largest |z|
  const rv = rawVectors.get(domain) || new Array(nDims).fill(0);
  let maxAbsZ = 0, keySignal = '';
  for (let i = 0; i < nDims; i++) {
    const absZ = Math.abs(dv[i]);
    if (absZ > maxAbsZ) { maxAbsZ = absZ; keySignal = SIGNAL_DIMS[i].code; }
  }

  const profile = signalProfilesLocal.get(domain);
  outlierEntries.push({
    domain,
    score: domainScoreMapIn.get(domain) ?? null,
    outlierScore,
    nearestCluster: nearestName,
    nearestSim: Math.max(nearestSim, 0),
    keySignal,
    tone: profile?.dominant_tone ?? null,
  });
}
outlierEntries.sort((a, b) => b.outlierScore - a.outlierScore);

// --- Stats ---
const totalDomains = domainNames.length;
const totalClusters = enrichedClusters.length;
const unalignedCount = loneWolfDomains.length;
const loneWolfRatio = totalDomains > 0 ? unalignedCount / totalDomains : 0;
const mostDiff = interClusterVar.length > 0 ? interClusterVar[0] : null;
const leastDiff = interClusterVar.length > 0 ? interClusterVar[interClusterVar.length - 1] : null;

// --- Signal Space data (for SignalSpace component) ---
const signalSpacePoints = [...zVectors.entries()].map(([domain, zVector]) => {
  const cluster = domainToCluster.get(domain);
  const enriched = cluster ? enrichedClusters.find(c => c.id === cluster.id) : null;
  const profile = signalProfilesLocal.get(domain);
  return {
    domain,
    zVector,
    hcbScore: domainScoreMapIn.get(domain) ?? null,
    storyCount: profile?.count ?? 1,
    clusterName: enriched?.name ?? null,
    clusterColor: enriched?.color ?? 'var(--fg-secondary)',
  };
});

// Build domain scores lookup for template rendering
const domainScores: Record<string, number | null> = {};
for (const [d, s] of domainScoreMapIn) {
  domainScores[d] = s;
}

return {
  enrichedClusters, loneWolfDomains, histograms, coreHistograms,
  crossClusterPairs, sameClusterDivergent, outlierEntries,
  pcLines, pcCentroidLines, interClusterVar, affinityMatrix,
  signalSpacePoints, totalDomains, totalClusters, unalignedCount,
  loneWolfRatio, mostDiff, leastDiff, maxVar, nClusters,
  profileCount: signalProfilesLocal.size,
  pcDimMins, pcDimMaxs, populationMedian, dimValues, domainScores,
};
} // end computeFactionsData

const fd = await cachedQuery<FactionsData>(kv, 'sys:factions', () =>
  Promise.resolve(computeFactionsData(signalProfilesArr, domainScoreMap, karmaMap)), 600);

const {
  enrichedClusters, loneWolfDomains, histograms, coreHistograms,
  crossClusterPairs, sameClusterDivergent, outlierEntries,
  pcLines, pcCentroidLines, interClusterVar, affinityMatrix,
  signalSpacePoints, totalDomains, totalClusters, unalignedCount,
  loneWolfRatio, mostDiff, leastDiff, maxVar, nClusters,
  profileCount, pcDimMins, pcDimMaxs, populationMedian, dimValues, domainScores,
} = fd;

// --- Template helper values ---
const nDims = SIGNAL_DIMS.length;
const PHI = (1 + Math.sqrt(5)) / 2;
const factionThreshold = 1 / PHI;
const allianceThreshold = 1 / (PHI * PHI);
const acquaintanceThreshold = 1 / (PHI * PHI * PHI);
const signalDimsProps = SIGNAL_DIMS.map(d => ({ code: d.code, fullLabel: d.fullLabel, color: d.color }));
---

<Base title="Domain Factions — HRO">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'sources', href: '/sources' }, { label: 'factions' }]} />

  {/* === Section 0: Header === */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Domain Factions</span>
        <span style="color: var(--fg-secondary); margin-left: 8px; font-size: var(--font-sm);">
          signal-profile clustering
        </span>
      </td>
    </tr>
    <tr>
      <td style="color: var(--fg-secondary); font-size: var(--font-xs); padding: 4px 0 6px 0; line-height: 1.5;">
        Domains grouped by <em>editorial character</em> &mdash; how they cover topics, not just what they score.
        Signal landscape shows 13 dimensions: 5 core (HRCB, editorial, structural, confidence, SETL) and
        8 editorial character signals. Clustering uses the 8 editorial dimensions with cosine similarity
        on z-normalized vectors and golden ratio (&#x3C6;) tier thresholds.
      </td>
    </tr>
    <tr>
      <td style="padding: 0 0 10px 0;">
        <div style="display: flex; flex-wrap: wrap; gap: 6px; font-size: var(--font-xs);">
          {SIGNAL_DIMS.map(d => (
            <span style={`background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 2px 7px; color: ${d.color};`}>
              <span style="font-weight: bold;">{d.code}</span>
              <span style="color: var(--fg-secondary);"> {d.fullLabel}</span>
            </span>
          ))}
        </div>
      </td>
    </tr>
  </table>

  {totalDomains < 5 ? (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 20px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; color: var(--fg-secondary); text-align: center;">
          Not enough evaluated domains for signal-profile clustering. At least 5 domains with 3+ evaluations are needed ({totalDomains} available).
        </td>
      </tr>
    </table>
  ) : (
    <>
      <FactionSignalLandscape profileCount={profileCount} coreHistograms={coreHistograms} histograms={histograms} enrichedClusters={enrichedClusters} />

      <FactionParallelCoords
        totalClusters={totalClusters} totalDomains={totalDomains} unalignedCount={unalignedCount}
        mostDiff={mostDiff} leastDiff={leastDiff} loneWolfRatio={loneWolfRatio}
        enrichedClusters={enrichedClusters} pcLines={pcLines} pcCentroidLines={pcCentroidLines}
        signalDims={signalDimsProps} pcDimMins={pcDimMins} pcDimMaxs={pcDimMaxs}
        factionThreshold={factionThreshold} allianceThreshold={allianceThreshold} acquaintanceThreshold={acquaintanceThreshold}
      />

      <SignalSpace points={signalSpacePoints} />

      {enrichedClusters.length > 1 && (
        <FactionDifferentiation interClusterVar={interClusterVar} maxVar={maxVar} />
      )}

      {enrichedClusters.map(cl => (
        <FactionClusterCard cl={cl} nDims={nDims} dimValues={dimValues} populationMedian={populationMedian} domainScores={domainScores} signalDims={signalDimsProps} />
      ))}

      {nClusters > 1 && (
        <FactionAffinityMatrix enrichedClusters={enrichedClusters} affinityMatrix={affinityMatrix} nClusters={nClusters} />
      )}

      {(crossClusterPairs.length > 0 || sameClusterDivergent.length > 0) && (
        <FactionInterestingPairs crossClusterPairs={crossClusterPairs} sameClusterDivergent={sameClusterDivergent} />
      )}

      {outlierEntries.length > 0 && (
        <FactionOutliers outlierEntries={outlierEntries} />
      )}

      {/* === Methodology Notes === */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0 20px 0;">
        <tr>
          <td>
            <details style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 12px;">
              <summary style="color: var(--fg-secondary); font-size: var(--font-sm); cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;">
                Methodology Notes
              </summary>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); line-height: 1.6; margin-top: 8px;">
                <p><strong style="color: var(--fg-secondary);">Clustering input:</strong> 8 signal dimensions per domain &mdash;
                  Epistemic Quality (EQ), Solution Orientation (SO), Stakeholder Representation (SR), Transparency (TD),
                  Propaganda Techniques (PT, inverted), Arousal (AR), Valence (VA), Fair Witness (FW).</p>
                <p><strong style="color: var(--fg-secondary);">Z-normalization:</strong> Each dimension is standardized to zero mean and unit variance
                  across all domains with 3+ evaluations. Missing values are imputed as 0 (population mean). Domains with &gt;3 missing dimensions are flagged.</p>
                <p><strong style="color: var(--fg-secondary);">Similarity:</strong> Cosine similarity on z-normalized 8D vectors measures editorial character similarity
                  independent of magnitude.</p>
                <p><strong style="color: var(--fg-secondary);">Clustering:</strong> Agglomerative hierarchical clustering with average linkage. Pairs are sorted by
                  descending similarity and greedily merged when average inter-cluster similarity &ge; 1/&#x3C6; (~0.618).
                  If this produces a single giant cluster, the fallback threshold 1/&#x3C6;&sup2; (~0.382) is used.</p>
                <p><strong style="color: var(--fg-secondary);">Golden ratio tiers:</strong>
                  Faction &ge; 1/&#x3C6; (0.618) &middot;
                  Alliance &ge; 1/&#x3C6;&sup2; (0.382) &middot;
                  Acquaintance &ge; 1/&#x3C6;&sup3; (0.236) &middot;
                  Neutral &ge; 0 &middot;
                  Rival &lt; 0</p>
                <p><strong style="color: var(--fg-secondary);">Parallel coordinates:</strong> Each domain is drawn as a polyline across 8 vertical axes
                  (one per signal dimension). Values are normalized to the observed min/max per dimension. Thick lines show cluster centroids;
                  thin lines show individual domains. Bundled lines indicate agreement; crossing lines indicate divergence.</p>
                <p><strong style="color: var(--fg-secondary);">Archetype naming:</strong> ~12 pattern rules map signal combinations to descriptive names
                  (e.g., high EQ + high TD + low PT &rarr; &ldquo;Rigorous Analysts&rdquo;). Fallback uses marker-based names.</p>
                <p><strong style="color: var(--fg-secondary);">Minimum data:</strong> Requires 5+ domains with 3+ evaluations each.</p>
              </div>
            </details>
          </td>
        </tr>
      </table>
    </>
  )}
</Base>
