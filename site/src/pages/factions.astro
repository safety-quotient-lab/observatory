---
import Base from '../layouts/Base.astro';
import { getAllDomainStats, getDomainFingerprints, getDomainSignalProfiles } from '../lib/db';
import { SECTIONS } from '../lib/udhr';
import { scoreToColor, formatScore } from '../lib/colors';

const db = Astro.locals.runtime.env.DB;

// --- 1. Parallel fetch ---
const [domains, signalProfiles] = await Promise.all([
  getAllDomainStats(db, 'count', 50),
  getDomainSignalProfiles(db),
]);

const evaluatedDomains = domains.filter(d => d.avg_score !== null && d.count >= 3);
const domainNames = evaluatedDomains.map(d => d.domain);
const fingerprints = await getDomainFingerprints(db, domainNames);

// --- 2. Cosine similarity ---
interface FactionPair {
  a: string;
  b: string;
  similarity: number;
}

function cosineSim(va: (number | null)[], vb: (number | null)[]): number | null {
  let dot = 0, magA = 0, magB = 0, valid = 0;
  for (let i = 0; i < va.length; i++) {
    const a = va[i], b = vb[i];
    if (a === null || b === null) continue;
    dot += a * b;
    magA += a * a;
    magB += b * b;
    valid++;
  }
  if (valid < 5 || magA === 0 || magB === 0) return null;
  return dot / (Math.sqrt(magA) * Math.sqrt(magB));
}

const pairs: FactionPair[] = [];
const domainList = [...fingerprints.keys()];
for (let i = 0; i < domainList.length; i++) {
  for (let j = i + 1; j < domainList.length; j++) {
    const a = domainList[i], b = domainList[j];
    const va = fingerprints.get(a), vb = fingerprints.get(b);
    if (!va || !vb) continue;
    const sim = cosineSim(va, vb);
    if (sim !== null) pairs.push({ a, b, similarity: sim });
  }
}

// --- 3. Greedy clustering ---
interface Cluster {
  members: string[];
  avgScore: number | null;
}

const clusters: Cluster[] = [];
const assigned = new Set<string>();
const threshold = 0.85;

for (const pair of [...pairs].sort((a, b) => b.similarity - a.similarity)) {
  if (pair.similarity < threshold) break;
  const aCluster = clusters.find(c => c.members.includes(pair.a));
  const bCluster = clusters.find(c => c.members.includes(pair.b));
  if (aCluster && bCluster && aCluster !== bCluster) {
    aCluster.members.push(...bCluster.members);
    clusters.splice(clusters.indexOf(bCluster), 1);
  } else if (aCluster) {
    if (!aCluster.members.includes(pair.b)) aCluster.members.push(pair.b);
  } else if (bCluster) {
    if (!bCluster.members.includes(pair.a)) bCluster.members.push(pair.a);
  } else {
    clusters.push({ members: [pair.a, pair.b], avgScore: null });
  }
  assigned.add(pair.a);
  assigned.add(pair.b);
}

// Add lone wolves
for (const d of domainList) {
  if (!assigned.has(d)) clusters.push({ members: [d], avgScore: null });
}

// Compute avg scores
const domainScoreMap = new Map(evaluatedDomains.map(d => [d.domain, d.avg_score]));
for (const c of clusters) {
  const scores = c.members.map(m => domainScoreMap.get(m)).filter((s): s is number => s !== null);
  c.avgScore = scores.length > 0 ? scores.reduce((a, b) => a + b, 0) / scores.length : null;
}

clusters.sort((a, b) => b.members.length - a.members.length);

// --- 4. Per-cluster signal averages ---
interface FactionSignals {
  eq: number;
  so: number;
  sr: number;
  td: number;
  pt: number;
  fw: number;
  valence: number;
  arousal: number;
  dominance: number;
  hnScore: number;
  hnComments: number;
  posterKarma: number;
  dominantTone: string | null;
  dominantScope: string | null;
  dominantReadingLevel: string | null;
  dominantSentiment: string | null;
}

function avgSignals(members: string[]): FactionSignals {
  const vals = members.map(m => signalProfiles.get(m)).filter(Boolean) as import('../lib/db').DomainSignalProfile[];
  function avg(fn: (p: import('../lib/db').DomainSignalProfile) => number | null): number {
    const nums = vals.map(fn).filter((n): n is number => n !== null);
    return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
  }
  // Mode: most common non-null value
  function mode(fn: (p: import('../lib/db').DomainSignalProfile) => string | null): string | null {
    const strs = vals.map(fn).filter((s): s is string => s !== null);
    if (strs.length === 0) return null;
    const counts = new Map<string, number>();
    for (const s of strs) counts.set(s, (counts.get(s) || 0) + 1);
    let best = strs[0], bestCount = 0;
    for (const [k, v] of counts) { if (v > bestCount) { best = k; bestCount = v; } }
    return best;
  }
  return {
    eq: avg(p => p.avg_eq),
    so: avg(p => p.avg_so),
    sr: avg(p => p.avg_sr),
    td: avg(p => p.avg_td),
    pt: avg(p => p.avg_pt_count),
    fw: avg(p => p.avg_fw_ratio),
    valence: avg(p => p.avg_valence),
    arousal: avg(p => p.avg_arousal),
    dominance: avg(p => p.avg_dominance),
    hnScore: avg(p => p.avg_hn_score),
    hnComments: avg(p => p.avg_hn_comments),
    posterKarma: avg(p => p.avg_poster_karma),
    dominantTone: mode(p => p.dominant_tone),
    dominantScope: mode(p => p.dominant_scope),
    dominantReadingLevel: mode(p => p.dominant_reading_level),
    dominantSentiment: mode(p => p.dominant_sentiment),
  };
}

// --- 5. Signal typecode assignment ---
interface Archetype {
  name: string;
  tagline: string;
  color: string;
}

// Signal dimension definitions for typecodes
const SIGNAL_DIMS: { code: string; fullLabel: string; label: string; color: string; extract: (s: FactionSignals) => number }[] = [
  { code: 'EQ', fullLabel: 'Epistemic Quality (EQ)', label: 'epistemic quality', color: '#60a5fa', extract: s => s.eq },
  { code: 'SO', fullLabel: 'Solution Orientation (SO)', label: 'solution orientation', color: '#4ade80', extract: s => s.so },
  { code: 'SR', fullLabel: 'Stakeholder Representation (SR)', label: 'stakeholder representation', color: '#a78bfa', extract: s => s.sr },
  { code: 'TD', fullLabel: 'Transparency & Disclosure (TD)', label: 'transparency & disclosure', color: '#34d399', extract: s => s.td },
  { code: 'PT', fullLabel: 'Propaganda Techniques (PT)', label: 'propaganda techniques', color: '#f87171', extract: s => s.pt },
  { code: 'AR', fullLabel: 'Arousal (AR)', label: 'arousal', color: '#fb923c', extract: s => s.arousal },
  { code: 'VA', fullLabel: 'Valence (VA)', label: 'valence', color: '#fbbf24', extract: s => s.valence },
  { code: 'FW', fullLabel: 'Fair Witness (FW)', label: 'fair witness', color: '#22d3ee', extract: s => s.fw },
];

// Compute p33/p66 percentile thresholds for typecode assignment
function computePercentiles(profiles: Map<string, import('../lib/db').DomainSignalProfile>) {
  const vals = [...profiles.values()];
  function percentile(arr: number[], p: number): number {
    const sorted = [...arr].sort((a, b) => a - b);
    if (sorted.length === 0) return 0;
    const idx = (p / 100) * (sorted.length - 1);
    const lo = Math.floor(idx), hi = Math.ceil(idx);
    if (lo === hi) return sorted[lo];
    return sorted[lo] + (sorted[hi] - sorted[lo]) * (idx - lo);
  }
  function extract(fn: (p: import('../lib/db').DomainSignalProfile) => number | null): number[] {
    return vals.map(fn).filter((n): n is number => n !== null);
  }
  return {
    eq:      { p33: percentile(extract(p => p.avg_eq), 33),      p66: percentile(extract(p => p.avg_eq), 66) },
    so:      { p33: percentile(extract(p => p.avg_so), 33),      p66: percentile(extract(p => p.avg_so), 66) },
    sr:      { p33: percentile(extract(p => p.avg_sr), 33),      p66: percentile(extract(p => p.avg_sr), 66) },
    td:      { p33: percentile(extract(p => p.avg_td), 33),      p66: percentile(extract(p => p.avg_td), 66) },
    pt:      { p33: percentile(extract(p => p.avg_pt_count), 33),p66: percentile(extract(p => p.avg_pt_count), 66) },
    arousal: { p33: percentile(extract(p => p.avg_arousal), 33), p66: percentile(extract(p => p.avg_arousal), 66) },
    valence: { p33: percentile(extract(p => p.avg_valence), 33), p66: percentile(extract(p => p.avg_valence), 66) },
    fw:      { p33: percentile(extract(p => p.avg_fw_ratio), 33),p66: percentile(extract(p => p.avg_fw_ratio), 66) },
  };
}

type Percentiles = ReturnType<typeof computePercentiles>;

// Map signal codes to percentile keys
const SIGNAL_PCTL_KEY: Record<string, keyof Percentiles> = {
  EQ: 'eq', SO: 'so', SR: 'sr', TD: 'td',
  PT: 'pt', AR: 'arousal', VA: 'valence', FW: 'fw',
};

function assignTypecode(sig: FactionSignals, pctl: Percentiles): Archetype {
  const markers: { code: string; sign: '+' | '-'; label: string; color: string }[] = [];

  for (const dim of SIGNAL_DIMS) {
    const val = dim.extract(sig);
    const key = SIGNAL_PCTL_KEY[dim.code];
    const { p33, p66 } = pctl[key];
    if (val >= p66) {
      markers.push({ code: dim.code, sign: '+', label: dim.label, color: dim.color });
    } else if (val <= p33) {
      markers.push({ code: dim.code, sign: '-', label: dim.label, color: dim.color });
    }
  }

  if (markers.length === 0) {
    return { name: '(baseline)', tagline: 'All signals in the middle third of the population', color: '#818cf8' };
  }

  const name = markers.map(m => `${m.code}${m.sign}`).join('\u00b7');
  const highItems = markers.filter(m => m.sign === '+');
  const lowItems = markers.filter(m => m.sign === '-');
  const parts: string[] = [];
  if (highItems.length > 0) parts.push('High ' + highItems.map(m => m.label).join(', '));
  if (lowItems.length > 0) parts.push('Low ' + lowItems.map(m => m.label).join(', '));
  const tagline = parts.join(' · ');
  // Color from first marker (prioritize + signals)
  const primary = highItems[0] || lowItems[0];
  const color = primary.color;

  return { name, tagline, color };
}

// --- 6. Build enriched faction data ---
interface EnrichedFaction {
  members: string[];
  avgScore: number | null;
  signals: FactionSignals;
  archetype: Archetype;
  avgFingerprint: (number | null)[];
}

const percentiles = computePercentiles(signalProfiles);

const multiFactions: EnrichedFaction[] = [];
const loneWolves: { domain: string; score: number | null; signals: FactionSignals; nearestFaction: string; nearestSim: number }[] = [];

for (const c of clusters) {
  const signals = avgSignals(c.members);
  const archetype = assignTypecode(signals, percentiles);

  // Compute average fingerprint
  const avgFp: (number | null)[] = new Array(31).fill(null);
  for (let i = 0; i < 31; i++) {
    const vals = c.members.map(m => fingerprints.get(m)?.[i]).filter((v): v is number => v !== null);
    avgFp[i] = vals.length > 0 ? vals.reduce((a, b) => a + b, 0) / vals.length : null;
  }

  if (c.members.length > 1) {
    multiFactions.push({ members: c.members, avgScore: c.avgScore, signals, archetype, avgFingerprint: avgFp });
  } else {
    // Lone wolf — find nearest multi-member faction
    const wolfFp = fingerprints.get(c.members[0]);
    let nearestName = 'None';
    let nearestSim = -1;
    if (wolfFp) {
      for (const f of multiFactions) {
        const sim = cosineSim(wolfFp, f.avgFingerprint);
        if (sim !== null && sim > nearestSim) {
          nearestSim = sim;
          nearestName = f.archetype.name;
        }
      }
    }
    loneWolves.push({
      domain: c.members[0],
      score: c.avgScore,
      signals,
      nearestFaction: nearestName,
      nearestSim: Math.max(nearestSim, 0),
    });
  }
}

// --- 7. Alliance/rivalry signal overlap ---
const sortedPairsDesc = [...pairs].sort((a, b) => b.similarity - a.similarity);
const sortedPairsAsc = [...pairs].sort((a, b) => a.similarity - b.similarity);

const signalKeys: (keyof Pick<FactionSignals, 'eq' | 'so' | 'sr' | 'td' | 'pt' | 'fw'>)[] = ['eq', 'so', 'sr', 'td', 'pt', 'fw'];
const signalFullLabels: Record<string, string> = {
  EQ: 'Epistemic Quality (EQ)',
  SO: 'Solution Orientation (SO)',
  SR: 'Stakeholder Representation (SR)',
  TD: 'Transparency & Disclosure (TD)',
  PT: 'Propaganda Techniques (PT)',
  FW: 'Fair Witness (FW)',
  AR: 'Arousal (AR)',
  VA: 'Valence (VA)',
};

function findSharedFaction(a: string, b: string): string | null {
  for (const f of multiFactions) {
    if (f.members.includes(a) && f.members.includes(b)) return f.archetype.name;
  }
  return null;
}

function getSignalOverlap(a: string, b: string): string {
  const sa = signalProfiles.get(a);
  const sb = signalProfiles.get(b);
  if (!sa || !sb) return 'N/A';
  const sigVals: { key: string; diff: number; va: number; vb: number }[] = [
    { key: 'EQ', diff: Math.abs((sa.avg_eq ?? 0) - (sb.avg_eq ?? 0)), va: sa.avg_eq ?? 0, vb: sb.avg_eq ?? 0 },
    { key: 'SO', diff: Math.abs((sa.avg_so ?? 0) - (sb.avg_so ?? 0)), va: sa.avg_so ?? 0, vb: sb.avg_so ?? 0 },
    { key: 'SR', diff: Math.abs((sa.avg_sr ?? 0) - (sb.avg_sr ?? 0)), va: sa.avg_sr ?? 0, vb: sb.avg_sr ?? 0 },
    { key: 'TD', diff: Math.abs((sa.avg_td ?? 0) - (sb.avg_td ?? 0)), va: sa.avg_td ?? 0, vb: sb.avg_td ?? 0 },
    { key: 'PT', diff: Math.abs((sa.avg_pt_count ?? 0) - (sb.avg_pt_count ?? 0)), va: sa.avg_pt_count ?? 0, vb: sb.avg_pt_count ?? 0 },
    { key: 'FW', diff: Math.abs((sa.avg_fw_ratio ?? 0) - (sb.avg_fw_ratio ?? 0)), va: sa.avg_fw_ratio ?? 0, vb: sb.avg_fw_ratio ?? 0 },
  ];
  sigVals.sort((a, b) => a.diff - b.diff);
  return signalFullLabels[sigVals[0].key] || sigVals[0].key;
}

function getSignalDivergence(a: string, b: string): string {
  const sa = signalProfiles.get(a);
  const sb = signalProfiles.get(b);
  if (!sa || !sb) return 'N/A';
  const sigVals: { key: string; diff: number; va: number; vb: number }[] = [
    { key: 'EQ', diff: Math.abs((sa.avg_eq ?? 0) - (sb.avg_eq ?? 0)), va: sa.avg_eq ?? 0, vb: sb.avg_eq ?? 0 },
    { key: 'SO', diff: Math.abs((sa.avg_so ?? 0) - (sb.avg_so ?? 0)), va: sa.avg_so ?? 0, vb: sb.avg_so ?? 0 },
    { key: 'SR', diff: Math.abs((sa.avg_sr ?? 0) - (sb.avg_sr ?? 0)), va: sa.avg_sr ?? 0, vb: sb.avg_sr ?? 0 },
    { key: 'TD', diff: Math.abs((sa.avg_td ?? 0) - (sb.avg_td ?? 0)), va: sa.avg_td ?? 0, vb: sb.avg_td ?? 0 },
    { key: 'PT', diff: Math.abs((sa.avg_pt_count ?? 0) - (sb.avg_pt_count ?? 0)), va: sa.avg_pt_count ?? 0, vb: sb.avg_pt_count ?? 0 },
    { key: 'FW', diff: Math.abs((sa.avg_fw_ratio ?? 0) - (sb.avg_fw_ratio ?? 0)), va: sa.avg_fw_ratio ?? 0, vb: sb.avg_fw_ratio ?? 0 },
  ];
  sigVals.sort((a, b) => b.diff - a.diff);
  const top = sigVals[0];
  const label = signalFullLabels[top.key] || top.key;
  return `${label}: ${top.va.toFixed(2)} vs ${top.vb.toFixed(2)}`;
}

const top20Alliances = sortedPairsDesc.slice(0, 20);
const rivalPairs = sortedPairsAsc.filter(p => p.similarity < 0.3).slice(0, 20);

// --- 8. Group colors for heatmap ---
const groupColors: Record<string, string> = {
  'Foundation': '#a78bfa',
  'Security': '#f87171',
  'Legal': '#22d3ee',
  'Personal': '#34d399',
  'Privacy': '#38bdf8',
  'Expression': '#fbbf24',
  'Economic': '#fb923c',
  'Cultural': '#e879f9',
  'Order': '#818cf8',
};

function getGroupColor(group: string): string {
  for (const [key, color] of Object.entries(groupColors)) {
    if (group.toLowerCase().includes(key.toLowerCase())) return color;
  }
  return '#888';
}

// Column labels for heatmap
const colLabels = ['P', ...Array.from({ length: 30 }, (_, i) => String(i + 1))];

// Stats
const totalDomains = domainList.length;
const totalFactions = multiFactions.length;
const unalignedCount = loneWolves.length;

// Signal bar helper: clamp to [0,1]
function clamp01(v: number): number { return Math.max(0, Math.min(1, v)); }

// --- 9. Signal distribution histograms ---
interface SignalHistogram {
  code: string;
  fullLabel: string;
  color: string;
  bins: { x0: number; x1: number; count: number }[];
  p33: number;
  p66: number;
  min: number;
  max: number;
  maxCount: number;
}

function buildHistograms(profiles: Map<string, import('../lib/db').DomainSignalProfile>, pctl: Percentiles): SignalHistogram[] {
  const vals = [...profiles.values()];
  const extractors: { code: string; fullLabel: string; color: string; fn: (p: import('../lib/db').DomainSignalProfile) => number | null; pctlKey: keyof Percentiles }[] = [
    { code: 'EQ', fullLabel: 'Epistemic Quality (EQ)', color: '#60a5fa', fn: p => p.avg_eq, pctlKey: 'eq' },
    { code: 'SO', fullLabel: 'Solution Orientation (SO)', color: '#4ade80', fn: p => p.avg_so, pctlKey: 'so' },
    { code: 'SR', fullLabel: 'Stakeholder Representation (SR)', color: '#a78bfa', fn: p => p.avg_sr, pctlKey: 'sr' },
    { code: 'TD', fullLabel: 'Transparency & Disclosure (TD)', color: '#34d399', fn: p => p.avg_td, pctlKey: 'td' },
    { code: 'PT', fullLabel: 'Propaganda Techniques (PT)', color: '#f87171', fn: p => p.avg_pt_count, pctlKey: 'pt' },
    { code: 'AR', fullLabel: 'Arousal (AR)', color: '#fb923c', fn: p => p.avg_arousal, pctlKey: 'arousal' },
    { code: 'VA', fullLabel: 'Valence (VA)', color: '#fbbf24', fn: p => p.avg_valence, pctlKey: 'valence' },
    { code: 'FW', fullLabel: 'Fair Witness (FW)', color: '#22d3ee', fn: p => p.avg_fw_ratio, pctlKey: 'fw' },
  ];

  return extractors.map(ext => {
    const raw = vals.map(ext.fn).filter((n): n is number => n !== null);
    if (raw.length === 0) return { code: ext.code, fullLabel: ext.fullLabel, color: ext.color, bins: [], p33: 0, p66: 0, min: 0, max: 0, maxCount: 0 };

    const min = Math.min(...raw);
    const max = Math.max(...raw);
    const numBins = 12;
    const range = max - min || 1;
    const binWidth = range / numBins;

    const bins: { x0: number; x1: number; count: number }[] = [];
    for (let i = 0; i < numBins; i++) {
      bins.push({ x0: min + i * binWidth, x1: min + (i + 1) * binWidth, count: 0 });
    }
    for (const v of raw) {
      const idx = Math.min(Math.floor((v - min) / binWidth), numBins - 1);
      bins[idx].count++;
    }

    const maxCount = Math.max(...bins.map(b => b.count), 1);
    const { p33, p66 } = pctl[ext.pctlKey];

    return { code: ext.code, fullLabel: ext.fullLabel, color: ext.color, bins, p33, p66, min, max, maxCount };
  });
}

const histograms = buildHistograms(signalProfiles, percentiles);
---

<Base title="Domain Factions — HN HRCB">

  {/* --- Header --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">Domain Factions</span>
        <span style="color: #828282; margin-left: 8px; font-size: var(--font-sm);">
          Stackpole faction analysis
        </span>
      </td>
    </tr>
    <tr>
      <td style="color: #666; font-size: var(--font-xs); padding: 4px 0 8px 0;">
        Domains clustered by cosine similarity on 31-dimension UDHR fingerprints, characterized by supplementary signal profile.
      </td>
    </tr>
  </table>

  {/* --- Summary Stats Strip --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 0 0 8px 0;">
    <tr>
      <td style="display: flex; flex-wrap: wrap; gap: 8px;">
        <span style="background: #1a1a25; border: 1px solid #222230; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #a78bfa;">
          {totalFactions} factions
        </span>
        <span style="background: #1a1a25; border: 1px solid #222230; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #60a5fa;">
          {totalDomains} domains
        </span>
        <span style="background: #1a1a25; border: 1px solid #222230; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #888;">
          {unalignedCount} unaligned
        </span>
        <span style="background: #1a1a25; border: 1px solid #222230; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #555;">
          threshold &ge; {threshold}
        </span>
      </td>
    </tr>
  </table>

  {evaluatedDomains.length < 3 ? (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
      <tr>
        <td style="padding: 20px; background: #12121a; border: 1px solid #222230; border-radius: 6px; color: #888; text-align: center;">
          Not enough evaluated domains to form factions. At least 3 domains with 3+ evaluations are needed.
        </td>
      </tr>
    </table>
  ) : (
    <>
      {/* --- Signal Distributions --- */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
        <tr>
          <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
              Signal Distributions
              <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                across {signalProfiles.size} domains with 3+ evaluations
              </span>
            </div>
            <div style="color: #555; font-size: var(--font-xs); margin-bottom: 10px;">
              Dashed lines mark p33 / p66 percentile cutoffs used for typecode assignment.
              Values left of p33 get <span style="color: #f87171;">−</span>, right of p66 get <span style="color: #34d399;">+</span>, middle third omitted.
            </div>

            {/* Percentile threshold table */}
            <table cellpadding="3" cellspacing="0" style="font-size: var(--font-xs); margin-bottom: 12px; border-collapse: collapse;">
              <tr style="color: #555;">
                <td style="padding-right: 12px;">Signal</td>
                <td style="text-align: right; padding-right: 12px;">p33</td>
                <td style="text-align: right; padding-right: 12px;">p66</td>
                <td style="text-align: right; padding-right: 12px;">Range</td>
              </tr>
              {histograms.map(h => (
                <tr style="border-top: 1px solid #1a1a25;">
                  <td style={`color: ${h.color}; padding-right: 12px;`}>{h.fullLabel}</td>
                  <td style="text-align: right; color: #f87171; padding-right: 12px;" class="score-font">{h.p33.toFixed(2)}</td>
                  <td style="text-align: right; color: #34d399; padding-right: 12px;" class="score-font">{h.p66.toFixed(2)}</td>
                  <td style="text-align: right; color: #666; padding-right: 12px;" class="score-font">{h.min.toFixed(2)} – {h.max.toFixed(2)}</td>
                </tr>
              ))}
            </table>

            {/* Histogram grid */}
            <div style="display: flex; flex-wrap: wrap; gap: 12px;">
              {histograms.map(h => {
                if (h.bins.length === 0) return null;
                const chartW = 220;
                const chartH = 60;
                const barW = chartW / h.bins.length;
                const range = h.max - h.min || 1;
                // Map a value to x position
                const toX = (v: number) => ((v - h.min) / range) * chartW;
                return (
                  <div style={`width: ${chartW + 2}px; flex-shrink: 0;`}>
                    <div style={`color: ${h.color}; font-size: var(--font-xs); margin-bottom: 2px;`}>{h.code}</div>
                    <svg width={chartW + 2} height={chartH + 16} xmlns="http://www.w3.org/2000/svg">
                      {/* Bars */}
                      {h.bins.map((bin, bi) => {
                        const barH = (bin.count / h.maxCount) * chartH;
                        return (
                          <rect x={bi * barW + 1} y={chartH - barH} width={Math.max(barW - 1, 1)} height={barH}
                                fill={h.color} opacity="0.5" rx="1">
                            <title>{bin.x0.toFixed(2)} – {bin.x1.toFixed(2)}: {bin.count} domains</title>
                          </rect>
                        );
                      })}
                      {/* p33 line */}
                      <line x1={toX(h.p33) + 1} y1="0" x2={toX(h.p33) + 1} y2={chartH}
                            stroke="#f87171" stroke-width="1.5" stroke-dasharray="3,2" />
                      <text x={toX(h.p33) + 1} y={chartH + 10} fill="#f87171" font-size="7" font-family="monospace" text-anchor="middle">
                        p33: {h.p33.toFixed(2)}
                      </text>
                      {/* p66 line */}
                      <line x1={toX(h.p66) + 1} y1="0" x2={toX(h.p66) + 1} y2={chartH}
                            stroke="#34d399" stroke-width="1.5" stroke-dasharray="3,2" />
                      <text x={toX(h.p66) + 1} y={chartH + 10} fill="#34d399" font-size="7" font-family="monospace" text-anchor="middle">
                        p66: {h.p66.toFixed(2)}
                      </text>
                      {/* Axis line */}
                      <line x1="1" y1={chartH} x2={chartW + 1} y2={chartH} stroke="#333" stroke-width="0.5" />
                    </svg>
                  </div>
                );
              })}
            </div>
          </td>
        </tr>
      </table>

      {/* --- Faction Cards --- */}
      {multiFactions.map((f, fi) => {
        const sig = f.signals;
        const arch = f.archetype;
        // Normalize values for bars (0-1 scale)
        const bars = [
          { label: 'Epistemic Quality (EQ)', value: clamp01(sig.eq), tip: `Epistemic Quality: ${sig.eq.toFixed(2)}` },
          { label: 'Solution Orientation (SO)', value: clamp01(sig.so), tip: `Solution Orientation: ${sig.so.toFixed(2)}` },
          { label: 'Stakeholder Rep (SR)', value: clamp01(sig.sr), tip: `Stakeholder Representation: ${sig.sr.toFixed(2)}` },
          { label: 'Transparency (TD)', value: clamp01(sig.td), tip: `Transparency & Disclosure: ${sig.td.toFixed(2)}` },
          { label: 'Propaganda (PT, inv)', value: clamp01(1 - Math.min(sig.pt / 5, 1)), tip: `Propaganda Techniques (inverted): ${sig.pt.toFixed(1)} flags` },
          { label: 'Fair Witness (FW)', value: clamp01(sig.fw), tip: `Fair Witness ratio: ${sig.fw.toFixed(2)}` },
        ];
        const barWidth = 120;
        return (
          <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
            <tr>
              <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
                {/* Header: archetype name + avg HRCB */}
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                  <span style={`color: ${arch.color}; font-weight: bold; font-size: var(--font-sm);`}>
                    {arch.name}
                  </span>
                  {f.avgScore !== null && (
                    <span class="score-font" style={`color: ${scoreToColor(f.avgScore)}; font-size: var(--font-sm);`}>
                      {formatScore(f.avgScore)}
                    </span>
                  )}
                </div>

                {/* Tagline + badges */}
                <div style="color: #666; font-size: var(--font-xs); margin-bottom: 6px;">
                  {arch.tagline}
                </div>
                <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                  <span style="background: #0d0d14; border: 1px solid #222230; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #888;">
                    {f.members.length} domains
                  </span>
                  {sig.dominantTone && (
                    <span style="background: #0d0d14; border: 1px solid #222230; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #888;">
                      {sig.dominantTone}
                    </span>
                  )}
                  {sig.dominantScope && (
                    <span style="background: #0d0d14; border: 1px solid #222230; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #888;">
                      {sig.dominantScope}
                    </span>
                  )}
                  {sig.dominantReadingLevel && (
                    <span style="background: #0d0d14; border: 1px solid #222230; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #888;">
                      {sig.dominantReadingLevel}
                    </span>
                  )}
                </div>

                {/* HN engagement row */}
                <div style="display: flex; gap: 16px; margin-bottom: 10px; font-size: var(--font-xs);">
                  <span style="color: #888;">
                    <span style="color: #555;">Pts</span> <span class="score-font" style="color: #fb923c;">{Math.round(sig.hnScore)}</span>
                  </span>
                  <span style="color: #888;">
                    <span style="color: #555;">Cmts</span> <span class="score-font" style="color: #60a5fa;">{Math.round(sig.hnComments)}</span>
                  </span>
                  <span style="color: #888;">
                    <span style="color: #555;">Karma</span> <span class="score-font" style="color: #a78bfa;">{Math.round(sig.posterKarma)}</span>
                  </span>
                </div>

                {/* Signal bars + UDHR fingerprint side by side */}
                <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 10px;">
                  {/* Signal bars */}
                  <div>
                    <div style="color: #555; font-size: var(--font-xs); margin-bottom: 4px;">Signal Profile</div>
                    {bars.map(b => (
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 2px;" title={b.tip}>
                        <span style="color: #666; font-size: 8px; font-family: monospace; width: 160px; flex-shrink: 0; text-align: right;">{b.label}</span>
                        <div style={`width: ${barWidth}px; height: 10px; background: #1a1a25; border-radius: 2px; position: relative;`}>
                          <div style={`width: ${Math.round(b.value * barWidth)}px; height: 10px; background: ${arch.color}; opacity: 0.8; border-radius: 2px;`}></div>
                        </div>
                      </div>
                    ))}
                  </div>

                  {/* UDHR fingerprint */}
                  <div>
                    <div style="color: #555; font-size: var(--font-xs); margin-bottom: 4px;">UDHR Fingerprint</div>
                    <svg width={31 * 12 + 2} height="18" xmlns="http://www.w3.org/2000/svg">
                      {f.avgFingerprint.map((v, vi) => (
                        <rect x={vi * 12} y="0" width="11" height="16" rx="1"
                              fill={v !== null ? scoreToColor(v) : '#1a1a25'}
                              opacity={v !== null ? '0.9' : '0.3'}>
                          <title>{colLabels[vi]}: {v !== null ? formatScore(v) : 'ND'}</title>
                        </rect>
                      ))}
                    </svg>
                  </div>
                </div>

                {/* Member domains */}
                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                  {f.members.map(m => {
                    const score = domainScoreMap.get(m);
                    return (
                      <a href={`/domain/${m}`}
                         style={`color: ${score !== undefined && score !== null ? scoreToColor(score) : '#888'}; font-size: var(--font-xs); padding: 2px 6px; background: #0d0d14; border: 1px solid #222230; border-radius: 3px; text-decoration: none;`}>
                        {m}
                        {score !== null && score !== undefined && (
                          <span class="score-font" style="margin-left: 3px; font-size: var(--font-xs);">{formatScore(score)}</span>
                        )}
                      </a>
                    );
                  })}
                </div>
              </td>
            </tr>
          </table>
        );
      })}

      {/* --- Fingerprint Comparison Heatmap --- */}
      {multiFactions.length > 1 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 8px 0;">
          <tr>
            <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Fingerprint Comparison
                <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                  faction-averaged UDHR provision scores
                </span>
              </div>
              <div style="overflow-x: auto;">
                <svg width={31 * 16 + 140} height={multiFactions.length * 20 + 36} xmlns="http://www.w3.org/2000/svg">
                  {/* Group color indicator bars */}
                  {SECTIONS.map((sec, si) => (
                    <rect x={140 + si * 16} y="0" width="15" height="4" rx="1" fill={getGroupColor(sec.group)} opacity="0.6">
                      <title>{sec.group}</title>
                    </rect>
                  ))}
                  {/* Column headers */}
                  {colLabels.map((label, li) => (
                    <text x={140 + li * 16 + 7} y="18" fill="#555" font-size="7" font-family="monospace" text-anchor="middle">{label}</text>
                  ))}
                  {/* Rows */}
                  {multiFactions.map((f, fi) => (
                    <g>
                      <text x="0" y={24 + fi * 20 + 13} fill={f.archetype.color} font-size="9" font-family="monospace">
                        {f.archetype.name.slice(0, 16)}
                      </text>
                      {f.avgFingerprint.map((v, vi) => (
                        <rect x={140 + vi * 16} y={24 + fi * 20 + 2} width="15" height="16" rx="2"
                              fill={v !== null ? scoreToColor(v) : '#1a1a25'}
                              opacity={v !== null ? '0.85' : '0.2'}>
                          <title>{f.archetype.name} — {colLabels[vi]}: {v !== null ? formatScore(v) : 'ND'}</title>
                        </rect>
                      ))}
                    </g>
                  ))}
                </svg>
              </div>
              {/* Group legend */}
              <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px;">
                {Object.entries(groupColors).map(([group, color]) => (
                  <span style={`color: ${color}; font-size: var(--font-xs);`}>{group}</span>
                ))}
              </div>
            </td>
          </tr>
        </table>
      )}

      {/* --- Faction Signal Comparison Chart --- */}
      {multiFactions.length > 1 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Signal Comparison
                <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                  cross-faction signal profiles
                </span>
              </div>
              <div style="overflow-x: auto;">
                {(() => {
                  const sigNames = ['Epistemic Quality (EQ)', 'Solution Orientation (SO)', 'Stakeholder Rep (SR)', 'Transparency (TD)', 'Propaganda (PT, inv)', 'Fair Witness (FW)'];
                  const nF = multiFactions.length;
                  const barH = 10;
                  const groupH = nF * (barH + 2) + 14;
                  const maxBarW = 200;
                  const labelW = 170;
                  const totalH = sigNames.length * groupH + 10;
                  return (
                    <svg width={labelW + maxBarW + 10} height={totalH} xmlns="http://www.w3.org/2000/svg">
                      {sigNames.map((sn, gi) => {
                        const yOff = gi * groupH;
                        return (
                          <g>
                            <text x="0" y={yOff + 10} fill="#888" font-size="9" font-family="monospace">{sn}</text>
                            {multiFactions.map((f, fi) => {
                              const vals = [f.signals.eq, f.signals.so, f.signals.sr, f.signals.td, 1 - Math.min(f.signals.pt / 5, 1), f.signals.fw];
                              const v = clamp01(vals[gi]);
                              return (
                                <g>
                                  <rect x={labelW} y={yOff + 14 + fi * (barH + 2)} width={maxBarW} height={barH} rx="2" fill="#1a1a25" />
                                  <rect x={labelW} y={yOff + 14 + fi * (barH + 2)} width={Math.round(v * maxBarW)} height={barH} rx="2" fill={f.archetype.color} opacity="0.8">
                                    <title>{f.archetype.name}: {vals[gi].toFixed(2)}</title>
                                  </rect>
                                </g>
                              );
                            })}
                          </g>
                        );
                      })}
                    </svg>
                  );
                })()}
              </div>
              {/* Legend */}
              <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px;">
                {multiFactions.map(f => (
                  <span style={`display: inline-flex; align-items: center; gap: 4px; font-size: var(--font-xs);`}>
                    <span style={`display: inline-block; width: 8px; height: 8px; border-radius: 2px; background: ${f.archetype.color};`}></span>
                    <span style={`color: ${f.archetype.color};`}>{f.archetype.name}</span>
                  </span>
                ))}
              </div>
            </td>
          </tr>
        </table>
      )}

      {/* --- Alliance Table --- */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
        <tr>
          <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
              Strongest Alliances
              <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                top 20 most similar domain pairs
              </span>
            </div>
            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
              <tr style="color: #555;">
                <td>Domain A</td><td>Domain B</td><td style="text-align: right;">Similarity</td><td>Shared Faction</td><td>Key Overlap</td>
              </tr>
              {top20Alliances.map(p => (
                <tr style="border-top: 1px solid #1a1a25;">
                  <td><a href={`/domain/${p.a}`} style="color: #aaa; text-decoration: none;">{p.a}</a></td>
                  <td><a href={`/domain/${p.b}`} style="color: #aaa; text-decoration: none;">{p.b}</a></td>
                  <td style="text-align: right; color: #34d399;" class="score-font">{p.similarity.toFixed(3)}</td>
                  <td style="color: #888;">{findSharedFaction(p.a, p.b) || '—'}</td>
                  <td style="color: #888;">{getSignalOverlap(p.a, p.b)}</td>
                </tr>
              ))}
            </table>
          </td>
        </tr>
      </table>

      {/* --- Rivalry Table --- */}
      {rivalPairs.length > 0 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Strongest Rivals
                <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                  pairs with similarity &lt; 0.3
                </span>
              </div>
              <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                <tr style="color: #555;">
                  <td>Domain A</td><td>Domain B</td><td style="text-align: right;">Similarity</td><td>Key Divergence</td>
                </tr>
                {rivalPairs.map(p => (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td><a href={`/domain/${p.a}`} style="color: #aaa; text-decoration: none;">{p.a}</a></td>
                    <td><a href={`/domain/${p.b}`} style="color: #aaa; text-decoration: none;">{p.b}</a></td>
                    <td style="text-align: right; color: #f87171;" class="score-font">{p.similarity.toFixed(3)}</td>
                    <td style="color: #888; font-size: var(--font-xs);">{getSignalDivergence(p.a, p.b)}</td>
                  </tr>
                ))}
              </table>
            </td>
          </tr>
        </table>
      )}

      {/* --- Lone Wolves --- */}
      {loneWolves.length > 0 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0 20px 0;">
          <tr>
            <td style="padding: 12px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Lone Wolves
                <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                  single-member clusters
                </span>
              </div>
              <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                <tr style="color: #555;">
                  <td>Domain</td><td style="text-align: right;">HRCB</td><td style="text-align: right;">Pts</td><td style="text-align: right;">Karma</td>
                  <td style="text-align: right;">Epistemic Quality (EQ)</td><td style="text-align: right;">Propaganda (PT)</td><td>Tone</td><td>Nearest Faction</td>
                </tr>
                {loneWolves.map(w => (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td><a href={`/domain/${w.domain}`} style="color: #aaa; text-decoration: none;">{w.domain}</a></td>
                    <td style={`text-align: right; color: ${w.score !== null ? scoreToColor(w.score) : '#555'};`} class="score-font">
                      {w.score !== null ? formatScore(w.score) : 'ND'}
                    </td>
                    <td style="text-align: right; color: #fb923c;" class="score-font">{Math.round(w.signals.hnScore)}</td>
                    <td style="text-align: right; color: #a78bfa;" class="score-font">{Math.round(w.signals.posterKarma)}</td>
                    <td style="text-align: right; color: #888;" class="score-font">{w.signals.eq.toFixed(2)}</td>
                    <td style="text-align: right; color: #888;" class="score-font">{w.signals.pt.toFixed(1)}</td>
                    <td style="color: #888;">{w.signals.dominantTone || '—'}</td>
                    <td style="color: #888;">
                      {w.nearestFaction}
                      <span style="color: #555; margin-left: 4px;" class="score-font">{w.nearestSim.toFixed(2)}</span>
                    </td>
                  </tr>
                ))}
              </table>
            </td>
          </tr>
        </table>
      )}
    </>
  )}
</Base>
