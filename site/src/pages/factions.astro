                </span>
              )}
              <span style="font-size: var(--font-xs); color: #1a5568; margin-left: 8px;">
                Thick lines = cluster centroids · Thin lines = individual domains · Bundled = agreement · Crossing = divergence
              </span>
            </div>

            {/* Threshold badges */}
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px;">
              <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #a78bfa;">
                Faction &ge; 1/&#x3C6; ({factionThreshold.toFixed(3)})
              </span>
              <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #34d399;">
                Alliance &ge; 1/&#x3C6;&sup2; ({allianceThreshold.toFixed(3)})
              </span>
              <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 2px 8px; font-size: var(--font-xs); color: #fbbf24;">
                Acquaintance &ge; 1/&#x3C6;&sup3; ({acquaintanceThreshold.toFixed(3)})
              </span>
            </div>
          </td>
        </tr>
      </table>

      {/* === Section 2: What Drives Differentiation === */}
      {enrichedClusters.length > 1 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
              <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
                What Drives Differentiation
                <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                  inter-cluster variance per signal dimension
                </span>
              </div>
              <svg width="100%" viewBox={`0 0 500 ${interClusterVar.length * 28 + 10}`} style="max-width: 500px; height: auto;">
                {interClusterVar.map((v, i) => {
                  const barW = (v.variance / maxVar) * 350;
                  const y = i * 28 + 5;
                  return (
                    <g>
                      <text x="70" y={y + 14} fill="#5b7279" font-size="10" font-family="monospace" text-anchor="end">{v.code}</text>
                      <rect x="80" y={y + 2} width={350} height="16" rx="2" fill="#0d4655" />
                      <rect x="80" y={y + 2} width={Math.max(barW, 2)} height="16" rx="2" fill={v.color} opacity="0.8">
                        <title>{v.label}: variance {v.variance.toFixed(3)}</title>
                      </rect>
                      <text x={85 + barW} y={y + 14} fill="#5b7279" font-size="9" font-family="monospace">{v.variance.toFixed(3)}</text>
                    </g>
                  );
                })}
              </svg>
            </td>
          </tr>
        </table>
      )}

      {/* === Section 3: Cluster Cards === */}
      {enrichedClusters.map((cl) => {
        // Radar chart values: normalize rawCentroid values to [0,1] for display
        const radarSize = 200;
        const radarCx = radarSize / 2;
        const radarCy = radarSize / 2;
        const radarR = radarSize / 2 - 30;
        const numAxes = nDims;
        const angleStep = 360 / numAxes;

        function polarToXY(angle: number, r: number): [number, number] {
          const rad = ((angle - 90) * Math.PI) / 180;
          return [radarCx + r * Math.cos(rad), radarCy + r * Math.sin(rad)];
        }

        // Normalize values for radar: map from raw to [0,1]
        const radarVals = cl.rawCentroid.map((v, i) => {
          const dimMin = Math.min(...dimValues[i], 0);
          const dimMax = Math.max(...dimValues[i], 1);
          const range = dimMax - dimMin || 1;
          return clamp01((v - dimMin) / range);
        });
        const medianVals = populationMedian.map((v, i) => {
          const dimMin = Math.min(...dimValues[i], 0);
          const dimMax = Math.max(...dimValues[i], 1);
          const range = dimMax - dimMin || 1;
          return clamp01((v - dimMin) / range);
        });

        const radarPoints = radarVals.map((v, i) => polarToXY(i * angleStep, v * radarR));
        const medianPoints = medianVals.map((v, i) => polarToXY(i * angleStep, v * radarR));
        const radarPoly = radarPoints.map(([x, y]) => `${x},${y}`).join(' ');
        const medianPoly = medianPoints.map(([x, y]) => `${x},${y}`).join(' ');

        return (
          <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
            <tr>
              <td style="padding: 12px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
                {/* Header */}
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px;">
                  <span style={`color: ${cl.color}; font-weight: bold; font-size: var(--font-sm);`}>
                    {cl.name}
                    <span style="color: #5b7279; font-weight: normal; margin-left: 8px; font-size: var(--font-xs);">
                      {cl.members.length} domains
                    </span>
                  </span>
                  {cl.avgScore !== null && (
                    <span class="score-font" style={`color: ${scoreToColor(cl.avgScore)}; font-size: var(--font-sm);`}>
                      {formatScore(cl.avgScore)}
                    </span>
                  )}
                </div>

                {/* Archetype + description */}
                {cl.archetype && (
                  <div style="margin-bottom: 4px;">
                    <span style="color: #5b7279; font-size: var(--font-xs); font-style: italic;">
                      {cl.icon} {cl.archetype}
                    </span>
                    {cl.description && (
                      <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 6px;">
                        &mdash; {cl.description}
                      </span>
                    )}
                  </div>
                )}

                {/* Insight */}
                <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 8px; line-height: 1.4;">
                  {cl.insight}
                </div>

                <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 10px;">
                  {/* Signal radar */}
                  <div>
                    <svg width={radarSize} height={radarSize} viewBox={`0 0 ${radarSize} ${radarSize}`} style="display: block;">
                      {/* Grid rings */}
                      {[0.25, 0.5, 0.75, 1.0].map(r => {
                        const pts = Array.from({ length: numAxes }, (_, i) => {
                          const [x, y] = polarToXY(i * angleStep, r * radarR);
                          return `${x},${y}`;
                        }).join(' ');
                        return <polygon points={pts} fill="none" stroke="#1a5568" stroke-width="1" />;
                      })}

                      {/* Axes */}
                      {SIGNAL_DIMS.map((dim, i) => {
                        const [ax, ay] = polarToXY(i * angleStep, radarR);
                        const [lx, ly] = polarToXY(i * angleStep, radarR + 18);
                        return (
                          <g>
                            <line x1={radarCx} y1={radarCy} x2={ax} y2={ay} stroke="#1a5568" stroke-width="1" />
                            <text x={lx} y={ly} fill={dim.color} font-size="8" font-family="monospace" text-anchor="middle" dominant-baseline="middle">
                              {dim.code}
                            </text>
                          </g>
                        );
                      })}

                      {/* Population median polygon */}
                      <polygon points={medianPoly} fill="none" stroke="#5b7279" stroke-width="1" stroke-dasharray="3,2" />

                      {/* Cluster data polygon */}
                      <polygon points={radarPoly} fill={cl.color} fill-opacity="0.15" stroke={cl.color} stroke-width="2" />

                      {/* Data points */}
                      {radarPoints.map(([x, y], i) => (
                        <circle cx={x} cy={y} r="3" fill={cl.color} stroke="#093946" stroke-width="1">
                          <title>{SIGNAL_DIMS[i].code}: {cl.rawCentroid[i].toFixed(2)}</title>
                        </circle>
                      ))}
                    </svg>
                    <div style="text-align: center; font-size: 8px; color: #5b7279; margin-top: 2px;">
                      <span style={`color: ${cl.color};`}>&#9632;</span> cluster
                      <span style="color: #5b7279; margin-left: 6px;">- - -</span> population median
                    </div>
                  </div>

                  {/* Key characteristics */}
                  <div style="flex: 1; min-width: 200px;">
                    <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 4px;">Key Characteristics</div>
                    <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
                      {cl.dominantTone && (
                        <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #5b7279;">
                          {cl.dominantTone}
                        </span>
                      )}
                      {cl.dominantScope && (
                        <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #5b7279;">
                          {cl.dominantScope}
                        </span>
                      )}
                      {cl.dominantReadingLevel && (
                        <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #5b7279;">
                          {cl.dominantReadingLevel}
                        </span>
                      )}
                      {cl.avgSetl !== null && (
                        <span style="background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: #5b7279;">
                          SETL <span class="score-font" style={`color: ${scoreToColor(cl.avgSetl)};`}>{cl.avgSetl > 0 ? '+' : ''}{cl.avgSetl.toFixed(2)}</span>
                        </span>
                      )}
                    </div>

                    {/* HN engagement */}
                    <div style="display: flex; gap: 16px; margin-bottom: 10px; font-size: var(--font-xs);">
                      <span style="color: #5b7279;">
                        <span style="color: #5b7279;">Pts</span> <span class="score-font" style="color: #fb923c;">{Math.round(cl.avgHnScore)}</span>
                      </span>
                      <span style="color: #5b7279;">
                        <span style="color: #5b7279;">Cmts</span> <span class="score-font" style="color: #60a5fa;">{Math.round(cl.avgHnComments)}</span>
                      </span>
                    </div>

                    {/* Member domains */}
                    <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 4px;">Members</div>
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                      {cl.members.map(m => {
                        const score = domainScoreMap.get(m);
                        const isLiminal = cl.liminalMembers.some(l => l.domain === m);
                        return (
                          <a href={`/domain/${m}`}
                             style={`color: ${score !== undefined && score !== null ? scoreToColor(score) : '#5b7279'}; font-size: var(--font-xs); padding: 2px 6px; background: #002d38; border: 1px solid ${isLiminal ? '#fbbf24' : '#1a5568'}; border-radius: 3px; text-decoration: none;`}>
                            {m}
                            {score !== null && score !== undefined && (
                              <span class="score-font" style="margin-left: 3px; font-size: var(--font-xs);">{formatScore(score)}</span>
                            )}
                            {isLiminal && <span style="color: #fbbf24; margin-left: 2px;" title="Liminal member (high affinity with another cluster)">*</span>}
                          </a>
                        );
                      })}
                    </div>

                    {/* Liminal members detail */}
                    {cl.liminalMembers.length > 0 && (
                      <div style="margin-top: 6px; font-size: var(--font-xs); color: #5b7279;">
                        <span style="color: #fbbf24;">*</span> Liminal:
                        {cl.liminalMembers.map(l => (
                          <span style="margin-left: 4px;">
                            {l.domain} &rarr; {l.secondCluster} <span class="score-font" style="color: #5b7279;">({l.similarity.toFixed(2)})</span>
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </td>
            </tr>
          </table>
        );
      })}

      {/* === Section 4: Inter-Cluster Affinity Matrix === */}
      {nClusters > 1 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
              <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Inter-Cluster Affinity
                <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                  cosine similarity between cluster centroids
                </span>
              </div>
              <div style="overflow-x: auto;">
                <svg width={nClusters * 60 + 180} height={nClusters * 60 + 40} viewBox={`0 0 ${nClusters * 60 + 180} ${nClusters * 60 + 40}`}>
                  {/* Column headers */}
                  {enrichedClusters.map((cl, j) => (
                    <text x={180 + j * 60 + 25} y="16" fill={cl.color} font-size="7" font-family="monospace" text-anchor="middle">
                      {cl.name.length > 12 ? cl.name.slice(0, 12) + '..' : cl.name}
                    </text>
                  ))}
                  {/* Rows */}
                  {enrichedClusters.map((clI, i) => (
                    <g>
                      <text x="175" y={26 + i * 60 + 25} fill={clI.color} font-size="7" font-family="monospace" text-anchor="end">
                        {clI.name.length > 22 ? clI.name.slice(0, 22) + '..' : clI.name}
                      </text>
                      {enrichedClusters.map((clJ, j) => {
                        const sim = affinityMatrix[i][j];
                        const tier = tierLabel(sim);
                        return (
                          <g>
                            <rect x={180 + j * 60} y={26 + i * 60} width="50" height="50" rx="4"
                                  fill={affinityColor(sim)} opacity={affinityOpacity(sim)}>
                              <title>{clI.name} vs {clJ.name}: {sim.toFixed(3)} ({tier.label})</title>
                            </rect>
                            <text x={180 + j * 60 + 25} y={26 + i * 60 + 28} fill="#98a8a8" font-size="10" font-family="monospace" text-anchor="middle">
                              {sim.toFixed(2)}
                            </text>
                            {i !== j && (
                              <text x={180 + j * 60 + 25} y={26 + i * 60 + 40} fill="#8faaab" font-size="7" font-family="monospace" text-anchor="middle">
                                {tier.label}
                              </text>
                            )}
                          </g>
                        );
                      })}
                    </g>
                  ))}
                </svg>
              </div>
              <div style="display: flex; gap: 12px; margin-top: 6px; font-size: var(--font-xs); color: #5b7279;">
                <span><span style="color: #34d399;">&#9632;</span> Allied</span>
                <span><span style="color: #fbbf24;">&#9632;</span> Acquaintance</span>
                <span><span style="color: #0d4655;">&#9632;</span> Neutral</span>
                <span><span style="color: #f87171;">&#9632;</span> Rival</span>
              </div>
            </td>
          </tr>
        </table>
      )}

      {/* === Section 6: Interesting Pairs === */}
      {(crossClusterPairs.length > 0 || sameClusterDivergent.length > 0) && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
              <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Interesting Pairs
                <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                  editorially similar across clusters &amp; divergent within clusters
                </span>
              </div>
              <div style="display: flex; gap: 16px; flex-wrap: wrap;">
                {/* Left: cross-cluster closest */}
                {crossClusterPairs.length > 0 && (
                  <div style="flex: 1; min-width: 280px;">
                    <div style="color: #34d399; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; border-bottom: 1px solid rgba(52, 211, 153, 0.2); padding-bottom: 4px;">
                      Cross-Cluster Harmony
                    </div>
                    <div class="table-wrap">
                      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                        <tr style="color: #5b7279;">
                          <td>Domain A</td><td>Domain B</td><td style="text-align: right;">Sim</td><td>Clusters</td>
                        </tr>
                        {crossClusterPairs.map(p => (
                          <tr style="border-top: 1px solid #0d4655; background: rgba(52, 211, 153, 0.03);">
                            <td><a href={`/domain/${p.a}`} style="color: #8faaab; text-decoration: none;">{p.a}</a></td>
                            <td><a href={`/domain/${p.b}`} style="color: #8faaab; text-decoration: none;">{p.b}</a></td>
                            <td style="text-align: right; color: #34d399;" class="score-font">{p.similarity.toFixed(3)}</td>
                            <td style="color: #5b7279; font-size: var(--font-xs);">{p.clusterA} / {p.clusterB}</td>
                          </tr>
                        ))}
                      </table>
                    </div>
                  </div>
                )}
                {/* Right: same-cluster most divergent */}
                {sameClusterDivergent.length > 0 && (
                  <div style="flex: 1; min-width: 280px;">
                    <div style="color: #f87171; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; border-bottom: 1px solid rgba(248, 113, 113, 0.2); padding-bottom: 4px;">
                      Intra-Cluster Tension
                    </div>
                    <div class="table-wrap">
                      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                        <tr style="color: #5b7279;">
                          <td>Domain A</td><td>Domain B</td><td style="text-align: right;">Sim</td><td>Cluster</td>
                        </tr>
                        {sameClusterDivergent.map(p => (
                          <tr style="border-top: 1px solid #0d4655; background: rgba(248, 113, 113, 0.03);">
                            <td><a href={`/domain/${p.a}`} style="color: #8faaab; text-decoration: none;">{p.a}</a></td>
                            <td><a href={`/domain/${p.b}`} style="color: #8faaab; text-decoration: none;">{p.b}</a></td>
                            <td style="text-align: right; color: #f87171;" class="score-font">{p.similarity.toFixed(3)}</td>
                            <td style="color: #5b7279; font-size: var(--font-xs);">{p.cluster}</td>
                          </tr>
                        ))}
                      </table>
                    </div>
                  </div>
                )}
              </div>
            </td>
          </tr>
        </table>
      )}

      {/* === Section 7: Outliers & Lone Wolves === */}
      {outlierEntries.length > 0 && (
        <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0;">
          <tr>
            <td style="padding: 12px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
              <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Outliers & Lone Wolves
                <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                  domains not assigned to any cluster, sorted by outlier score
                </span>
              </div>
              <div class="table-wrap">
                <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                  <tr style="color: #5b7279;">
                    <td>Domain</td>
                    <td style="text-align: right;">HRCB</td>
                    <td style="text-align: right;">Outlier</td>
                    <td>Nearest Cluster</td>
                    <td style="text-align: right;">Similarity</td>
                    <td>Key Signal</td>
                    <td>Tone</td>
                  </tr>
                  {outlierEntries.map(w => {
                    const tier = tierLabel(w.nearestSim);
                    return (
                      <tr style="border-top: 1px solid #0d4655;">
                        <td><a href={`/domain/${w.domain}`} style="color: #8faaab; text-decoration: none;">{w.domain}</a></td>
                        <td style={`text-align: right; color: ${w.score !== null ? scoreToColor(w.score) : '#5b7279'};`} class="score-font">
                          {w.score !== null ? formatScore(w.score) : 'ND'}
                        </td>
                        <td style="text-align: right; color: #fb923c;" class="score-font">{w.outlierScore.toFixed(2)}</td>
                        <td style="color: #5b7279;">
                          {w.nearestCluster}
                        </td>
                        <td style={`text-align: right; color: ${tier.color};`} class="score-font">
                          {w.nearestSim.toFixed(2)}
                          <span style="color: #5b7279; margin-left: 3px; font-size: var(--font-xs);">{tier.label}</span>
                        </td>
                        <td style="color: #5b7279;">{w.keySignal}</td>
                        <td style="color: #5b7279;">{w.tone || '\u2014'}</td>
                      </tr>
                    );
                  })}
                </table>
              </div>
            </td>
          </tr>
        </table>
      )}

      {/* === Section 8: Methodology Notes === */}
      <table cellpadding="0" cellspacing="0" width="100%" style="padding: 4px 0 20px 0;">
        <tr>
          <td>
            <details style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 12px;">
              <summary style="color: #5b7279; font-size: var(--font-sm); cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;">
                Methodology Notes
              </summary>
              <div style="color: #5b7279; font-size: var(--font-xs); line-height: 1.6; margin-top: 8px;">
                <p><strong style="color: #5b7279;">Clustering input:</strong> 8 signal dimensions per domain &mdash;
                  Epistemic Quality (EQ), Solution Orientation (SO), Stakeholder Representation (SR), Transparency (TD),
                  Propaganda Techniques (PT, inverted), Arousal (AR), Valence (VA), Fair Witness (FW).</p>
                <p><strong style="color: #5b7279;">Z-normalization:</strong> Each dimension is standardized to zero mean and unit variance
                  across all domains with 3+ evaluations. Missing values are imputed as 0 (population mean). Domains with &gt;3 missing dimensions are flagged.</p>
                <p><strong style="color: #5b7279;">Similarity:</strong> Cosine similarity on z-normalized 8D vectors measures editorial character similarity
                  independent of magnitude.</p>
                <p><strong style="color: #5b7279;">Clustering:</strong> Agglomerative hierarchical clustering with average linkage. Pairs are sorted by
                  descending similarity and greedily merged when average inter-cluster similarity &ge; 1/&#x3C6; (~0.618).
                  If this produces a single giant cluster, the fallback threshold 1/&#x3C6;&sup2; (~0.382) is used.</p>
                <p><strong style="color: #5b7279;">Golden ratio tiers:</strong>
                  Faction &ge; 1/&#x3C6; (0.618) &middot;
                  Alliance &ge; 1/&#x3C6;&sup2; (0.382) &middot;
                  Acquaintance &ge; 1/&#x3C6;&sup3; (0.236) &middot;
                  Neutral &ge; 0 &middot;
                  Rival &lt; 0</p>
                <p><strong style="color: #5b7279;">Parallel coordinates:</strong> Each domain is drawn as a polyline across 8 vertical axes
                  (one per signal dimension). Values are normalized to the observed min/max per dimension. Thick lines show cluster centroids;
                  thin lines show individual domains. Bundled lines indicate agreement; crossing lines indicate divergence.</p>
                <p><strong style="color: #5b7279;">Archetype naming:</strong> ~12 pattern rules map signal combinations to descriptive names
                  (e.g., high EQ + high TD + low PT &rarr; &ldquo;Rigorous Analysts&rdquo;). Fallback uses marker-based names.</p>
                <p><strong style="color: #5b7279;">Minimum data:</strong> Requires 5+ domains with 3+ evaluations each.</p>
              </div>
            </details>
          </td>
        </tr>
      </table>
    </>
  )}
</Base>
