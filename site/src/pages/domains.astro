---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getAllDomainStats, getDomainIntelligence, getMostGatekeptDomains, getDomainKarmaMap } from '../lib/db';
import type { DomainSortOption } from '../lib/db';
import { scoreToColor, formatScore, formatSetl, setlToColor, confidenceToColor, formatConfidence } from '../lib/colors';
import { cachedQuery } from '../lib/db-utils';

const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'count') as DomainSortOption;
const validDomainSorts: DomainSortOption[] = ['count', 'score', 'setl', 'conf'];
const safeSort = validDomainSorts.includes(sort) ? sort : 'count';

const classify = url.searchParams.get('class') || 'all';
const validClassify = ['all', 'positive', 'negative', 'neutral', 'contested'];
const safeClassify = validClassify.includes(classify) ? classify : 'all';

const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));
const PER_PAGE = 50;
const offset = (page - 1) * PER_PAGE;
const isFirstPage = page === 1;

// For classification filters, we need to fetch more since filtering reduces results.
// For 'all' (no filter), use paginated DB query directly.
const fetchLimit = safeClassify === 'all' ? PER_PAGE + 1 : 500;
const fetchOffset = safeClassify === 'all' ? offset : 0;

const fetchPromises: [Promise<DomainStat[]>, Promise<any[]>, Promise<any[]>, Promise<{domain: string; avg_karma: number; user_count: number}[]>] = [
  cachedQuery(kv, `allDomainStats:${safeSort}:${fetchLimit}:${fetchOffset}`, () => getAllDomainStats(db, safeSort, fetchLimit, fetchOffset)).catch(() => []),
  isFirstPage
    ? cachedQuery(kv, 'domainIntelligence', () => getDomainIntelligence(db, 'stories', 3, 150)).catch(() => [])
    : Promise.resolve([]),
  isFirstPage
    ? cachedQuery(kv, 'mostGatekeptDomains', () => getMostGatekeptDomains(db)).catch(() => [])
    : Promise.resolve([]),
  isFirstPage
    ? cachedQuery<{domain: string; avg_karma: number; user_count: number}[]>(kv, 'domainKarmaMap', async () => {
        const m = await getDomainKarmaMap(db);
        return [...m.values()];
      }, 600).catch(() => [])
    : Promise.resolve([]),
];
const [allDomains, intelDomains, gatekeptDomains, karmaMapArr] = await Promise.all(fetchPromises);
const karmaMap = new Map(karmaMapArr.map(k => [k.domain, k]));

// Insight cards from domain-intel (page 1 only)
const hrcbDomains = intelDomains.filter(d => d.evaluated >= 3 && d.avg_hrcb !== null);
const topHrcb = [...hrcbDomains].sort((a, b) => (b.avg_hrcb || 0) - (a.avg_hrcb || 0)).slice(0, 5);
const bottomHrcb = [...hrcbDomains].sort((a, b) => (a.avg_hrcb || 0) - (b.avg_hrcb || 0)).slice(0, 5);
const controversial = [...hrcbDomains].filter(d => d.hrcb_range !== null).sort((a, b) => (b.hrcb_range || 0) - (a.hrcb_range || 0)).slice(0, 5);
const highEngagement = intelDomains.filter(d => d.stories >= 3 && d.comment_per_point !== null).sort((a, b) => (b.comment_per_point || 0) - (a.comment_per_point || 0)).slice(0, 5);
const diverse = intelDomains.filter(d => d.stories >= 3).sort((a, b) => b.unique_submitters - a.unique_submitters).slice(0, 5);
const topKarma = [...karmaMap.values()].sort((a, b) => b.avg_karma - a.avg_karma).slice(0, 5);

// Scatter data: merge karma + HRCB per domain (page 1 only)
const scatterDomains = intelDomains
  .filter(d => d.avg_hrcb !== null && karmaMap.has(d.domain) && (karmaMap.get(d.domain)?.avg_karma ?? 0) > 0)
  .map(d => {
    const k = karmaMap.get(d.domain)!;
    return { domain: d.domain, avg_karma: k.avg_karma, avg_hrcb: d.avg_hrcb as number, stories: d.stories };
  });

// Pearson r on log10(karma) vs avg_hrcb
let domainPearsonR: number | null = null;
if (scatterDomains.length >= 5) {
  const logK = scatterDomains.map(d => Math.log10(d.avg_karma));
  const hrcbs = scatterDomains.map(d => d.avg_hrcb);
  const n = scatterDomains.length;
  const sumA = logK.reduce((s, v) => s + v, 0);
  const sumB = hrcbs.reduce((s, v) => s + v, 0);
  const sumAB = logK.reduce((s, v, i) => s + v * hrcbs[i], 0);
  const sumA2 = logK.reduce((s, v) => s + v * v, 0);
  const sumB2 = hrcbs.reduce((s, v) => s + v * v, 0);
  const num = n * sumAB - sumA * sumB;
  const den = Math.sqrt(Math.max(0, n * sumA2 - sumA * sumA) * Math.max(0, n * sumB2 - sumB * sumB));
  domainPearsonR = den > 0 ? num / den : null;
}
const domainScatterJson = JSON.stringify(scatterDomains);

// Filter by classification + paginate
let domains: DomainStat[];
let hasMore: boolean;

if (safeClassify === 'all') {
  // DB-level pagination — fetched PER_PAGE + 1
  hasMore = allDomains.length > PER_PAGE;
  domains = hasMore ? allDomains.slice(0, PER_PAGE) : allDomains;
} else {
  // Client-side filter — fetched 500, slice for current page
  const filtered = allDomains.filter(d => {
    if (d.avg_score === null) return false;
    switch (safeClassify) {
      case 'positive': return d.avg_score > 0.05;
      case 'negative': return d.avg_score < -0.05;
      case 'neutral': return d.avg_score >= -0.05 && d.avg_score <= 0.05;
      case 'contested': return d.count >= 3 && d.avg_score !== null && Math.abs(d.avg_score) < 0.15;
      default: return true;
    }
  });
  const pageSlice = filtered.slice(offset, offset + PER_PAGE + 1);
  hasMore = pageSlice.length > PER_PAGE;
  domains = hasMore ? pageSlice.slice(0, PER_PAGE) : pageSlice;
}

function buildDomainUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const s = params.sort ?? safeSort;
  const c = params.class ?? safeClassify;
  const pg = params.p ?? '1';
  if (s !== 'count') p.set('sort', s);
  if (c !== 'all') p.set('class', c);
  if (pg !== '1') p.set('p', pg);
  const qs = p.toString();
  return qs ? `/domains?${qs}` : '/domains';
}

const siteUrl = url.origin;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'HN HRCB — Domain Signal Profiles',
  description: `Aggregated HRCB scores and supplementary signals for ${allDomains.length} domains from Hacker News stories`,
  url: `${siteUrl}/domains`,
  numberOfItems: allDomains.length,
  itemListElement: allDomains.slice(0, 20).map((d, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Organization',
      name: d.domain,
      url: `${siteUrl}/domain/${d.domain}`,
    },
  })),
};
---

<Base title="Domains">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'sources', href: '/sources' }, { label: 'domains' }]} />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">Domains</span>
        <span style="color: #5b7279; margin-left: 8px; font-size: var(--font-base);">
          {safeClassify !== 'all' ? `(${safeClassify})` : ''}{page > 1 ? ` · page ${page}` : ''}
        </span>
        <div class="subtext" style="font-size: var(--font-sm); margin-top: 4px;">
          <span style="color: #5b7279;">sort:</span>
          {(['count', 'score', 'setl', 'conf'] as const).map((opt, i) => {
            const labels = { count: 'stories', score: 'hrcb', setl: 'setl', conf: 'confidence' } as any;
            return (
              <>
                {i > 0 && <span style="color: #1a5568;"> | </span>}
                {safeSort === opt
                  ? <span style="color: #d56500; font-weight: bold;">{labels[opt]}</span>
                  : <a href={buildDomainUrl({ sort: opt })}>{labels[opt]}</a>
                }
              </>
            );
          })}
          <br />
          <span style="color: #5b7279;">show:</span>
          {(['all', 'positive', 'negative', 'neutral', 'contested'] as const).map((opt, i) => (
            <>
              {i > 0 && <span style="color: #1a5568;"> | </span>}
              {safeClassify === opt
                ? <span style="color: #d56500; font-weight: bold;">{opt}</span>
                : <a href={buildDomainUrl({ class: opt })}>{opt}</a>
              }
            </>
          ))}
        </div>
      </td>
    </tr>
  </table>

  {/* Domain insight cards (page 1 only) */}
  {isFirstPage && hrcbDomains.length > 0 && (
    <div style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px; margin-bottom: 10px;">
      <div class="insight-grid">
        <div style="padding: 4px 8px;">
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most HR-Positive</div>
          {topHrcb.map(d => (
            <div style="margin-bottom: 3px;">
              <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
              <span class="score-font" style={`color: ${scoreToColor(d.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(d.avg_hrcb)}</span>
            </div>
          ))}
        </div>
        <div style="padding: 4px 8px;">
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most HR-Negative</div>
          {bottomHrcb.map(d => (
            <div style="margin-bottom: 3px;">
              <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
              <span class="score-font" style={`color: ${scoreToColor(d.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(d.avg_hrcb)}</span>
            </div>
          ))}
        </div>
        <div style="padding: 4px 8px;">
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Contested</div>
          {controversial.map(d => (
            <div style="margin-bottom: 3px;">
              <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
              <span class="score-font" style="color: #e2b340; font-size: var(--font-sm); margin-left: 4px;">{d.hrcb_range !== null ? d.hrcb_range.toFixed(2) : '--'}</span>
            </div>
          ))}
        </div>
        <div style="padding: 4px 8px;">
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Engaging</div>
          {highEngagement.map(d => (
            <div style="margin-bottom: 3px;">
              <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
              <span class="score-font" style="color: #60a5fa; font-size: var(--font-sm); margin-left: 4px;">{d.comment_per_point !== null ? d.comment_per_point.toFixed(2) : '--'}</span>
              <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 2px;">c/pt</span>
            </div>
          ))}
        </div>
        <div style="padding: 4px 8px;">
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Diverse</div>
          {diverse.map(d => (
            <div style="margin-bottom: 3px;">
              <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
              <span class="score-font" style="color: #a78bfa; font-size: var(--font-sm); margin-left: 4px;">{d.unique_submitters}</span>
              <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 2px;">users</span>
            </div>
          ))}
        </div>
        {topKarma.length > 0 && (
          <div style="padding: 4px 8px;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Highest Karma</div>
            {topKarma.map(d => (
              <div style="margin-bottom: 3px;">
                <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
                <span class="score-font" style="color: #22d3ee; font-size: var(--font-sm); margin-left: 4px;">{Math.round(d.avg_karma).toLocaleString()}</span>
                <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 2px;">avg</span>
              </div>
            ))}
          </div>
        )}
        {gatekeptDomains.length > 0 && (
          <div style="padding: 4px 8px;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Gatekept</div>
            {gatekeptDomains.map(d => (
              <div style="margin-bottom: 3px;">
                <a href={`/domain/${d.domain}`} style="color: #98a8a8; font-size: var(--font-sm);">{d.domain}</a>
                <span class="score-font" style="color: #d56500; font-size: var(--font-sm); margin-left: 4px;">{d.gate_pct}%</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  )}

  {/* Domain Karma vs HRCB scatter (page 1 only) */}
  {isFirstPage && scatterDomains.length >= 5 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
            Domain Karma vs HRCB
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
              avg poster karma vs avg HRCB per domain · {scatterDomains.length} domains
            </span>
            {domainPearsonR !== null && (
              <span style={`margin-left: 8px; background: #002d38; border: 1px solid #1a5568; border-radius: 3px; padding: 1px 6px; font-size: var(--font-xs); color: ${Math.abs(domainPearsonR) > 0.3 ? '#22d3ee' : '#5b7279'};`}>
                r = {domainPearsonR > 0 ? '+' : ''}{domainPearsonR.toFixed(3)}
              </span>
            )}
          </div>
          <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 4px;">
            X: log&#8321;&#8320;(avg karma) · Y: avg HRCB · size: story count · hover for details
          </div>
          <canvas id="domain-karma-scatter" width="800" height="400" style="width: 100%; max-width: 800px; height: auto; aspect-ratio: 2/1; background: #002d38; border-radius: 4px;" aria-label="Domain karma vs HRCB scatter plot"></canvas>
        </td>
      </tr>
    </table>
  )}

  <div class="table-wrap">
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 20px;">
    <tr>
      <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        {domains.length > 0 ? (
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base); min-width: 480px;">
            <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td width="24">#</td>
              <td>Domain</td>
              <td width="70" align="center">Stories</td>
              <td width="80" align="center" title="Evaluated / Total (percentage)">Coverage</td>
              <td width="80" align="center">Avg HRCB</td>
              <td width="60" align="center" title="Average editorial channel score">Avg E</td>
              <td width="60" align="center" title="Average structural channel score">Avg S</td>
              <td width="60" align="center" title="Evidence-weighted confidence">Avg Conf</td>
              <td width="70" align="center" title="Structural-Editorial Tension Level">Avg SETL</td>
            </tr>
            {domains.map((d, i) => {
              const pct = d.count > 0 ? Math.round((d.evaluated / d.count) * 100) : 0;
              const coverageColor = pct === 100 ? '#4ade80' : pct >= 50 ? '#eab308' : '#5b7279';
              return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="color: #5b7279;" class="score-font">{offset + i + 1}</td>
                <td>
                  <a href={`/domain/${d.domain}`} style="color: #98a8a8;">{d.domain}</a>
                </td>
                <td align="center" class="score-font" style="color: #5b7279;">{d.count}</td>
                <td align="center" class="score-font" style={`color: ${coverageColor};`}>
                  {d.evaluated}/{d.count} <span style="color: #5b7279;">({pct}%)</span>
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(d.avg_score)};`}>
                  {d.avg_score !== null ? formatScore(d.avg_score) : <span style="color: #5b7279;">—</span>}
                </td>
                <td align="center" class="score-font" style={`color: ${d.avg_editorial !== null ? scoreToColor(d.avg_editorial) : '#5b7279'};`}>
                  {d.avg_editorial !== null ? formatScore(d.avg_editorial) : <span style="color: #5b7279;">—</span>}
                </td>
                <td align="center" class="score-font" style={`color: ${d.avg_structural !== null ? scoreToColor(d.avg_structural) : '#5b7279'};`}>
                  {d.avg_structural !== null ? formatScore(d.avg_structural) : <span style="color: #5b7279;">—</span>}
                </td>
                <td align="center" class="score-font" style={`color: ${confidenceToColor(d.avg_conf)};`}>
                  {d.avg_conf !== null ? formatConfidence(d.avg_conf) : <span style="color: #5b7279;">—</span>}
                </td>
                <td align="center" class="score-font" style={`color: ${setlToColor(d.avg_setl)};`}>
                  {d.avg_setl !== null ? formatSetl(d.avg_setl) : <span style="color: #5b7279;">—</span>}
                </td>
              </tr>
              );
            })}
          </table>
        ) : (
          <div style="color: #5b7279; font-size: var(--font-sm); padding: 10px;">
            {safeClassify !== 'all' ? `No ${safeClassify} domains found.` : 'No domain data yet.'}
            {safeClassify !== 'all' && (
              <a href="/domains" style="color: #d56500; margin-left: 6px;">show all</a>
            )}
          </div>
        )}
      </td>
    </tr>
  </table>
  </div>

  {/* Pagination */}
  {(hasMore || page > 1) && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="text-align: center; padding: 8px;">
          {page > 1 && (
            <a href={buildDomainUrl({ p: String(page - 1) })} style="color: #d56500; margin-right: 16px;">
              prev
            </a>
          )}
          {hasMore && (
            <a href={buildDomainUrl({ p: String(page + 1) })} style="color: #d56500;">
              More
            </a>
          )}
        </td>
      </tr>
    </table>
  )}

  <script define:vars={{ domainScatterJson }}>
    const data = JSON.parse(domainScatterJson);
    const canvas = document.getElementById('domain-karma-scatter');
    if (canvas && data.length > 0) {
      const ctx = canvas.getContext('2d');
      const W = canvas.width, H = canvas.height;
      const pad = 40;

      const logKarmas = data.map(d => Math.log10(d.avg_karma));
      const minLK = Math.min(...logKarmas);
      const maxLK = Math.max(...logKarmas);
      const minHrcb = Math.min(...data.map(d => d.avg_hrcb), -0.5);
      const maxHrcb = Math.max(...data.map(d => d.avg_hrcb), 0.5);
      const maxStories = Math.max(...data.map(d => d.stories), 1);

      function x(lk) { return pad + ((lk - minLK) / (maxLK - minLK || 1)) * (W - pad * 2); }
      function y(hrcb) { return H - pad - ((hrcb - minHrcb) / (maxHrcb - minHrcb)) * (H - pad * 2); }

      // Axes
      ctx.strokeStyle = '#1a5568';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad, pad); ctx.lineTo(pad, H - pad); ctx.lineTo(W - pad, H - pad);
      ctx.stroke();

      // Zero line
      const zeroY = y(0);
      ctx.strokeStyle = '#0d4655';
      ctx.setLineDash([3, 3]);
      ctx.beginPath();
      ctx.moveTo(pad, zeroY); ctx.lineTo(W - pad, zeroY);
      ctx.stroke();
      ctx.setLineDash([]);

      // Labels
      ctx.fillStyle = '#5b7279';
      ctx.font = '10px monospace';
      ctx.fillText('0', pad - 12, zeroY + 3);
      ctx.fillText(`10^${maxLK.toFixed(1)}`, W - pad - 40, H - pad + 15);
      ctx.fillText(`10^${minLK.toFixed(1)}`, pad, H - pad + 15);

      function fmtScore(s) {
        if (s === null) return 'ND';
        return (s > 0 ? '+' : '') + s.toFixed(2);
      }

      function scoreColor(score) {
        if (score > 0) {
          const t = Math.min(score, 1);
          return `rgb(${Math.round(234+(22-234)*t)},${Math.round(179+(163-179)*t)},${Math.round(8+(74-8)*t)})`;
        } else if (score < 0) {
          const t = Math.min(Math.abs(score), 1);
          return `rgb(${Math.round(234+(220-234)*t)},${Math.round(179+(38-179)*t)},${Math.round(8+(38-8)*t)})`;
        }
        return '#eab308';
      }

      // Points
      for (const d of data) {
        const lk = Math.log10(d.avg_karma);
        const r = 3 + (d.stories / maxStories) * 6;
        ctx.beginPath();
        ctx.arc(x(lk), y(d.avg_hrcb), r, 0, 2 * Math.PI);
        ctx.fillStyle = scoreColor(d.avg_hrcb);
        ctx.globalAlpha = 0.7;
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      // Tooltip
      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const scale = canvas.clientWidth / W;
        const mx = (e.clientX - rect.left) / scale;
        const my = (e.clientY - rect.top) / scale;
        let found = null;
        for (const d of data) {
          const lk = Math.log10(d.avg_karma);
          if (Math.hypot(x(lk) - mx, y(d.avg_hrcb) - my) < 10) {
            found = d;
            break;
          }
        }
        canvas.title = found
          ? `${found.domain}\nAvg karma: ${Math.round(found.avg_karma).toLocaleString()} | HRCB: ${fmtScore(found.avg_hrcb)} | ${found.stories} stories`
          : '';
      });
    }
  </script>
</Base>
