---
import Base from '../layouts/Base.astro';
import { getDomainIntelligence } from '../lib/db';
import type { DomainIntelSortOption } from '../lib/db';
import { scoreToColor, formatScore } from '../lib/colors';

const db = Astro.locals.runtime.env.DB;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'stories') as DomainIntelSortOption;
const validSorts: DomainIntelSortOption[] = ['stories', 'score', 'comments', 'hrcb', 'engagement', 'submitters', 'controversy'];
const safeSort = validSorts.includes(sort) ? sort : 'stories';
const minStories = Math.max(2, Math.min(20, parseInt(url.searchParams.get('min') || '2', 10) || 2));

const domains = await getDomainIntelligence(db, safeSort, minStories, 150);

// Compute aggregate stats
const totalDomains = domains.length;
const totalStories = domains.reduce((s, d) => s + d.stories, 0);
const avgEngagement = domains.filter(d => d.comment_per_point !== null).reduce((s, d) => s + (d.comment_per_point || 0), 0) / (domains.filter(d => d.comment_per_point !== null).length || 1);
const domainsWithHrcb = domains.filter(d => d.avg_hrcb !== null);
const avgHrcb = domainsWithHrcb.length > 0 ? domainsWithHrcb.reduce((s, d) => s + (d.avg_hrcb || 0), 0) / domainsWithHrcb.length : null;

// Top/bottom HRCB domains (min 3 stories evaluated)
const hrcbDomains = domains.filter(d => d.evaluated >= 3 && d.avg_hrcb !== null);
const topHrcb = [...hrcbDomains].sort((a, b) => (b.avg_hrcb || 0) - (a.avg_hrcb || 0)).slice(0, 5);
const bottomHrcb = [...hrcbDomains].sort((a, b) => (a.avg_hrcb || 0) - (b.avg_hrcb || 0)).slice(0, 5);

// Most controversial (widest HRCB range, min 3 evaluated)
const controversial = [...hrcbDomains].filter(d => d.hrcb_range !== null).sort((a, b) => (b.hrcb_range || 0) - (a.hrcb_range || 0)).slice(0, 5);

// Highest engagement (comment-per-point, min 3 stories)
const highEngagement = domains.filter(d => d.stories >= 3 && d.comment_per_point !== null).sort((a, b) => (b.comment_per_point || 0) - (a.comment_per_point || 0)).slice(0, 5);

// Most diverse (unique submitters, min 3 stories)
const diverse = domains.filter(d => d.stories >= 3).sort((a, b) => b.unique_submitters - a.unique_submitters).slice(0, 5);

function sortUrl(s: string): string {
  const p = new URLSearchParams();
  if (s !== 'stories') p.set('sort', s);
  if (minStories !== 2) p.set('min', String(minStories));
  const qs = p.toString();
  return qs ? `/domain-intel?${qs}` : '/domain-intel';
}

function minUrl(m: number): string {
  const p = new URLSearchParams();
  if (safeSort !== 'stories') p.set('sort', safeSort);
  if (m !== 2) p.set('min', String(m));
  const qs = p.toString();
  return qs ? `/domain-intel?${qs}` : '/domain-intel';
}

type SortLabels = Record<string, string>;
const sortLabels: SortLabels = {
  stories: 'stories', score: 'hn score', comments: 'comments',
  hrcb: 'hrcb', engagement: 'engagement', submitters: 'submitters', controversy: 'controversy'
};
---

<Base title="Domain Intelligence — HN HRCB">
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">Domain Intelligence</span>
        <span style="color: #828282; margin-left: 8px; font-size: var(--font-base);">
          {totalDomains} domains, {totalStories} stories
        </span>
        <div class="subtext" style="font-size: var(--font-sm); margin-top: 4px;">
          <span style="color: #666;">sort:</span>
          {Object.entries(sortLabels).map(([key, label], i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {safeSort === key
                ? <span style="color: #ff6600; font-weight: bold;">{label}</span>
                : <a href={sortUrl(key)}>{label}</a>
              }
            </>
          ))}
          <br />
          <span style="color: #666;">min stories:</span>
          {[2, 3, 5, 10].map((m, i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {minStories === m
                ? <span style="color: #ff6600; font-weight: bold;">{m}</span>
                : <a href={minUrl(m)}>{m}</a>
              }
            </>
          ))}
        </div>
      </td>
    </tr>
  </table>

  {/* --- Insight cards --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <table cellpadding="0" cellspacing="0" width="100%">
          <tr>
            {/* Most HR-positive domains */}
            <td style="vertical-align: top; width: 20%; padding: 4px 8px;">
              <div style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most HR-Positive</div>
              {topHrcb.map(d => (
                <div style="margin-bottom: 3px;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9; font-size: var(--font-sm);">{d.domain}</a>
                  <span class="score-font" style={`color: ${scoreToColor(d.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(d.avg_hrcb)}</span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 2px;">({d.evaluated})</span>
                </div>
              ))}
            </td>
            {/* Most HR-negative domains */}
            <td style="vertical-align: top; width: 20%; padding: 4px 8px; border-left: 1px solid #1a1a25;">
              <div style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most HR-Negative</div>
              {bottomHrcb.map(d => (
                <div style="margin-bottom: 3px;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9; font-size: var(--font-sm);">{d.domain}</a>
                  <span class="score-font" style={`color: ${scoreToColor(d.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(d.avg_hrcb)}</span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 2px;">({d.evaluated})</span>
                </div>
              ))}
            </td>
            {/* Most controversial */}
            <td style="vertical-align: top; width: 20%; padding: 4px 8px; border-left: 1px solid #1a1a25;">
              <div style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Contested</div>
              {controversial.map(d => (
                <div style="margin-bottom: 3px;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9; font-size: var(--font-sm);">{d.domain}</a>
                  <span class="score-font" style="color: #e2b340; font-size: var(--font-sm); margin-left: 4px;">
                    {d.hrcb_range !== null ? d.hrcb_range.toFixed(2) : '—'}
                  </span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 2px;">range</span>
                </div>
              ))}
            </td>
            {/* Highest engagement */}
            <td style="vertical-align: top; width: 20%; padding: 4px 8px; border-left: 1px solid #1a1a25;">
              <div style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Engaging</div>
              {highEngagement.map(d => (
                <div style="margin-bottom: 3px;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9; font-size: var(--font-sm);">{d.domain}</a>
                  <span class="score-font" style="color: #60a5fa; font-size: var(--font-sm); margin-left: 4px;">
                    {d.comment_per_point !== null ? d.comment_per_point.toFixed(2) : '—'}
                  </span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 2px;">c/pt</span>
                </div>
              ))}
            </td>
            {/* Most diverse */}
            <td style="vertical-align: top; width: 20%; padding: 4px 8px; border-left: 1px solid #1a1a25;">
              <div style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Diverse</div>
              {diverse.map(d => (
                <div style="margin-bottom: 3px;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9; font-size: var(--font-sm);">{d.domain}</a>
                  <span class="score-font" style="color: #a78bfa; font-size: var(--font-sm); margin-left: 4px;">{d.unique_submitters}</span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 2px;">users</span>
                </div>
              ))}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* --- Main table --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 20px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; overflow-x: auto;">
        <div style="overflow-x: auto;">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm); min-width: 900px;">
            <tr style="color: #555; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td width="20">#</td>
              <td>Domain</td>
              <td width="55" align="center" title="Total stories from this domain">Stories</td>
              <td width="55" align="center" title="Unique submitters">Users</td>
              <td width="70" align="center" title="Average HN score">Avg Pts</td>
              <td width="65" align="center" title="Average comments per story">Avg Cmt</td>
              <td width="50" align="center" title="Comments per HN point — measures discussion intensity">C/Pt</td>
              <td width="65" align="center" title="Average HRCB score">HRCB</td>
              <td width="130" align="center" title="HRCB score distribution: positive / neutral / negative">E/S Split</td>
              <td width="130" align="center" title="Percentage positive / neutral / negative">+/0/-</td>
              <td width="55" align="center" title="HRCB score range across stories from this domain">Range</td>
            </tr>
            {domains.map((d, i) => {
              const eBarW = 50;
              const sBarW = 50;
              const ePct = d.avg_editorial !== null ? Math.abs(d.avg_editorial) * 50 : 0;
              const sPct = d.avg_structural !== null ? Math.abs(d.avg_structural) * 50 : 0;
              const eColor = d.avg_editorial !== null ? scoreToColor(d.avg_editorial) : '#333';
              const sColor = d.avg_structural !== null ? scoreToColor(d.avg_structural) : '#333';
              const eDir = (d.avg_editorial || 0) >= 0 ? 'right' : 'left';
              const sDir = (d.avg_structural || 0) >= 0 ? 'right' : 'left';
              return (
                <tr style="border-top: 1px solid #1a1a25;">
                  <td style="color: #555;" class="score-font">{i + 1}</td>
                  <td>
                    <a href={`/domain/${d.domain}`} style="color: #c9c9c9;">{d.domain}</a>
                  </td>
                  <td align="center" class="score-font" style="color: #888;">{d.stories}</td>
                  <td align="center" class="score-font" style="color: #888;">{d.unique_submitters}</td>
                  <td align="center" class="score-font" style="color: #888;">{d.avg_hn_score}</td>
                  <td align="center" class="score-font" style="color: #888;">{d.avg_comments}</td>
                  <td align="center" class="score-font" style={`color: ${d.comment_per_point !== null && d.comment_per_point > 0.8 ? '#60a5fa' : '#666'};`}>
                    {d.comment_per_point !== null ? d.comment_per_point.toFixed(2) : '—'}
                  </td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(d.avg_hrcb)}; font-weight: bold;`}>
                    {d.avg_hrcb !== null ? formatScore(d.avg_hrcb) : <span style="color: #555;">—</span>}
                  </td>
                  <td align="center">
                    {d.avg_editorial !== null && d.avg_structural !== null ? (
                      <div style="display: inline-flex; gap: 4px; align-items: center;" title={`E: ${formatScore(d.avg_editorial)} | S: ${formatScore(d.avg_structural)}`}>
                        <span style="color: #555; font-size: 8px;">E</span>
                        <div style={`width: ${eBarW}px; height: 6px; background: #1a1a25; border-radius: 2px; position: relative; overflow: hidden;`}>
                          <div style={`position: absolute; ${(d.avg_editorial || 0) >= 0 ? 'left: 50%' : `left: ${50 - ePct}%`}; width: ${ePct}%; height: 100%; background: ${eColor}; border-radius: 1px;`}></div>
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: #333;"></div>
                        </div>
                        <span style="color: #555; font-size: 8px;">S</span>
                        <div style={`width: ${sBarW}px; height: 6px; background: #1a1a25; border-radius: 2px; position: relative; overflow: hidden;`}>
                          <div style={`position: absolute; ${(d.avg_structural || 0) >= 0 ? 'left: 50%' : `left: ${50 - sPct}%`}; width: ${sPct}%; height: 100%; background: ${sColor}; border-radius: 1px;`}></div>
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: #333;"></div>
                        </div>
                      </div>
                    ) : <span style="color: #555;">—</span>}
                  </td>
                  <td align="center">
                    {d.positive_pct !== null ? (
                      <div style="display: inline-flex; gap: 0; width: 100px; height: 8px; border-radius: 2px; overflow: hidden;" title={`+${d.positive_pct}% / ${d.neutral_pct}% / ${d.negative_pct}%`}>
                        <div style={`width: ${d.positive_pct}%; background: #22c55e;`}></div>
                        <div style={`width: ${d.neutral_pct || 0}%; background: #555;`}></div>
                        <div style={`width: ${d.negative_pct || 0}%; background: #ef4444;`}></div>
                      </div>
                    ) : <span style="color: #555;">—</span>}
                  </td>
                  <td align="center" class="score-font" style={`color: ${d.hrcb_range !== null && d.hrcb_range > 0.5 ? '#e2b340' : '#666'};`}>
                    {d.hrcb_range !== null ? d.hrcb_range.toFixed(2) : '—'}
                  </td>
                </tr>
              );
            })}
          </table>
        </div>
      </td>
    </tr>
  </table>
</Base>
