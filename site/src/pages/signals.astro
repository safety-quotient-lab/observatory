---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SignalKeyFindings from '../components/SignalKeyFindings.astro';
import SignalTransparency from '../components/SignalTransparency.astro';
import SignalAccessibility from '../components/SignalAccessibility.astro';
import SignalPersuasion from '../components/SignalPersuasion.astro';
import SignalReaderSafety from '../components/SignalReaderSafety.astro';
import SignalDiscourse from '../components/SignalDiscourse.astro';
import SignalTemporal from '../components/SignalTemporal.astro';
import SignalTensions from '../components/SignalTensions.astro';
import { getStatusCounts, getSignalOverview, getTdSignalAggregates, getComplexityAggregates, getTemporalFramingAggregates, HOMEPAGE_BLOB_KEY } from '../lib/db';
import type { PsqAggregates, HomepageBlob } from '../lib/db';
import { PSQ_THREAT_DIMENSIONS, PSQ_PROTECTIVE_DIMENSIONS } from '../lib/eval-types';
import { formatPsqScore } from '../lib/colors';
import { computeGeoInsights } from '../lib/geo-reference';
import { wilsonCI, meanCI } from '../lib/stats';
import { cachedQuery, readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = (Astro.locals as any).runtime.env.CONTENT_CACHE as KVNamespace;

let storyCount = 0;
let signalData: Awaited<ReturnType<typeof getSignalOverview>> | null = null;

try {
  const [status, signals] = await Promise.all([
    getStatusCounts(db),
    cachedQuery(kv, 'sys:signalOverview', () => getSignalOverview(db), 120),
  ]);
  storyCount = status.done;
  signalData = signals;
} catch {}

let tdData: Awaited<ReturnType<typeof getTdSignalAggregates>> | null = null;
try {
  tdData = await cachedQuery(kv, 'sys:tdSignalAggregates', () => getTdSignalAggregates(db), 300);
} catch {}

let complexityData: Awaited<ReturnType<typeof getComplexityAggregates>> | null = null;
try {
  complexityData = await cachedQuery(kv, 'sys:complexityAggregates', () => getComplexityAggregates(db), 600);
} catch {}

let temporalData: Awaited<ReturnType<typeof getTemporalFramingAggregates>> | null = null;
try {
  temporalData = await cachedQuery(kv, 'sys:temporalFramingAggregates', () => getTemporalFramingAggregates(db), 600);
} catch {}

// PSQ aggregates — read from homepage KV blob (no new D1 query)
let psqAggregates: PsqAggregates | null = null;
try {
  const blob = await kv.get(HOMEPAGE_BLOB_KEY, 'json') as HomepageBlob | null;
  if (blob?.psqAggregates) psqAggregates = blob.psqAggregates;
} catch {}

// PSQ dimension split
const threatDims: Array<{ name: string; avg: number }> = [];
const protectiveDims: Array<{ name: string; avg: number }> = [];
if (psqAggregates?.dim_averages) {
  for (const [name, avg] of Object.entries(psqAggregates.dim_averages)) {
    if (typeof avg !== 'number') continue; // skip null/undefined from KV blob
    if (PSQ_THREAT_DIMENSIONS.has(name)) threatDims.push({ name, avg });
    else if (PSQ_PROTECTIVE_DIMENSIONS.has(name)) protectiveDims.push({ name, avg });
  }
  threatDims.sort((a, b) => a.avg - b.avg); // worst threats first
  protectiveDims.sort((a, b) => b.avg - a.avg); // strongest protections first
}
const threatAvg = threatDims.length > 0 ? threatDims.reduce((s, d) => s + d.avg, 0) / threatDims.length : null;
const protectiveAvg = protectiveDims.length > 0 ? protectiveDims.reduce((s, d) => s + d.avg, 0) / protectiveDims.length : null;
const psqCI = psqAggregates?.avg_psq != null && psqAggregates.psq_stddev != null && psqAggregates.story_count > 1
  ? meanCI(psqAggregates.avg_psq, psqAggregates.psq_stddev, psqAggregates.story_count)
  : null;

// Transparency rows with Wilson CIs
const tdN = tdData?.td_measured ?? 0;
const tdRows = tdData ? [
  { label: 'Any disclosure',      pct: tdData.any_disclosure_pct,      ci: wilsonCI(tdData.any_disclosure_count ?? 0, tdN) },
  { label: 'Author identified',   pct: tdData.author_identified_pct,   ci: wilsonCI(tdData.author_identified_count ?? 0, tdN) },
  { label: 'Conflicts disclosed', pct: tdData.conflicts_disclosed_pct, ci: wilsonCI(tdData.conflicts_disclosed_count ?? 0, tdN) },
  { label: 'Funding disclosed',   pct: tdData.funding_disclosed_pct,   ci: wilsonCI(tdData.funding_disclosed_count ?? 0, tdN) },
] : [];

// Persuasion techniques — tier breakdown (A=3 high-severity, B=2 moderate, C=1 low)
const PT_TIER_A = new Set(['reductio_ad_hitlerum', 'appeal_to_fear', 'name_calling', 'false_dilemma', 'thought_terminating_cliche']);
const PT_TIER_B = new Set(['causal_oversimplification', 'strawman', 'whataboutism', 'bandwagon', 'flag_waving', 'exaggeration', 'doubt']);
const PT_TIER_C = new Set(['loaded_language', 'repetition', 'appeal_to_authority', 'slogans', 'red_herring', 'obfuscation']);

const techDist = signalData?.technique_distribution ?? {};
let tierA = { count: 0, techniques: [] as string[] };
let tierB = { count: 0, techniques: [] as string[] };
let tierC = { count: 0, techniques: [] as string[] };
for (const [tech, count] of Object.entries(techDist)) {
  if (PT_TIER_A.has(tech)) { tierA.count += count; tierA.techniques.push(tech); }
  else if (PT_TIER_B.has(tech)) { tierB.count += count; tierB.techniques.push(tech); }
  else if (PT_TIER_C.has(tech)) { tierC.count += count; tierC.techniques.push(tech); }
}
const totalPt = tierA.count + tierB.count + tierC.count;
const maxTier = Math.max(tierA.count, tierB.count, tierC.count, 1);
const tierACI = wilsonCI(tierA.count, totalPt);
const tierBCI = wilsonCI(tierB.count, totalPt);
const tierCCI = wilsonCI(tierC.count, totalPt);

// Persuasion: top technique per tier for drill-through link
const topTierA = tierA.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];
const topTierB = tierB.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];
const topTierC = tierC.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];

// Jargon / knowledge distributions
const clN = complexityData?.total_measured ?? 0;
const jargonRows = complexityData ? [
  { label: 'Plain language',    count: complexityData.jargon_low,    param: 'low',    ci: wilsonCI(complexityData.jargon_low, clN) },
  { label: 'Some jargon',       count: complexityData.jargon_medium, param: 'medium', ci: wilsonCI(complexityData.jargon_medium, clN) },
  { label: 'Heavy jargon',      count: complexityData.jargon_high,   param: 'high',   ci: wilsonCI(complexityData.jargon_high, clN) },
] : [];
const maxJargon = jargonRows.length > 0 ? Math.max(...jargonRows.map(r => r.count), 1) : 1;

const knowledgeRows = complexityData ? [
  { label: 'Self-contained',    count: complexityData.knowledge_none,             ci: wilsonCI(complexityData.knowledge_none, clN) },
  { label: 'General audience',  count: complexityData.knowledge_general,          ci: wilsonCI(complexityData.knowledge_general, clN) },
  { label: 'Domain knowledge',  count: complexityData.knowledge_domain_specific,  ci: wilsonCI(complexityData.knowledge_domain_specific, clN) },
  { label: 'Expert only',       count: complexityData.knowledge_expert,           ci: wilsonCI(complexityData.knowledge_expert, clN) },
] : [];
const maxKnowledge = knowledgeRows.length > 0 ? Math.max(...knowledgeRows.map(r => r.count), 1) : 1;

// Temporal framing
const tfN = temporalData?.total_measured ?? 0;
const focusRows = temporalData ? [
  { label: 'Retrospective', count: temporalData.retrospective, pct: temporalData.retrospective_pct, color: 'var(--color-amber)',         param: 'retrospective', ci: wilsonCI(temporalData.retrospective, tfN) },
  { label: 'Present',       count: temporalData.present,       pct: temporalData.present_pct,       color: 'var(--channel-editorial)',   param: 'present',       ci: wilsonCI(temporalData.present, tfN) },
  { label: 'Prospective',   count: temporalData.prospective,   pct: temporalData.prospective_pct,   color: 'var(--color-positive)',      param: 'prospective',   ci: wilsonCI(temporalData.prospective, tfN) },
  { label: 'Mixed',         count: temporalData.mixed,         pct: temporalData.mixed_pct,         color: 'var(--fg-secondary)',        param: 'mixed',         ci: wilsonCI(temporalData.mixed, tfN) },
] : [];
const maxFocus = focusRows.length > 0 ? Math.max(...focusRows.map(r => r.count), 1) : 1;

const horizonTotal = temporalData ? (temporalData.horizon_immediate + temporalData.horizon_short_term + temporalData.horizon_medium_term + temporalData.horizon_long_term + temporalData.horizon_historical + temporalData.horizon_unspecified) : 0;
const horizonRows = temporalData ? [
  { label: 'Immediate',   count: temporalData.horizon_immediate,   ci: wilsonCI(temporalData.horizon_immediate, horizonTotal) },
  { label: 'Short-term',  count: temporalData.horizon_short_term,  ci: wilsonCI(temporalData.horizon_short_term, horizonTotal) },
  { label: 'Medium-term', count: temporalData.horizon_medium_term, ci: wilsonCI(temporalData.horizon_medium_term, horizonTotal) },
  { label: 'Long-term',   count: temporalData.horizon_long_term,   ci: wilsonCI(temporalData.horizon_long_term, horizonTotal) },
  { label: 'Historical',  count: temporalData.horizon_historical,  ci: wilsonCI(temporalData.horizon_historical, horizonTotal) },
  { label: 'Unspecified', count: temporalData.horizon_unspecified,  ci: wilsonCI(temporalData.horizon_unspecified, horizonTotal) },
].filter(r => r.count > 0) : [];
const maxHorizon = horizonRows.length > 0 ? Math.max(...horizonRows.map(r => r.count), 1) : 1;

// Tone — top 5 only
const toneEntries = signalData?.tone_distribution
  ? Object.entries(signalData.tone_distribution).sort((a, b) => b[1] - a[1]).slice(0, 5)
  : [];
const maxTone = toneEntries.length > 0 ? toneEntries[0][1] : 1;
const totalTone = signalData?.tone_distribution ? Object.values(signalData.tone_distribution).reduce((a, b) => a + b, 0) : 0;

// Geographic scope
const scopeEntries = signalData?.scope_distribution
  ? Object.entries(signalData.scope_distribution).sort((a, b) => b[1] - a[1])
  : [];
const maxScope = scopeEntries.length > 0 ? scopeEntries[0][1] : 1;
const totalScope = scopeEntries.reduce((sum, [, c]) => sum + c, 0);

// Geographic enrichment from Wolfram reference data
const geoInsights = computeGeoInsights();

// Retro/prospective ratio
const retroRatio = temporalData?.retrospective_pct != null && temporalData?.prospective_pct != null && temporalData.prospective_pct > 0
  ? (temporalData.retrospective_pct / temporalData.prospective_pct).toFixed(1)
  : null;

// Key findings — computed from existing aggregates
const findings: Array<{ text: string; anchor: string }> = [];

if (complexityData?.expert_pct != null) {
  const expertCI = wilsonCI(complexityData.knowledge_expert, clN);
  findings.push({
    text: `${complexityData.expert_pct.toFixed(0)}% ±${Math.ceil(expertCI.margin)} of stories assume expert-level knowledge`,
    anchor: '#accessibility',
  });
}
if (tdData?.author_identified_pct != null) {
  const authorCI = wilsonCI(tdData.author_identified_count ?? 0, tdN);
  findings.push({
    text: `Only ${tdData.author_identified_pct.toFixed(0)}% ±${Math.ceil(authorCI.margin)} of stories identify their author`,
    anchor: '#transparency',
  });
}
if (retroRatio) {
  findings.push({
    text: `Tech coverage looks backward ${retroRatio}× more than forward`,
    anchor: '#temporal',
  });
}
if (totalPt > 0) {
  const emotionCount = tierA.count + tierB.count;
  const emotionPct = Math.round((emotionCount / totalPt) * 100);
  const emotionCI = wilsonCI(emotionCount, totalPt);
  findings.push({
    text: `${emotionPct}% ±${Math.ceil(emotionCI.margin)} of persuasion techniques target emotion, not logic`,
    anchor: '#persuasion',
  });
}
if (geoInsights.usMentionPct > 0) {
  findings.push({
    text: `${geoInsights.usMentionPct}% of geographic mentions are US — ${geoInsights.underrepCountries} countries totaling ${Math.round(geoInsights.underrepPop / 1_000_000_000 * 10) / 10}B people have zero coverage`,
    anchor: '#discourse',
  });
}
if (psqAggregates?.avg_psq != null && psqAggregates.story_count > 10) {
  const psqFindingCI = psqCI ? ` ±${psqCI.margin.toFixed(1)}` : '';
  findings.push({
    text: `Average reader safety score: ${formatPsqScore(psqAggregates.avg_psq)}${psqFindingCI}/10 across ${psqAggregates.story_count} stories`,
    anchor: '#reader-safety',
  });
}

// Signal tensions — cross-signal patterns from existing data
interface SignalTension {
  label: string;
  description: string;
  metric1: { name: string; value: string; color: string };
  metric2: { name: string; value: string; color: string };
  article: string;
  articleHref: string;
}

const tensions: SignalTension[] = [];

// Knowledge gatekeeping: high transparency + low accessibility
if (tdData?.any_disclosure_pct != null && complexityData?.expert_pct != null) {
  const highTransparency = tdData.any_disclosure_pct > 50;
  const lowAccessibility = complexityData.expert_pct > 30;
  if (highTransparency && lowAccessibility) {
    tensions.push({
      label: 'Knowledge gatekeeping',
      description: 'Sources disclose who they are, but write in ways most people cannot understand. Transparency without accessibility creates an informed elite.',
      metric1: { name: 'Disclosure rate', value: `${tdData.any_disclosure_pct.toFixed(0)}%`, color: 'var(--color-positive)' },
      metric2: { name: 'Expert-only', value: `${complexityData.expert_pct.toFixed(0)}%`, color: 'var(--color-negative)' },
      article: 'Art. 26 vs Art. 19',
      articleHref: '/article/26',
    });
  }
}

// Backward-looking discourse: high retrospective + low prospective
if (retroRatio && parseFloat(retroRatio) >= 2.0) {
  tensions.push({
    label: 'Retrospective bias',
    description: 'Tech discourse overwhelmingly analyzes past events rather than advocating for future change. Accountability without forward vision limits rights progress.',
    metric1: { name: 'Backward focus', value: `${temporalData!.retrospective_pct!.toFixed(0)}%`, color: 'var(--color-amber)' },
    metric2: { name: 'Forward focus', value: `${temporalData!.prospective_pct!.toFixed(0)}%`, color: 'var(--color-positive)' },
    article: 'Art. 28',
    articleHref: '/article/28',
  });
}

// Persuasion rewarded: high-severity techniques present at scale
if (tierA.count > 0 && totalPt > 50) {
  const tierAPct = Math.round((tierA.count / totalPt) * 100);
  if (tierAPct >= 5) {
    tensions.push({
      label: 'High-severity persuasion at scale',
      description: 'The most manipulative techniques (name-calling, fear appeals, false dilemmas) appear regularly in tech coverage. Discourse quality suffers when severe persuasion goes unnoted.',
      metric1: { name: 'High-severity', value: `${tierA.count.toLocaleString()} uses`, color: 'var(--color-negative)' },
      metric2: { name: 'Share of all PT', value: `${tierAPct}%`, color: 'var(--color-warning)' },
      article: 'Art. 19',
      articleHref: '/article/19',
    });
  }
}

// Low disclosure in heavily jargoned content
if (tdData?.any_disclosure_pct != null && complexityData?.accessible_pct != null) {
  const lowTransparency = tdData.any_disclosure_pct < 40;
  const lowAccessibility = complexityData.accessible_pct < 20;
  if (lowTransparency && lowAccessibility) {
    tensions.push({
      label: 'Opaque discourse',
      description: 'Most stories neither identify their authors nor write for a general audience. When content lacks both transparency and accessibility, it functions as insider communication.',
      metric1: { name: 'Disclosure rate', value: `${tdData.any_disclosure_pct.toFixed(0)}%`, color: 'var(--color-warning)' },
      metric2: { name: 'Accessible', value: `${complexityData.accessible_pct.toFixed(0)}%`, color: 'var(--color-warning)' },
      article: 'Art. 19 + Art. 26',
      articleHref: '/article/19',
    });
  }
}
---

<Base title="Signals">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'signals' }]} />
  <table cellpadding="0" cellspacing="0" width="100%" style="max-width: 680px; padding: 10px 0;">
    <tr>
      <td>
        <h1 style="font-size: var(--font-md); margin-bottom: 4px;">What {storyCount.toLocaleString()} stories reveal</h1>
        <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 16px;">
          Invisible rights patterns across every evaluated Hacker News story, measured against the <a href="https://www.un.org/en/about-us/universal-declaration-of-human-rights" target="_blank" rel="noopener" style="color: var(--channel-editorial);">Universal Declaration of Human Rights</a>.
          <a href="/about#supplementary" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 6px;">Methodology &rarr;</a>
        </p>

        {/* ═══ 1. KEY FINDINGS ═══ */}

        <SignalKeyFindings findings={findings} />

        {/* ═══ 2. TRANSPARENCY ═══ */}

        {tdData && tdData.td_measured > 0 && (
          <SignalTransparency
            tdRows={tdRows} tdN={tdN}
            tdMeasured={tdData.td_measured} doneCt={storyCount}
            highTdPct={tdData.high_td_pct}
          />
        )}

        {/* ═══ 3. ACCESSIBILITY ═══ */}

        {complexityData && complexityData.total_measured > 0 && (
          <SignalAccessibility
            jargonRows={jargonRows} knowledgeRows={knowledgeRows}
            maxJargon={maxJargon} maxKnowledge={maxKnowledge}
            clN={clN} expertPct={complexityData.expert_pct}
            accessiblePct={complexityData.accessible_pct}
            knowledgeExpert={complexityData.knowledge_expert}
          />
        )}

        {/* ═══ 4. PERSUASION TECHNIQUES (tier breakdown) ═══ */}

        {totalPt > 0 && (
          <SignalPersuasion
            tierA={tierA} tierB={tierB} tierC={tierC}
            totalPt={totalPt} maxTier={maxTier}
            tierACI={tierACI} tierBCI={tierBCI} tierCCI={tierCCI}
            topTierA={topTierA} topTierB={topTierB} topTierC={topTierC}
          />
        )}

        {/* ═══ 5. TEMPORAL FRAMING ═══ */}

        {temporalData && temporalData.total_measured > 0 && (
          <SignalTemporal
            focusRows={focusRows} horizonRows={horizonRows}
            maxFocus={maxFocus} maxHorizon={maxHorizon}
            tfN={tfN} horizonTotal={horizonTotal}
            retroRatio={retroRatio} storyCount={storyCount}
          />
        )}

        {/* ═══ 6. READER SAFETY (PSQ) ═══ */}

        {psqAggregates && psqAggregates.story_count > 0 && (
          <SignalReaderSafety
            psqAggregates={psqAggregates}
            threatDims={threatDims} protectiveDims={protectiveDims}
            threatAvg={threatAvg} protectiveAvg={protectiveAvg}
            psqCI={psqCI}
          />
        )}

        {/* ═══ 7. DISCOURSE CHARACTER (merged tone + scope) ═══ */}

        {(toneEntries.length > 0 || scopeEntries.length > 0) && (
          <SignalDiscourse
            toneEntries={toneEntries} scopeEntries={scopeEntries}
            maxTone={maxTone} maxScope={maxScope}
            totalTone={totalTone} totalScope={totalScope}
            geoInsights={geoInsights}
          />
        )}

        {/* ═══ 8. SIGNAL TENSIONS ═══ */}

        <SignalTensions tensions={tensions} />

        {/* ═══ 8. METHODOLOGY NOTES ═══ */}

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--color-positive-vivid);">Fair Witness</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">Every evaluation separates observable facts from interpretive inferences — no black boxes.</span>
          <a href="/about#fair-witness" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; white-space: nowrap;">how it works &rarr;</a>
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--fg-primary);">9 supplementary signals</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">Beyond the core HRCB score: epistemic quality, stakeholder voice, solution orientation, and more.</span>
          <a href="/about#supplementary" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; white-space: nowrap;">full reference &rarr;</a>
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--fg-primary);">&plusmn; confidence intervals</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">All proportions show 95% Wilson score intervals. t-distribution critical values verified via <a href="https://www.wolframalpha.com" target="_blank" rel="noopener" style="color: var(--channel-editorial);">Wolfram Alpha</a>.</span>
        </div>

      </td>
    </tr>
  </table>
</Base>
