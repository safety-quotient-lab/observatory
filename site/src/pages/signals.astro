---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getStatusCounts, getSignalOverview, getTdSignalAggregates, getComplexityAggregates, getTemporalFramingAggregates, HOMEPAGE_BLOB_KEY } from '../lib/db';
import type { PsqAggregates, HomepageBlob } from '../lib/db';
import { PSQ_THREAT_DIMENSIONS, PSQ_PROTECTIVE_DIMENSIONS } from '../lib/eval-types';
import { scoreToColor, normalizePsq, formatPsqScore } from '../lib/colors';
import { computeGeoInsights } from '../lib/geo-reference';
import { wilsonCI } from '../lib/stats';
import { cachedQuery, readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = (Astro.locals as any).runtime.env.CONTENT_CACHE as KVNamespace;

let storyCount = 0;
let signalData: Awaited<ReturnType<typeof getSignalOverview>> | null = null;

try {
  const [status, signals] = await Promise.all([
    getStatusCounts(db),
    cachedQuery(kv, 'sys:signalOverview', () => getSignalOverview(db), 120),
  ]);
  storyCount = status.done;
  signalData = signals;
} catch {}

let tdData: Awaited<ReturnType<typeof getTdSignalAggregates>> | null = null;
try {
  tdData = await cachedQuery(kv, 'sys:tdSignalAggregates', () => getTdSignalAggregates(db), 300);
} catch {}

let complexityData: Awaited<ReturnType<typeof getComplexityAggregates>> | null = null;
try {
  complexityData = await cachedQuery(kv, 'sys:complexityAggregates', () => getComplexityAggregates(db), 600);
} catch {}

let temporalData: Awaited<ReturnType<typeof getTemporalFramingAggregates>> | null = null;
try {
  temporalData = await cachedQuery(kv, 'sys:temporalFramingAggregates', () => getTemporalFramingAggregates(db), 600);
} catch {}

// PSQ aggregates — read from homepage KV blob (no new D1 query)
let psqAggregates: PsqAggregates | null = null;
try {
  const blob = await kv.get(HOMEPAGE_BLOB_KEY, 'json') as HomepageBlob | null;
  if (blob?.psqAggregates) psqAggregates = blob.psqAggregates;
} catch {}

// PSQ dimension split
const threatDims: Array<{ name: string; avg: number }> = [];
const protectiveDims: Array<{ name: string; avg: number }> = [];
if (psqAggregates?.dim_averages) {
  for (const [name, avg] of Object.entries(psqAggregates.dim_averages)) {
    if (PSQ_THREAT_DIMENSIONS.has(name)) threatDims.push({ name, avg });
    else if (PSQ_PROTECTIVE_DIMENSIONS.has(name)) protectiveDims.push({ name, avg });
  }
  threatDims.sort((a, b) => a.avg - b.avg); // worst threats first
  protectiveDims.sort((a, b) => b.avg - a.avg); // strongest protections first
}
const threatAvg = threatDims.length > 0 ? threatDims.reduce((s, d) => s + d.avg, 0) / threatDims.length : null;
const protectiveAvg = protectiveDims.length > 0 ? protectiveDims.reduce((s, d) => s + d.avg, 0) / protectiveDims.length : null;

// Transparency rows with Wilson CIs
const tdN = tdData?.td_measured ?? 0;
const tdRows = tdData ? [
  { label: 'Any disclosure',      pct: tdData.any_disclosure_pct,      ci: wilsonCI(tdData.any_disclosure_count ?? 0, tdN) },
  { label: 'Author identified',   pct: tdData.author_identified_pct,   ci: wilsonCI(tdData.author_identified_count ?? 0, tdN) },
  { label: 'Conflicts disclosed', pct: tdData.conflicts_disclosed_pct, ci: wilsonCI(tdData.conflicts_disclosed_count ?? 0, tdN) },
  { label: 'Funding disclosed',   pct: tdData.funding_disclosed_pct,   ci: wilsonCI(tdData.funding_disclosed_count ?? 0, tdN) },
] : [];

// Persuasion techniques — tier breakdown (A=3 high-severity, B=2 moderate, C=1 low)
const PT_TIER_A = new Set(['reductio_ad_hitlerum', 'appeal_to_fear', 'name_calling', 'false_dilemma', 'thought_terminating_cliche']);
const PT_TIER_B = new Set(['causal_oversimplification', 'strawman', 'whataboutism', 'bandwagon', 'flag_waving', 'exaggeration', 'doubt']);
const PT_TIER_C = new Set(['loaded_language', 'repetition', 'appeal_to_authority', 'slogans', 'red_herring', 'obfuscation']);

const techDist = signalData?.technique_distribution ?? {};
let tierA = { count: 0, techniques: [] as string[] };
let tierB = { count: 0, techniques: [] as string[] };
let tierC = { count: 0, techniques: [] as string[] };
for (const [tech, count] of Object.entries(techDist)) {
  if (PT_TIER_A.has(tech)) { tierA.count += count; tierA.techniques.push(tech); }
  else if (PT_TIER_B.has(tech)) { tierB.count += count; tierB.techniques.push(tech); }
  else if (PT_TIER_C.has(tech)) { tierC.count += count; tierC.techniques.push(tech); }
}
const totalPt = tierA.count + tierB.count + tierC.count;
const maxTier = Math.max(tierA.count, tierB.count, tierC.count, 1);

// Persuasion: top technique per tier for drill-through link
const topTierA = tierA.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];
const topTierB = tierB.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];
const topTierC = tierC.techniques.sort((a, b) => (techDist[b] ?? 0) - (techDist[a] ?? 0))[0];

// Jargon / knowledge distributions
const clN = complexityData?.total_measured ?? 0;
const jargonRows = complexityData ? [
  { label: 'Plain language',    count: complexityData.jargon_low,    param: 'low',    ci: wilsonCI(complexityData.jargon_low, clN) },
  { label: 'Some jargon',       count: complexityData.jargon_medium, param: 'medium', ci: wilsonCI(complexityData.jargon_medium, clN) },
  { label: 'Heavy jargon',      count: complexityData.jargon_high,   param: 'high',   ci: wilsonCI(complexityData.jargon_high, clN) },
] : [];
const maxJargon = jargonRows.length > 0 ? Math.max(...jargonRows.map(r => r.count), 1) : 1;

const knowledgeRows = complexityData ? [
  { label: 'Self-contained',    count: complexityData.knowledge_none,             ci: wilsonCI(complexityData.knowledge_none, clN) },
  { label: 'General audience',  count: complexityData.knowledge_general,          ci: wilsonCI(complexityData.knowledge_general, clN) },
  { label: 'Domain knowledge',  count: complexityData.knowledge_domain_specific,  ci: wilsonCI(complexityData.knowledge_domain_specific, clN) },
  { label: 'Expert only',       count: complexityData.knowledge_expert,           ci: wilsonCI(complexityData.knowledge_expert, clN) },
] : [];
const maxKnowledge = knowledgeRows.length > 0 ? Math.max(...knowledgeRows.map(r => r.count), 1) : 1;

// Temporal framing
const tfN = temporalData?.total_measured ?? 0;
const focusRows = temporalData ? [
  { label: 'Retrospective', count: temporalData.retrospective, pct: temporalData.retrospective_pct, color: 'var(--color-amber)',         param: 'retrospective', ci: wilsonCI(temporalData.retrospective, tfN) },
  { label: 'Present',       count: temporalData.present,       pct: temporalData.present_pct,       color: 'var(--channel-editorial)',   param: 'present',       ci: wilsonCI(temporalData.present, tfN) },
  { label: 'Prospective',   count: temporalData.prospective,   pct: temporalData.prospective_pct,   color: 'var(--color-positive)',      param: 'prospective',   ci: wilsonCI(temporalData.prospective, tfN) },
  { label: 'Mixed',         count: temporalData.mixed,         pct: temporalData.mixed_pct,         color: 'var(--fg-secondary)',        param: 'mixed',         ci: wilsonCI(temporalData.mixed, tfN) },
] : [];
const maxFocus = focusRows.length > 0 ? Math.max(...focusRows.map(r => r.count), 1) : 1;

const horizonRows = temporalData ? [
  { label: 'Immediate',   count: temporalData.horizon_immediate },
  { label: 'Short-term',  count: temporalData.horizon_short_term },
  { label: 'Medium-term', count: temporalData.horizon_medium_term },
  { label: 'Long-term',   count: temporalData.horizon_long_term },
  { label: 'Historical',  count: temporalData.horizon_historical },
  { label: 'Unspecified', count: temporalData.horizon_unspecified },
].filter(r => r.count > 0) : [];
const maxHorizon = horizonRows.length > 0 ? Math.max(...horizonRows.map(r => r.count), 1) : 1;

// Tone — top 5 only
const toneEntries = signalData?.tone_distribution
  ? Object.entries(signalData.tone_distribution).sort((a, b) => b[1] - a[1]).slice(0, 5)
  : [];
const maxTone = toneEntries.length > 0 ? toneEntries[0][1] : 1;
const totalTone = signalData?.tone_distribution ? Object.values(signalData.tone_distribution).reduce((a, b) => a + b, 0) : 0;

// Geographic scope
const scopeEntries = signalData?.scope_distribution
  ? Object.entries(signalData.scope_distribution).sort((a, b) => b[1] - a[1])
  : [];
const maxScope = scopeEntries.length > 0 ? scopeEntries[0][1] : 1;
const totalScope = scopeEntries.reduce((sum, [, c]) => sum + c, 0);

// Geographic enrichment from Wolfram reference data
const geoInsights = computeGeoInsights();

// Retro/prospective ratio
const retroRatio = temporalData?.retrospective_pct != null && temporalData?.prospective_pct != null && temporalData.prospective_pct > 0
  ? (temporalData.retrospective_pct / temporalData.prospective_pct).toFixed(1)
  : null;

// Key findings — computed from existing aggregates
const findings: Array<{ text: string; anchor: string }> = [];

if (complexityData?.expert_pct != null) {
  const expertCI = wilsonCI(complexityData.knowledge_expert, clN);
  findings.push({
    text: `${complexityData.expert_pct.toFixed(0)}% ±${Math.ceil(expertCI.margin)} of stories assume expert-level knowledge`,
    anchor: '#accessibility',
  });
}
if (tdData?.author_identified_pct != null) {
  const authorCI = wilsonCI(tdData.author_identified_count ?? 0, tdN);
  findings.push({
    text: `Only ${tdData.author_identified_pct.toFixed(0)}% ±${Math.ceil(authorCI.margin)} of stories identify their author`,
    anchor: '#transparency',
  });
}
if (retroRatio) {
  findings.push({
    text: `Tech coverage looks backward ${retroRatio}× more than forward`,
    anchor: '#temporal',
  });
}
if (totalPt > 0) {
  const emotionCount = tierA.count + tierB.count;
  const emotionPct = Math.round((emotionCount / totalPt) * 100);
  findings.push({
    text: `${emotionPct}% of persuasion techniques target emotion, not logic`,
    anchor: '#persuasion',
  });
}
if (geoInsights.usMentionPct > 0) {
  findings.push({
    text: `${geoInsights.usMentionPct}% of geographic mentions are US — ${geoInsights.underrepCountries} countries totaling ${Math.round(geoInsights.underrepPop / 1_000_000_000 * 10) / 10}B people have zero coverage`,
    anchor: '#discourse',
  });
}
if (psqAggregates?.avg_psq != null && psqAggregates.story_count > 10) {
  findings.push({
    text: `Average reader safety score: ${formatPsqScore(psqAggregates.avg_psq)}/10 across ${psqAggregates.story_count} stories`,
    anchor: '#reader-safety',
  });
}

// Signal tensions — cross-signal patterns from existing data
interface SignalTension {
  label: string;
  description: string;
  metric1: { name: string; value: string; color: string };
  metric2: { name: string; value: string; color: string };
  article: string;
  articleHref: string;
}

const tensions: SignalTension[] = [];

// Knowledge gatekeeping: high transparency + low accessibility
if (tdData?.any_disclosure_pct != null && complexityData?.expert_pct != null) {
  const highTransparency = tdData.any_disclosure_pct > 50;
  const lowAccessibility = complexityData.expert_pct > 30;
  if (highTransparency && lowAccessibility) {
    tensions.push({
      label: 'Knowledge gatekeeping',
      description: 'Sources disclose who they are, but write in ways most people cannot understand. Transparency without accessibility creates an informed elite.',
      metric1: { name: 'Disclosure rate', value: `${tdData.any_disclosure_pct.toFixed(0)}%`, color: 'var(--color-positive)' },
      metric2: { name: 'Expert-only', value: `${complexityData.expert_pct.toFixed(0)}%`, color: 'var(--color-negative)' },
      article: 'Art. 26 vs Art. 19',
      articleHref: '/article/26',
    });
  }
}

// Backward-looking discourse: high retrospective + low prospective
if (retroRatio && parseFloat(retroRatio) >= 2.0) {
  tensions.push({
    label: 'Retrospective bias',
    description: 'Tech discourse overwhelmingly analyzes past events rather than advocating for future change. Accountability without forward vision limits rights progress.',
    metric1: { name: 'Backward focus', value: `${temporalData!.retrospective_pct!.toFixed(0)}%`, color: 'var(--color-amber)' },
    metric2: { name: 'Forward focus', value: `${temporalData!.prospective_pct!.toFixed(0)}%`, color: 'var(--color-positive)' },
    article: 'Art. 28',
    articleHref: '/article/28',
  });
}

// Persuasion rewarded: high-severity techniques present at scale
if (tierA.count > 0 && totalPt > 50) {
  const tierAPct = Math.round((tierA.count / totalPt) * 100);
  if (tierAPct >= 5) {
    tensions.push({
      label: 'High-severity persuasion at scale',
      description: 'The most manipulative techniques (name-calling, fear appeals, false dilemmas) appear regularly in tech coverage. Discourse quality suffers when severe persuasion goes unnoted.',
      metric1: { name: 'High-severity', value: `${tierA.count.toLocaleString()} uses`, color: 'var(--color-negative)' },
      metric2: { name: 'Share of all PT', value: `${tierAPct}%`, color: 'var(--color-warning)' },
      article: 'Art. 19',
      articleHref: '/article/19',
    });
  }
}

// Low disclosure in heavily jargoned content
if (tdData?.any_disclosure_pct != null && complexityData?.accessible_pct != null) {
  const lowTransparency = tdData.any_disclosure_pct < 40;
  const lowAccessibility = complexityData.accessible_pct < 20;
  if (lowTransparency && lowAccessibility) {
    tensions.push({
      label: 'Opaque discourse',
      description: 'Most stories neither identify their authors nor write for a general audience. When content lacks both transparency and accessibility, it functions as insider communication.',
      metric1: { name: 'Disclosure rate', value: `${tdData.any_disclosure_pct.toFixed(0)}%`, color: 'var(--color-warning)' },
      metric2: { name: 'Accessible', value: `${complexityData.accessible_pct.toFixed(0)}%`, color: 'var(--color-warning)' },
      article: 'Art. 19 + Art. 26',
      articleHref: '/article/19',
    });
  }
}
---

<Base title="Signals">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'signals' }]} />
  <table cellpadding="0" cellspacing="0" width="100%" style="max-width: 680px; padding: 10px 0;">
    <tr>
      <td>
        <h1 style="font-size: var(--font-md); margin-bottom: 4px;">What {storyCount.toLocaleString()} stories reveal</h1>
        <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 16px;">
          Invisible rights patterns across every evaluated Hacker News story, measured against the <a href="https://www.un.org/en/about-us/universal-declaration-of-human-rights" target="_blank" rel="noopener" style="color: var(--channel-editorial);">Universal Declaration of Human Rights</a>.
          <a href="/about#supplementary" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 6px;">Methodology &rarr;</a>
        </p>

        {/* ═══ 1. KEY FINDINGS ═══ */}

        {findings.length > 0 && (
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 20px;">
            {findings.map((f, i) => (
              <div style={`padding: 4px 0;${i > 0 ? ' border-top: 1px solid var(--color-border);' : ''}`}>
                <a href={f.anchor} style="color: var(--fg-primary); font-size: var(--font-sm); text-decoration: none;">
                  <span style="color: var(--channel-hrcb); margin-right: 6px;">&rsaquo;</span>{f.text}
                </a>
              </div>
            ))}
          </div>
        )}

        {/* ═══ 2. TRANSPARENCY ═══ */}

        {tdData && tdData.td_measured > 0 && (
          <div id="transparency" style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Transparency
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              Who's transparent about what they write? <a href="/article/19" style="color: var(--channel-editorial);">UDHR Article 19</a> protects expression — but expression without disclosure undermines trust.
              <a href="/sources" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">by source &rarr;</a>
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
                {tdRows.map(({ label, pct, ci }) => (
                  <tr>
                    <td style="width: 155px; color: var(--fg-primary); white-space: nowrap;">{label}</td>
                    <td style="padding: 0 8px;">
                      <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
                        <div style={`background: var(--color-positive); opacity: 0.5; border-radius: 3px; height: 14px; width: ${pct ?? 0}%;`}></div>
                      </div>
                    </td>
                    <td style="width: 70px; text-align: right; color: var(--fg-primary); white-space: nowrap;" class="score-font">
                      {pct !== null ? (
                        <span title={`95% CI: ${(ci.lower * 100).toFixed(1)}–${(ci.upper * 100).toFixed(1)}% (Wilson, n=${tdN})`}>
                          {pct.toFixed(0)}%<span style="color: var(--fg-secondary); font-size: var(--font-xs);"> ±{Math.ceil(ci.margin)}</span>
                        </span>
                      ) : 'n/a'}
                    </td>
                  </tr>
                ))}
              </table>
              <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
                {tdData.td_measured.toLocaleString()} stories measured.
                {tdData.high_td_pct !== null && (
                  <> <span style="color: var(--color-positive);">{tdData.high_td_pct.toFixed(0)}%</span> meet high transparency standards.</>
                )}
                <a href="/api/v1/signals" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 6px; white-space: nowrap;">data &rarr;</a>
              </p>
            </div>
          </div>
        )}

        {/* ═══ 3. ACCESSIBILITY ═══ */}

        {complexityData && complexityData.total_measured > 0 && (
          <div id="accessibility" style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Accessibility
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              Who can understand this content? <a href="/article/26" style="color: var(--channel-editorial);">UDHR Article 26</a> protects the right to education — jargon and assumed expertise create invisible barriers.
              <a href="https://unratified.org/covenant" target="_blank" rel="noopener" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">ICESCR Art. 13 &rarr;</a>
              <a href="/api/v1/signals" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">data &rarr;</a>
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); margin: 0 0 6px 0; font-weight: bold;">Jargon Density</p>
                  <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
                    {jargonRows.map(({ label, count, param, ci }) => (
                      <tr>
                        <td style="width: 110px; color: var(--fg-primary); white-space: nowrap;">{label}</td>
                        <td style="padding: 0 6px;">
                          <div style="background: var(--bg-primary); border-radius: 3px; height: 12px; width: 100%; position: relative;">
                            <div style={`background: var(--color-amber); opacity: 0.5; border-radius: 3px; height: 12px; width: ${Math.round((count / maxJargon) * 100)}%;`}></div>
                          </div>
                        </td>
                        <td style="width: 70px; text-align: right; color: var(--fg-secondary); white-space: nowrap;" class="score-font">
                          <a href={`/stories?jargon=${param}`} style="color: inherit; text-decoration: none;" title={`95% CI: ${(ci.lower * 100).toFixed(1)}–${(ci.upper * 100).toFixed(1)}% (Wilson, n=${clN})`}>{count.toLocaleString()}<span style="font-size: var(--font-xs); opacity: 0.7;"> ±{Math.ceil(ci.margin)}</span></a>
                        </td>
                      </tr>
                    ))}
                  </table>
                </div>
                <div>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); margin: 0 0 6px 0; font-weight: bold;">Assumed Knowledge</p>
                  <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
                    {knowledgeRows.map(({ label, count, ci }) => (
                      <tr>
                        <td style="width: 110px; color: var(--fg-primary); white-space: nowrap;">{label}</td>
                        <td style="padding: 0 6px;">
                          <div style="background: var(--bg-primary); border-radius: 3px; height: 12px; width: 100%; position: relative;">
                            <div style={`background: var(--channel-hrcb); opacity: 0.5; border-radius: 3px; height: 12px; width: ${Math.round((count / maxKnowledge) * 100)}%;`}></div>
                          </div>
                        </td>
                        <td style="width: 70px; text-align: right; color: var(--fg-secondary); white-space: nowrap;" class="score-font">
                          <span title={`95% CI: ${(ci.lower * 100).toFixed(1)}–${(ci.upper * 100).toFixed(1)}% (Wilson, n=${clN})`}>{count.toLocaleString()}<span style="font-size: var(--font-xs); opacity: 0.7;"> ±{Math.ceil(ci.margin)}</span></span>
                        </td>
                      </tr>
                    ))}
                  </table>
                </div>
              </div>
              <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
                {complexityData.expert_pct !== null && (
                  <><span style="color: var(--color-negative);">{complexityData.expert_pct.toFixed(0)}%</span> <span style="color: var(--fg-secondary); font-size: var(--font-xs);" title={`95% CI (Wilson, n=${clN})`}>&plusmn;{Math.ceil(wilsonCI(complexityData.knowledge_expert, clN).margin)}</span> of stories assume expert-level knowledge. </>
                )}
                {complexityData.accessible_pct !== null && (
                  <><span style="color: var(--color-positive);">{complexityData.accessible_pct.toFixed(0)}%</span> are plain-language and self-contained.</>
                )}
              </p>
            </div>
          </div>
        )}

        {/* ═══ 4. PERSUASION TECHNIQUES (tier breakdown) ═══ */}

        {totalPt > 0 && (
          <div id="persuasion" style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Persuasion Techniques
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              How does tech discourse persuade? PTC-18 techniques grouped by severity — high-severity techniques manipulate through fear, identity attacks, and false choices.
              <a href="/stories?show=negative&sort=score" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">flagged stories &rarr;</a>
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
                {tierA.count > 0 && (
                  <tr>
                    <td style="width: 155px; color: var(--fg-primary); white-space: nowrap;">
                      <span style="color: var(--color-negative); font-weight: bold;">High severity</span>
                    </td>
                    <td style="padding: 0 8px;">
                      <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
                        <div style={`background: var(--color-negative); opacity: 0.5; border-radius: 3px; height: 14px; width: ${Math.round((tierA.count / maxTier) * 100)}%;`}></div>
                      </div>
                    </td>
                    <td style="width: 50px; text-align: right; color: var(--fg-primary);" class="score-font">
                      {topTierA ? (
                        <a href={`/stories?show=negative&sort=score&pt=${encodeURIComponent(topTierA)}`} style="color: inherit; text-decoration: none;" title="Stories with high-severity techniques">{tierA.count.toLocaleString()}</a>
                      ) : tierA.count.toLocaleString()}
                    </td>
                  </tr>
                )}
                {tierB.count > 0 && (
                  <tr>
                    <td style="width: 155px; color: var(--fg-primary); white-space: nowrap;">
                      <span style="color: var(--color-warning); font-weight: bold;">Moderate</span>
                    </td>
                    <td style="padding: 0 8px;">
                      <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
                        <div style={`background: var(--color-warning); opacity: 0.5; border-radius: 3px; height: 14px; width: ${Math.round((tierB.count / maxTier) * 100)}%;`}></div>
                      </div>
                    </td>
                    <td style="width: 50px; text-align: right; color: var(--fg-primary);" class="score-font">
                      {topTierB ? (
                        <a href={`/stories?show=negative&sort=score&pt=${encodeURIComponent(topTierB)}`} style="color: inherit; text-decoration: none;" title="Stories with moderate techniques">{tierB.count.toLocaleString()}</a>
                      ) : tierB.count.toLocaleString()}
                    </td>
                  </tr>
                )}
                {tierC.count > 0 && (
                  <tr>
                    <td style="width: 155px; color: var(--fg-primary); white-space: nowrap;">
                      <span style="color: var(--fg-secondary); font-weight: bold;">Low severity</span>
                    </td>
                    <td style="padding: 0 8px;">
                      <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
                        <div style={`background: var(--fg-secondary); opacity: 0.3; border-radius: 3px; height: 14px; width: ${Math.round((tierC.count / maxTier) * 100)}%;`}></div>
                      </div>
                    </td>
                    <td style="width: 50px; text-align: right; color: var(--fg-primary);" class="score-font">
                      {topTierC ? (
                        <a href={`/stories?show=negative&sort=score&pt=${encodeURIComponent(topTierC)}`} style="color: inherit; text-decoration: none;" title="Stories with low-severity techniques">{tierC.count.toLocaleString()}</a>
                      ) : tierC.count.toLocaleString()}
                    </td>
                  </tr>
                )}
              </table>
              <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
                {tierA.count > 0 && (
                  <><span style="color: var(--color-negative);">{tierA.count.toLocaleString()}</span> uses of high-severity techniques (name-calling, appeal to fear, false dilemma). </>
                )}
                {tierB.count > 0 && (
                  <><span style="color: var(--color-warning);">{tierB.count.toLocaleString()}</span> moderate (whataboutism, strawman). </>
                )}
                {tierC.count > 0 && (
                  <>{tierC.count.toLocaleString()} low-severity (loaded language, slogans). </>
                )}
                <a href="/about#supplementary" style="color: var(--channel-hrcb);">PTC-18 taxonomy &rarr;</a>
              </p>
            </div>
          </div>
        )}

        {/* ═══ 5. TEMPORAL FRAMING ═══ */}

        {temporalData && temporalData.total_measured > 0 && (
          <div id="temporal" style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Temporal Framing
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              Does tech coverage look backward or forward? Retrospective analysis and prospective advocacy signal different relationships to change.
              <a href="/api/v1/signals" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">data &rarr;</a>
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <table cellpadding="2" cellspacing="0" style="font-size: var(--font-sm); width: 100%;">
                {focusRows.map(({ label, count, pct, color, param, ci }) => (
                  <tr>
                    <td style="width: 110px; color: var(--fg-primary); white-space: nowrap;">{label}</td>
                    <td style="padding: 0 8px;">
                      <div style="background: var(--bg-primary); border-radius: 3px; height: 14px; width: 100%; position: relative;">
                        <div style={`background: ${color}; opacity: 0.5; border-radius: 3px; height: 14px; width: ${Math.round((count / maxFocus) * 100)}%;`}></div>
                      </div>
                    </td>
                    <td style="width: 70px; text-align: right; color: var(--fg-primary); white-space: nowrap;" class="score-font">
                      {pct !== null ? (
                        <a href={`/stories?temporal=${param}`} style="color: inherit; text-decoration: none;" title={`95% CI: ${(ci.lower * 100).toFixed(1)}–${(ci.upper * 100).toFixed(1)}% (Wilson, n=${tfN})`}>
                          {pct.toFixed(0)}%<span style="color: var(--fg-secondary); font-size: var(--font-xs);"> ±{Math.ceil(ci.margin)}</span>
                        </a>
                      ) : '\u2014'}
                    </td>
                  </tr>
                ))}
              </table>
              {horizonRows.length > 0 && (
                <>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); margin: 10px 0 4px 0; font-weight: bold;">Time Horizon</p>
                  <table cellpadding="2" cellspacing="0" style="font-size: var(--font-xs); width: 100%;">
                    {horizonRows.map(({ label, count }) => (
                      <tr>
                        <td style="width: 90px; color: var(--fg-secondary); white-space: nowrap;">{label}</td>
                        <td style="padding: 0 6px;">
                          <div style="background: var(--bg-primary); border-radius: 2px; height: 10px; width: 100%;">
                            <div style={`background: var(--fg-secondary); opacity: 0.3; border-radius: 2px; height: 10px; width: ${Math.round((count / maxHorizon) * 100)}%;`}></div>
                          </div>
                        </td>
                        <td style="width: 40px; text-align: right; color: var(--fg-secondary);" class="score-font">{count.toLocaleString()}</td>
                      </tr>
                    ))}
                  </table>
                </>
              )}
              <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
                {retroRatio && (
                  <>Tech coverage looks backward <span class="score-font">{retroRatio}&times;</span> more than forward. </>
                )}
                {temporalData.total_measured.toLocaleString()} stories measured.
              </p>
            </div>
          </div>
        )}

        {/* ═══ 6. READER SAFETY (PSQ) ═══ */}

        {psqAggregates && psqAggregates.story_count > 0 && (
          <div id="reader-safety" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 2px;">
              <div role="heading" aria-level="2" style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0;">
                Reader Safety
              </div>
              <span class="psq-experimental">experimental</span>
            </div>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              How safe does this content feel to encounter? <a href="/article/3" style="color: var(--channel-editorial);">UDHR Article 3</a> protects security of person; <a href="/article/12" style="color: var(--channel-editorial);">Article 12</a> protects against attacks on reputation. PSQ measures psychoemotional safety across threat exposure and protective factors.
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
                <div style="text-align: center;">
                  <div style="color: var(--fg-secondary); font-size: var(--font-xs);">avg PSQ</div>
                  <span class="score-font" style={`color: ${scoreToColor(normalizePsq(psqAggregates.avg_psq))}; font-size: var(--font-md);`}>
                    {formatPsqScore(psqAggregates.avg_psq)}
                  </span>
                  <span style="color: var(--fg-secondary); font-size: var(--font-xs);">/10</span>
                </div>
                <div style="color: var(--fg-secondary); font-size: var(--font-xs);">
                  {psqAggregates.story_count} stories scored
                </div>
                {threatAvg != null && protectiveAvg != null && (
                  <div style="margin-left: auto; display: flex; gap: 12px; font-size: var(--font-xs);">
                    <span>
                      <span style="color: var(--fg-secondary);">Threat avg: </span>
                      <span class="score-font" style={`color: ${scoreToColor(normalizePsq(threatAvg))};`}>{threatAvg.toFixed(1)}</span>
                    </span>
                    <span>
                      <span style="color: var(--fg-secondary);">Protective avg: </span>
                      <span class="score-font" style={`color: ${scoreToColor(normalizePsq(protectiveAvg))};`}>{protectiveAvg.toFixed(1)}</span>
                    </span>
                  </div>
                )}
              </div>

              {threatDims.length > 0 && (
                <div style="margin-bottom: 8px;">
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); margin: 0 0 4px 0; font-weight: bold;">Threat Dimensions</p>
                  {threatDims.map(({ name, avg }) => {
                    const dimNorm = normalizePsq(avg);
                    const dimColor = dimNorm != null ? scoreToColor(dimNorm) : 'var(--fg-secondary)';
                    return (
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 3px;">
                        <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 120px; text-align: right; white-space: nowrap;">
                          {name.replace(/_/g, ' ')}
                        </span>
                        <div style="flex: 1; height: 8px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; position: relative; max-width: 200px;">
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--fg-secondary); opacity: 0.2;"></div>
                          {dimNorm != null && (dimNorm >= 0 ? (
                            <div style={`position: absolute; left: 50%; top: 0; width: ${dimNorm * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 0 3px 3px 0;`}></div>
                          ) : (
                            <div style={`position: absolute; right: 50%; top: 0; width: ${Math.abs(dimNorm) * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 3px 0 0 3px;`}></div>
                          ))}
                        </div>
                        <span class="score-font" style={`color: ${dimColor}; font-size: var(--font-xs); width: 40px; text-align: right;`}>
                          {avg.toFixed(1)}/10
                        </span>
                      </div>
                    );
                  })}
                </div>
              )}

              {protectiveDims.length > 0 && (
                <div>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); margin: 0 0 4px 0; font-weight: bold;">Protective Dimensions</p>
                  {protectiveDims.map(({ name, avg }) => {
                    const dimNorm = normalizePsq(avg);
                    const dimColor = dimNorm != null ? scoreToColor(dimNorm) : 'var(--fg-secondary)';
                    return (
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 3px;">
                        <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 120px; text-align: right; white-space: nowrap;">
                          {name.replace(/_/g, ' ')}
                        </span>
                        <div style="flex: 1; height: 8px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; position: relative; max-width: 200px;">
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--fg-secondary); opacity: 0.2;"></div>
                          {dimNorm != null && (dimNorm >= 0 ? (
                            <div style={`position: absolute; left: 50%; top: 0; width: ${dimNorm * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 0 3px 3px 0;`}></div>
                          ) : (
                            <div style={`position: absolute; right: 50%; top: 0; width: ${Math.abs(dimNorm) * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 3px 0 0 3px;`}></div>
                          ))}
                        </div>
                        <span class="score-font" style={`color: ${dimColor}; font-size: var(--font-xs); width: 40px; text-align: right;`}>
                          {avg.toFixed(1)}/10
                        </span>
                      </div>
                    );
                  })}
                </div>
              )}

              <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 8px 0 0 0;">
                PSQ (Psychoemotional Safety Quotient) — an independent signal measuring reader safety across 10 dimensions.
                <a href="/about#supplementary" style="color: var(--channel-hrcb); margin-left: 4px;">methodology &rarr;</a>
              </p>
            </div>
          </div>
        )}

        {/* ═══ 7. DISCOURSE CHARACTER (merged tone + scope) ═══ */}

        {(toneEntries.length > 0 || scopeEntries.length > 0) && (
          <div id="discourse" style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Discourse Character
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              How does tech discourse sound, and who does it address? Emotional tone shapes how rights issues land; geographic scope reveals whose "<a href="/article/25" style="color: var(--channel-editorial);">adequate standard of living</a>" gets discussed.
              <a href="/sources" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 4px; white-space: nowrap;">by source &rarr;</a>
            </p>
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              {toneEntries.length > 0 && (
                <div style={scopeEntries.length > 0 ? 'margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--color-border);' : ''}>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Dominant Tone (top 5 of {totalTone})</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {toneEntries.map(([label, count]) => {
                      const pct = maxTone > 0 ? Math.round((count / maxTone) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-inference); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                </div>
              )}

              {scopeEntries.length > 0 && (
                <div>
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Geographic Scope</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {scopeEntries.map(([label, count]) => {
                      const pct = maxScope > 0 ? Math.round((count / maxScope) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-sentiment); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                  <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 6px 0 0 0; line-height: 1.5;">
                    <span style="color: var(--color-warning);">{geoInsights.usMentionPct}%</span> of geographic mentions reference the US.
                    Covered countries represent <span style="color: var(--fg-primary);">{geoInsights.coveragePct}%</span> of world population — but
                    {' '}<span style="color: var(--color-negative);">{Math.round(geoInsights.underrepPop / 1_000_000_000 * 10) / 10}B people</span> across
                    {' '}{geoInsights.underrepCountries} countries (Indonesia, Pakistan, Nigeria, Bangladesh, Ethiopia) have zero coverage.
                    <span style="color: var(--fg-secondary); font-style: italic; margin-left: 4px;">
                      Source: <a href="https://www.wolframalpha.com" target="_blank" rel="noopener" style="color: var(--fg-secondary);">Wolfram Alpha</a> 2023 estimates
                    </span>
                  </p>
                </div>
              )}
            </div>
          </div>
        )}

        {/* ═══ 7. SIGNAL TENSIONS ═══ */}

        {tensions.length > 0 && (
          <div style="margin-bottom: 20px;">
            <h2 style="font-size: var(--font-sm); color: var(--fg-primary); font-weight: bold; margin: 0 0 2px 0;">
              Signal Tensions
            </h2>
            <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">
              Where signals contradict each other, rights patterns emerge. These cross-signal tensions reveal how the tech ecosystem relates to human rights in ways no single metric captures.
            </p>
            {tensions.map((t) => (
              <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 8px;">
                <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
                  <span style="color: var(--fg-primary); font-size: var(--font-sm); font-weight: bold;">{t.label}</span>
                  <a href={t.articleHref} style="color: var(--channel-editorial); font-size: var(--font-xs); white-space: nowrap;">{t.article}</a>
                </div>
                <p style="color: var(--fg-secondary); font-size: var(--font-xs); margin: 0 0 8px 0;">{t.description}</p>
                <div style="display: flex; gap: 16px; font-size: var(--font-xs);">
                  <span>
                    <span style="color: var(--fg-secondary);">{t.metric1.name}: </span>
                    <span style={`color: ${t.metric1.color}; font-weight: bold;`} class="score-font">{t.metric1.value}</span>
                  </span>
                  <span style="color: var(--fg-secondary);">vs</span>
                  <span>
                    <span style="color: var(--fg-secondary);">{t.metric2.name}: </span>
                    <span style={`color: ${t.metric2.color}; font-weight: bold;`} class="score-font">{t.metric2.value}</span>
                  </span>
                </div>
              </div>
            ))}
          </div>
        )}

        {/* ═══ 8. METHODOLOGY NOTES ═══ */}

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--color-positive-vivid);">Fair Witness</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">Every evaluation separates observable facts from interpretive inferences — no black boxes.</span>
          <a href="/about#fair-witness" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; white-space: nowrap;">how it works &rarr;</a>
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--fg-primary);">9 supplementary signals</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">Beyond the core HRCB score: epistemic quality, stakeholder voice, solution orientation, and more.</span>
          <a href="/about#supplementary" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; white-space: nowrap;">full reference &rarr;</a>
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px;">
          <b style="color: var(--fg-primary);">&plusmn; confidence intervals</b>
          <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 6px;">All proportions show 95% Wilson score intervals. t-distribution critical values verified via <a href="https://www.wolframalpha.com" target="_blank" rel="noopener" style="color: var(--channel-editorial);">Wolfram Alpha</a>.</span>
        </div>

      </td>
    </tr>
  </table>
</Base>
