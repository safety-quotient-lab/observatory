import Base from '../layouts/Base.astro';
---

<Base title="404 Not Found">
  <table width="100%">
    <tr>
      <td style="padding: 60px 20px; text-align: center;">
        <div style="font-size: 24pt; color: var(--color-orange); font-weight: bold; margin-bottom: 12px;">404</div>
        <div style="color: var(--fg-secondary); margin-bottom: 20px;">Page not found.</div>
        <div style="font-size: 8pt;">
          <a href="/" style="color: var(--color-orange);">home</a>
          <span style="color: var(--color-border); margin: 0 8px;">|</span>
          <a href="/status" style="color: var(--color-orange);">status</a>
          <span style="color: var(--color-border); margin: 0 8px;">|</span>
          <a href="/about" style="color: var(--color-orange);">about</a>
        </div>
      </td>
    </tr>
  </table>
</Base>
