          </table>
        </details>

      </td>
    </tr>
  </table>
</Base>

<style>
  /* Persona toggle — Reader (default) shows reader content, hides researcher */
  .persona-researcher { display: none; }
  body[data-persona="researcher"] .persona-researcher { display: block; }
  body[data-persona="researcher"] .persona-reader { display: none; }
  /* Inline span variants */
  span.persona-researcher { display: none; }
  body[data-persona="researcher"] span.persona-researcher { display: inline; }
  body[data-persona="researcher"] span.persona-reader { display: none; }
</style>

<script is:inline>
  // Sync button states after DOM is ready
  (function () {
    var p = document.body.dataset.persona || 'reader';
    document.querySelectorAll('.persona-btn').forEach(function (b) {
      b.classList.toggle('filter-active', b.dataset.persona === p);
    });
  })();

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.persona-btn');
    if (!btn) return;
    var p = btn.dataset.persona;
    localStorage.setItem('hro_persona', p);
    document.body.dataset.persona = p;
    document.querySelectorAll('.persona-btn').forEach(function (b) {
      b.classList.toggle('filter-active', b.dataset.persona === p);
    });
  });
</script>
