            <tr>
              <td style="color: var(--fg-secondary);" class="score-font">Evaluator (full)</td><td style="color: var(--fg-primary);" class="score-font">Anthropic Claude Haiku 4.5</td>
              <td style="color: var(--fg-secondary);" class="score-font">Database</td><td style="color: var(--fg-primary);" class="score-font">Cloudflare D1</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);" class="score-font">Evaluator (~lite)</td><td style="color: var(--color-orange);" class="score-font">Workers AI (Llama 4 Scout, Llama 3.3 70B, Qwen3 30B)</td>
              <td style="color: var(--fg-secondary);" class="score-font">Snapshots</td><td style="color: var(--fg-primary);" class="score-font">R2 (content audit trail)</td>
            </tr>
            <tr>
              <td style="color: var(--fg-secondary);" class="score-font">Cron</td><td style="color: var(--fg-primary);" class="score-font">Every 1 min (6 HN lists, top 7 pages)</td>
