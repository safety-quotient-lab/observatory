          <h2 style="font-size: var(--font-base); margin: 20px 0 8px 0;">Technical Details</h2>

          <table cellpadding="4" cellspacing="0" style="font-size: var(--font-sm); background: var(--bg-surface); border: 1px solid var(--color-border); border-radius: 4px; margin-bottom: 0;" width="100%">
            <tr>
              <td style="color: var(--fg-secondary);" class="score-font">Schema</td><td style="color: var(--fg-primary);" class="score-font">3.7</td>
              <td style="color: var(--fg-secondary);" class="score-font">Framework</td><td style="color: var(--fg-primary);" class="score-font">Astro + CF Pages</td>
