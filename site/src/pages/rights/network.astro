---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import { SECTIONS } from '../../lib/udhr';
import { getArticlePairStats, getArticleDetailedStats } from '../../lib/db';
import { scoreToColor, formatScore } from '../../lib/colors';
import { readDb } from '../../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);

const [pairStats, articleStats] = await Promise.all([
  getArticlePairStats(db),
  getArticleDetailedStats(db),
]);

// Build nodes: one per UDHR section
const statsMap = new Map(articleStats.map(a => [a.section, a]));

const groupColors: Record<string, string> = {
  'Foundation': '#a78bfa',
  'Security': '#f87171',
  'Legal': '#22d3ee',
  'Personal': '#34d399',
  'Political': '#fbbf24',
  'Economic': '#fb923c',
  'Limits': '#7d80d1',
};

function getGroupColor(group: string): string {
  for (const [key, color] of Object.entries(groupColors)) {
    if (group.toLowerCase().includes(key.toLowerCase())) return color;
  }
  return '#5b7279';
}

const nodes = SECTIONS.map(s => {
  const stat = statsMap.get(s.id);
  return {
    id: s.id,
    label: s.id === 'Preamble' ? 'P' : String(s.number),
    title: s.shortTitle,
    group: s.group,
    color: getGroupColor(s.group),
    avgScore: stat?.avg_final ?? null,
    signalCount: stat?.signal_count ?? 0,
  };
});

// --- Kruskal's MST ---
// Build edge list from all correlation pairs, weight = 1 - |r|
type Edge = { source: string; target: string; r: number; n: number; weight: number };
const allEdges: Edge[] = [];
for (const [key, r] of pairStats.correlation) {
  const [a, b] = key.split('|');
  if (a === b) continue;
  const n = pairStats.cooccurrence.get(key) || 0;
  allEdges.push({ source: a, target: b, r, n, weight: 1 - Math.abs(r) });
}

// Sort by weight ascending (strongest correlations first)
allEdges.sort((a, b) => a.weight - b.weight);

// Union-Find with path compression and union by rank
const parent = new Map<string, string>();
const rank = new Map<string, number>();
for (const s of SECTIONS) {
  parent.set(s.id, s.id);
  rank.set(s.id, 0);
}

function find(x: string): string {
  const p = parent.get(x)!;
  if (p !== x) {
    parent.set(x, find(p));
  }
  return parent.get(x)!;
}

function union(a: string, b: string): boolean {
  const ra = find(a), rb = find(b);
  if (ra === rb) return false;
  const rankA = rank.get(ra)!, rankB = rank.get(rb)!;
  if (rankA < rankB) { parent.set(ra, rb); }
  else if (rankA > rankB) { parent.set(rb, ra); }
  else { parent.set(rb, ra); rank.set(ra, rankA + 1); }
  return true;
}

const mstEdges: { source: string; target: string; r: number; n: number }[] = [];
for (const e of allEdges) {
  if (mstEdges.length >= 30) break; // 31 nodes → 30 edges
  if (union(e.source, e.target)) {
    mstEdges.push({ source: e.source, target: e.target, r: e.r, n: e.n });
  }
}

// --- Full correlation data for Tension & Harmony tables ---
const allCorrelationPairs = allEdges
  .map(e => ({ source: e.source, target: e.target, r: e.r, n: e.n }));

const harmonyPairs = [...allCorrelationPairs]
  .sort((a, b) => b.r - a.r)
  .slice(0, 10);

const tensionPairs = [...allCorrelationPairs]
  .sort((a, b) => a.r - b.r)
  .slice(0, 10);

// --- Power rankings: sorted by avg score descending ---
const powerRankings = SECTIONS.map(s => {
  const stat = statsMap.get(s.id);
  return {
    id: s.id,
    number: s.number,
    shortTitle: s.shortTitle,
    avgScore: stat?.avg_final ?? null,
    avgEditorial: stat?.avg_editorial ?? null,
    avgStructural: stat?.avg_structural ?? null,
    signalCount: stat?.signal_count ?? 0,
    ndCount: stat?.nd_count ?? 0,
    stddev: stat?.stddev_final ?? 0,
  };
}).sort((a, b) => (b.avgScore ?? -999) - (a.avgScore ?? -999));

// --- E/S channel data ---
const esData = SECTIONS.map(s => {
  const stat = statsMap.get(s.id);
  return {
    id: s.id,
    label: s.id === 'Preamble' ? 'P' : String(s.number),
    editorial: stat?.avg_editorial ?? 0,
    structural: stat?.avg_structural ?? 0,
  };
});

// Helper to get article number for links
function getArticleNumber(id: string): number {
  return SECTIONS.find(s => s.id === id)?.number ?? 0;
}

// Serialize for client
const graphData = JSON.stringify({ nodes, edges: mstEdges });
const powerData = JSON.stringify(powerRankings);
---

<Base title="Rights Network — HN HRCB">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'rights', href: '/rights' }, { label: 'network' }]} />
  <SubNav items={[{ label: 'Articles', href: '/rights/articles' }, { label: 'Observatory', href: '/rights/observatory' }, { label: 'Network', href: '/rights/network' }]} current="/rights/network" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Rights Correlation Network</span>
        <span style="color: var(--fg-secondary); margin-left: 8px; font-size: var(--font-sm);">
          MST backbone — minimum spanning tree by Pearson |r|
        </span>
      </td>
    </tr>
  </table>

  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 0 0 5px 0;">
    <tr>
      <td style="color: var(--fg-secondary); font-size: var(--font-sm); line-height: 1.6; padding: 4px 0;">
        How do UDHR rights move together across Hacker News stories? This page maps the statistical relationships between all 31 provisions. The graph below uses a minimum spanning tree to show the single strongest path connecting every article — green edges link rights that rise and fall together, red edges link rights that pull in opposite directions, and blue edges mark near-zero correlation. Below the graph, the tension and harmony tables list the most aligned and most opposed pairs across all evaluated content, the editorial/structural chart shows whether each right is driven more by what sites say versus what they do, and the power rankings table lets you sort articles by score, volatility, or signal count.
      </td>
    </tr>
  </table>

  {/* === Section 1: MST Backbone Graph === */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 8px;">
          {Object.entries(groupColors).map(([group, color]) => (
            <span style={`color: ${color}; font-size: var(--font-xs);`}>{group}</span>
          ))}
        </div>
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 8px;">
          Green edges = positive r · Red edges = negative r · Blue edges = neutral (|r| ≤ 0.1) · Width = strength · 30 MST edges · Drag nodes to explore
        </div>
        <canvas id="network-canvas" width="1200" height="900" style="width: 100%; max-width: 1200px; height: auto; aspect-ratio: 4/3; background: var(--bg-primary); border-radius: 4px; cursor: grab;"></canvas>
      </td>
    </tr>
  </table>

  {/* === Section 2: Tension & Harmony Pairs === */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;">
          Tension & Harmony Pairs
        </div>
        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          {/* Harmony (left) */}
          <div style="flex: 1; min-width: 280px;">
            <div style="color: var(--color-positive-medium); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; border-bottom: 1px solid rgba(52, 211, 153, 0.2); padding-bottom: 4px;">
              Harmony — Top 10 Positive
            </div>
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              <tr style="color: var(--fg-secondary);">
                <td>Article A</td><td>Article B</td><td style="text-align: right;">r</td><td style="text-align: right;">n</td>
              </tr>
              {harmonyPairs.map(e => (
                <tr style="border-top: 1px solid var(--bg-surface); background: rgba(52, 211, 153, 0.03);">
                  <td>
                    <a href={`/article/${getArticleNumber(e.source)}`} style="color: var(--fg-emphasis);">{e.source}</a>
                  </td>
                  <td>
                    <a href={`/article/${getArticleNumber(e.target)}`} style="color: var(--fg-emphasis);">{e.target}</a>
                  </td>
                  <td style="text-align: right; color: var(--color-positive-medium);" class="score-font">
                    +{e.r.toFixed(3)}
                  </td>
                  <td style="text-align: right; color: var(--fg-secondary);" class="score-font">{e.n}</td>
                </tr>
              ))}
            </table>
          </div>
          {/* Tension (right) */}
          <div style="flex: 1; min-width: 280px;">
            <div style="color: var(--color-negative-light); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; border-bottom: 1px solid rgba(248, 113, 113, 0.2); padding-bottom: 4px;">
              Tension — Top 10 Negative
            </div>
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              <tr style="color: var(--fg-secondary);">
                <td>Article A</td><td>Article B</td><td style="text-align: right;">r</td><td style="text-align: right;">n</td>
              </tr>
              {tensionPairs.map(e => (
                <tr style="border-top: 1px solid var(--bg-surface); background: rgba(248, 113, 113, 0.03);">
                  <td>
                    <a href={`/article/${getArticleNumber(e.source)}`} style="color: var(--fg-emphasis);">{e.source}</a>
                  </td>
                  <td>
                    <a href={`/article/${getArticleNumber(e.target)}`} style="color: var(--fg-emphasis);">{e.target}</a>
                  </td>
                  <td style="text-align: right; color: var(--color-negative-light);" class="score-font">
                    {e.r.toFixed(3)}
                  </td>
                  <td style="text-align: right; color: var(--fg-secondary);" class="score-font">{e.n}</td>
                </tr>
              ))}
            </table>
          </div>
        </div>
      </td>
    </tr>
  </table>

  {/* === Section 3: E/S Channel Split (SVG diverging bar chart) === */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
          Editorial / Structural Channel Split
          <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
            <span style="color: var(--channel-structural);">■</span> Editorial (right)
            <span style="color: var(--color-sentiment); margin-left: 8px;">■</span> Structural (left)
          </span>
        </div>
        <svg id="es-chart" viewBox="0 0 800 750" style="width: 100%; max-width: 800px; height: auto; font-family: monospace;">
          {/* Scale labels */}
          <text x="100" y="16" fill="var(--fg-secondary)" font-size="10" text-anchor="end">-1.0</text>
          <text x="400" y="16" fill="var(--fg-secondary)" font-size="10" text-anchor="middle">0</text>
          <text x="700" y="16" fill="var(--fg-secondary)" font-size="10" text-anchor="start">+1.0</text>
          {/* Center line */}
          <line x1="400" y1="20" x2="400" y2={20 + esData.length * 23} stroke="var(--bg-surface)" stroke-width="1" stroke-dasharray="3,3" />
          {/* Scale lines */}
          <line x1="100" y1="20" x2="100" y2={20 + esData.length * 23} stroke="var(--bg-surface)" stroke-width="1" />
          <line x1="700" y1="20" x2="700" y2={20 + esData.length * 23} stroke="var(--bg-surface)" stroke-width="1" />
          {esData.map((d, i) => {
            const y = 28 + i * 23;
            const barH = 16;
            const centerX = 400;
            const scale = 300; // pixels per 1.0 unit

            // Structural extends LEFT from center (cyan)
            const sVal = d.structural ?? 0;
            const sWidth = Math.abs(sVal) * scale;
            const sX = sVal < 0 ? centerX - sWidth : centerX;

            // Editorial extends RIGHT from center (purple)
            const eVal = d.editorial ?? 0;
            const eWidth = Math.abs(eVal) * scale;
            const eX = eVal > 0 ? centerX : centerX - eWidth;

            return (
              <g>
                {/* Article label */}
                <text x="90" y={y + barH / 2 + 1} fill="var(--fg-secondary)" font-size="10" text-anchor="end" dominant-baseline="middle">
                  {d.id === 'Preamble' ? 'Preamble' : `Art. ${d.label}`}
                </text>
                {/* Structural bar (cyan, extends left) */}
                {sWidth > 0 && (
                  <rect x={centerX - sWidth} y={y} width={sWidth} height={barH} fill="var(--color-sentiment)" opacity="0.7" rx="2" />
                )}
                {/* Editorial bar (purple, extends right) */}
                {eWidth > 0 && (
                  <rect x={centerX} y={y} width={eWidth} height={barH} fill="var(--channel-structural)" opacity="0.7" rx="2" />
                )}
              </g>
            );
          })}
        </svg>
      </td>
    </tr>
  </table>

  {/* === Section 4: Power Rankings (sortable table) === */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 20px 0;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
          Power Rankings
          <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
            Click column headers to sort
          </span>
        </div>
        <table id="power-table" cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <thead>
            <tr style="color: var(--fg-secondary); cursor: pointer; user-select: none;">
              <td data-col="rank" data-type="num" style="width: 40px;">#</td>
              <td data-col="article" data-type="str">Article</td>
              <td data-col="shortTitle" data-type="str">Short Title</td>
              <td data-col="avgScore" data-type="num" style="text-align: right;">Avg Score ▼</td>
              <td data-col="signalCount" data-type="num" style="text-align: right;">Signal</td>
              <td data-col="ndCount" data-type="num" style="text-align: right;">ND</td>
              <td data-col="stddev" data-type="num" style="text-align: right;">Volatility</td>
              <td data-col="avgEditorial" data-type="num" style="text-align: right;">Avg E</td>
              <td data-col="avgStructural" data-type="num" style="text-align: right;">Avg S</td>
            </tr>
          </thead>
          <tbody id="power-body">
            {powerRankings.map((r, i) => (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="color: var(--fg-secondary);" class="score-font">{i + 1}</td>
                <td>
                  <a href={`/article/${r.number}`} style="color: var(--fg-emphasis);">
                    {r.id === 'Preamble' ? 'Preamble' : `Article ${r.number}`}
                  </a>
                </td>
                <td style="color: var(--fg-secondary);">{r.shortTitle}</td>
                <td style={`text-align: right; color: ${scoreToColor(r.avgScore)};`} class="score-font" data-val={r.avgScore ?? -999}>
                  {formatScore(r.avgScore)}
                </td>
                <td style="text-align: right; color: var(--fg-emphasis);" class="score-font" data-val={r.signalCount}>{r.signalCount}</td>
                <td style="text-align: right; color: var(--fg-secondary);" class="score-font" data-val={r.ndCount}>{r.ndCount}</td>
                <td style="text-align: right; color: var(--fg-secondary);" class="score-font" data-val={r.stddev}>
                  {r.stddev.toFixed(3)}
                </td>
                <td style={`text-align: right; color: ${scoreToColor(r.avgEditorial)};`} class="score-font" data-val={r.avgEditorial ?? -999}>
                  {formatScore(r.avgEditorial)}
                </td>
                <td style={`text-align: right; color: ${scoreToColor(r.avgStructural)};`} class="score-font" data-val={r.avgStructural ?? -999}>
                  {formatScore(r.avgStructural)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </td>
    </tr>
  </table>

  {/* === Client-side: MST Force Graph === */}
  <script define:vars={{ graphData }}>
    const { nodes, edges } = JSON.parse(graphData);
    const canvas = document.getElementById('network-canvas');
    const ctx = canvas.getContext('2d');
    const W = canvas.width;
    const H = canvas.height;

    // Initialize positions in a circle
    nodes.forEach((n, i) => {
      const angle = (2 * Math.PI * i) / nodes.length;
      n.x = W / 2 + (W * 0.35) * Math.cos(angle);
      n.y = H / 2 + (H * 0.35) * Math.sin(angle);
      n.vx = 0;
      n.vy = 0;
    });

    const nodeMap = new Map(nodes.map(n => [n.id, n]));

    // Force simulation parameters
    const REPULSION = 8000;
    const SPRING_LENGTH = 180;
    const SPRING_K = 0.02;
    const DAMPING = 0.9;
    const CENTER_PULL = 0;
    let alpha = 1.0;
    const ALPHA_DECAY = 0.998;
    const ALPHA_MIN = 0.001;

    let dragging = null;
    let dragMoved = false;
    let mx = 0, my = 0;
    let hoveredNode = null;
    let hoveredEdge = null;

    function getScale() {
      return canvas.clientWidth / W;
    }

    canvas.addEventListener('mousedown', (e) => {
      const rect = canvas.getBoundingClientRect();
      const scale = getScale();
      mx = (e.clientX - rect.left) / scale;
      my = (e.clientY - rect.top) / scale;
      for (const n of nodes) {
        if (Math.hypot(n.x - mx, n.y - my) < 18) {
          dragging = n;
          dragMoved = false;
          alpha = Math.max(alpha, 0.3);
          canvas.style.cursor = 'grabbing';
          break;
        }
      }
    });

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const scale = getScale();
      mx = (e.clientX - rect.left) / scale;
      my = (e.clientY - rect.top) / scale;
      if (dragging) {
        dragMoved = true;
        dragging.x = mx;
        dragging.y = my;
        dragging.vx = 0;
        dragging.vy = 0;
      }
      // Hover detection: check nodes first, then edges
      hoveredNode = null;
      hoveredEdge = null;
      for (const n of nodes) {
        if (Math.hypot(n.x - mx, n.y - my) < 20) {
          hoveredNode = n;
          break;
        }
      }
      if (!hoveredNode) {
        // Check edge proximity
        for (const e of edges) {
          const a = nodeMap.get(e.source);
          const b = nodeMap.get(e.target);
          if (!a || !b) continue;
          const dist = pointToSegmentDist(mx, my, a.x, a.y, b.x, b.y);
          if (dist < 8) {
            hoveredEdge = e;
            break;
          }
        }
      }
      canvas.style.cursor = dragging ? 'grabbing' : (hoveredNode || hoveredEdge) ? 'pointer' : 'grab';
    });

    canvas.addEventListener('mouseup', () => {
      if (dragging && !dragMoved) {
        // Click without drag — navigate to article page
        const num = dragging.id === 'Preamble' ? 0 : parseInt(dragging.label, 10);
        window.location.href = '/article/' + num;
      }
      dragging = null;
      canvas.style.cursor = 'grab';
    });

    // Point-to-segment distance for edge hover
    function pointToSegmentDist(px, py, x1, y1, x2, y2) {
      const dx = x2 - x1, dy = y2 - y1;
      const lenSq = dx * dx + dy * dy;
      if (lenSq === 0) return Math.hypot(px - x1, py - y1);
      let t = ((px - x1) * dx + (py - y1) * dy) / lenSq;
      t = Math.max(0, Math.min(1, t));
      return Math.hypot(px - (x1 + t * dx), py - (y1 + t * dy));
    }

    function simulate() {
      if (alpha < ALPHA_MIN && !dragging) return;

      // Repulsion between all pairs
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const dist = Math.max(Math.hypot(dx, dy), 1);
          const force = REPULSION * alpha / (dist * dist);
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          a.vx -= fx; a.vy -= fy;
          b.vx += fx; b.vy += fy;
        }
      }

      // Spring forces along MST edges
      for (const e of edges) {
        const a = nodeMap.get(e.source);
        const b = nodeMap.get(e.target);
        if (!a || !b) continue;
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist = Math.max(Math.hypot(dx, dy), 1);
        const targetLen = SPRING_LENGTH;
        const displacement = dist - targetLen;
        const force = SPRING_K * alpha * displacement;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.vx += fx; a.vy += fy;
        b.vx -= fx; b.vy -= fy;
      }

      // Center pull
      for (const n of nodes) {
        n.vx += (W / 2 - n.x) * CENTER_PULL;
        n.vy += (H / 2 - n.y) * CENTER_PULL;
      }

      // Update positions
      for (const n of nodes) {
        if (n === dragging) continue;
        n.vx *= DAMPING;
        n.vy *= DAMPING;
        n.x += n.vx;
        n.y += n.vy;
        n.x = Math.max(30, Math.min(W - 30, n.x));
        n.y = Math.max(30, Math.min(H - 30, n.y));
      }

      if (!dragging) alpha *= ALPHA_DECAY;
    }

    function edgeColor(r) {
      if (r > 0.1) return { stroke: 'rgba(52, 211, 153,', base: '#34d399' };  // green
      if (r < -0.1) return { stroke: 'rgba(248, 113, 113,', base: '#f87171' }; // red
      return { stroke: 'rgba(96, 165, 250,', base: '#60a5fa' };                // blue (neutral)
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // Draw edges
      for (const e of edges) {
        const a = nodeMap.get(e.source);
        const b = nodeMap.get(e.target);
        if (!a || !b) continue;
        const absR = Math.abs(e.r);
        const ec = edgeColor(e.r);
        const isHovered = e === hoveredEdge;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = ec.stroke + (isHovered ? '1.0)' : (0.3 + absR * 0.5).toFixed(2) + ')');
        ctx.lineWidth = isHovered ? Math.max(3, absR * 5) : Math.max(1, absR * 4);
        ctx.stroke();
      }

      // Draw nodes
      for (const n of nodes) {
        const isHovered = n === hoveredNode;
        const radius = Math.max(12, 8 + n.signalCount * 0.08);
        ctx.beginPath();
        ctx.arc(n.x, n.y, radius, 0, 2 * Math.PI);
        ctx.fillStyle = isHovered ? '#fff' : n.color;
        ctx.fill();
        ctx.strokeStyle = isHovered ? n.color : '#002d38';
        ctx.lineWidth = isHovered ? 3 : 2;
        ctx.stroke();

        // Label
        ctx.fillStyle = isHovered ? '#000' : '#fff';
        ctx.font = 'bold 11px monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(n.label, n.x, n.y);
      }

      // Draw tooltip for hovered node
      if (hoveredNode) {
        const n = hoveredNode;
        const radius = Math.max(12, 8 + n.signalCount * 0.08);
        // Find connected edge with strongest |r|
        let connInfo = '';
        let bestR = 0;
        for (const e of edges) {
          if (e.source === n.id || e.target === n.id) {
            if (Math.abs(e.r) > Math.abs(bestR)) {
              bestR = e.r;
              const other = e.source === n.id ? e.target : e.source;
              const otherNode = nodeMap.get(other);
              connInfo = ` (r = ${bestR > 0 ? '+' : ''}${bestR.toFixed(2)} with ${otherNode?.label || other})`;
            }
          }
        }
        const label = n.id + ': ' + n.title + connInfo;
        drawTooltip(n.x, n.y - radius - 28, label, n.color);
      }

      // Draw tooltip for hovered edge
      if (hoveredEdge && !hoveredNode) {
        const e = hoveredEdge;
        const a = nodeMap.get(e.source);
        const b = nodeMap.get(e.target);
        if (a && b) {
          const midX = (a.x + b.x) / 2;
          const midY = (a.y + b.y) / 2;
          const aNode = nodeMap.get(e.source);
          const bNode = nodeMap.get(e.target);
          const label = `${e.source} ↔ ${e.target}: r = ${e.r > 0 ? '+' : ''}${e.r.toFixed(3)} (n=${e.n})`;
          const ec = edgeColor(e.r);
          drawTooltip(midX, midY - 20, label, ec.base);
        }
      }
    }

    function drawTooltip(cx, ty, label, borderColor) {
      ctx.font = 'bold 12px sans-serif';
      const tw = ctx.measureText(label).width;
      const px = 8, py = 4;
      let tx = cx - tw / 2 - px;
      if (tx < 4) tx = 4;
      if (tx + tw + px * 2 > W - 4) tx = W - 4 - tw - px * 2;
      if (ty < 4) ty += 50;
      ctx.fillStyle = 'rgba(18, 18, 26, 0.95)';
      ctx.strokeStyle = borderColor;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.roundRect(tx, ty, tw + px * 2, 20 + py * 2, 4);
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = '#98a8a8';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'middle';
      ctx.fillText(label, tx + px, ty + 10 + py);
    }

    function loop() {
      simulate();
      draw();
      requestAnimationFrame(loop);
    }

    loop();
  </script>

  {/* === Client-side: Power Rankings sort === */}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const table = document.getElementById('power-table');
      if (!table) return;
      const thead = table.querySelector('thead');
      const tbody = document.getElementById('power-body');
      if (!thead || !tbody) return;

      const headers = thead.querySelectorAll('td[data-col]');
      let currentSort = 'avgScore';
      let ascending = false;

      function sortTable(col, type) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const colIdx = Array.from(headers).findIndex(h => h.dataset.col === col);
        if (colIdx < 0) return;

        if (currentSort === col) {
          ascending = !ascending;
        } else {
          currentSort = col;
          ascending = type === 'str'; // strings default ascending, numbers descending
        }

        rows.sort((a, b) => {
          const cellA = a.children[colIdx];
          const cellB = b.children[colIdx];
          let va, vb;
          if (type === 'num') {
            va = parseFloat(cellA.dataset.val ?? cellA.textContent ?? '0');
            vb = parseFloat(cellB.dataset.val ?? cellB.textContent ?? '0');
            if (isNaN(va)) va = -9999;
            if (isNaN(vb)) vb = -9999;
          } else {
            va = (cellA.textContent ?? '').trim().toLowerCase();
            vb = (cellB.textContent ?? '').trim().toLowerCase();
          }
          let cmp = va < vb ? -1 : va > vb ? 1 : 0;
          return ascending ? cmp : -cmp;
        });

        // Update rank column and re-append
        rows.forEach((row, i) => {
          row.children[0].textContent = String(i + 1);
          tbody.appendChild(row);
        });

        // Update header indicators
        headers.forEach(h => {
          const base = h.textContent.replace(/ [▲▼]/g, '').trim();
          if (h.dataset.col === col) {
            h.textContent = base + (ascending ? ' ▲' : ' ▼');
          } else {
            h.textContent = base;
          }
        });
      }

      headers.forEach(h => {
        h.addEventListener('click', () => {
          sortTable(h.dataset.col, h.dataset.type);
        });
      });
    });
  </script>
</Base>
