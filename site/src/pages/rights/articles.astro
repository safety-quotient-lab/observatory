---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import { scoreToColor, formatScore, confidenceToColor, formatConfidence } from '../../lib/colors';
import { ARTICLE_TITLES, ARTICLE_GROUPS, SECTIONS } from '../../lib/udhr';
import { getArticleDetailedStats, getArticleSparklines } from '../../lib/db';
import { cachedQuery } from '../../lib/db-utils';

const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

const [articleStats, sparklinesRaw] = await Promise.all([
  cachedQuery(kv, 'articleDetailedStats', () => getArticleDetailedStats(db), 600),
  cachedQuery(kv, 'articleSparklines:30', () => getArticleSparklines(db, 30), 600),
]);

// Build section → ordered final values map from daily rollup rows
const sparklines = new Map<string, number[]>();
for (const row of sparklinesRaw) {
  let arr = sparklines.get(row.section);
  if (!arr) { arr = []; sparklines.set(row.section, arr); }
  arr.push(row.final);
}

const statsMap = new Map(articleStats.map(a => [a.section, a]));
const totalEvaluated = Math.max(...articleStats.map(a => a.signal_count + a.nd_count), 0);

// Group sections by UDHR group
const groupedSections = new Map<string, typeof SECTIONS>();
for (const s of SECTIONS) {
  const arr = groupedSections.get(s.group) || [];
  arr.push(s);
  groupedSections.set(s.group, arr);
}

const groupColors: Record<string, string> = {
  'Foundation & Dignity': '#a78bfa',
  'Civil & Political Rights': '#60a5fa',
  'Legal Rights': '#22d3ee',
  'Personal Freedoms': '#34d399',
  'Political & Community Rights': '#fbbf24',
  'Economic, Social & Cultural Rights': '#fb923c',
  'Order & Limitations': '#f87171',
};
---

<Base title="UDHR Articles — HN HRCB">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'rights', href: '/rights' }, { label: 'articles' }]} />
  <SubNav items={[{ label: 'Articles', href: '/rights/articles' }, { label: 'Observatory', href: '/rights/observatory' }, { label: 'Network', href: '/rights/network' }]} current="/rights/articles" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">UDHR Articles</span>
        <span style="color: #5b7279; margin-left: 8px; font-size: var(--font-base);">
          31 provisions · {articleStats.filter(a => a.signal_count > 0).length} with scores
        </span>
      </td>
    </tr>
  </table>

  {[...groupedSections.entries()].map(([group, sections]) => {
    const color = groupColors[group] || '#5b7279';
    return (
      <div class="table-wrap">
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
            <div style="margin-bottom: 8px; display: flex; align-items: center; gap: 8px;">
              <span style={`color: ${color}; font-size: var(--font-sm); font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;`}>{group}</span>
              <span style="color: #1a5568; font-size: var(--font-xs);">{sections.length} articles</span>
            </div>

            <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base); min-width: 480px;">
              {sections.map(s => {
                const stat = statsMap.get(s.id);
                const hasData = stat && stat.signal_count > 0;
                const covPct = stat && totalEvaluated > 0 ? Math.round((stat.signal_count / totalEvaluated) * 100) : 0;
                const spark = sparklines.get(s.id) || [];
                let sparkPath = '';
                if (spark.length > 1) {
                  const w = 60, h = 14;
                  const step = w / (spark.length - 1);
                  sparkPath = spark.map((v, i) => {
                    const x = i * step;
                    const y = h / 2 - (v * h / 2);
                    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
                  }).join(' ');
                }
                return (
                  <tr style="border-top: 1px solid #0d4655;">
                    <td style="width: 24px; color: #5b7279;" class="score-font">
                      <a href={`/article/${s.number}`} style={`color: ${hasData ? color : '#0d4655'}; font-weight: bold;`}>
                        {s.id === 'Preamble' ? 'P' : s.number}
                      </a>
                    </td>
                    <td>
                      <a href={`/article/${s.number}`} style={`color: ${hasData ? '#98a8a8' : '#5b7279'};`}>
                        {s.title}
                      </a>
                      <div style="color: #1a5568; font-size: var(--font-xs); margin-top: 1px; max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        {s.text.slice(0, 120)}{s.text.length > 120 ? '...' : ''}
                      </div>
                    </td>
                    <td style="width: 70px; text-align: right;" class="score-font">
                      {hasData ? (
                        <span style={`color: ${scoreToColor(stat.avg_final)};`}>{formatScore(stat.avg_final)}</span>
                      ) : (
                        <span style="color: #0d4655;">—</span>
                      )}
                    </td>
                    <td style="width: 60px; text-align: right; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                      {hasData ? `${stat.signal_count} (${covPct}%)` : ''}
                    </td>
                    <td style="width: 65px; text-align: center;">
                      {spark.length > 1 ? (
                        <svg width="60" height="14" viewBox="0 0 60 14">
                          <line x1="0" y1="7" x2="60" y2="7" stroke="#0d4655" stroke-width="0.5" />
                          <path d={sparkPath} fill="none" stroke={color} stroke-width="1" />
                        </svg>
                      ) : (
                        <span style="color: #0d4655;">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </table>
          </td>
        </tr>
      </table>
      </div>
    );
  })}
</Base>
