---
import Base from '../../layouts/Base.astro';
import { getEvaluatedCount } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;

const evalCount = await getEvaluatedCount(db);

// Sub-page cards
const subPages = [
  {
    title: 'Observatory',
    href: '/rights/observatory',
    description: 'Deep-dive research dashboard. UDHR heatmap, propaganda landscape, stakeholder voices, and evidence transparency.',
  },
  {
    title: 'Articles',
    href: '/rights/articles',
    description: 'Browse all 31 UDHR provisions with scoring trends and coverage statistics.',
  },
  {
    title: 'Network',
    href: '/rights/network',
    description: 'Rights correlation network. Which UDHR provisions move together?',
  },
];
---

<Base title="Rights">
  <div style="padding: 8px 0 16px 0;">
    <!-- Header -->
    <div style="margin-bottom: 16px;">
      <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">Rights</span>
      <span style="color: #5b7279; margin-left: 8px; font-size: var(--font-sm);">
        Human rights analysis across {evalCount.toLocaleString()} evaluated stories
      </span>
    </div>

    <!-- Sub-page cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px;">
      {subPages.map(page => (
        <a href={page.href} style="text-decoration: none;">
          <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; transition: border-color 0.2s;"
               class="hub-card">
            <div style="margin-bottom: 6px;">
              <span style="color: #98a8a8; font-size: var(--font-sm); font-weight: bold;">{page.title}</span>
            </div>
            <div style="color: #5b7279; font-size: var(--font-xs); line-height: 1.5;">
              {page.description}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <style>
    .hub-card:hover {
      border-color: var(--fg-secondary) !important;
    }
  </style>
</Base>
