---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import { getArticleDetailedStats, getArticleSparklines, getSignalOverview, getDomainStats, getDomainFingerprints, getDailyHrcb, getStatusCounts, getTopPropagandaStories, getStakeholderOverview, getRegionDistribution } from '../../lib/db';
import { scoreToColor, formatScore, computeConfidence, confidenceToColor, formatConfidence, fwRatioColor, formatFwRatio } from '../../lib/colors';
import { ARTICLE_GROUPS, ARTICLE_TITLES, ALL_SECTIONS, SECTIONS } from '../../lib/udhr';
import { readDb } from '../../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);

const [articleStats, sparklinesRaw, statusCounts, dailyHrcb, topDomains, propagandaStories] = await Promise.all([
  getArticleDetailedStats(db),
  getArticleSparklines(db, 60),
  getStatusCounts(db),
  getDailyHrcb(db, 60),
  getDomainStats(db, 10),
  getTopPropagandaStories(db, 15),
]);

// Build section → ordered final values map from daily rollup rows
const sparklines = new Map<string, number[]>();
for (const row of sparklinesRaw) {
  let arr = sparklines.get(row.section);
  if (!arr) { arr = []; sparklines.set(row.section, arr); }
  arr.push(row.final);
}

// Graceful fallback for newer queries
let signalOverview: Awaited<ReturnType<typeof getSignalOverview>> | null = null;
let stakeholderData: Awaited<ReturnType<typeof getStakeholderOverview>> | null = null;
let regionData: Awaited<ReturnType<typeof getRegionDistribution>> | null = null;
try {
  [signalOverview, stakeholderData, regionData] = await Promise.all([
    getSignalOverview(db),
    getStakeholderOverview(db),
    getRegionDistribution(db),
  ]);
} catch { /* graceful fallback */ }

const domainFingerprints = await getDomainFingerprints(db, topDomains.map(d => d.domain));

// Derived data
const statsMap = new Map(articleStats.map(a => [a.section, a]));
const totalEvaluated = statusCounts.done;
const allScores = articleStats.filter(a => a.avg_final !== null);
const meanHrcb = allScores.length > 0
  ? allScores.reduce((sum, a) => sum + (a.avg_final ?? 0), 0) / allScores.length
  : null;
const coveragePct = ALL_SECTIONS.length > 0
  ? Math.round((allScores.length / ALL_SECTIONS.length) * 100)
  : 0;

// Rights Under Pressure
const sortedByScore = [...articleStats].filter(a => a.avg_final !== null).sort((a, b) => (a.avg_final ?? 0) - (b.avg_final ?? 0));
const mostNegative = sortedByScore.slice(0, 5);
const mostTriggered = [...articleStats].filter(a => a.signal_count > 0).sort((a, b) => b.signal_count - a.signal_count).slice(0, 5);
const lowestCoverage = [...articleStats].filter(a => a.signal_count >= 0).sort((a, b) => a.signal_count - b.signal_count).slice(0, 5);

// Evidence Transparency — sorted by lowest FW ratio
const articlesWithFwRatio = articleStats
  .map(a => {
    const total = (a.evidence_h ?? 0) + (a.evidence_m ?? 0) + (a.evidence_l ?? 0);
    const ratio = total > 0 ? (a.evidence_h ?? 0) / total : null;
    return { ...a, fw_ratio: ratio, fw_total: total };
  })
  .filter(a => a.fw_ratio !== null && a.fw_total > 0)
  .sort((a, b) => (a.fw_ratio ?? 0) - (b.fw_ratio ?? 0))
  .slice(0, 10);

// Propaganda technique distribution
const techniqueEntries = signalOverview?.technique_distribution
  ? Object.entries(signalOverview.technique_distribution).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const maxTechniqueCount = techniqueEntries.length > 0 ? techniqueEntries[0][1] : 1;

// Stakeholder data
const speaksEntries = stakeholderData?.who_speaks
  ? Object.entries(stakeholderData.who_speaks).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const aboutEntries = stakeholderData?.who_spoken_about
  ? Object.entries(stakeholderData.who_spoken_about).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const maxSpeaks = speaksEntries.length > 0 ? speaksEntries[0][1] : 1;
const maxAbout = aboutEntries.length > 0 ? aboutEntries[0][1] : 1;

// Region data
const scopeEntries = regionData?.scopes
  ? Object.entries(regionData.scopes).sort((a, b) => b[1] - a[1])
  : [];
const maxScopeCount = scopeEntries.length > 0 ? scopeEntries[0][1] : 1;
const regionEntries = regionData?.regions
  ? regionData.regions.slice(0, 15)
  : [];
const maxRegionCount = regionEntries.length > 0 ? regionEntries[0].count : 1;

// Daily HRCB chart data
const dailyReversed = [...dailyHrcb]; // already chronological from getDailyHrcb
const maxDailyCount = dailyReversed.length > 0 ? Math.max(...dailyReversed.map(d => d.count)) : 1;
const latestDailyScore = dailyReversed.length > 0 ? dailyReversed[dailyReversed.length - 1].avg : 0;

// Group colors
const groupColors: Record<string, string> = {
  'Foundation': '#a78bfa',
  'Security': '#f87171',
  'Legal': '#22d3ee',
  'Privacy & Movement': '#34d399',
  'Personal': '#60a5fa',
  'Expression': '#fbbf24',
  'Economic & Social': '#fb923c',
  'Cultural': '#e879f9',
  'Order & Duties': '#7d80d1',
};
---

<Base title="Human Rights Observatory">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'rights', href: '/rights' }, { label: 'observatory' }]} />
  <SubNav items={[{ label: 'Articles', href: '/rights/articles' }, { label: 'Observatory', href: '/rights/observatory' }, { label: 'Network', href: '/rights/network' }]} current="/rights/observatory" />
  <div style="padding: 8px 0 16px 0;">

    <!-- 1. Header -->
    <div style="margin-bottom: 16px;">
      <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">Human Rights Observatory</span>
      <span style="color: #5b7279; margin-left: 8px; font-size: var(--font-sm);">
        Deep-dive research dashboard
      </span>
    </div>

    <!-- Stats row -->
    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 16px;">
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 10px 16px; min-width: 120px;">
        <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">Evaluated</div>
        <div style="color: #98a8a8; font-size: var(--font-md); font-weight: bold;" class="score-font">{totalEvaluated.toLocaleString()}</div>
      </div>
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 10px 16px; min-width: 120px;">
        <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">Mean HRCB</div>
        <div style={`font-size: var(--font-md); font-weight: bold; color: ${scoreToColor(meanHrcb)};`} class="score-font">
          {formatScore(meanHrcb)}
        </div>
      </div>
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 10px 16px; min-width: 120px;">
        <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">Coverage</div>
        <div style="color: #98a8a8; font-size: var(--font-md); font-weight: bold;" class="score-font">{coveragePct}%</div>
      </div>
    </div>

    <!-- 2. UDHR Rights Heatmap -->
    <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">UDHR Rights Heatmap</div>

      {Object.entries(ARTICLE_GROUPS).map(([group, sectionIds]) => {
        const color = groupColors[group] || '#5b7279';
        return (
          <div style="margin-bottom: 10px;">
            <div style={`color: ${color}; font-size: var(--font-xs); margin-bottom: 4px; opacity: 0.8;`}>{group}</div>
            <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
              {sectionIds.map(sid => {
                const stat = statsMap.get(sid);
                const score = stat?.avg_final ?? null;
                const count = stat?.signal_count ?? 0;
                const section = SECTIONS.find(s => s.id === sid);
                const label = sid === 'Preamble' ? 'P' : String(section?.number ?? '?');
                const title = ARTICLE_TITLES[sid] ?? sid;
                const barWidth = score !== null ? Math.abs(score) * 100 : 0;
                const barColor = scoreToColor(score);
                const spark = sparklines.get(sid) || [];
                let sparkPath = '';
                if (spark.length > 1) {
                  const w = 80;
                  const h = 20;
                  const step = w / (spark.length - 1);
                  sparkPath = spark.map((v, i) => {
                    const x = i * step;
                    const y = h / 2 - (v * h / 2);
                    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
                  }).join(' ');
                }
                return (
                  <tr style="border-top: 1px solid #0d4655;">
                    <td style={`width: 22px; padding: 3px 4px; color: ${score !== null ? color : '#0d4655'}; font-weight: bold;`} class="score-font">
                      <a href={`/article/${section?.number ?? 0}`} style={`color: inherit; text-decoration: none;`}>{label}</a>
                    </td>
                    <td title={title} style={`padding: 3px 4px; color: ${score !== null ? '#98a8a8' : '#5b7279'}; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;`}>
                      <a href={`/article/${section?.number ?? 0}`} style={`color: inherit; text-decoration: none;`}>{title}</a>
                    </td>
                    <td style="width: 140px; padding: 3px 4px;">
                      {score !== null ? (
                        <div style="display: flex; align-items: center; gap: 4px;">
                          <div style="flex: 1; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                            <div style={`width: ${barWidth}%; height: 100%; background: ${barColor}; border-radius: 3px;`}></div>
                          </div>
                          <span style={`color: ${barColor}; font-size: var(--font-xs); min-width: 36px; text-align: right;`} class="score-font">{formatScore(score)}</span>
                        </div>
                      ) : (
                        <span style="color: #0d4655;">--</span>
                      )}
                    </td>
                    <td style="width: 50px; padding: 3px 4px; text-align: right; color: #5b7279;" class="score-font">
                      {count > 0 ? count : '--'}
                    </td>
                    <td style="width: 90px; padding: 3px 4px; text-align: center;">
                      {spark.length > 1 ? (
                        <svg width="80" height="20" viewBox="0 0 80 20">
                          <line x1="0" y1="10" x2="80" y2="10" stroke="#0d4655" stroke-width="0.5" />
                          <path d={sparkPath} fill="none" stroke={color} stroke-width="1" />
                        </svg>
                      ) : (
                        <span style="color: #0d4655;">--</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </table>
          </div>
        );
      })}
    </div>

    <!-- 3. Rights Under Pressure -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-bottom: 16px;">
      <!-- Most Negative -->
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Most Negative</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {mostNegative.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: #98a8a8; font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style={`color: ${scoreToColor(a.avg_final)}; font-size: var(--font-xs);`} class="score-font">{formatScore(a.avg_final)}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>

      <!-- Most Triggered -->
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Most Triggered</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {mostTriggered.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: #98a8a8; font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style="color: #5b7279; font-size: var(--font-xs);" class="score-font">{a.signal_count}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>

      <!-- Lowest Coverage -->
      <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Lowest Coverage</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {lowestCoverage.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: #98a8a8; font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style="color: #5b7279; font-size: var(--font-xs);" class="score-font">{a.signal_count}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>
    </div>

    <!-- 4. Evidence Transparency -->
    <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Evidence Transparency — Weakest Fair Witness Ratios</div>
      <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 10px;">
        FW Ratio = High-evidence signals / total evidence signals. Lower = more inference-heavy.
      </div>
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr style="color: #5b7279; font-size: var(--font-xs);">
          <td style="padding: 4px 0;">Article</td>
          <td style="width: 200px; padding: 4px 0;">Ratio</td>
          <td style="width: 50px; text-align: right; padding: 4px 0;">%</td>
        </tr>
        {articlesWithFwRatio.map(a => {
          const section = SECTIONS.find(s => s.id === a.section);
          const pct = a.fw_ratio !== null ? Math.round(a.fw_ratio * 100) : 0;
          const barColor = fwRatioColor(a.fw_ratio);
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 4px 0;">
                <a href={`/article/${section?.number ?? 0}`} style="color: #98a8a8; font-size: var(--font-xs); text-decoration: none;">
                  {ARTICLE_TITLES[a.section] ?? a.section}
                </a>
              </td>
              <td style="width: 200px; padding: 4px 0;">
                <div style="height: 8px; background: #0d4655; border-radius: 4px; overflow: hidden;">
                  <div style={`width: ${pct}%; height: 100%; background: ${barColor}; border-radius: 4px;`}></div>
                </div>
              </td>
              <td style="width: 50px; text-align: right; padding: 4px 0;">
                <span style={`color: ${barColor}; font-size: var(--font-xs);`} class="score-font">{formatFwRatio(a.fw_ratio)}</span>
              </td>
            </tr>
          );
        })}
      </table>
      {articlesWithFwRatio.length === 0 && (
        <div style="color: #5b7279; font-size: var(--font-xs); padding: 8px 0;">No evidence data available yet.</div>
      )}
    </div>

    <!-- 5. Propaganda Landscape -->
    <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Propaganda Landscape</div>

      {techniqueEntries.length > 0 && (
        <div style="margin-bottom: 14px;">
          <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 6px;">Technique Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {techniqueEntries.map(([technique, count]) => {
              const pct = maxTechniqueCount > 0 ? Math.round((count / maxTechniqueCount) * 100) : 0;
              return (
                <tr>
                  <td title={technique} style="padding: 3px 0; color: #98a8a8; font-size: var(--font-xs); width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {technique}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: #f87171; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 40px; text-align: right; padding: 3px 0; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
        </div>
      )}

      {propagandaStories.length > 0 ? (
        <div>
          <div style="color: #5b7279; font-size: var(--font-xs); margin-bottom: 6px;">Top Flagged Stories</div>
          <div class="table-wrap">
          <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs); min-width: 480px;">
            <tr style="color: #5b7279;">
              <td style="padding: 4px 0;">Title</td>
              <td style="width: 120px; padding: 4px 0;">Domain</td>
              <td style="width: 50px; text-align: right; padding: 4px 0;">Flags</td>
              <td style="width: 60px; text-align: right; padding: 4px 0;">HRCB</td>
            </tr>
            {propagandaStories.map(s => (
              <tr style="border-top: 1px solid #0d4655;">
                <td title={s.title} style="padding: 4px 0; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  <a href={`/item/${s.hn_id}`} style="color: #98a8a8; text-decoration: none;">{s.title}</a>
                </td>
                <td title={s.domain ?? '--'} style="width: 120px; padding: 4px 0; color: #5b7279; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.domain ? <a href={`/domain/${s.domain}`} style="color: #5b7279; text-decoration: none;">{s.domain}</a> : '--'}
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0; color: #f87171;" class="score-font">
                  {s.pt_flag_count}
                </td>
                <td style="width: 60px; text-align: right; padding: 4px 0;">
                  <span style={`color: ${scoreToColor(s.hcb_editorial_mean ?? s.hcb_weighted_mean)};`} class="score-font">{formatScore(s.hcb_editorial_mean ?? s.hcb_weighted_mean)}</span>
                </td>
              </tr>
            ))}
          </table>
          </div>
        </div>
      ) : (
        <div style="color: #5b7279; font-size: var(--font-xs); padding: 8px 0;">No propaganda flags detected yet.</div>
      )}
    </div>

    <!-- 6. Stakeholder Voice -->
    {(speaksEntries.length > 0 || aboutEntries.length > 0) && (
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
        <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Who Speaks</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {speaksEntries.map(([name, count]) => {
              const pct = maxSpeaks > 0 ? Math.round((count / maxSpeaks) * 100) : 0;
              return (
                <tr>
                  <td title={name} style="padding: 3px 0; color: #98a8a8; font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {name}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: #a78bfa; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {speaksEntries.length === 0 && (
            <div style="color: #5b7279; font-size: var(--font-xs);">No data.</div>
          )}
        </div>

        <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Who Is Spoken About</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {aboutEntries.map(([name, count]) => {
              const pct = maxAbout > 0 ? Math.round((count / maxAbout) * 100) : 0;
              return (
                <tr>
                  <td title={name} style="padding: 3px 0; color: #98a8a8; font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {name}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: #22d3ee; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {aboutEntries.length === 0 && (
            <div style="color: #5b7279; font-size: var(--font-xs);">No data.</div>
          )}
        </div>
      </div>
    )}

    <!-- 7. Geographic Coverage -->
    {(scopeEntries.length > 0 || regionEntries.length > 0) && (
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
        <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Scope Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {scopeEntries.map(([scope, count]) => {
              const pct = maxScopeCount > 0 ? Math.round((count / maxScopeCount) * 100) : 0;
              return (
                <tr>
                  <td style="padding: 3px 0; color: #98a8a8; font-size: var(--font-xs); width: 100px;">
                    {scope}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: #34d399; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 40px; text-align: right; padding: 3px 0; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {scopeEntries.length === 0 && (
            <div style="color: #5b7279; font-size: var(--font-xs);">No scope data.</div>
          )}
        </div>

        <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Region Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {regionEntries.map(r => {
              const pct = maxRegionCount > 0 ? Math.round((r.count / maxRegionCount) * 100) : 0;
              return (
                <tr>
                  <td title={r.region} style="padding: 3px 0; color: #98a8a8; font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {r.region}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: #60a5fa; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: #5b7279; font-size: var(--font-xs);" class="score-font">
                    {r.count}
                  </td>
                </tr>
              );
            })}
          </table>
          {regionEntries.length === 0 && (
            <div style="color: #5b7279; font-size: var(--font-xs);">No region data.</div>
          )}
        </div>
      </div>
    )}

    <!-- 8. Temporal Trends -->
    <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Temporal Trends — 60-Day HRCB</div>
      {dailyReversed.length > 1 ? (() => {
        const chartW = 400;
        const chartH = 100;
        const barAreaH = 24;
        const lineAreaH = chartH - barAreaH;
        const step = chartW / (dailyReversed.length - 1);

        // Score line path
        const linePath = dailyReversed.map((d, i) => {
          const x = i * step;
          const y = lineAreaH / 2 - (d.avg * lineAreaH / 2);
          return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${Math.max(0, Math.min(lineAreaH, y)).toFixed(1)}`;
        }).join(' ');

        // Bar width
        const barW = Math.max(1, step * 0.6);

        return (
          <svg width="100%" viewBox={`0 0 ${chartW} ${chartH}`} preserveAspectRatio="xMidYMid meet" style="max-width: 600px;">
            {/* Zero reference line */}
            <line x1="0" y1={lineAreaH / 2} x2={chartW} y2={lineAreaH / 2} stroke="#1a5568" stroke-width="0.5" stroke-dasharray="4,4" />
            {/* Score line */}
            <path d={linePath} fill="none" stroke={scoreToColor(latestDailyScore)} stroke-width="1.5" />
            {/* Daily count bars */}
            {dailyReversed.map((d, i) => {
              const x = i * step - barW / 2;
              const barH = maxDailyCount > 0 ? (d.count / maxDailyCount) * barAreaH : 0;
              const barY = chartH - barH;
              return (
                <rect x={x.toFixed(1)} y={barY.toFixed(1)} width={barW.toFixed(1)} height={barH.toFixed(1)} fill="#1a5568" rx="1" />
              );
            })}
          </svg>
        );
      })() : (
        <div style="color: #5b7279; font-size: var(--font-xs);">Not enough data for trend chart.</div>
      )}
      <div style="display: flex; justify-content: space-between; margin-top: 6px;">
        <span style="color: #5b7279; font-size: var(--font-xs);">
          {dailyReversed.length > 0 ? dailyReversed[0].day : ''}
        </span>
        <div style="display: flex; gap: 12px;">
          <span style="color: #5b7279; font-size: var(--font-xs);">
            <span style={`display: inline-block; width: 8px; height: 2px; background: ${scoreToColor(latestDailyScore)}; vertical-align: middle; margin-right: 4px;`}></span>
            avg HRCB
          </span>
          <span style="color: #5b7279; font-size: var(--font-xs);">
            <span style="display: inline-block; width: 8px; height: 6px; background: #1a5568; vertical-align: middle; margin-right: 4px;"></span>
            eval count
          </span>
        </div>
        <span style="color: #5b7279; font-size: var(--font-xs);">
          {dailyReversed.length > 0 ? dailyReversed[dailyReversed.length - 1].day : ''}
        </span>
      </div>
    </div>

    <!-- 9. Domain Rights Profiles -->
    <div style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Domain Rights Profiles — Top 10</div>
      <div class="table-wrap">
      <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs); min-width: 480px;">
        <tr style="color: #5b7279;">
          <td style="padding: 4px 0;">Domain</td>
          <td style="width: 60px; text-align: right; padding: 4px 0;">HRCB</td>
          <td style="width: 50px; text-align: right; padding: 4px 0;">Stories</td>
          <td style="padding: 4px 8px;">Fingerprint</td>
        </tr>
        {topDomains.map(d => {
          const fp = domainFingerprints.get(d.domain);
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 4px 0;">
                <a href={`/domain/${d.domain}`} style="color: #98a8a8; text-decoration: none;">{d.domain}</a>
              </td>
              <td style="width: 60px; text-align: right; padding: 4px 0;">
                <span style={`color: ${scoreToColor(d.avg_score)};`} class="score-font">{formatScore(d.avg_score)}</span>
              </td>
              <td style="width: 50px; text-align: right; padding: 4px 0; color: #5b7279;" class="score-font">
                {d.count}
              </td>
              <td style="padding: 4px 8px;">
                {fp ? (
                  <div style="display: flex; gap: 1px; align-items: center;">
                    {fp.map((val, idx) => {
                      const bg = val !== null ? scoreToColor(val) : '#0d4655';
                      const opacity = val !== null ? '1' : '0.3';
                      return (
                        <div style={`width: 6px; height: 10px; background: ${bg}; border-radius: 1px; opacity: ${opacity};`} title={`${SECTIONS[idx]?.id ?? idx}: ${val !== null ? formatScore(val) : 'ND'}`}></div>
                      );
                    })}
                  </div>
                ) : (
                  <span style="color: #0d4655;">--</span>
                )}
              </td>
            </tr>
          );
        })}
      </table>
      </div>
    </div>

  </div>

  <style>
    .table-wrap {
      overflow-x: auto;
    }
    @media (max-width: 640px) {
      div[style*="grid-template-columns: 1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</Base>
