---
import Base from '../../layouts/Base.astro';
import { scoreToColor, formatScore, computeSetl, formatSetl, setlToColor, computeHotl, formatHotl, hotlToColor, computeConfidence, confidenceToColor, formatConfidence } from '../../lib/colors';
import { ARTICLE_TITLES, ALL_SECTIONS, getSection } from '../../lib/udhr';
import { getArticleRanking } from '../../lib/db';

const { n } = Astro.params;
const articleNum = parseInt(n!, 10);

if (isNaN(articleNum) || articleNum < 0 || articleNum > 30) {
  return Astro.redirect('/');
}

const section = articleNum === 0 ? 'Preamble' : `Article ${articleNum}`;
const articleTitle = ARTICLE_TITLES[section] || section;
const udhrSection = getSection(articleNum);

const db = Astro.locals.runtime.env.DB;
const rankings = await getArticleRanking(db, articleNum);

const prevNum = articleNum > 0 ? articleNum - 1 : null;
const nextNum = articleNum < 30 ? articleNum + 1 : null;

const jsonLd = udhrSection ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  name: `${section}: ${articleTitle}`,
  headline: `UDHR ${section} — ${articleTitle}`,
  description: udhrSection.text.slice(0, 200) + (udhrSection.text.length > 200 ? '...' : ''),
  url: `${Astro.url.origin}/article/${articleNum}`,
  isPartOf: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;
---

<Base title={`${section}: ${articleTitle} — Rankings`}>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">{section}</span>
        <span style="color: #828282; margin-left: 8px;">{articleTitle}</span>
      </td>
    </tr>
    <tr>
      <td class="subtext" style="padding: 4px 0 8px 0;">
        Stories ranked by their score on this UDHR provision.
        {prevNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${prevNum}`}>&larr; {prevNum === 0 ? 'Preamble' : `Article ${prevNum}`}</a>
          </>
        )}
        {nextNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${nextNum}`}>Article {nextNum} &rarr;</a>
          </>
        )}
      </td>
    </tr>
  </table>

  {/* UDHR Article Text */}
  {udhrSection && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
            UDHR Text
            <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
              {udhrSection.group}
            </span>
          </div>
          <div style="color: #aaa; font-size: var(--font-base); line-height: 1.6; white-space: pre-line;">{udhrSection.text}</div>
        </td>
      </tr>
    </table>
  )}

  {/* Article navigation */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 0 0 10px 0;">
    <tr>
      <td>
        <div style="color: #828282; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">All Articles</div>
        <div style="display: flex; flex-wrap: wrap; gap: 3px;">
          {ALL_SECTIONS.map((sec, i) => {
            const num = sec === 'Preamble' ? 0 : i;
            const isActive = num === articleNum;
            return (
              <a
                href={`/article/${num}`}
                style={`display: inline-block; padding: 2px 6px; font-size: var(--font-sm); border-radius: 3px; ${
                  isActive
                    ? 'background: rgba(255,102,0,0.2); color: #ff6600; border: 1px solid rgba(255,102,0,0.4);'
                    : 'background: #1a1a25; color: #828282; border: 1px solid #222230;'
                }`}
                class="score-font"
              >
                {sec === 'Preamble' ? 'P' : i}
              </a>
            );
          })}
        </div>
      </td>
    </tr>
  </table>

  {rankings.length > 0 ? (
    <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base);">
      <tr style="color: #828282; font-size: var(--font-sm);">
        <td width="30">#</td>
        <td width="60" align="center">HRCB</td>
        <td width="34" align="center" title="Confidence: signal coverage" style="cursor: help;">Conf</td>
        <td>Story</td>
        <td width="60" align="center" title="Editorial — what the content says" style="cursor: help;">Editorial</td>
        <td width="60" align="center" title="Structural — what the site does" style="cursor: help;">Structural</td>
        <td width="50" align="center" title="Structural-Editorial Tension Level" style="cursor: help;">SETL</td>
        <td width="50" align="center" title="Higher Order Tension Level" style="cursor: help;">HOTL</td>
        <td width="60" align="center" title="Evidence strength (High, Medium, Low)" style="cursor: help;">Evidence</td>
        <td width="60" align="center">Overall</td>
      </tr>
      {rankings.map((row, i) => {
        const rowSetl = computeSetl(row.structural, row.editorial);
        const rowHotl = computeHotl(row.hn_score, row.hn_comments);
        const rowConf = computeConfidence(row.hcb_evidence_h, row.hcb_evidence_m, row.hcb_evidence_l, row.hcb_nd_count);
        return (
        <tr style="border-top: 1px solid #222230;">
          <td style="color: #828282;" class="score-font">{i + 1}.</td>
          <td align="center">
            <span class="score-font" style={`color: ${scoreToColor(row.final)}; font-weight: bold;`}>
              {formatScore(row.final)}
            </span>
          </td>
          <td align="center" class="score-font" style={`color: ${confidenceToColor(rowConf)}; font-size: var(--font-sm);`}>
            {formatConfidence(rowConf)}
          </td>
          <td>
            <a href={`/item/${row.hn_id}`}>{row.title}</a>
            {row.domain && (
              <span style="color: #828282; font-size: var(--font-sm); margin-left: 4px;">({row.domain})</span>
            )}
          </td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.editorial)}; font-size: var(--font-sm);`}>
            {formatScore(row.editorial)}
          </td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.structural)}; font-size: var(--font-sm);`}>
            {formatScore(row.structural)}
          </td>
          <td align="center" class="score-font" style={`color: ${setlToColor(rowSetl)}; font-size: var(--font-sm);`}>
            {formatSetl(rowSetl)}
          </td>
          <td align="center" class="score-font" style={`color: ${hotlToColor(rowHotl)}; font-size: var(--font-sm);`}>
            {formatHotl(rowHotl)}
          </td>
          <td align="center" style="color: #828282; font-size: var(--font-sm);">
            {row.evidence ? ({'H': 'High', 'M': 'Medium', 'L': 'Low'}[row.evidence] ?? row.evidence) : ''}
          </td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.hcb_weighted_mean)}; font-size: var(--font-sm);`}>
            {formatScore(row.hcb_weighted_mean)}
          </td>
        </tr>
        );
      })}
    </table>
  ) : (
    <table width="100%">
      <tr>
        <td style="padding: 20px; text-align: center; color: #828282;">
          <div style="margin-bottom: 8px;">No stories have scored on this provision yet.</div>
          <div style="font-size: var(--font-sm); color: #555;">
            When stories are evaluated, those with signal on <strong style="color: #888;">{section}</strong> will be ranked here.
            Browse other articles above to see existing rankings.
          </div>
        </td>
      </tr>
    </table>
  )}

</Base>
