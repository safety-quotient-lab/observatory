---
import Base from '../../layouts/Base.astro';
import { scoreToColor, formatScore, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence } from '../../lib/colors';
import { ARTICLE_TITLES, ALL_SECTIONS, getSection } from '../../lib/udhr';
import { getArticleRanking, getArticleCoverage } from '../../lib/db';

const { n } = Astro.params;
const articleNum = parseInt(n!, 10);

if (isNaN(articleNum) || articleNum < 0 || articleNum > 30) {
  return Astro.redirect('/');
}

const section = articleNum === 0 ? 'Preamble' : `Article ${articleNum}`;
const articleTitle = ARTICLE_TITLES[section] || section;
const udhrSection = getSection(articleNum);

const db = Astro.locals.runtime.env.DB;
const url = new URL(Astro.request.url);
const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));
const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

const [rankings, coverage] = await Promise.all([
  getArticleRanking(db, articleNum, PER_PAGE + 1, offset),
  getArticleCoverage(db),
]);
const hasMore = rankings.length > PER_PAGE;
const displayRankings = hasMore ? rankings.slice(0, PER_PAGE) : rankings;

// Build a map of section -> { signal_count, avg_final } for the article selector
const coverageMap = new Map(coverage.map(c => [c.section, c]));

const prevNum = articleNum > 0 ? articleNum - 1 : null;
const nextNum = articleNum < 30 ? articleNum + 1 : null;

const jsonLd = udhrSection ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  name: `${section}: ${articleTitle}`,
  headline: `UDHR ${section} — ${articleTitle}`,
  description: udhrSection.text.slice(0, 200) + (udhrSection.text.length > 200 ? '...' : ''),
  url: `${Astro.url.origin}/article/${articleNum}`,
  isPartOf: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;
---

<Base title={`${section}: ${articleTitle} — Rankings`}>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}
  {/* Breadcrumb */}
  <div style="padding: 4px 0; font-size: var(--font-xs); color: #555;">
    <a href="/" style="color: #555;">home</a>
    <span style="color: #333;"> / </span>
    <a href="/rights/articles" style="color: #555;">articles</a>
    <span style="color: #333;"> / </span>
    <span style="color: #888;">{section}</span>
  </div>
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">{section}</span>
        <span style="color: #828282; margin-left: 8px;">{articleTitle}</span>
      </td>
    </tr>
    <tr>
      <td class="subtext" style="padding: 4px 0 8px 0;">
        Stories ranked by their score on this UDHR provision.
        {page > 1 && <span style="color: #555;"> · page {page}</span>}
        {prevNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${prevNum}`}>&larr; {prevNum === 0 ? 'Preamble' : `Article ${prevNum}`}</a>
          </>
        )}
        {nextNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${nextNum}`}>Article {nextNum} &rarr;</a>
          </>
        )}
      </td>
    </tr>
  </table>

  {/* UDHR Article Text */}
  {udhrSection && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
            UDHR Text
            <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
              {udhrSection.group}
            </span>
          </div>
          <div style="color: #aaa; font-size: var(--font-base); line-height: 1.6; white-space: pre-line;">{udhrSection.text}</div>
        </td>
      </tr>
    </table>
  )}

  {/* Article navigation */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 0 0 10px 0;">
    <tr>
      <td>
        <div style="color: #828282; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
          All Articles
          <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
            {coverage.filter(c => c.signal_count > 0).length}/{ALL_SECTIONS.length} with scores
          </span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 3px;">
          {ALL_SECTIONS.map((sec, i) => {
            const num = sec === 'Preamble' ? 0 : i;
            const isActive = num === articleNum;
            const cov = coverageMap.get(sec);
            const hasScores = cov && cov.signal_count > 0;
            let style: string;
            if (isActive) {
              style = 'background: rgba(255,102,0,0.2); color: #ff6600; border: 1px solid rgba(255,102,0,0.4);';
            } else if (hasScores) {
              style = `background: ${scoreToColor(cov.avg_final)}20; color: ${scoreToColor(cov.avg_final)}; border: 1px solid ${scoreToColor(cov.avg_final)}40;`;
            } else {
              style = 'background: #1a1a25; color: #444; border: 1px solid #1a1a25;';
            }
            return (
              <a
                href={`/article/${num}`}
                style={`display: inline-block; padding: 2px 6px; font-size: var(--font-sm); border-radius: 3px; ${style}`}
                class="score-font"
                title={`${sec}: ${ARTICLE_TITLES[sec]}${hasScores ? ` — ${cov.signal_count} stories, avg ${formatScore(cov.avg_final)}` : ' — no scores yet'}`}
              >
                {sec === 'Preamble' ? 'P' : i}
              </a>
            );
          })}
        </div>
      </td>
    </tr>
  </table>

  {displayRankings.length > 0 ? (
    <table id="article-table" cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base);">
      <thead>
        <tr style="color: #828282; font-size: var(--font-sm); cursor: pointer; user-select: none;">
          <td data-col="rank" data-type="num" width="30"># ▼</td>
          <td data-col="hrcb" data-type="num" width="60" align="center">HRCB</td>
          <td data-col="pts" data-type="num" width="34" align="center" title="HN Points">Pts</td>
          <td data-col="cmt" data-type="num" width="34" align="center" title="HN Comments">Cmt</td>
          <td data-col="conf" data-type="num" width="34" align="center" title="Confidence: signal coverage">Conf</td>
          <td data-col="story" data-type="str">Story</td>
          <td data-col="editorial" data-type="num" width="60" align="center" title="Editorial — what the content says">Editorial</td>
          <td data-col="structural" data-type="num" width="60" align="center" title="Structural — what the site does">Structural</td>
          <td data-col="setl" data-type="num" width="50" align="center" title="Structural-Editorial Tension Level">SETL</td>
          <td data-col="evidence" data-type="evidence" width="60" align="center" title="Evidence strength (High, Medium, Low)">Evidence</td>
          <td data-col="overall" data-type="num" width="60" align="center">Overall</td>
        </tr>
      </thead>
      <tbody id="article-body">
        {displayRankings.map((row, i) => {
          const rowSetl = computeSetl(row.structural, row.editorial);
          const rowConf = computeConfidence(row.hcb_evidence_h, row.hcb_evidence_m, row.hcb_evidence_l, row.hcb_nd_count);
          return (
          <tr style="border-top: 1px solid #222230;">
            <td style="color: #828282;" class="score-font" data-val={offset + i + 1}>{offset + i + 1}.</td>
            <td align="center" data-val={row.final ?? -999}>
              <span class="score-font" style={`color: ${scoreToColor(row.final)}; font-weight: bold;`}>
                {formatScore(row.final)}
              </span>
            </td>
            <td align="center" style="color: #888; font-size: var(--font-sm);" data-val={row.hn_score ?? -999}>
              {row.hn_score ?? ''}
            </td>
            <td align="center" style="color: #666; font-size: var(--font-sm);" data-val={row.hn_comments ?? -999}>
              {row.hn_comments ?? ''}
            </td>
            <td align="center" class="score-font" style={`color: ${confidenceToColor(rowConf)}; font-size: var(--font-sm);`} data-val={rowConf ?? -999}>
              {formatConfidence(rowConf)}
            </td>
            <td data-val={row.title}>
              <a href={`/item/${row.hn_id}`}>{row.title}</a>
              {row.domain && (
                <span style="color: #828282; font-size: var(--font-sm); margin-left: 4px;">({row.domain})</span>
              )}
            </td>
            <td align="center" class="score-font" style={`color: ${scoreToColor(row.editorial)}; font-size: var(--font-sm);`} data-val={row.editorial ?? -999}>
              {formatScore(row.editorial)}
            </td>
            <td align="center" class="score-font" style={`color: ${scoreToColor(row.structural)}; font-size: var(--font-sm);`} data-val={row.structural ?? -999}>
              {formatScore(row.structural)}
            </td>
            <td align="center" class="score-font" style={`color: ${setlToColor(rowSetl)}; font-size: var(--font-sm);`} data-val={rowSetl ?? -999}>
              {formatSetl(rowSetl)}
            </td>
            <td align="center" style="color: #828282; font-size: var(--font-sm);" data-val={row.evidence === 'H' ? 3 : row.evidence === 'M' ? 2 : row.evidence === 'L' ? 1 : 0}>
              {row.evidence ? ({'H': 'High', 'M': 'Medium', 'L': 'Low'}[row.evidence] ?? row.evidence) : ''}
            </td>
            <td align="center" class="score-font" style={`color: ${scoreToColor(row.hcb_weighted_mean)}; font-size: var(--font-sm);`} data-val={row.hcb_weighted_mean ?? -999}>
              {formatScore(row.hcb_weighted_mean)}
            </td>
          </tr>
          );
        })}
      </tbody>
    </table>
  ) : (() => {
    const articlesWithScores = coverage.filter(c => c.signal_count > 0);
    const nearbyWithScores = articlesWithScores
      .map(c => ({ ...c, dist: Math.abs(c.sort_order - articleNum) }))
      .sort((a, b) => a.dist - b.dist)
      .slice(0, 5);
    return (
    <table cellpadding="0" cellspacing="0" width="100%">
      <tr>
        <td style="padding: 15px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="text-align: center; margin-bottom: 12px;">
            <span style="color: #555; font-size: var(--font-lg);">&#9675;</span>
            <div style="color: #888; margin-top: 6px;">No stories have scored on <strong style="color: #c9c9c9;">{section}</strong> yet.</div>
            <div style="font-size: var(--font-sm); color: #555; margin-top: 4px;">
              When stories are evaluated, those with signal on this provision will be ranked here.
            </div>
          </div>

          {nearbyWithScores.length > 0 && (
            <div style="border-top: 1px solid #1a1a25; padding-top: 10px;">
              <div style="color: #666; font-size: var(--font-sm); margin-bottom: 6px;">Nearby articles with rankings:</div>
              <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
                {nearbyWithScores.map(c => (
                  <tr>
                    <td style="width: 20px;" class="score-font">
                      <a href={`/article/${c.sort_order}`} style={`color: ${scoreToColor(c.avg_final)};`}>
                        {c.section === 'Preamble' ? 'P' : c.section.replace('Article ', '')}
                      </a>
                    </td>
                    <td>
                      <a href={`/article/${c.sort_order}`} style="color: #888;">
                        {ARTICLE_TITLES[c.section]}
                      </a>
                    </td>
                    <td style="width: 50px; text-align: right;" class="score-font">
                      <span style={`color: ${scoreToColor(c.avg_final)};`}>{formatScore(c.avg_final)}</span>
                    </td>
                    <td style="width: 60px; text-align: right; color: #555; font-size: var(--font-xs);">
                      {c.signal_count} stories
                    </td>
                  </tr>
                ))}
              </table>
            </div>
          )}
        </td>
      </tr>
    </table>
    );
  })()}

  {hasMore && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0 20px 0;">
      <tr>
        <td style="padding-left: 40px;">
          <a href={`/article/${articleNum}?p=${page + 1}`} class="morelink" style="color: #828282; font-size: var(--font-base);">
            More
          </a>
        </td>
      </tr>
    </table>
  )}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const table = document.getElementById('article-table');
      if (!table) return;
      const thead = table.querySelector('thead');
      const tbody = document.getElementById('article-body');
      if (!thead || !tbody) return;

      const headers = thead.querySelectorAll('td[data-col]');
      let currentSort = 'rank';
      let ascending = true;

      function sortTable(col, type) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const colIdx = Array.from(headers).findIndex(h => h.dataset.col === col);
        if (colIdx < 0) return;

        if (currentSort === col) {
          ascending = !ascending;
        } else {
          currentSort = col;
          ascending = type === 'str';
        }

        rows.sort((a, b) => {
          const cellA = a.children[colIdx];
          const cellB = b.children[colIdx];
          let va, vb;
          if (type === 'str') {
            va = (cellA.dataset.val ?? cellA.textContent ?? '').trim().toLowerCase();
            vb = (cellB.dataset.val ?? cellB.textContent ?? '').trim().toLowerCase();
          } else {
            va = parseFloat(cellA.dataset.val ?? cellA.textContent ?? '0');
            vb = parseFloat(cellB.dataset.val ?? cellB.textContent ?? '0');
            if (isNaN(va)) va = -9999;
            if (isNaN(vb)) vb = -9999;
          }
          let cmp = va < vb ? -1 : va > vb ? 1 : 0;
          return ascending ? cmp : -cmp;
        });

        rows.forEach((row, i) => {
          row.children[0].textContent = (i + 1) + '.';
          tbody.appendChild(row);
        });

        headers.forEach(h => {
          const base = h.textContent.replace(/ [▲▼]/g, '').trim();
          h.textContent = h.dataset.col === col ? base + (ascending ? ' ▲' : ' ▼') : base;
        });
      }

      headers.forEach(h => {
        h.addEventListener('click', () => {
          sortTable(h.dataset.col, h.dataset.type);
        });
      });
    });
  </script>
</Base>
