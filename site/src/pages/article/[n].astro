---
import Base from '../../layouts/Base.astro';
import { scoreToColor, formatScore } from '../../lib/colors';
import { ARTICLE_TITLES, ALL_SECTIONS } from '../../lib/udhr';
import { getArticleRanking } from '../../lib/db';

const { n } = Astro.params;
const articleNum = parseInt(n!, 10);

if (isNaN(articleNum) || articleNum < 0 || articleNum > 30) {
  return Astro.redirect('/');
}

const section = articleNum === 0 ? 'Preamble' : `Article ${articleNum}`;
const articleTitle = ARTICLE_TITLES[section] || section;

const db = Astro.locals.runtime.env.DB;
const rankings = await getArticleRanking(db, articleNum, 100);

const prevNum = articleNum > 0 ? articleNum - 1 : null;
const nextNum = articleNum < 30 ? articleNum + 1 : null;
---

<Base title={`${section}: ${articleTitle} — Rankings`}>
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: 12pt; color: #c9c9c9; font-weight: bold;">{section}</span>
        <span style="color: #828282; margin-left: 8px;">{articleTitle}</span>
      </td>
    </tr>
    <tr>
      <td class="subtext" style="padding: 4px 0 8px 0;">
        Stories ranked by their score on this UDHR provision.
        {prevNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${prevNum}`}>&larr; {prevNum === 0 ? 'Preamble' : `Article ${prevNum}`}</a>
          </>
        )}
        {nextNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${nextNum}`}>Article {nextNum} &rarr;</a>
          </>
        )}
      </td>
    </tr>
  </table>

  {rankings.length > 0 ? (
    <table cellpadding="4" cellspacing="0" width="100%" style="font-size: 9pt;">
      <tr style="color: #828282; font-size: 8pt;">
        <td width="30">#</td>
        <td width="60" align="center">Score</td>
        <td>Story</td>
        <td width="50" align="center" title="Editorial — what the content says" style="cursor: help;">E</td>
        <td width="50" align="center" title="Structural — what the site does" style="cursor: help;">S</td>
        <td width="40" align="center" title="Evidence strength (High, Medium, Low)" style="cursor: help;">Ev.</td>
        <td width="60" align="center">Overall</td>
      </tr>
      {rankings.map((row, i) => (
        <tr style="border-top: 1px solid #222230;">
          <td style="color: #828282;" class="score-font">{i + 1}.</td>
          <td align="center">
            <span class="score-font" style={`color: ${scoreToColor(row.final)}; font-weight: bold;`}>
              {formatScore(row.final)}
            </span>
          </td>
          <td>
            <a href={`/item/${row.hn_id}`}>{row.title}</a>
            {row.domain && (
              <span style="color: #828282; font-size: 8pt; margin-left: 4px;">({row.domain})</span>
            )}
          </td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.editorial)}; font-size: 8pt;`}>
            {formatScore(row.editorial)}
          </td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.structural)}; font-size: 8pt;`}>
            {formatScore(row.structural)}
          </td>
          <td align="center" style="color: #828282; font-size: 8pt; cursor: help;"
              title={row.evidence ? ({H: 'High evidence', M: 'Medium evidence', L: 'Low evidence'} as Record<string, string>)[row.evidence] || row.evidence : ''}
          >{row.evidence || ''}</td>
          <td align="center" class="score-font" style={`color: ${scoreToColor(row.hcb_weighted_mean)}; font-size: 8pt;`}>
            {formatScore(row.hcb_weighted_mean)}
          </td>
        </tr>
      ))}
    </table>
  ) : (
    <table width="100%">
      <tr>
        <td style="padding: 20px; text-align: center; color: #828282;">
          No evaluated stories with scores for {section} yet.
        </td>
      </tr>
    </table>
  )}

  {/* Article navigation */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 15px 0;">
    <tr>
      <td>
        <div style="color: #828282; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">All Articles</div>
        <div style="display: flex; flex-wrap: wrap; gap: 3px;">
          {ALL_SECTIONS.map((sec, i) => {
            const num = sec === 'Preamble' ? 0 : i;
            const isActive = num === articleNum;
            return (
              <a
                href={`/article/${num}`}
                style={`display: inline-block; padding: 2px 6px; font-size: 8pt; border-radius: 3px; ${
                  isActive
                    ? 'background: rgba(255,102,0,0.2); color: #ff6600; border: 1px solid rgba(255,102,0,0.4);'
                    : 'background: #1a1a25; color: #828282; border: 1px solid #222230;'
                }`}
                class="score-font"
              >
                {sec === 'Preamble' ? 'P' : i}
              </a>
            );
          })}
        </div>
      </td>
    </tr>
  </table>
</Base>
