---
// SPDX-License-Identifier: Apache-2.0
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { scoreToColor, formatScore, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence } from '../../lib/colors';
import { ARTICLE_TITLES, ARTICLE_SHORT_TITLES, ALL_SECTIONS, getSection } from '../../lib/udhr';
import { getArticleRanking, getArticleCoverage, getArticleDetailStats, getArticleDirectionalityBreakdown, getArticleThemeBreakdown } from '../../lib/db';
import type { ArticleRankingRow } from '../../lib/db';
import { readDb } from '../../lib/db-utils';

const { n } = Astro.params;
const articleNum = parseInt(n!, 10);

if (isNaN(articleNum) || articleNum < 0 || articleNum > 30) {
  return Astro.redirect('/');
}

const section = articleNum === 0 ? 'Preamble' : `Article ${articleNum}`;
const articleTitle = ARTICLE_TITLES[section] || section;
const udhrSection = getSection(articleNum);

const db = readDb(Astro.locals.runtime.env.DB);
const url = new URL(Astro.request.url);
const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));
const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

const [rankings, coverage] = await Promise.all([
  getArticleRanking(db, articleNum, PER_PAGE + 1, offset),
  getArticleCoverage(db),
]);
const hasMore = rankings.length > PER_PAGE;
const displayRankings = hasMore ? rankings.slice(0, PER_PAGE) : rankings;

// Build a map of section -> { signal_count, avg_final } for the article selector
const coverageMap = new Map(coverage.map(c => [c.section, c]));

// Deep dive data
const deepStats = await getArticleDetailStats(db, section);
const [directionality, themes, bottom3] = await Promise.all([
  getArticleDirectionalityBreakdown(db, section),
  getArticleThemeBreakdown(db, section),
  page === 1 ? getArticleRanking(db, articleNum, 3, 0, 'asc') : Promise.resolve([] as ArticleRankingRow[]),
]);
const stddev = deepStats?.variance != null ? Math.sqrt(deepStats.variance) : null;
const top3 = page === 1 ? displayRankings.slice(0, 3) : [];
const showDeepDive = page === 1 && displayRankings.length > 0 && deepStats != null && deepStats.count > 0;
const evTotal = deepStats ? deepStats.evidence_h + deepStats.evidence_m + deepStats.evidence_l + deepStats.evidence_nd : 0;
const evPcts = evTotal > 0
  ? { h: (deepStats!.evidence_h / evTotal) * 100, m: (deepStats!.evidence_m / evTotal) * 100,
      l: (deepStats!.evidence_l / evTotal) * 100, nd: (deepStats!.evidence_nd / evTotal) * 100 }
  : { h: 0, m: 0, l: 0, nd: 0 };
const evidenceRows = deepStats && evTotal > 0 ? [
  { key: 'h',  label: 'High',   count: deepStats.evidence_h,  pct: evPcts.h,  color: 'var(--color-positive)' },
  { key: 'm',  label: 'Medium', count: deepStats.evidence_m,  pct: evPcts.m,  color: 'var(--color-warning)' },
  { key: 'l',  label: 'Low',    count: deepStats.evidence_l,  pct: evPcts.l,  color: 'var(--color-orange)' },
  { key: 'nd', label: 'ND',     count: deepStats.evidence_nd, pct: evPcts.nd, color: 'var(--color-border)' },
] : [];
const dirMax = directionality.length > 0 ? Math.max(...directionality.map(d => d.cnt)) : 1;
const DIRMETA: { [k: string]: { label: string; desc: string; color: string } } = {
  A: { label: 'Affirming',  desc: 'Content affirms the right',           color: 'var(--color-positive)' },
  P: { label: 'Pressuring', desc: 'Content pressures toward the right',  color: 'var(--color-warning)' },
  F: { label: 'Framing',    desc: 'Frames narrative around the right',   color: 'var(--color-blue)' },
  C: { label: 'Contesting', desc: 'Content contests or undermines',      color: 'var(--color-negative)' },
  D: { label: 'Deflecting', desc: 'Deflects attention from the right',   color: '#9333ea' },
  N: { label: 'Neutral',    desc: 'Neutral or factual reference',        color: 'var(--fg-secondary)' },
};

const prevNum = articleNum > 0 ? articleNum - 1 : null;
const nextNum = articleNum < 30 ? articleNum + 1 : null;

const jsonLd = udhrSection ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  name: `${section}: ${articleTitle}`,
  headline: `UDHR ${section} — ${articleTitle}`,
  description: udhrSection.text.slice(0, 200) + (udhrSection.text.length > 200 ? '...' : ''),
  url: `${Astro.url.origin}/article/${articleNum}`,
  isPartOf: {
    '@type': 'Legislation',
    name: 'Universal Declaration of Human Rights',
    legislationIdentifier: 'A/RES/217(III)',
    datePublished: '1948-12-10',
    legislationPassedBy: {
      '@type': 'Organization',
      name: 'United Nations General Assembly',
    },
  },
} : null;
---

<Base title={`${section}: ${articleTitle} — Rankings`}>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}
  <Breadcrumb crumbs={[
    { label: 'home', href: '/' },
    { label: 'articles', href: '/rights/articles' },
    { label: section },
  ]} />
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">{section}</span>
        <span style="color: var(--fg-secondary); margin-left: 8px;">{articleTitle}</span>
      </td>
    </tr>
    <tr>
      <td class="subtext" style="padding: 4px 0 8px 0;">
        Stories ranked by their score on this UDHR provision.
        {page > 1 && <span style="color: var(--fg-secondary);"> · page {page}</span>}
        {prevNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${prevNum}`}>&larr; {ARTICLE_SHORT_TITLES[prevNum === 0 ? 'Preamble' : `Article ${prevNum}`] ?? `Article ${prevNum}`}</a>
          </>
        )}
        {nextNum !== null && (
          <>
            <span> | </span>
            <a href={`/article/${nextNum}`}>{ARTICLE_SHORT_TITLES[`Article ${nextNum}`] ?? `Article ${nextNum}`} &rarr;</a>
          </>
        )}
      </td>
    </tr>
  </table>

  {/* UDHR Article Text */}
  {udhrSection && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
            UDHR Text
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
              {udhrSection.group}
            </span>
          </div>
          <div style="color: var(--fg-emphasis); font-size: var(--font-base); line-height: 1.6; white-space: pre-line;">{udhrSection.text}</div>
        </td>
      </tr>
    </table>
  )}

  {/* Article navigation */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 0 0 10px 0;">
    <tr>
      <td>
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">
          All Articles
          <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
            {coverage.filter(c => c.signal_count > 0).length}/{ALL_SECTIONS.length} with scores
          </span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 3px;">
          {ALL_SECTIONS.map((sec, i) => {
            const num = sec === 'Preamble' ? 0 : i;
            const isActive = num === articleNum;
            const cov = coverageMap.get(sec);
            const hasScores = cov && cov.signal_count > 0;
            let style: string;
            if (isActive) {
              style = 'background: rgba(255,102,0,0.2); color: var(--color-orange); border: 1px solid rgba(255,102,0,0.4);';
            } else if (hasScores) {
              style = `background: ${scoreToColor(cov.avg_final)}20; color: ${scoreToColor(cov.avg_final)}; border: 1px solid ${scoreToColor(cov.avg_final)}40;`;
            } else {
              style = 'background: var(--bg-surface); color: var(--color-border); border: 1px solid var(--bg-surface);';
            }
            return (
              <a
                href={`/article/${num}`}
                style={`display: inline-block; padding: 2px 6px; font-size: var(--font-sm); border-radius: 3px; ${style}`}
                class="score-font"
                title={`${sec}: ${ARTICLE_TITLES[sec]}${hasScores ? ` — ${cov.signal_count} stories, avg ${formatScore(cov.avg_final)}` : ' — no scores yet'}`}
              >
                {sec === 'Preamble' ? 'P' : i}
              </a>
            );
          })}
        </div>
      </td>
    </tr>
  </table>

  {displayRankings.length > 0 ? (
    <table id="article-table" cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-base);">
      <thead>
        <tr style="color: var(--fg-secondary); font-size: var(--font-sm); cursor: pointer; user-select: none;">
          <td data-col="rank" data-type="num" width="30"># ▼</td>
          <td data-col="story" data-type="str">Story</td>
          <td data-col="hrcb" data-type="num" width="50" align="center" title="Score for this UDHR provision">Score</td>
          <td data-col="editorial" data-type="num" width="36" align="center" title="Editorial — what the content says">E</td>
          <td data-col="structural" data-type="num" width="36" align="center" title="Structural — what the site does">S</td>
          <td data-col="setl" data-type="num" width="40" align="center" title="Structural-Editorial Tension Level">SETL</td>
          <td data-col="evidence" data-type="evidence" width="50" align="center" title="Evidence strength (High, Medium, Low)">Evid</td>
          <td data-col="pts" data-type="num" width="34" align="center" title="HN Points">Pts</td>
        </tr>
      </thead>
      <tbody id="article-body">
        {displayRankings.map((row, i) => {
          const rowSetl = computeSetl(row.structural, row.editorial);
          const rowConf = computeConfidence(row.hcb_evidence_h, row.hcb_evidence_m, row.hcb_evidence_l, row.hcb_nd_count);
          return (
          <tr style="border-top: 1px solid var(--color-border);">
            <td style="color: var(--fg-secondary);" class="score-font" data-val={offset + i + 1}>{offset + i + 1}.</td>
            <td data-val={row.title}>
              <a href={`/item/${row.hn_id}`}>{row.title}</a>
              {row.domain && (
                <span style="color: var(--fg-secondary); font-size: var(--font-sm); margin-left: 4px;">({row.domain})</span>
              )}
            </td>
            <td align="center" data-val={row.final ?? -999}>
              <span class="score-font" style={`color: ${scoreToColor(row.final)}; font-weight: bold;`}>
                {formatScore(row.final)}
              </span>
            </td>
            <td align="center" class="score-font" style={`color: ${scoreToColor(row.editorial)}; font-size: var(--font-sm);`} data-val={row.editorial ?? -999}>
              {formatScore(row.editorial)}
            </td>
            <td align="center" class="score-font" style={`color: ${scoreToColor(row.structural)}; font-size: var(--font-sm);`} data-val={row.structural ?? -999}>
              {formatScore(row.structural)}
            </td>
            <td align="center" class="score-font" style={`color: ${setlToColor(rowSetl)}; font-size: var(--font-sm);`} data-val={rowSetl ?? -999}>
              {formatSetl(rowSetl)}
            </td>
            <td align="center" style="color: var(--fg-secondary); font-size: var(--font-sm);" data-val={row.evidence === 'H' ? 3 : row.evidence === 'M' ? 2 : row.evidence === 'L' ? 1 : 0}>
              {row.evidence ? ({'H': 'High', 'M': 'Med', 'L': 'Low'}[row.evidence] ?? row.evidence) : ''}
            </td>
            <td align="center" style="color: var(--fg-secondary); font-size: var(--font-sm);" data-val={row.hn_score ?? -999}>
              {row.hn_score ?? ''}
            </td>
          </tr>
          );
        })}
      </tbody>
    </table>
  ) : (() => {
    const articlesWithScores = coverage.filter(c => c.signal_count > 0);
    const nearbyWithScores = articlesWithScores
      .map(c => ({ ...c, dist: Math.abs(c.sort_order - articleNum) }))
      .sort((a, b) => a.dist - b.dist)
      .slice(0, 5);
    return (
    <table cellpadding="0" cellspacing="0" width="100%">
      <tr>
        <td style="padding: 15px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="text-align: center; margin-bottom: 12px;">
            <span style="color: var(--fg-secondary); font-size: var(--font-lg);">&#9675;</span>
            <div style="color: var(--fg-secondary); margin-top: 6px;">No stories have scored on <strong style="color: var(--fg-primary);">{section}</strong> yet.</div>
            <div style="font-size: var(--font-sm); color: var(--fg-secondary); margin-top: 4px;">
              When stories are evaluated, those with signal on this provision will be ranked here.
            </div>
          </div>

          {nearbyWithScores.length > 0 && (
            <div style="border-top: 1px solid var(--bg-surface); padding-top: 10px;">
              <div style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 6px;">Nearby articles with rankings:</div>
              <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
                {nearbyWithScores.map(c => (
                  <tr>
                    <td style="width: 20px;" class="score-font">
                      <a href={`/article/${c.sort_order}`} style={`color: ${scoreToColor(c.avg_final)};`}>
                        {c.section === 'Preamble' ? 'P' : c.section.replace('Article ', '')}
                      </a>
                    </td>
                    <td>
                      <a href={`/article/${c.sort_order}`} style="color: var(--fg-secondary);">
                        {ARTICLE_TITLES[c.section]}
                      </a>
                    </td>
                    <td style="width: 50px; text-align: right;" class="score-font">
                      <span style={`color: ${scoreToColor(c.avg_final)};`}>{formatScore(c.avg_final)}</span>
                    </td>
                    <td style="width: 60px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);">
                      {c.signal_count} stories
                    </td>
                  </tr>
                ))}
              </table>
            </div>
          )}
        </td>
      </tr>
    </table>
    );
  })()}

  {hasMore && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0 20px 0;">
      <tr>
        <td style="padding-left: 40px;">
          <a href={`/article/${articleNum}?p=${page + 1}`} class="morelink" style="color: var(--fg-secondary); font-size: var(--font-base);">
            More
          </a>
        </td>
      </tr>
    </table>
  )}

  {/* ═══ Deep Dive ═══ */}
  {showDeepDive && deepStats && (
    <details open class="collapsible-section" style="margin-top: 10px;">
      <summary>
        Deep Dive
        <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
          {deepStats.count.toLocaleString()} stories · all-time section stats
        </span>
      </summary>

      {/* Score stat cards */}
      <div class="stat-cards" style="margin-bottom: 10px; gap: 6px;">
        <div style="background: var(--bg-surface); padding: 8px 12px; border-radius: 4px; flex: 1; min-width: 70px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;">Stories</div>
          <div class="score-font" style="font-size: var(--font-md); color: var(--fg-primary);">{deepStats.count.toLocaleString()}</div>
        </div>
        <div style="background: var(--bg-surface); padding: 8px 12px; border-radius: 4px; flex: 1; min-width: 70px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;">Avg</div>
          <div class="score-font" style={`font-size: var(--font-md); color: ${scoreToColor(deepStats.avg_final)};`}>{formatScore(deepStats.avg_final)}</div>
        </div>
        {stddev != null && (
          <div style="background: var(--bg-surface); padding: 8px 12px; border-radius: 4px; flex: 1; min-width: 70px;">
            <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;">Stddev</div>
            <div class="score-font" style="font-size: var(--font-md); color: var(--fg-secondary);">{stddev.toFixed(3)}</div>
          </div>
        )}
        <div style="background: var(--bg-surface); padding: 8px 12px; border-radius: 4px; flex: 1; min-width: 70px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;">Best</div>
          <div class="score-font" style={`font-size: var(--font-md); color: ${scoreToColor(deepStats.max_final)};`}>{formatScore(deepStats.max_final)}</div>
        </div>
        <div style="background: var(--bg-surface); padding: 8px 12px; border-radius: 4px; flex: 1; min-width: 70px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px;">Worst</div>
          <div class="score-font" style={`font-size: var(--font-md); color: ${scoreToColor(deepStats.min_final)};`}>{formatScore(deepStats.min_final)}</div>
        </div>
      </div>

      {/* Top 3 / Bottom 3 */}
      {(top3.length > 0 || bottom3.length > 0) && (
        <div class="two-col" style="gap: 8px; margin-bottom: 10px;">
          {top3.length > 0 && (
            <div>
              <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Strongest alignment</div>
              {top3.map(r => (
                <div style={`background: var(--bg-surface); border-radius: 4px; padding: 6px 10px; margin-bottom: 4px; border-left: 3px solid ${scoreToColor(r.final)};`}>
                  <div class="score-font" style={`color: ${scoreToColor(r.final)}; font-size: var(--font-sm); font-weight: bold;`}>{formatScore(r.final)}</div>
                  <div style="font-size: var(--font-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px;">
                    <a href={`/item/${r.hn_id}`} style="color: var(--fg-primary);">{r.title}</a>
                  </div>
                  {r.domain && <div style="color: var(--fg-secondary); font-size: 9px;">{r.domain}</div>}
                </div>
              ))}
            </div>
          )}
          {bottom3.length > 0 && (
            <div>
              <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">Weakest alignment</div>
              {bottom3.map(r => (
                <div style={`background: var(--bg-surface); border-radius: 4px; padding: 6px 10px; margin-bottom: 4px; border-left: 3px solid ${scoreToColor(r.final)};`}>
                  <div class="score-font" style={`color: ${scoreToColor(r.final)}; font-size: var(--font-sm); font-weight: bold;`}>{formatScore(r.final)}</div>
                  <div style="font-size: var(--font-sm); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px;">
                    <a href={`/item/${r.hn_id}`} style="color: var(--fg-primary);">{r.title}</a>
                  </div>
                  {r.domain && <div style="color: var(--fg-secondary); font-size: 9px;">{r.domain}</div>}
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* Evidence breakdown */}
      {evidenceRows.length > 0 && (
        <div style="margin-bottom: 10px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Evidence strength</div>
          <div style="display: flex; flex-direction: column; gap: 4px;">
            {evidenceRows.filter(ev => ev.count > 0).map(ev => (
              <div style="display: flex; align-items: center; gap: 6px; font-size: var(--font-xs);">
                <span style={`color: ${ev.color}; width: 44px; flex-shrink: 0;`}>{ev.label}</span>
                <div style="flex: 1; height: 8px; background: #082e38; border-radius: 3px; overflow: hidden;">
                  <div style={`width: ${ev.pct.toFixed(1)}%; height: 100%; background: ${ev.color}; border-radius: 3px;`}></div>
                </div>
                <span style="color: var(--fg-secondary); width: 58px; text-align: right; flex-shrink: 0; font-family: monospace; font-size: 9px;">{ev.count} ({ev.pct.toFixed(0)}%)</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Directionality markers */}
      {directionality.length > 0 && (
        <div style="margin-bottom: 10px;">
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Directionality markers</div>
          <div style="display: flex; flex-direction: column; gap: 4px;">
            {directionality.map(d => {
              const meta = DIRMETA[d.marker] ?? { label: d.marker, desc: '', color: 'var(--fg-secondary)' };
              const pct = dirMax > 0 ? (d.cnt / dirMax) * 100 : 0;
              return (
                <div style="display: flex; align-items: center; gap: 6px; font-size: var(--font-xs);" title={meta.desc}>
                  <span style={`color: ${meta.color}; width: 70px; flex-shrink: 0;`}>{meta.label}</span>
                  <div style="flex: 1; height: 8px; background: #082e38; border-radius: 3px; overflow: hidden;">
                    <div style={`width: ${pct.toFixed(1)}%; height: 100%; background: ${meta.color}; border-radius: 3px; opacity: 0.75;`}></div>
                  </div>
                  <span style="color: var(--fg-secondary); width: 30px; text-align: right; flex-shrink: 0; font-family: monospace; font-size: 9px;">{d.cnt}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Theme tags */}
      {themes.length > 0 && (
        <div>
          <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Top themes</div>
          <div style="display: flex; flex-wrap: wrap; gap: 4px;">
            {themes.map(t => (
              <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; background: var(--bg-surface); border-radius: 10px; font-size: 9px; color: var(--fg-primary); border: 1px solid var(--color-border);">
                {t.theme}
                <span style="color: var(--color-border);">{t.cnt}</span>
              </span>
            ))}
          </div>
        </div>
      )}
    </details>
  )}

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const table = document.getElementById('article-table');
      if (!table) return;
      const thead = table.querySelector('thead');
      const tbody = document.getElementById('article-body');
      if (!thead || !tbody) return;

      const headers = thead.querySelectorAll('td[data-col]');
      let currentSort = 'rank';
      let ascending = true;

      function sortTable(col, type) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const colIdx = Array.from(headers).findIndex(h => h.dataset.col === col);
        if (colIdx < 0) return;

        if (currentSort === col) {
          ascending = !ascending;
        } else {
          currentSort = col;
          ascending = type === 'str';
        }

        rows.sort((a, b) => {
          const cellA = a.children[colIdx];
          const cellB = b.children[colIdx];
          let va, vb;
          if (type === 'str') {
            va = (cellA.dataset.val ?? cellA.textContent ?? '').trim().toLowerCase();
            vb = (cellB.dataset.val ?? cellB.textContent ?? '').trim().toLowerCase();
          } else {
            va = parseFloat(cellA.dataset.val ?? cellA.textContent ?? '0');
            vb = parseFloat(cellB.dataset.val ?? cellB.textContent ?? '0');
            if (isNaN(va)) va = -9999;
            if (isNaN(vb)) vb = -9999;
          }
          let cmp = va < vb ? -1 : va > vb ? 1 : 0;
          return ascending ? cmp : -cmp;
        });

        rows.forEach((row, i) => {
          row.children[0].textContent = (i + 1) + '.';
          tbody.appendChild(row);
        });

        headers.forEach(h => {
          const base = h.textContent.replace(/ [▲▼]/g, '').trim();
          h.textContent = h.dataset.col === col ? base + (ascending ? ' ▲' : ' ▼') : base;
        });
      }

      headers.forEach(h => {
        h.addEventListener('click', () => {
          sortTable(h.dataset.col, h.dataset.type);
        });
      });
    });
  </script>
</Base>
