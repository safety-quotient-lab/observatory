---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import SubNav from '../components/SubNav.astro';
import { getArticleDetailedStats, getArticleSparklines, getSignalOverview, getDomainStats, getDomainFingerprints, getDailyHrcb, getStatusCounts, getTopPropagandaStories, getStakeholderOverview, getRegionDistribution, HOMEPAGE_BLOB_KEY } from '../lib/db';
import type { HomepageBlob } from '../lib/db';
import { scoreToColor, formatScore, fwRatioColor, formatFwRatio, normalizePsq, formatPsqScore } from '../lib/colors';
import type { PsqAggregates } from '../lib/db';
import { ARTICLE_GROUPS, ARTICLE_TITLES, ALL_SECTIONS, SECTIONS } from '../lib/udhr';
import { readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = (Astro.locals as any).runtime.env.CONTENT_CACHE as KVNamespace;

// ── Hot path: serve from KV blob (zero D1 queries) ──────────────────────────
let blob: HomepageBlob | null = null;
try {
  blob = await kv.get(HOMEPAGE_BLOB_KEY, 'json') as HomepageBlob | null;
} catch { /* fall through to D1 */ }

// ── Cold path: D1 fallback (first request or blob expired) ───────────────────
let articleStats: Awaited<ReturnType<typeof getArticleDetailedStats>>;
let sparklinesRaw: Awaited<ReturnType<typeof getArticleSparklines>>;
let statusCounts: Awaited<ReturnType<typeof getStatusCounts>>;
let dailyHrcb: Awaited<ReturnType<typeof getDailyHrcb>>;
let topDomains: Awaited<ReturnType<typeof getDomainStats>>;
let propagandaStories: Awaited<ReturnType<typeof getTopPropagandaStories>>;
let signalOverview: Awaited<ReturnType<typeof getSignalOverview>> | null = null;
let stakeholderData: Awaited<ReturnType<typeof getStakeholderOverview>> | null = null;
let regionData: Awaited<ReturnType<typeof getRegionDistribution>> | null = null;
let domainFingerprints: Map<string, (number | null)[]>;
let psqAggregates: PsqAggregates | null = null;
let rightsBalance: { positive: number; neutral: number; negative: number } | null = null;

if (blob) {
  ({ articleStats, sparklinesRaw, statusCounts, dailyHrcb, topDomains, propagandaStories,
     signalOverview, stakeholderData, regionData } = blob);
  psqAggregates = blob.psqAggregates ?? null;
  rightsBalance = blob.rightsBalance ?? null;
  domainFingerprints = new Map(Object.entries(blob.domainFingerprintsRaw));
} else {
  [articleStats, sparklinesRaw, statusCounts, dailyHrcb, topDomains, propagandaStories] = await Promise.all([
    getArticleDetailedStats(db),
    getArticleSparklines(db, 60),
    getStatusCounts(db),
    getDailyHrcb(db, 60),
    getDomainStats(db, 10),
    getTopPropagandaStories(db, 15),
  ]);
  try {
    [signalOverview, stakeholderData, regionData] = await Promise.all([
      getSignalOverview(db),
      getStakeholderOverview(db),
      getRegionDistribution(db),
    ]);
  } catch { /* graceful fallback */ }
  domainFingerprints = await getDomainFingerprints(db, topDomains.map(d => d.domain));
}

// Build section → ordered final values map from daily rollup rows
const sparklines = new Map<string, number[]>();
for (const row of sparklinesRaw) {
  let arr = sparklines.get(row.section);
  if (!arr) { arr = []; sparklines.set(row.section, arr); }
  arr.push(row.final);
}

// Derived data
const statsMap = new Map(articleStats.map(a => [a.section, a]));
const totalEvaluated = statusCounts.done;
const allScores = articleStats.filter(a => a.avg_editorial !== null);
const meanEditorial = allScores.length > 0
  ? allScores.reduce((sum, a) => sum + (a.avg_editorial ?? 0), 0) / allScores.length
  : null;
const structuralScores = articleStats.filter(a => a.avg_structural !== null);
const meanStructural = structuralScores.length > 0
  ? structuralScores.reduce((sum, a) => sum + (a.avg_structural ?? 0), 0) / structuralScores.length
  : null;
const coveragePct = ALL_SECTIONS.length > 0
  ? Math.round((allScores.length / ALL_SECTIONS.length) * 100)
  : 0;

// Hero lens data (derived from signalOverview — no extra queries)
const avgTdScore = signalOverview?.avg_td ?? null;
const avgFwRatio = signalOverview?.avg_fw_ratio ?? null;
const ptTotalFlags = signalOverview?.technique_distribution
  ? Object.values(signalOverview.technique_distribution).reduce((a, b) => a + b, 0) : null;

// Rights Under Pressure
const sortedByScore = [...articleStats].filter(a => a.avg_editorial !== null).sort((a, b) => (a.avg_editorial ?? 0) - (b.avg_editorial ?? 0));
const mostNegative = sortedByScore.slice(0, 5);
const mostTriggered = [...articleStats].filter(a => a.signal_count > 0).sort((a, b) => b.signal_count - a.signal_count).slice(0, 5);
const lowestCoverage = [...articleStats].filter(a => a.signal_count >= 0).sort((a, b) => a.signal_count - b.signal_count).slice(0, 5);

// Evidence Transparency — sorted by lowest FW ratio
const articlesWithFwRatio = articleStats
  .map(a => {
    const total = (a.evidence_h ?? 0) + (a.evidence_m ?? 0) + (a.evidence_l ?? 0);
    const ratio = total > 0 ? (a.evidence_h ?? 0) / total : null;
    return { ...a, fw_ratio: ratio, fw_total: total };
  })
  .filter(a => a.fw_ratio !== null && a.fw_total > 0)
  .sort((a, b) => (a.fw_ratio ?? 0) - (b.fw_ratio ?? 0))
  .slice(0, 10);

// Propaganda technique distribution
const techniqueEntries = signalOverview?.technique_distribution
  ? Object.entries(signalOverview.technique_distribution).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const maxTechniqueCount = techniqueEntries.length > 0 ? techniqueEntries[0][1] : 1;

// Stakeholder data
const speaksEntries = stakeholderData?.who_speaks
  ? Object.entries(stakeholderData.who_speaks).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const aboutEntries = stakeholderData?.who_spoken_about
  ? Object.entries(stakeholderData.who_spoken_about).sort((a, b) => b[1] - a[1]).slice(0, 10)
  : [];
const maxSpeaks = speaksEntries.length > 0 ? speaksEntries[0][1] : 1;
const maxAbout = aboutEntries.length > 0 ? aboutEntries[0][1] : 1;

// Region data
const scopeEntries = regionData?.scopes
  ? Object.entries(regionData.scopes).sort((a, b) => b[1] - a[1])
  : [];
const maxScopeCount = scopeEntries.length > 0 ? scopeEntries[0][1] : 1;
const regionEntries = regionData?.regions
  ? regionData.regions.slice(0, 15)
  : [];
const maxRegionCount = regionEntries.length > 0 ? regionEntries[0].count : 1;

// Daily HRCB chart data
const dailyReversed = [...dailyHrcb]; // already chronological from getDailyHrcb
const maxDailyCount = dailyReversed.length > 0 ? Math.max(...dailyReversed.map(d => d.count)) : 1;
const latestDailyScore = dailyReversed.length > 0 ? dailyReversed[dailyReversed.length - 1].avg : 0;

// Pre-computed trend chart geometry (avoids IIFE in JSX template)
const chartW = 400, chartH = 100, barAreaH = 24;
const lineAreaH = chartH - barAreaH;
const chartStep = dailyReversed.length > 1 ? chartW / (dailyReversed.length - 1) : 0;
const chartLinePath = dailyReversed.length > 1 ? dailyReversed.map((d, i) => {
  const x = i * chartStep;
  const y = lineAreaH / 2 - (d.avg * lineAreaH / 2);
  return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${Math.max(0, Math.min(lineAreaH, y)).toFixed(1)}`;
}).join(' ') : '';
const chartBarW = dailyReversed.length > 1 ? Math.max(1, chartStep * 0.6) : 0;

// Group colors — mapped to UDHR rights generations (pedagogical taxonomy)
// 1st gen (civil/political, "freedom FROM"): cool blues → teals
// 2nd gen (economic/social/cultural, "entitlement TO"): warm ambers
// 3rd gen (solidarity/collective): violet
// Hero-derived insights
const tensionCount = articleStats.filter(a =>
  a.avg_editorial != null && a.avg_structural != null &&
  Math.abs(a.avg_editorial - a.avg_structural) >= 0.10
).length;
const mostNegativeEntry = mostNegative.length > 0 ? mostNegative[0] : null;
const mostPositiveEntry = sortedByScore.length > 0 ? sortedByScore[sortedByScore.length - 1] : null;

const groupColors: Record<string, string> = {
  'Foundation': '#94a3b8',      // slate-400 — meta-principles, neutral
  'Security': '#60a5fa',        // blue-400 — 1st gen: bodily integrity
  'Legal': '#38bdf8',           // sky-400 — 1st gen: due process
  'Privacy & Movement': '#22d3ee', // cyan-400 — 1st gen: personal autonomy
  'Personal': '#2dd4bf',        // teal-400 — 1st gen: intimate sphere
  'Expression': '#5aad8f',      // emerald-400 — 1st gen: political voice
  'Economic & Social': '#fbbf24', // amber-400 — 2nd gen: material welfare
  'Cultural': '#fb923c',        // orange-400 — 2nd gen: intellectual development
  'Order & Duties': '#a78bfa',  // violet-400 — 3rd gen: collective framework
};
---

<Base title="Human Rights Observatory, Hacker News Edition">
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Human Rights Observatory',
    alternateName: 'HRO',
    url: 'https://observatory.unratified.org',
    description: 'Hacker News stories scored against all 31 provisions of the UN Universal Declaration of Human Rights. Editorial and structural channel analysis with Fair Witness evidence transparency.',
    publisher: {
      '@type': 'Organization',
      name: 'Safety Quotient Lab',
      url: 'https://github.com/safety-quotient-lab',
      knowsAbout: [
        'Universal Declaration of Human Rights',
        'International Covenant on Economic, Social and Cultural Rights',
        'Human rights compatibility analysis',
        'Structural-editorial tension in tech media',
        'AI-assisted content evaluation',
        'Fair Witness evidence methodology',
      ],
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://observatory.unratified.org/search?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
    isPartOf: {
      '@type': 'WebSite',
      name: 'Unratified',
      url: 'https://unratified.org',
      description: 'The U.S. signed the ICESCR in 1977 and has never ratified it. Exploring why — and what it means for economic and social rights.',
    },
  }).replace(/</g, '\\u003c')} />
  <SubNav items={[{ label: 'Articles', href: '/rights/articles' }, { label: 'Observatory', href: '/' }, { label: 'Network', href: '/rights/network' }]} current="/" />
  <div style="padding: 8px 0 16px 0;">

    <!-- 1. Hero -->
    <div class="hero-section" style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 16px; margin-bottom: 16px;">
      <div role="heading" aria-level="1" style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold; margin-bottom: 6px;">Human Rights Observatory, Hacker News Edition</div>
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); line-height: 1.5; margin-bottom: 6px;">
        Every story on Hacker News is evaluated against the 30 articles and Preamble of the
        <a href="https://www.un.org/en/about-us/universal-declaration-of-human-rights" target="_blank" rel="noopener" style="color: var(--channel-editorial);">Universal Declaration of Human Rights</a>.
        What does tech content say about rights — and does the platform match?
      </div>
      <div style="color: var(--fg-secondary); font-size: var(--font-xs); line-height: 1.4; margin-bottom: 6px;">
        Corpus: Hacker News submissions only — a predominantly US, English-speaking, technology-focused community. Scores reflect this sample, not global discourse.
      </div>
      <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 10px;">
        Part of the <a href="https://unratified.org" target="_blank" rel="noopener" style="color: var(--channel-hrcb);">Unratified</a> project by <a href="https://github.com/safety-quotient-lab" target="_blank" rel="noopener" style="color: var(--fg-secondary);">Safety Quotient Lab</a> — the U.S. signed an international economic rights covenant in 1977 and has never ratified it.
      </div>
      <div class="hero-pills" style="font-size: var(--font-xs);">
        <a href="/stories" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
          <span class="score-font" style="color: var(--fg-primary); font-weight: bold;">{totalEvaluated.toLocaleString()}</span>
          <span style="color: var(--fg-secondary);"> stories evaluated</span>
        </a>
        {rightsBalance && (totalEvaluated > 0) && (
          <a href="/stories" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
            <span class="score-font" style="color: var(--color-positive); font-weight: bold;">{Math.round(rightsBalance.positive / totalEvaluated * 100)}%</span>
            <span style="color: var(--fg-secondary);"> positive</span>
            <span style="color: var(--fg-secondary);"> · </span>
            <span class="score-font" style="color: var(--color-negative-light); font-weight: bold;">{Math.round(rightsBalance.negative / totalEvaluated * 100)}%</span>
            <span style="color: var(--fg-secondary);"> negative</span>
          </a>
        )}
        {avgTdScore !== null && (
          <a href="/signals" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
            <span style="color: var(--color-positive);">Transparency</span>
            <span style="color: var(--fg-secondary);"> avg </span>
            <span class="score-font" style="color: var(--fg-primary); font-weight: bold;">{(avgTdScore * 100).toFixed(0)}%</span>
          </a>
        )}
        {ptTotalFlags !== null && ptTotalFlags > 0 && (
          <a href="/signals" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
            <span style="color: var(--color-negative-light);">Persuasion</span>
            <span style="color: var(--fg-secondary);"> — </span>
            <span class="score-font" style="color: var(--fg-primary); font-weight: bold;">{ptTotalFlags.toLocaleString()}</span>
            <span style="color: var(--fg-secondary);"> flags</span>
          </a>
        )}
        {avgFwRatio !== null && (
          <a href="/about#fair-witness" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
            <span style="color: var(--color-amber);">Evidence</span>
            <span style="color: var(--fg-secondary);"> — </span>
            <span class="score-font" style="color: var(--fg-primary); font-weight: bold;">{(avgFwRatio * 100).toFixed(0)}%</span>
            <span style="color: var(--fg-secondary);"> observable</span>
          </a>
        )}
        {tensionCount > 0 && (
          <a href="/about#setl" style="background: var(--bg-surface); border-radius: 3px; padding: 2px 8px; text-decoration: none;">
            <span class="score-font" style="color: var(--color-warning); font-weight: bold;">{tensionCount}</span>
            <span style="color: var(--fg-secondary);" title="SETL tension: content discusses a right that the hosting site's own practices appear to undermine"> say ≠ do</span>
          </a>
        )}
      </div>
    </div>

    <!-- 1b. Narrative findings — plain English before the data -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px; line-height: 1.8;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">What we're finding</div>
      <div style="color: var(--fg-primary); font-size: var(--font-base);">
        {mostPositiveEntry && mostNegativeEntry && (
          <p style="margin: 0 0 8px 0;">
            Most tech coverage engages with human rights — but unevenly.
            <a href={`/article/${SECTIONS.find(s => s.id === mostPositiveEntry.section)?.number ?? 0}`} style="color: var(--color-positive); font-weight: bold;">
              {ARTICLE_TITLES[mostPositiveEntry.section]}
            </a> appears most often, while
            <a href={`/article/${SECTIONS.find(s => s.id === mostNegativeEntry.section)?.number ?? 0}`} style="color: var(--color-negative); font-weight: bold;">
              {ARTICLE_TITLES[mostNegativeEntry.section]}
            </a> scores lowest.
          </p>
        )}
        {tensionCount > 0 && (
          <p style="margin: 0 0 8px 0;">
            <span style="color: var(--color-warning); font-weight: bold;">{tensionCount} of 31</span> UDHR provisions show tension between what content <em>says</em> about rights and what the hosting site actually <em>does</em> — like a privacy article on a site that tracks you.
          </p>
        )}
        {avgTdScore !== null && (
          <p style="margin: 0 0 8px 0;">
            Transparency is low: the average disclosure score across all stories is <span class="score-font" style="font-weight: bold;">{(avgTdScore * 100).toFixed(0)}%</span>.
            <a href="/signals" style="color: var(--channel-hrcb); margin-left: 4px;">See all findings &rarr;</a>
          </p>
        )}
        <p style="margin: 0; padding-top: 8px; border-top: 1px solid var(--bg-surface); color: var(--fg-secondary); font-size: var(--font-sm);">
          These patterns — rights discussed but not backed by law — reflect a specific gap: the U.S. signed the international economic and social rights covenant in 1977 and has never ratified it.
          <a href="https://unratified.org" target="_blank" rel="noopener" style="color: var(--channel-hrcb); font-weight: bold;">unratified.org</a> is building the case for why AI makes closing it urgent.
        </p>
      </div>
    </div>

    <!-- 2. UDHR Rights Heatmap -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 10px;">
        <span style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">UDHR Rights Heatmap</span>
        <span style="color: var(--fg-secondary); font-size: var(--font-xs); opacity: 0.7;">content scores · <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--color-warning); vertical-align: middle;" title="SETL tension dot: editorial and structural channels diverge significantly for this provision"></span> says ≠ does</span>
      </div>

      <div style="display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; align-items: center;">
        <span style="color: var(--fg-secondary); font-size: var(--font-xs);">sort:</span>
        <button class="hm-sort filter-active" data-sort="default">article #</button>
        <span class="filter-sep">|</span>
        <button class="hm-sort filter-link" data-sort="negative">most negative</button>
        <span class="filter-sep">|</span>
        <button class="hm-sort filter-link" data-sort="positive">most positive</button>
        <span class="filter-sep">|</span>
        <button class="hm-sort filter-link" data-sort="count">most triggered</button>
        <span class="filter-sep">|</span>
        <button class="hm-sort filter-link" data-sort="setl">highest tension</button>
      </div>

      <div id="hm-groups">
      {Object.entries(ARTICLE_GROUPS).map(([group, sectionIds]) => {
        const color = groupColors[group] || 'var(--fg-secondary)';
        return (
          <div style="margin-bottom: 10px;">
            <div style={`color: ${color}; font-size: var(--font-xs); margin-bottom: 4px; opacity: 0.8;`}>{group}</div>
            <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
              {sectionIds.map(sid => {
                const stat = statsMap.get(sid);
                const score = stat?.avg_editorial ?? null;
                const count = stat?.signal_count ?? 0;
                const section = SECTIONS.find(s => s.id === sid);
                const label = sid === 'Preamble' ? 'P' : String(section?.number ?? '?');
                const title = ARTICLE_TITLES[sid] ?? sid;
                const barColor = scoreToColor(score);
                const setl = (stat?.avg_editorial != null && stat?.avg_structural != null)
                  ? Math.abs(stat.avg_editorial - stat.avg_structural) : null;
                const spark = sparklines.get(sid) || [];
                let sparkPath = '';
                if (spark.length > 1) {
                  const w = 80;
                  const h = 20;
                  const step = w / (spark.length - 1);
                  sparkPath = spark.map((v, i) => {
                    const x = i * step;
                    const y = h / 2 - (v * h / 2);
                    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
                  }).join(' ');
                }
                let trendDir = null;
                if (spark.length >= 6) {
                  const half = Math.floor(spark.length / 2);
                  const recent = spark.slice(-half).reduce((a: number, b: number) => a + b, 0) / half;
                  const prev = spark.slice(0, half).reduce((a: number, b: number) => a + b, 0) / half;
                  const delta = recent - prev;
                  trendDir = delta > 0.03 ? '↑' : delta < -0.03 ? '↓' : '→';
                }
                const trendColor = trendDir === '↑' ? 'var(--color-positive)' : trendDir === '↓' ? 'var(--color-negative)' : 'var(--fg-secondary)';
                return (
                  <Fragment>
                    <tr style="border-top: 1px solid var(--bg-surface);" data-score={score !== null ? String(score) : ''} data-count={String(count)} data-setl={setl !== null ? String(setl) : ''} data-article={String(section?.number ?? 0)} data-group={group}>
                      <td style={`width: 22px; padding: 3px 4px; color: ${score !== null ? color : 'var(--bg-surface)'}; font-weight: bold;`} class="score-font hm-score">
                        <a href={`/article/${section?.number ?? 0}`} style={`color: inherit; text-decoration: none;`}>{label}</a>
                      </td>
                      <td title={`${title} (n=${count})`} class="hm-title" style={`padding: 3px 4px; color: ${score !== null ? 'var(--fg-primary)' : 'var(--fg-secondary)'}; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;`}>
                        <a href={`/article/${section?.number ?? 0}`} style={`color: inherit; text-decoration: none;`}>{title}</a>
                        {count > 0 && <span style="color: var(--fg-secondary); font-size: 9px; margin-left: 4px;">n={count}</span>}
                      </td>
                      <td class="hm-data" style="width: 140px; padding: 3px 4px;">
                        {score !== null ? (
                          <div style="display: flex; align-items: center; gap: 4px;">
                            <div style="flex: 1; height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; position: relative;">
                              <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--fg-secondary); opacity: 0.3;"></div>
                              {score < 0 ? (
                                <div style={`position: absolute; right: 50%; top: 0; width: ${Math.abs(score) * 50}%; height: 100%; background: ${barColor}; border-radius: 3px 0 0 3px;`}></div>
                              ) : (
                                <div style={`position: absolute; left: 50%; top: 0; width: ${score * 50}%; height: 100%; background: ${barColor}; border-radius: 0 3px 3px 0;`}></div>
                              )}
                            </div>
                            <span style={`color: ${barColor}; font-size: var(--font-xs); min-width: 36px; text-align: right;`} class="score-font">{formatScore(score)}</span>
                          </div>
                        ) : (
                          <span style="color: var(--bg-surface);">--</span>
                        )}
                      </td>
                      <td class="hm-data" style="width: 18px; padding: 3px 2px; text-align: center;" title={setl !== null ? `E/S tension: ${setl.toFixed(2)}` : 'No tension data'}>
                        {setl !== null && setl >= 0.10 ? (
                          <div style={`width: 8px; height: 8px; border-radius: 50%; margin: 0 auto; background: ${setl >= 0.25 ? 'var(--color-negative)' : 'var(--color-warning)'}; opacity: ${Math.min(1, 0.5 + setl)};`}></div>
                        ) : null}
                      </td>
                      <td class="hm-data score-font" style="width: 50px; padding: 3px 4px; text-align: right; color: var(--fg-secondary);">
                        {count > 0 ? count : '--'}
                      </td>
                      <td class="hm-data" style="width: 90px; padding: 3px 4px; text-align: center;">
                        {spark.length > 1 ? (
                          <div style="display: inline-flex; align-items: center; gap: 2px;">
                            <svg width="64" height="20" viewBox="0 0 80 20">
                              <line x1="0" y1="10" x2="80" y2="10" stroke="var(--bg-surface)" stroke-width="0.5" />
                              <path d={sparkPath} fill="none" stroke={color} stroke-width="1" />
                            </svg>
                            {trendDir && <span style={`color: ${trendColor}; font-size: var(--font-xs);`} class="score-font">{trendDir}</span>}
                          </div>
                        ) : (
                          <span style="color: var(--bg-surface);">--</span>
                        )}
                      </td>
                    </tr>
                    <tr class="hm-trend">
                      <td colSpan={6} style="padding: 2px 4px 4px 26px;">
                        <div style="display: flex; align-items: center; gap: 6px;">
                          <div style="flex: 1; min-width: 80px;">
                            {score !== null ? (
                              <div style="display: flex; align-items: center; gap: 4px;">
                                <div style="flex: 1; height: 5px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; position: relative;">
                                  <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--fg-secondary); opacity: 0.3;"></div>
                                  {score < 0 ? (
                                    <div style={`position: absolute; right: 50%; top: 0; width: ${Math.abs(score) * 50}%; height: 100%; background: ${barColor}; border-radius: 3px 0 0 3px;`}></div>
                                  ) : (
                                    <div style={`position: absolute; left: 50%; top: 0; width: ${score * 50}%; height: 100%; background: ${barColor}; border-radius: 0 3px 3px 0;`}></div>
                                  )}
                                </div>
                                <span style={`color: ${barColor}; font-size: var(--font-xs); min-width: 34px; text-align: right;`} class="score-font">{formatScore(score)}</span>
                              </div>
                            ) : <span style="color: var(--bg-surface); font-size: var(--font-xs);">--</span>}
                          </div>
                          {setl !== null && setl >= 0.10 ? (
                            <div style={`width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; background: ${setl >= 0.25 ? 'var(--color-negative)' : 'var(--color-warning)'}; opacity: ${Math.min(1, 0.5 + setl)};`} title={`E/S tension: ${setl.toFixed(2)}`}></div>
                          ) : <div style="width: 7px; flex-shrink: 0;"></div>}
                          <span style="color: var(--fg-secondary); font-size: var(--font-xs); flex-shrink: 0;" class="score-font">{count > 0 ? count : '--'}</span>
                          {spark.length > 1 ? (
                            <svg width="64" height="16" viewBox="0 0 80 20" style="flex-shrink: 0;">
                              <line x1="0" y1="10" x2="80" y2="10" stroke="var(--bg-surface)" stroke-width="0.5" />
                              <path d={sparkPath} fill="none" stroke={color} stroke-width="1.2" />
                            </svg>
                          ) : null}
                          {trendDir && <span style={`color: ${trendColor}; font-size: var(--font-xs); flex-shrink: 0;`} class="score-font">{trendDir}</span>}
                        </div>
                      </td>
                    </tr>
                  </Fragment>
                );
              })}
            </table>
          </div>
        );
      })}
      </div>
      <div id="hm-sorted" style="display:none;">
        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tbody id="hm-sorted-body"></tbody>
        </table>
      </div>
    </div>

    <!-- 3. Rights Under Pressure -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-bottom: 16px;">
      <!-- Most Negative -->
      <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Most Negative</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {mostNegative.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: var(--fg-primary); font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style={`color: ${scoreToColor(a.avg_editorial)}; font-size: var(--font-xs);`} class="score-font">{formatScore(a.avg_editorial)}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>

      <!-- Most Triggered -->
      <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Most Triggered</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {mostTriggered.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: var(--fg-primary); font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style="color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{a.signal_count}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>

      <!-- Lowest Coverage -->
      <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Lowest Coverage</div>
        <table cellpadding="0" cellspacing="0" width="100%">
          {lowestCoverage.map(a => {
            const section = SECTIONS.find(s => s.id === a.section);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 0;">
                  <a href={`/article/${section?.number ?? 0}`} style="color: var(--fg-primary); font-size: var(--font-xs); text-decoration: none;">
                    {ARTICLE_TITLES[a.section] ?? a.section}
                  </a>
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0;">
                  <span style="color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{a.signal_count}</span>
                </td>
              </tr>
            );
          })}
        </table>
      </div>
    </div>

    <!-- 4. Evidence Transparency -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">
        Evidence Transparency — Weakest Fair Witness Ratios
        <a href="/about#fair-witness" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; text-transform: none; letter-spacing: 0; font-weight: normal; white-space: nowrap;">what's this? →</a>
      </div>
      <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 10px;">
        FW Ratio = High-evidence signals / total evidence signals. Lower = more inference-heavy.
      </div>
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr style="color: var(--fg-secondary); font-size: var(--font-xs);">
          <td style="padding: 4px 0;">Article</td>
          <td class="fw-bar-col" style="width: 200px; padding: 4px 0;">Ratio</td>
          <td style="width: 50px; text-align: right; padding: 4px 0;">%</td>
        </tr>
        {articlesWithFwRatio.map(a => {
          const section = SECTIONS.find(s => s.id === a.section);
          const pct = a.fw_ratio !== null ? Math.round(a.fw_ratio * 100) : 0;
          const barColor = fwRatioColor(a.fw_ratio);
          return (
            <tr style="border-top: 1px solid var(--bg-surface);">
              <td style="padding: 4px 0;">
                <a href={`/article/${section?.number ?? 0}`} style="color: var(--fg-primary); font-size: var(--font-xs); text-decoration: none;">
                  {ARTICLE_TITLES[a.section] ?? a.section}
                </a>
              </td>
              <td class="fw-bar-col" style="width: 200px; padding: 4px 0;">
                <div style="height: 8px; background: var(--bg-surface); border-radius: 4px; overflow: hidden;">
                  <div style={`width: ${pct}%; height: 100%; background: ${barColor}; border-radius: 4px;`}></div>
                </div>
              </td>
              <td style="width: 50px; text-align: right; padding: 4px 0;">
                <span style={`color: ${barColor}; font-size: var(--font-xs);`} class="score-font">{formatFwRatio(a.fw_ratio)}</span>
              </td>
            </tr>
          );
        })}
      </table>
      {articlesWithFwRatio.length === 0 && (
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); padding: 8px 0;">No evidence data available yet.</div>
      )}
    </div>

    <!-- 5. Propaganda Landscape -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Propaganda Landscape</div>

      {techniqueEntries.length > 0 && (
        <div style="margin-bottom: 14px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 6px;">Technique Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {techniqueEntries.map(([technique, count]) => {
              const pct = maxTechniqueCount > 0 ? Math.round((count / maxTechniqueCount) * 100) : 0;
              return (
                <tr>
                  <td title={technique} style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {technique}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: var(--color-negative-light); border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 40px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                    <a href={`/stories?pt=${encodeURIComponent(technique)}`} style="color: inherit; text-decoration: none;" title={`Stories flagged for ${technique}`}>{count}</a>
                  </td>
                </tr>
              );
            })}
          </table>
        </div>
      )}

      {propagandaStories.length > 0 ? (
        <div>
          <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 6px;">Top Flagged Stories</div>
          <div class="table-wrap">
          <table class="prop-table" cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs); min-width: 480px;">
            <tr style="color: var(--fg-secondary);">
              <td style="padding: 4px 0;">Title</td>
              <td class="prop-domain" style="width: 120px; padding: 4px 0;">Domain</td>
              <td style="width: 50px; text-align: right; padding: 4px 0;">Flags</td>
              <td style="width: 60px; text-align: right; padding: 4px 0;">HRCB</td>
            </tr>
            {propagandaStories.map(s => (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td title={s.title} style="padding: 4px 0; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  <a href={`/item/${s.hn_id}`} style="color: var(--fg-primary); text-decoration: none;">{s.title}</a>
                </td>
                <td class="prop-domain" title={s.domain ?? '--'} style="width: 120px; padding: 4px 0; color: var(--fg-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.domain ? <a href={`/domain/${s.domain}`} style="color: var(--fg-secondary); text-decoration: none;">{s.domain}</a> : '--'}
                </td>
                <td style="width: 50px; text-align: right; padding: 4px 0; color: var(--color-negative-light);" class="score-font">
                  {s.pt_flag_count}
                </td>
                <td style="width: 60px; text-align: right; padding: 4px 0;">
                  <span style={`color: ${scoreToColor(s.hcb_editorial_mean ?? s.hcb_weighted_mean)};`} class="score-font">{formatScore(s.hcb_editorial_mean ?? s.hcb_weighted_mean)}</span>
                </td>
              </tr>
            ))}
          </table>
          </div>
        </div>
      ) : (
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); padding: 8px 0;">No propaganda flags detected yet.</div>
      )}
    </div>

    <!-- 6. Stakeholder Voice -->
    {(speaksEntries.length > 0 || aboutEntries.length > 0) && (
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Who Speaks</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {speaksEntries.map(([name, count]) => {
              const pct = maxSpeaks > 0 ? Math.round((count / maxSpeaks) * 100) : 0;
              return (
                <tr>
                  <td title={name} style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {name}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: var(--channel-structural); border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {speaksEntries.length === 0 && (
            <div style="color: var(--fg-secondary); font-size: var(--font-xs);">No data.</div>
          )}
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Who Is Spoken About</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {aboutEntries.map(([name, count]) => {
              const pct = maxAbout > 0 ? Math.round((count / maxAbout) * 100) : 0;
              return (
                <tr>
                  <td title={name} style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {name}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: var(--color-sentiment); border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {aboutEntries.length === 0 && (
            <div style="color: var(--fg-secondary); font-size: var(--font-xs);">No data.</div>
          )}
        </div>
      </div>
    )}

    <!-- 7. Geographic Coverage -->
    {(scopeEntries.length > 0 || regionEntries.length > 0) && (
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Scope Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {scopeEntries.map(([scope, count]) => {
              const pct = maxScopeCount > 0 ? Math.round((count / maxScopeCount) * 100) : 0;
              return (
                <tr>
                  <td style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 100px;">
                    {scope}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: var(--color-positive-medium); border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 40px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                    {count}
                  </td>
                </tr>
              );
            })}
          </table>
          {scopeEntries.length === 0 && (
            <div style="color: var(--fg-secondary); font-size: var(--font-xs);">No scope data.</div>
          )}
        </div>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Region Distribution</div>
          <table cellpadding="0" cellspacing="0" width="100%">
            {regionEntries.map(r => {
              const pct = maxRegionCount > 0 ? Math.round((r.count / maxRegionCount) * 100) : 0;
              return (
                <tr>
                  <td title={r.region} style="padding: 3px 0; color: var(--fg-primary); font-size: var(--font-xs); max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    {r.region}
                  </td>
                  <td style="padding: 3px 8px;">
                    <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: var(--channel-editorial); border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 30px; text-align: right; padding: 3px 0; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">
                    {r.count}
                  </td>
                </tr>
              );
            })}
          </table>
          {regionEntries.length === 0 && (
            <div style="color: var(--fg-secondary); font-size: var(--font-xs);">No region data.</div>
          )}
        </div>
      </div>
    )}

    <!-- 8. Temporal Trends -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">HRCB Trend{dailyReversed.length > 0 ? ` — ${dailyReversed.length} days` : ''}</div>
      {dailyReversed.length > 1 ? (
        <svg width="100%" viewBox={`0 0 ${chartW} ${chartH}`} preserveAspectRatio="xMidYMid meet" style="max-width: 600px;">
          <line x1="0" y1={lineAreaH / 2} x2={chartW} y2={lineAreaH / 2} stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="4,4" />
          <path d={chartLinePath} fill="none" stroke={scoreToColor(latestDailyScore)} stroke-width="1.5" />
          {dailyReversed.map((d, i) => {
            const x = i * chartStep - chartBarW / 2;
            const barH = maxDailyCount > 0 ? (d.count / maxDailyCount) * barAreaH : 0;
            const barY = chartH - barH;
            return <rect x={x.toFixed(1)} y={barY.toFixed(1)} width={chartBarW.toFixed(1)} height={barH.toFixed(1)} fill="var(--color-border)" rx="1" />;
          })}
        </svg>
      ) : (
        <div style="color: var(--fg-secondary); font-size: var(--font-xs);">Not enough data for trend chart.</div>
      )}
      <div style="display: flex; justify-content: space-between; margin-top: 6px;">
        <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
          {dailyReversed.length > 0 ? dailyReversed[0].day : ''}
        </span>
        <div style="display: flex; gap: 12px;">
          <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
            <span style={`display: inline-block; width: 8px; height: 2px; background: ${scoreToColor(latestDailyScore)}; vertical-align: middle; margin-right: 4px;`}></span>
            avg HRCB
          </span>
          <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
            <span style="display: inline-block; width: 8px; height: 6px; background: var(--color-border); vertical-align: middle; margin-right: 4px;"></span>
            eval count
          </span>
        </div>
        <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
          {dailyReversed.length > 0 ? dailyReversed[dailyReversed.length - 1].day : ''}
        </span>
      </div>
    </div>

    <!-- 8b. PSQ Safety Lens -->
    {psqAggregates && psqAggregates.story_count > 0 && (
      <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
          <div style="color: var(--color-violet); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em;">Reader Safety</div>
          <span class="psq-experimental">experimental</span>
          <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
            {psqAggregates.story_count} stories scored
          </span>
        </div>
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
          <div style="text-align: center;">
            <div style="color: var(--fg-secondary); font-size: var(--font-xs);">avg PSQ</div>
            <span class="score-font" style={`color: ${scoreToColor(normalizePsq(psqAggregates.avg_psq))}; font-size: var(--font-lg);`}>
              {formatPsqScore(psqAggregates.avg_psq)}
            </span>
          </div>
        </div>
        {Object.keys(psqAggregates.dim_averages).length > 0 && (
          <div>
            {Object.entries(psqAggregates.dim_averages).map(([name, avg]) => {
              const dimNorm = normalizePsq(avg);
              const dimColor = dimNorm != null ? scoreToColor(dimNorm) : 'var(--fg-secondary)';
              const label = name.replace(/_/g, ' ');
              return (
                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                  <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 110px; text-align: right; white-space: nowrap;">
                    {label}
                  </span>
                  <div style="flex: 1; height: 8px; background: var(--bg-surface); border-radius: 3px; overflow: hidden; position: relative; max-width: 200px;">
                    <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--fg-secondary); opacity: 0.2;"></div>
                    {dimNorm != null && (dimNorm >= 0 ? (
                      <div style={`position: absolute; left: 50%; top: 0; width: ${dimNorm * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 0 3px 3px 0;`}></div>
                    ) : (
                      <div style={`position: absolute; right: 50%; top: 0; width: ${Math.abs(dimNorm) * 50}%; height: 100%; background: ${dimColor}; opacity: 0.8; border-radius: 3px 0 0 3px;`}></div>
                    ))}
                  </div>
                  <span class="score-font" style={`color: ${dimColor}; font-size: var(--font-xs); width: 36px; text-align: right;`}>
                    {avg.toFixed(1)}/10
                  </span>
                </div>
              );
            })}
          </div>
        )}
      </div>
    )}

    <!-- 9. Domain Rights Profiles -->
    <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; margin-bottom: 16px;">
      <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">
        Domain Rights Profiles — Top 10
        <a href="/sources" style="color: var(--channel-hrcb); font-size: var(--font-xs); margin-left: 8px; text-transform: none; letter-spacing: 0; font-weight: normal; white-space: nowrap;">all sources →</a>
      </div>
      <div class="table-wrap">
      <table class="fp-table" cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs); min-width: 480px;">
        <tr style="color: var(--fg-secondary);">
          <td style="padding: 4px 0;">Domain</td>
          <td style="width: 60px; text-align: right; padding: 4px 0;">HRCB</td>
          <td style="width: 50px; text-align: right; padding: 4px 0;">Stories</td>
          <td class="fp-col" style="padding: 4px 8px;">Fingerprint</td>
        </tr>
        {topDomains.map(d => {
          const fp = domainFingerprints.get(d.domain);
          return (
            <tr style="border-top: 1px solid var(--bg-surface);">
              <td style="padding: 4px 0;">
                <a href={`/domain/${d.domain}`} style="color: var(--fg-primary); text-decoration: none;">{d.domain}</a>
              </td>
              <td style="width: 60px; text-align: right; padding: 4px 0;">
                <span style={`color: ${scoreToColor(d.avg_score)};`} class="score-font">{formatScore(d.avg_score)}</span>
              </td>
              <td style="width: 50px; text-align: right; padding: 4px 0; color: var(--fg-secondary);" class="score-font">
                {d.count}
              </td>
              <td class="fp-col" style="padding: 4px 8px;">
                {fp ? (
                  <div style="display: flex; gap: 1px; align-items: center;">
                    {fp.map((val, idx) => {
                      const bg = val !== null ? scoreToColor(val) : 'var(--bg-surface)';
                      const opacity = val !== null ? '1' : '0.3';
                      return (
                        <div style={`width: 6px; height: 10px; background: ${bg}; border-radius: 1px; opacity: ${opacity};`} title={`${SECTIONS[idx]?.id ?? idx}: ${val !== null ? formatScore(val) : 'ND'}`}></div>
                      );
                    })}
                  </div>
                ) : (
                  <span style="color: var(--bg-surface);">--</span>
                )}
              </td>
            </tr>
          );
        })}
      </table>
      </div>
    </div>

    <div style="color: var(--fg-secondary); font-size: var(--font-xs); padding: 12px 0 4px 0; border-top: 1px solid var(--color-border); margin-top: 16px;">
      <a href="https://github.com/safety-quotient-lab/observatory" target="_blank" rel="noopener" style="color: var(--fg-secondary);">Safety Quotient Lab</a> · Apache 2.0 ·
      <a href="https://unratified.org" target="_blank" rel="noopener" style="color: var(--channel-hrcb);">unratified.org</a>
    </div>

  </div>

  <style>
    .table-wrap {
      overflow-x: auto;
    }
    .hm-trend { display: none; }
    .hero-pills {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    @media (max-width: 540px) {
      .hm-data { display: none; }
      .hm-title { max-width: none !important; }
      .hm-trend { display: table-row; }
      /* Domain profiles: hide fingerprint column, shrink table */
      .fp-col { display: none; }
      .fp-table { min-width: 200px !important; }
      /* Propaganda stories: hide domain column, shrink table */
      .prop-domain { display: none; }
      .prop-table { min-width: 260px !important; }
      /* Evidence transparency: narrow bar column */
      .fw-bar-col { width: 100px !important; }
    }
    @media (max-width: 640px) {
      div[style*="grid-template-columns: 1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
      .hero-pills {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
      }
      .hero-pills > a {
        text-align: center;
      }
    }
  </style>

<style>
  .hm-sort {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-size: var(--font-xs);
    font-family: inherit;
    font-weight: normal;
  }
  .hm-sort:hover { text-decoration: underline; }
</style>

<script is:inline>
(function () {
  function sortHeatmap(mode) {
    var groups = document.getElementById('hm-groups');
    var sorted = document.getElementById('hm-sorted');
    var body = document.getElementById('hm-sorted-body');

    document.querySelectorAll('.hm-sort').forEach(function (btn) {
      var active = btn.dataset.sort === mode;
      btn.classList.toggle('filter-active', active);
      btn.classList.toggle('filter-link', !active);
    });

    if (mode === 'default') {
      groups.style.display = '';
      sorted.style.display = 'none';
      return;
    }

    var rows = Array.from(document.querySelectorAll('#hm-groups tr:not(.hm-trend)'));

    rows.sort(function (a, b) {
      var sa = parseFloat(a.dataset.score), sb = parseFloat(b.dataset.score);
      var ca = parseInt(a.dataset.count) || 0, cb = parseInt(b.dataset.count) || 0;
      var ta = parseFloat(a.dataset.setl), tb = parseFloat(b.dataset.setl);
      var hasA = !isNaN(sa), hasB = !isNaN(sb);
      if (mode === 'negative') {
        if (!hasA && !hasB) return 0;
        if (!hasA) return 1; if (!hasB) return -1;
        return sa - sb;
      }
      if (mode === 'positive') {
        if (!hasA && !hasB) return 0;
        if (!hasA) return 1; if (!hasB) return -1;
        return sb - sa;
      }
      if (mode === 'count') return cb - ca;
      if (mode === 'setl') {
        var htA = !isNaN(ta), htB = !isNaN(tb);
        if (!htA && !htB) return 0;
        if (!htA) return 1; if (!htB) return -1;
        return tb - ta;
      }
      return 0;
    });

    body.innerHTML = '';
    rows.forEach(function (row) {
      body.appendChild(row.cloneNode(true));
      var next = row.nextElementSibling;
      if (next && next.classList.contains('hm-trend')) {
        body.appendChild(next.cloneNode(true));
      }
    });

    groups.style.display = 'none';
    sorted.style.display = '';
  }

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.hm-sort');
    if (btn) sortHeatmap(btn.dataset.sort);
  });
})();
</script>
</Base>
