---
import Base from '../layouts/Base.astro';
import EvalCard from '../components/EvalCard.astro';
import { getFilteredStories, getStoryScores, getEvaluatedCount } from '../lib/db';
import type { SortOption, FilterOption } from '../lib/db';
import type { Score } from '../lib/types';

const db = Astro.locals.runtime.env.DB;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'time') as SortOption;
const filter = (url.searchParams.get('filter') || 'all') as FilterOption;

const validSorts: SortOption[] = ['time', 'score_desc', 'score_asc', 'hn_points'];
const validFilters: FilterOption[] = ['all', 'evaluated', 'positive', 'negative', 'neutral', 'pending', 'failed'];
const safeSort = validSorts.includes(sort) ? sort : 'time';
const safeFilter = validFilters.includes(filter) ? filter : 'all';

const stories = await getFilteredStories(db, safeSort, safeFilter, 500);
const evaluatedCount = await getEvaluatedCount(db);

// Fetch scores for evaluated stories (for mini heatmaps)
const storyScoresMap = new Map<number, Score[]>();
for (const story of stories) {
  if (story.eval_status === 'done') {
    const scores = await getStoryScores(db, story.hn_id);
    storyScoresMap.set(story.hn_id, scores);
  }
}

function buildUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const s = params.sort ?? safeSort;
  const f = params.filter ?? safeFilter;
  if (s !== 'time') p.set('sort', s);
  if (f !== 'all') p.set('filter', f);
  const qs = p.toString();
  return qs ? `/?${qs}` : '/';
}

const SORT_OPTIONS = [
  { value: 'time', label: 'new' },
  { value: 'score_desc', label: 'top hrcb' },
  { value: 'score_asc', label: 'bottom hrcb' },
  { value: 'hn_points', label: 'points' },
] as const;

const FILTER_OPTIONS = [
  { value: 'all', label: 'all' },
  { value: 'evaluated', label: 'evaluated' },
  { value: 'positive', label: 'positive' },
  { value: 'negative', label: 'negative' },
  { value: 'neutral', label: 'neutral' },
  { value: 'pending', label: 'pending' },
  { value: 'failed', label: 'failed' },
] as const;
---

<Base title="HN HRCB">
  {/* Filter/sort bar */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 4px 0;">
        <span class="subtext" style="font-size: 8pt;">
          <span style="color: #666;">sort:</span>
          {SORT_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {safeSort === opt.value
                ? <span style="color: #ff6600; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ sort: opt.value })}>{opt.label}</a>
              }
            </>
          ))}
          <span style="color: #444; margin: 0 6px;">·</span>
          <span style="color: #666;">show:</span>
          {FILTER_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {safeFilter === opt.value
                ? <span style="color: #ff6600; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ filter: opt.value })}>{opt.label}</a>
              }
            </>
          ))}
          <span style="color: #444; margin: 0 6px;">·</span>
          <span style="color: #555;">{stories.length} stories</span>
          {evaluatedCount > 0 && <span style="color: #555;"> ({evaluatedCount} evaluated)</span>}
        </span>
      </td>
    </tr>
  </table>

  <table cellpadding="0" cellspacing="0" class="itemlist" width="100%">
    {stories.map((story, i) => (
      <EvalCard
        story={story}
        scores={storyScoresMap.get(story.hn_id)}
        rank={i + 1}
      />
    ))}
  </table>

  {stories.length === 0 && (
    <table width="100%">
      <tr>
        <td style="padding: 40px 20px; text-align: center;">
          <div style="color: #828282; margin-bottom: 12px;">
            {safeFilter !== 'all'
              ? `No stories match the "${safeFilter}" filter.`
              : 'No stories yet.'}
          </div>
          {safeFilter !== 'all' ? (
            <a href="/" style="color: #ff6600;">clear filters</a>
          ) : (
            <>
              <button
                id="init-btn"
                style="background: #ff6600; color: #fff; border: none; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-size: 10pt; font-family: inherit;"
              >
                Fetch HN Top Stories
              </button>
              <div id="init-status" style="color: #828282; font-size: 8pt; margin-top: 8px;"></div>
              <script>
                document.getElementById('init-btn')!.addEventListener('click', async (e) => {
                  const btn = e.target as HTMLButtonElement;
                  const status = document.getElementById('init-status')!;
                  btn.disabled = true;
                  btn.style.opacity = '0.5';
                  btn.textContent = 'Fetching...';
                  status.textContent = 'Loading stories from Hacker News API...';
                  try {
                    const res = await fetch('/api/init', { method: 'POST' });
                    const data = await res.json();
                    if (res.ok) {
                      status.innerHTML = `<span style="color: #16a34a;">Loaded ${data.inserted} stories. Refreshing...</span>`;
                      setTimeout(() => window.location.reload(), 1000);
                    } else {
                      status.innerHTML = `<span style="color: #dc2626;">${data.error}</span>`;
                      btn.disabled = false;
                      btn.style.opacity = '1';
                      btn.textContent = 'Fetch HN Top Stories';
                    }
                  } catch (err) {
                    status.innerHTML = `<span style="color: #dc2626;">Network error: ${err}</span>`;
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.textContent = 'Fetch HN Top Stories';
                  }
                });
              </script>
            </>
          )}
        </td>
      </tr>
    </table>
  )}
</Base>
