---
import Base from '../layouts/Base.astro';
import EvalCard from '../components/EvalCard.astro';
import { getFilteredStoriesWithScores, getEvaluatedCount, getDistinctModels } from '../lib/db';
import type { SortOption, FilterOption, TypeOption, ModelOption } from '../lib/db';
import { modelDisplayName, getModelDef, isLiteMode } from '../lib/shared-eval';

const db = Astro.locals.runtime.env.DB;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'top') as SortOption;
const filter = (url.searchParams.get('filter') || 'all') as FilterOption;
const type = (url.searchParams.get('type') || 'all') as TypeOption;
const model = (url.searchParams.get('model') || 'any') as ModelOption;
const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));

const validSorts: SortOption[] = ['top', 'time', 'score_desc', 'score_asc', 'hn_points', 'conf_desc', 'conf_asc', 'velocity'];
const validFilters: FilterOption[] = ['all', 'evaluated', 'positive', 'negative', 'neutral', 'pending', 'failed'];
const validTypes: TypeOption[] = ['all', 'ask', 'show', 'job'];
const safeSort = validSorts.includes(sort) ? sort : 'top';
const safeFilter = validFilters.includes(filter) ? filter : 'all';
const safeType = validTypes.includes(type) ? type : 'all';

// Fetch distinct models for the selector — only show enabled models with evaluations
const allDistinctModels = await getDistinctModels(db);
const distinctModels = allDistinctModels.filter(m => {
  const def = getModelDef(m);
  return def ? def.enabled : false;
});
const safeModel = model === 'all' || model === 'any' || allDistinctModels.includes(model) ? model : 'any';

const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

// Single JOIN query: stories + scores in one round-trip
const stories = await getFilteredStoriesWithScores(db, safeSort, safeFilter, safeType, PER_PAGE + 1, offset, undefined, safeModel);
const hasMore = stories.length > PER_PAGE;
const displayStories = hasMore ? stories.slice(0, PER_PAGE) : stories;

const evaluatedCount = await getEvaluatedCount(db);

function buildUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const s = params.sort ?? safeSort;
  const f = params.filter ?? safeFilter;
  const t = params.type ?? safeType;
  const m = params.model ?? safeModel;
  const pg = params.p ?? '1';
  if (s !== 'top') p.set('sort', s);
  if (f !== 'all') p.set('filter', f);
  if (t !== 'all') p.set('type', t);
  if (m !== 'any') p.set('model', m);
  if (pg !== '1') p.set('p', pg);
  const qs = p.toString();
  return qs ? `/?${qs}` : '/';
}

const pageTitle = safeType === 'ask' ? 'Ask HN' : safeType === 'show' ? 'Show HN' : safeType === 'job' ? 'Jobs' : 'HN HRCB';

// JSON-LD: ItemList of evaluated stories (first page, default view only)
const jsonLd = (safeSort === 'top' && safeFilter === 'all' && safeType === 'all' && safeModel === 'any' && page === 1) ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'HN HRCB — Latest Evaluated Stories',
  description: `Hacker News stories evaluated for human rights compatibility bias. ${evaluatedCount} stories evaluated.`,
  url: `${url.origin}/`,
  numberOfItems: evaluatedCount,
  itemListElement: displayStories
    .filter(s => s.eval_status === 'done')
    .slice(0, 10)
    .map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${url.origin}/item/${s.hn_id}`,
      name: s.title,
    })),
} : null;

// Canonical URL: include sort/filter/type/model but exclude pagination
const canonicalParams = new URLSearchParams();
if (safeSort !== 'top') canonicalParams.set('sort', safeSort);
if (safeFilter !== 'all') canonicalParams.set('filter', safeFilter);
if (safeType !== 'all') canonicalParams.set('type', safeType);
if (safeModel !== 'any') canonicalParams.set('model', safeModel);
const canonicalQs = canonicalParams.toString();
const canonicalUrl = `${url.origin}${canonicalQs ? `/?${canonicalQs}` : '/'}`;

const SORT_OPTIONS = [
  { value: 'top', label: 'top' },
  { value: 'time', label: 'new' },
  { value: 'score_desc', label: 'top hrcb' },
  { value: 'score_asc', label: 'bottom hrcb' },
  { value: 'hn_points', label: 'points' },
  { value: 'conf_desc', label: 'top conf' },
  { value: 'conf_asc', label: 'bottom conf' },
  { value: 'velocity', label: 'velocity' },
] as const;

const FILTER_OPTIONS = [
  { value: 'all', label: 'all' },
  { value: 'evaluated', label: 'evaluated' },
  { value: 'positive', label: 'positive' },
  { value: 'negative', label: 'negative' },
  { value: 'neutral', label: 'neutral' },
  { value: 'pending', label: 'pending' },
  { value: 'failed', label: 'failed' },
] as const;

// Short display label for model IDs
function modelLabel(id: string): string {
  return modelDisplayName(id);
}
function isLiteModel(id: string): boolean {
  return getModelDef(id)?.prompt_mode === 'lite';
}
---

<Base title={pageTitle} canonicalUrl={canonicalUrl}>
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}
  {/* Filter/sort bar */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 4px 0;">
        <span class="subtext" style="font-size: var(--font-sm);">
          <span style="color: #5b7279;">sort:</span>
          {SORT_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #1a5568;"> | </span>}
              {safeSort === opt.value
                ? <span style="color: #d56500; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ sort: opt.value, p: '1' })}>{opt.label}</a>
              }
            </>
          ))}
          <br />
          <span style="color: #5b7279;">show:</span>
          {FILTER_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #1a5568;"> | </span>}
              {safeFilter === opt.value
                ? <span style="color: #d56500; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ filter: opt.value, p: '1' })}>{opt.label}</a>
              }
            </>
          ))}
          {distinctModels.length > 1 && (
            <>
              <br />
              <span style="color: #5b7279;">model:</span>
              {safeModel === 'any'
                ? <span style="color: #d56500; font-weight: bold;"> any</span>
                : <a href={buildUrl({ model: 'any', p: '1' })}> any</a>
              }
              <span style="color: #1a5568;"> | </span>
              {safeModel === 'all'
                ? <span style="color: #d56500; font-weight: bold;">all</span>
                : <a href={buildUrl({ model: 'all', p: '1' })}>all</a>
              }
              {distinctModels.map((m) => (
                <>
                  <span style="color: #1a5568;"> | </span>
                  {safeModel === m
                    ? <span style="color: #d56500; font-weight: bold;">{modelLabel(m)}{isLiteModel(m) && <a href="/about#eval-modes" class="lite-icon" style="margin-left: 3px; text-decoration: none; color: var(--color-orange);" title="Lite eval — click for details">L</a>}</span>
                    : <a href={buildUrl({ model: m, p: '1' })}>{modelLabel(m)}{isLiteModel(m) && <span class="lite-icon" style="margin-left: 3px;" title="Lite eval — click for details" onclick="event.preventDefault();event.stopPropagation();window.location.href='/about#eval-modes'" role="link">L</span>}</a>
                  }
                </>
              ))}
            </>
          )}
          <br />
          <span style="color: #5b7279;">score:</span>
          <button class="score-mode-btn" data-mode="hrcb" aria-label="Show HRCB composite scores">HRCB</button>
          <span style="color: #1a5568;"> | </span>
          <button class="score-mode-btn" data-mode="editorial" aria-label="Show Editorial channel scores">E</button>
          <span style="color: #1a5568;"> | </span>
          <button class="score-mode-btn" data-mode="structural" aria-label="Show Structural channel scores">S</button>
          <br />
          <span style="color: #5b7279;">{displayStories.length}{hasMore ? '+' : ''} stories</span>
          {evaluatedCount > 0 && <span style="color: #5b7279;"> ({evaluatedCount} evaluated)</span>}
          {page > 1 && <span style="color: #5b7279;"> · page {page}</span>}
          <span style="color: #5b7279;"> · </span>
          <a href="/past">past</a>
          <span style="color: #5b7279;"> · </span>
          <a href="/velocity">velocity</a>
          <span style="color: #5b7279;"> · </span>
          <a href="/dynamics">dynamics</a>
        </span>
      </td>
    </tr>
  </table>

  <div class="table-wrap">
  <table cellpadding="0" cellspacing="0" class="itemlist" width="100%">
    {displayStories.map((story, i) => (
      <EvalCard
        story={story}
        rank={offset + i + 1}
      />
    ))}
  </table>
  </div>

  {displayStories.length === 0 && (
    <table width="100%">
      <tr>
        <td style="padding: 40px 20px; text-align: center;">
          <div style="color: #5b7279; margin-bottom: 12px;">
            {safeFilter !== 'all' || safeType !== 'all'
              ? `No stories match the current filters.`
              : 'No stories yet.'}
          </div>
          {safeFilter !== 'all' || safeType !== 'all' ? (
            <a href="/" style="color: #d56500;">clear filters</a>
          ) : (
            <span style="color: #5b7279; font-size: var(--font-sm);">No stories yet. The cron worker will populate them shortly.</span>
          )}
        </td>
      </tr>
    </table>
  )}

  {/* Pagination */}
  {hasMore && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0 20px 0;">
      <tr>
        <td style="padding-left: 40px;">
          <a href={buildUrl({ p: String(page + 1) })} class="morelink" style="color: #5b7279; font-size: var(--font-base);">
            More
          </a>
        </td>
      </tr>
    </table>
  )}
</Base>
