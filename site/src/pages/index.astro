---
import Base from '../layouts/Base.astro';
import EvalCard from '../components/EvalCard.astro';
import { getFilteredStoriesWithScores, getEvaluatedCount, getDistinctModels } from '../lib/db';
import type { SortOption, FilterOption, TypeOption, ModelOption } from '../lib/db';
import { modelDisplayName } from '../lib/shared-eval';

const db = Astro.locals.runtime.env.DB;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'top') as SortOption;
const filter = (url.searchParams.get('filter') || 'all') as FilterOption;
const type = (url.searchParams.get('type') || 'all') as TypeOption;
const model = (url.searchParams.get('model') || 'all') as ModelOption;
const page = Math.max(1, parseInt(url.searchParams.get('p') || '1', 10));

const validSorts: SortOption[] = ['top', 'time', 'score_desc', 'score_asc', 'hn_points', 'conf_desc', 'conf_asc', 'velocity'];
const validFilters: FilterOption[] = ['all', 'evaluated', 'positive', 'negative', 'neutral', 'pending', 'failed'];
const validTypes: TypeOption[] = ['all', 'ask', 'show', 'job'];
const safeSort = validSorts.includes(sort) ? sort : 'top';
const safeFilter = validFilters.includes(filter) ? filter : 'all';
const safeType = validTypes.includes(type) ? type : 'all';

// Fetch distinct models for the selector
const distinctModels = await getDistinctModels(db);
const safeModel = model === 'all' || model === 'any' || distinctModels.includes(model) ? model : 'all';

const PER_PAGE = 30;
const offset = (page - 1) * PER_PAGE;

// Single JOIN query: stories + scores in one round-trip
const stories = await getFilteredStoriesWithScores(db, safeSort, safeFilter, safeType, PER_PAGE + 1, offset, undefined, safeModel);
const hasMore = stories.length > PER_PAGE;
const displayStories = hasMore ? stories.slice(0, PER_PAGE) : stories;

const evaluatedCount = await getEvaluatedCount(db);

function buildUrl(params: Record<string, string>): string {
  const p = new URLSearchParams();
  const s = params.sort ?? safeSort;
  const f = params.filter ?? safeFilter;
  const t = params.type ?? safeType;
  const m = params.model ?? safeModel;
  const pg = params.p ?? '1';
  if (s !== 'top') p.set('sort', s);
  if (f !== 'all') p.set('filter', f);
  if (t !== 'all') p.set('type', t);
  if (m !== 'all') p.set('model', m);
  if (pg !== '1') p.set('p', pg);
  const qs = p.toString();
  return qs ? `/?${qs}` : '/';
}

const pageTitle = safeType === 'ask' ? 'Ask HN' : safeType === 'show' ? 'Show HN' : safeType === 'job' ? 'Jobs' : 'HN HRCB';

// Canonical URL: include sort/filter/type/model but exclude pagination
const canonicalParams = new URLSearchParams();
if (safeSort !== 'top') canonicalParams.set('sort', safeSort);
if (safeFilter !== 'all') canonicalParams.set('filter', safeFilter);
if (safeType !== 'all') canonicalParams.set('type', safeType);
if (safeModel !== 'all') canonicalParams.set('model', safeModel);
const canonicalQs = canonicalParams.toString();
const canonicalUrl = `${url.origin}${canonicalQs ? `/?${canonicalQs}` : '/'}`;

const SORT_OPTIONS = [
  { value: 'top', label: 'top' },
  { value: 'time', label: 'new' },
  { value: 'score_desc', label: 'top hrcb' },
  { value: 'score_asc', label: 'bottom hrcb' },
  { value: 'hn_points', label: 'points' },
  { value: 'conf_desc', label: 'top conf' },
  { value: 'conf_asc', label: 'bottom conf' },
  { value: 'velocity', label: 'velocity' },
] as const;

const FILTER_OPTIONS = [
  { value: 'all', label: 'all' },
  { value: 'evaluated', label: 'evaluated' },
  { value: 'positive', label: 'positive' },
  { value: 'negative', label: 'negative' },
  { value: 'neutral', label: 'neutral' },
  { value: 'pending', label: 'pending' },
  { value: 'failed', label: 'failed' },
] as const;

// Short display label for model IDs
function modelLabel(id: string): string {
  return modelDisplayName(id);
}
---

<Base title={pageTitle} canonicalUrl={canonicalUrl}>
  {/* Filter/sort bar */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 4px 0;">
        <span class="subtext" style="font-size: var(--font-sm);">
          <span style="color: #666;">sort:</span>
          {SORT_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {safeSort === opt.value
                ? <span style="color: #ff6600; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ sort: opt.value, p: '1' })}>{opt.label}</a>
              }
            </>
          ))}
          <br />
          <span style="color: #666;">show:</span>
          {FILTER_OPTIONS.map((opt, i) => (
            <>
              {i > 0 && <span style="color: #444;"> | </span>}
              {safeFilter === opt.value
                ? <span style="color: #ff6600; font-weight: bold;">{opt.label}</span>
                : <a href={buildUrl({ filter: opt.value, p: '1' })}>{opt.label}</a>
              }
            </>
          ))}
          {distinctModels.length > 1 && (
            <>
              <br />
              <span style="color: #666;">model:</span>
              {safeModel === 'all'
                ? <span style="color: #ff6600; font-weight: bold;"> all</span>
                : <a href={buildUrl({ model: 'all', p: '1' })}> all</a>
              }
              <span style="color: #444;"> | </span>
              {safeModel === 'any'
                ? <span style="color: #ff6600; font-weight: bold;">any</span>
                : <a href={buildUrl({ model: 'any', p: '1' })}>any</a>
              }
              {distinctModels.map((m) => (
                <>
                  <span style="color: #444;"> | </span>
                  {safeModel === m
                    ? <span style="color: #ff6600; font-weight: bold;">{modelLabel(m)}</span>
                    : <a href={buildUrl({ model: m, p: '1' })}>{modelLabel(m)}</a>
                  }
                </>
              ))}
            </>
          )}
          <br />
          <span style="color: #555;">{displayStories.length}{hasMore ? '+' : ''} stories</span>
          {evaluatedCount > 0 && <span style="color: #555;"> ({evaluatedCount} evaluated)</span>}
          {page > 1 && <span style="color: #555;"> · page {page}</span>}
        </span>
      </td>
    </tr>
  </table>

  <div class="table-wrap">
  <table cellpadding="0" cellspacing="0" class="itemlist" width="100%">
    {displayStories.map((story, i) => (
      <EvalCard
        story={story}
        rank={offset + i + 1}
      />
    ))}
  </table>
  </div>

  {displayStories.length === 0 && (
    <table width="100%">
      <tr>
        <td style="padding: 40px 20px; text-align: center;">
          <div style="color: #828282; margin-bottom: 12px;">
            {safeFilter !== 'all' || safeType !== 'all'
              ? `No stories match the current filters.`
              : 'No stories yet.'}
          </div>
          {safeFilter !== 'all' || safeType !== 'all' ? (
            <a href="/" style="color: #ff6600;">clear filters</a>
          ) : (
            <span style="color: #828282; font-size: var(--font-sm);">No stories yet. The cron worker will populate them shortly.</span>
          )}
        </td>
      </tr>
    </table>
  )}

  {/* Pagination */}
  {hasMore && (
    <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0 20px 0;">
      <tr>
        <td style="padding-left: 40px;">
          <a href={buildUrl({ p: String(page + 1) })} class="morelink" style="color: #828282; font-size: var(--font-base);">
            More
          </a>
        </td>
      </tr>
    </table>
  )}
</Base>
