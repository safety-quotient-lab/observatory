---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getStatusCounts, getDomainSignalProfiles, getGlobalGateStats, HOMEPAGE_BLOB_KEY } from '../lib/db';
import type { PsqAggregates, HomepageBlob } from '../lib/db';
import type { DomainSignalProfile } from '../lib/db-entities';
import { cachedQuery, readDb } from '../lib/db-utils';
import { scoreToColor, formatScore, setlToColor, formatSetl, confidenceToColor, formatConfidence, fwRatioColor, formatFwRatio, normalizePsq, formatPsqScore } from '../lib/colors';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

let statusCounts = { total: 0, done: 0, pending: 0, failed: 0 };
let profiles: DomainSignalProfile[] = [];
let globalGate = { gated: 0, total: 0, gate_pct: 0 };

try {
  const [sc, cached, gg] = await Promise.all([
    getStatusCounts(db),
    cachedQuery(kv, 'domainSignalProfiles', async () => {
      const map = await getDomainSignalProfiles(db);
      return [...map.values()];
    }, 300),
    cachedQuery(kv, 'globalGateStats', () => getGlobalGateStats(db), 600),
  ]);
  statusCounts = sc;
  profiles = cached;
  globalGate = gg;
} catch {}

// PSQ aggregates — read from homepage KV blob (no new D1 query)
let psqAggregates: PsqAggregates | null = null;
try {
  const blob = await kv.get(HOMEPAGE_BLOB_KEY, 'json') as HomepageBlob | null;
  if (blob?.psqAggregates) psqAggregates = blob.psqAggregates;
} catch {}

const domainCount = profiles.length;
const storyCount = profiles.reduce((s, p) => s + p.count, 0);

// --- Pre-computed source metrics (KV-cached, avoids repeated CPU work) ---
interface SignalLeader {
  label: string;
  fullName: string;
  color: string;
  topDomain: string;
  topVal: number;
  bottomDomain: string;
  bottomVal: number;
  mean: number;
  note: string;
}

interface HrcbBand {
  label: string;
  min: number;
  max: number;
  count: number;
  color: string;
}

interface SourceMetrics {
  avgSetl: number | null;
  avgFw: number | null;
  avgConf: number | null;
  hrcbSpreadMin: number | null;
  hrcbSpreadMax: number | null;
  leaders: SignalLeader[];
  toneEntries: [string, number][];
  scopeEntries: [string, number][];
  levelEntries: [string, number][];
  sentimentEntries: [string, number][];
  bands: HrcbBand[];
}

function computeSourceMetrics(profs: DomainSignalProfile[]): SourceMetrics {
  // Aggregate metrics (single pass)
  let sumSetl = 0, cSetl = 0;
  let sumFw = 0, cFw = 0;
  let sumConf = 0, cConf = 0;
  let minHrcb = Infinity, maxHrcb = -Infinity;

  for (const p of profs) {
    if (p.avg_setl != null) { sumSetl += p.avg_setl; cSetl++; }
    if (p.avg_fw_ratio != null) { sumFw += p.avg_fw_ratio; cFw++; }
    if (p.avg_confidence != null) { sumConf += p.avg_confidence; cConf++; }
    if (p.avg_hrcb != null) {
      if (p.avg_hrcb < minHrcb) minHrcb = p.avg_hrcb;
      if (p.avg_hrcb > maxHrcb) maxHrcb = p.avg_hrcb;
    }
  }

  // Signal Leaders (8 dimensions)
  type SignalKey = 'avg_eq' | 'avg_so' | 'avg_sr' | 'avg_td' | 'avg_pt_count' | 'avg_valence' | 'avg_arousal' | 'avg_fw_ratio';
  const signalDims: { key: SignalKey; label: string; fullName: string; color: string; note: string }[] = [
    { key: 'avg_eq', label: 'EQ', fullName: 'Epistemic Quality', color: 'var(--color-amber)', note: '' },
    { key: 'avg_so', label: 'SO', fullName: 'Solution Orientation', color: 'var(--color-positive)', note: '' },
    { key: 'avg_sr', label: 'SR', fullName: 'Stakeholder Voice', color: 'var(--channel-editorial)', note: '' },
    { key: 'avg_td', label: 'TD', fullName: 'Transparency', color: 'var(--color-positive)', note: '' },
    { key: 'avg_pt_count', label: 'PT', fullName: 'Propaganda Flags', color: 'var(--color-negative)', note: 'inv' },
    { key: 'avg_valence', label: 'VA', fullName: 'Valence', color: 'var(--color-inference)', note: '' },
    { key: 'avg_arousal', label: 'AR', fullName: 'Arousal', color: '#818cf8', note: '' },
    { key: 'avg_fw_ratio', label: 'FW', fullName: 'Fair Witness Ratio', color: 'var(--color-positive-vivid)', note: '' },
  ];

  const leaders: SignalLeader[] = [];
  for (const dim of signalDims) {
    let topDomain = '--', bottomDomain = '--';
    let topVal = -Infinity, bottomVal = Infinity;
    let sum = 0, cnt = 0;
    for (const p of profs) {
      const v = p[dim.key];
      if (v == null) continue;
      sum += v; cnt++;
      if (v > topVal) { topVal = v; topDomain = p.domain; }
      if (v < bottomVal) { bottomVal = v; bottomDomain = p.domain; }
    }
    if (cnt > 0) {
      leaders.push({ label: dim.label, fullName: dim.fullName, color: dim.color,
        topDomain, topVal, bottomDomain, bottomVal, mean: sum / cnt, note: dim.note });
    }
  }

  // Dominant distributions
  const toneCounts: Record<string, number> = {};
  const scopeCounts: Record<string, number> = {};
  const levelCounts: Record<string, number> = {};
  const sentimentCounts: Record<string, number> = {};
  for (const p of profs) {
    if (p.dominant_tone) toneCounts[p.dominant_tone] = (toneCounts[p.dominant_tone] || 0) + 1;
    if (p.dominant_scope) scopeCounts[p.dominant_scope] = (scopeCounts[p.dominant_scope] || 0) + 1;
    if (p.dominant_reading_level) levelCounts[p.dominant_reading_level] = (levelCounts[p.dominant_reading_level] || 0) + 1;
    if (p.dominant_sentiment) sentimentCounts[p.dominant_sentiment] = (sentimentCounts[p.dominant_sentiment] || 0) + 1;
  }

  // HRCB Band Distribution
  const bands: HrcbBand[] = [
    { label: 'Strong Pos', min: 0.5, max: Infinity, count: 0, color: scoreToColor(0.9) },
    { label: 'Mod Pos', min: 0.2, max: 0.5, count: 0, color: scoreToColor(0.55) },
    { label: 'Mild Pos', min: 0.05, max: 0.2, count: 0, color: scoreToColor(0.25) },
    { label: 'Neutral', min: -0.05, max: 0.05, count: 0, color: scoreToColor(0) },
    { label: 'Mild Neg', min: -0.2, max: -0.05, count: 0, color: scoreToColor(-0.25) },
    { label: 'Mod Neg', min: -0.5, max: -0.2, count: 0, color: scoreToColor(-0.55) },
    { label: 'Strong Neg', min: -Infinity, max: -0.5, count: 0, color: scoreToColor(-0.9) },
  ];
  for (const p of profs) {
    if (p.avg_hrcb == null) continue;
    for (const b of bands) {
      if (p.avg_hrcb >= b.min && p.avg_hrcb < b.max) { b.count++; break; }
    }
  }

  return {
    avgSetl: cSetl > 0 ? sumSetl / cSetl : null,
    avgFw: cFw > 0 ? sumFw / cFw : null,
    avgConf: cConf > 0 ? sumConf / cConf : null,
    hrcbSpreadMin: minHrcb === Infinity ? null : minHrcb,
    hrcbSpreadMax: maxHrcb === -Infinity ? null : maxHrcb,
    leaders,
    toneEntries: Object.entries(toneCounts).sort((a, b) => b[1] - a[1]),
    scopeEntries: Object.entries(scopeCounts).sort((a, b) => b[1] - a[1]),
    levelEntries: Object.entries(levelCounts).sort((a, b) => b[1] - a[1]),
    sentimentEntries: Object.entries(sentimentCounts).sort((a, b) => b[1] - a[1]),
    bands,
  };
}

const metrics = await cachedQuery<SourceMetrics>(kv, 'sys:sourceMetrics', () => Promise.resolve(computeSourceMetrics(profiles)), 120);
const { avgSetl, avgFw, avgConf, hrcbSpreadMin, hrcbSpreadMax, leaders, toneEntries, scopeEntries, levelEntries, sentimentEntries, bands } = metrics;
const maxTone = toneEntries.length > 0 ? toneEntries[0][1] : 1;
const maxScope = scopeEntries.length > 0 ? scopeEntries[0][1] : 1;
const maxLevel = levelEntries.length > 0 ? levelEntries[0][1] : 1;
const maxSentiment = sentimentEntries.length > 0 ? sentimentEntries[0][1] : 1;
const maxBand = Math.max(...bands.map(b => b.count), 1);

// --- Hub cards ---
interface SectionCard {
  title: string;
  href: string;
  description: string;
  accent: string;
}
const sections: SectionCard[] = [
  {
    title: 'Domains',
    href: '/domains',
    description: 'Browse all domains by HRCB score, coverage, SETL, and confidence. Sorted directory with classification filters.',
    accent: 'var(--channel-editorial)',
  },
  {
    title: 'Users',
    href: '/users',
    description: 'User submission patterns, behavioral analysis, and human rights alignment profiles.',
    accent: 'var(--channel-structural)',
  },
  {
    title: 'Factions',
    href: '/factions',
    description: 'Editorial character clustering. Which domains think alike? Archetype analysis and affinity mapping.',
    accent: 'var(--color-amber)',
  },
];

// Pre-compute display values for metrics cards to avoid generics in JSX
const hrcbSpreadDisplay = hrcbSpreadMin != null && hrcbSpreadMax != null
  ? `${formatScore(hrcbSpreadMin)} .. ${formatScore(hrcbSpreadMax)}`
  : 'ND';
const hrcbSpreadColor = hrcbSpreadMin != null ? scoreToColor((hrcbSpreadMin + (hrcbSpreadMax ?? 0)) / 2) : '#4b5563';
const setlDisplay = formatSetl(avgSetl);
const setlColor = setlToColor(avgSetl);
const fwDisplay = formatFwRatio(avgFw);
const fwColor = fwRatioColor(avgFw);
const confDisplay = formatConfidence(avgConf);
const confColor = confidenceToColor(avgConf);

// Format helper for signal values
function fmtSig(val: number, note: string): string {
  if (note === 'inv') return val.toFixed(1) + ' flags';
  return val.toFixed(2);
}

// Key findings — computed from existing metrics (try/catch: frontmatter errors → silent SSR truncation)
const sourceFindings: Array<{ text: string; anchor: string }> = [];
try {
  if (avgSetl != null && avgSetl >= 0.15) {
    sourceFindings.push({
      text: `Average source says one thing, does another (SETL ${setlDisplay})`,
      anchor: '#source-metrics',
    });
  }
  if (hrcbSpreadMin != null && hrcbSpreadMax != null) {
    sourceFindings.push({
      text: `Source HRCB ranges from ${formatScore(hrcbSpreadMin)} to ${formatScore(hrcbSpreadMax)} — not all publishers are equal`,
      anchor: '#hrcb-distribution',
    });
  }
  if (leaders.length > 0) {
    const ptLeader = leaders.find(l => l.label === 'PT');
    if (ptLeader && ptLeader.topVal != null && ptLeader.topVal > 1) {
      sourceFindings.push({
        text: `${ptLeader.topDomain} averages ${ptLeader.topVal.toFixed(1)} propaganda flags per story`,
        anchor: '#signal-leaders',
      });
    }
    const tdLeader = leaders.find(l => l.label === 'TD');
    if (tdLeader && tdLeader.bottomVal != null && tdLeader.topVal != null) {
      sourceFindings.push({
        text: `Transparency ranges from ${tdLeader.bottomVal.toFixed(2)} (${tdLeader.bottomDomain}) to ${tdLeader.topVal.toFixed(2)} (${tdLeader.topDomain})`,
        anchor: '#signal-leaders',
      });
    }
  }
} catch { /* degrade gracefully — findings just won't show */ }

const siteUrl = new URL(Astro.request.url).origin;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Source Intelligence — HRO',
  description: `Signal profiles and factions analysis for ${domainCount} domains and ${storyCount} evaluated stories`,
  url: `${siteUrl}/sources`,
  hasPart: [
    { '@type': 'WebPage', name: 'Domains', url: `${siteUrl}/domains` },
    { '@type': 'WebPage', name: 'Users', url: `${siteUrl}/users` },
    { '@type': 'WebPage', name: 'Factions', url: `${siteUrl}/factions` },
  ],
};
---

<Base title="Source Intelligence">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'sources' }]} />
  <table cellpadding="0" cellspacing="0" width="100%" style="max-width: 680px; padding: 10px 0;">
    <tr>
      <td>
        <h1 style="font-size: var(--font-md); margin-bottom: 4px;">Source Intelligence</h1>
        <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 20px;">
          Who publishes what — editorial character across {domainCount} profiled sources.
        </p>

        {/* ═══ SECTION 1 — Source Universe ═══ */}

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 16px; display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;">
          <span style="background: rgba(213,101,0,0.15); color: var(--color-orange); border-radius: 3px; padding: 2px 7px; font-size: var(--font-xs); font-weight: bold; white-space: nowrap;">{domainCount} sources</span>
          <span style="color: var(--fg-primary); font-size: var(--font-sm);">
            <b>Source Intelligence</b> — {domainCount} domains with 3+ evaluated stories across {storyCount.toLocaleString()} total stories.
            {globalGate.gate_pct > 0 && <span style="color: var(--fg-secondary);"> {globalGate.gate_pct}% gated.</span>}
          </span>
          <a href="/about#dcp" style="color: var(--channel-hrcb); font-size: var(--font-xs); white-space: nowrap;">How sources are profiled &rarr;</a>
        </div>

        {/* ═══ KEY FINDINGS ═══ */}

        {sourceFindings.length > 0 && (
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px 12px; margin-bottom: 16px;">
            {sourceFindings.map((f, i) => (
              <div style={`padding: 4px 0;${i > 0 ? ' border-top: 1px solid var(--color-border);' : ''}`}>
                <a href={f.anchor} style="color: var(--fg-primary); font-size: var(--font-sm); text-decoration: none;">
                  <span style="color: var(--channel-hrcb); margin-right: 6px;">&rsaquo;</span>{f.text}
                </a>
              </div>
            ))}
          </div>
        )}

        {/* ═══ SECTION 2 — Source Metrics ═══ */}

        <div id="source-metrics" role="heading" aria-level="2" style="font-size: var(--font-base); margin: 0 0 8px 0; font-weight: bold;">Source Metrics</div>

        <div class="insight-grid" style="font-size: var(--font-base); margin-bottom: 20px;">
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
            <a href="/about#classification" style="text-decoration: none; font-weight: bold;" class="score-font">
              <span style={`color: ${hrcbSpreadColor};`}>HRCB Spread</span>
            </a><br>
            <span style={`color: ${hrcbSpreadColor}; font-size: var(--font-md);`} class="score-font">{hrcbSpreadDisplay}</span><br>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs);">Min..Max domain HRCB</span>
          </div>
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
            <a href="/about#setl" style="text-decoration: none; font-weight: bold;">
              <span style={`color: ${setlColor};`}>Avg SETL</span>
            </a><br>
            <span style={`color: ${setlColor}; font-size: var(--font-md);`} class="score-font">{setlDisplay}</span><br>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs);">Channel divergence</span>
          </div>
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
            <a href="/about#fair-witness" style="text-decoration: none; font-weight: bold;">
              <span style={`color: ${fwColor};`}>Fair Witness</span>
            </a><br>
            <span style={`color: ${fwColor}; font-size: var(--font-md);`} class="score-font">{fwDisplay}</span><br>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs);">Observable fact ratio</span>
          </div>
          <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
            <a href="/about#evidence" style="text-decoration: none; font-weight: bold;">
              <span style={`color: ${confColor};`}>Avg Confidence</span>
            </a><br>
            <span style={`color: ${confColor}; font-size: var(--font-md);`} class="score-font">{confDisplay}</span><br>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs);">Evidence strength</span>
          </div>
          {psqAggregates && psqAggregates.avg_psq != null && (
            <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
              <span style="color: var(--color-violet); font-weight: bold;">Avg PSQ</span>
              <span class="psq-experimental" style="margin-left: 4px;">experimental</span><br>
              <span style={`color: ${scoreToColor(normalizePsq(psqAggregates.avg_psq))}; font-size: var(--font-md);`} class="score-font">
                {formatPsqScore(psqAggregates.avg_psq)}<span style="font-size: var(--font-xs); color: var(--fg-secondary);">/10</span>
              </span><br>
              <span style="color: var(--fg-secondary); font-size: var(--font-xs);">
                Reader safety ({psqAggregates.story_count} stories)
              </span>
            </div>
          )}
        </div>

        {/* ═══ SECTION 3 — Signal Leaders ═══ */}

        {leaders.length > 0 && (
          <div id="signal-leaders">
            <div role="heading" aria-level="2" style="font-size: var(--font-base); margin: 0 0 4px 0; font-weight: bold;">Signal Leaders</div>
            <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 10px;">
              Who leads and lags on each editorial dimension? <a href="/article/19" style="color: var(--channel-editorial);">UDHR Article 19</a> protects expression — these signals reveal the character of that expression, source by source.
            </p>

            <div class="insight-grid" style="font-size: var(--font-base); margin-bottom: 20px;">
              {leaders.map((l) => {
                const topLabel = l.note === 'inv' ? 'Most flags' : 'Highest';
                const bottomLabel = l.note === 'inv' ? 'Fewest flags' : 'Lowest';
                return (
                  <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
                    <span class="badge" style={`background: ${l.color}22; color: ${l.color};`}>{l.label}</span>
                    <b style="color: var(--fg-primary); margin-left: 4px;">{l.fullName}</b>
                    <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 4px;">avg {fmtSig(l.mean, l.note)}</span>
                    <div style="margin-top: 6px; font-size: var(--font-sm);">
                      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px;">
                        <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 72px;">{topLabel}</span>
                        <a href={`/domain/${l.topDomain}`} style={`color: ${l.color}; text-decoration: none;`}>{l.topDomain}</a>
                        <span style="color: var(--fg-primary); margin-left: auto; padding-left: 6px;" class="score-font">{fmtSig(l.topVal, l.note)}</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: baseline;">
                        <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 72px;">{bottomLabel}</span>
                        <a href={`/domain/${l.bottomDomain}`} style="color: var(--fg-secondary); text-decoration: none;">{l.bottomDomain}</a>
                        <span style="color: var(--fg-secondary); margin-left: auto; padding-left: 6px;" class="score-font">{fmtSig(l.bottomVal, l.note)}</span>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* ═══ SECTION 4 — Editorial Character ═══ */}

        {(toneEntries.length > 0 || scopeEntries.length > 0 || levelEntries.length > 0 || sentimentEntries.length > 0) && (
          <div>
            <div role="heading" aria-level="2" style="font-size: var(--font-base); margin: 0 0 4px 0; font-weight: bold;">Editorial Character</div>
            <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 10px;">
              How sources sound and who they address. Tone shapes how rights issues land (<a href="/article/19" style="color: var(--channel-editorial);">Art. 19</a>); geographic scope reveals whose "<a href="/article/25" style="color: var(--channel-editorial);">adequate standard of living</a>" gets covered; reading level determines who can participate (<a href="/article/26" style="color: var(--channel-editorial);">Art. 26</a>).
            </p>

            <div class="insight-grid" style="margin-bottom: 20px;">

              {toneEntries.length > 0 && (
                <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Dominant Tone</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {toneEntries.map(([label, count]) => {
                      const pct = maxTone > 0 ? Math.round((count / maxTone) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-inference); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                </div>
              )}

              {scopeEntries.length > 0 && (
                <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Geographic Scope</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {scopeEntries.map(([label, count]) => {
                      const pct = maxScope > 0 ? Math.round((count / maxScope) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-sentiment); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                </div>
              )}

              {levelEntries.length > 0 && (
                <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Reading Level</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {levelEntries.map(([label, count]) => {
                      const pct = maxLevel > 0 ? Math.round((count / maxLevel) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-hn-score); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                </div>
              )}

              {sentimentEntries.length > 0 && (
                <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px;">
                  <p style="font-size: var(--font-xs); color: var(--fg-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 6px 0;">Dominant Sentiment</p>
                  <table cellpadding="0" cellspacing="0" width="100%">
                    {sentimentEntries.map(([label, count]) => {
                      const pct = maxSentiment > 0 ? Math.round((count / maxSentiment) * 100) : 0;
                      return (
                        <tr>
                          <td style="padding: 2px 0; color: var(--fg-primary); font-size: var(--font-xs); width: 110px;">{label}</td>
                          <td style="padding: 2px 8px;">
                            <div style="height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                              <div style={`width: ${pct}%; height: 100%; background: var(--color-positive); border-radius: 3px;`}></div>
                            </div>
                          </td>
                          <td style="width: 36px; text-align: right; color: var(--fg-secondary); font-size: var(--font-xs);" class="score-font">{count}</td>
                        </tr>
                      );
                    })}
                  </table>
                </div>
              )}

            </div>
          </div>
        )}

        {/* ═══ SECTION 5 — Source HRCB Distribution ═══ */}

        <div id="hrcb-distribution" role="heading" aria-level="2" style="font-size: var(--font-base); margin: 0 0 4px 0; font-weight: bold;">Source HRCB Distribution</div>
        <p style="color: var(--fg-secondary); font-size: var(--font-sm); margin-bottom: 10px;">
          Where sources fall on the human rights compatibility spectrum. The spread reveals whether tech media broadly aligns with UDHR principles or clusters in specific bands.
        </p>

        <div style="background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 4px; padding: 10px; margin-bottom: 20px;">
          <table cellpadding="0" cellspacing="0" width="100%">
            {bands.map((b) => {
              const pct = maxBand > 0 ? Math.round((b.count / maxBand) * 100) : 0;
              return (
                <tr>
                  <td style={`padding: 2px 0; color: ${b.color}; font-size: var(--font-xs); width: 80px;`}>{b.label}</td>
                  <td style="padding: 2px 8px;">
                    <div style="height: 10px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: ${b.color}; opacity: 0.65; border-radius: 3px;`}></div>
                    </div>
                  </td>
                  <td style="width: 36px; text-align: right; color: var(--fg-primary); font-size: var(--font-xs);" class="score-font">{b.count}</td>
                </tr>
              );
            })}
          </table>
        </div>

        {/* ═══ SECTION 6 — Deep Dive Cards ═══ */}

        <div role="heading" aria-level="2" style="font-size: var(--font-base); margin: 0 0 8px 0; font-weight: bold;">Deep Dives</div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; margin-bottom: 20px;">
          {sections.map(card => (
            <a href={card.href} style="text-decoration: none; display: block;">
              <div class="hub-card" style={`background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; padding: 14px; height: 100%; border-left: 3px solid ${card.accent}; transition: border-color 0.15s;`}>
                <div style={`color: ${card.accent}; font-size: var(--font-md); font-weight: bold;`}>{card.title}</div>
                <div style="color: var(--fg-secondary); font-size: var(--font-sm); margin-top: 4px; line-height: 1.5;">
                  {card.description}
                </div>
                <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-top: 6px;">
                  {card.href} &rarr;
                </div>
              </div>
            </a>
          ))}
        </div>

      </td>
    </tr>
  </table>

  <style>
    .hub-card:hover {
      border-color: var(--color-cyan) !important;
    }
  </style>
</Base>
