---
// SPDX-License-Identifier: Apache-2.0
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import ModelsTrustIndex from '../../components/ModelsTrustIndex.astro';
import ModelsCostAttribution from '../../components/ModelsCostAttribution.astro';
import ModelsMeasurementIntegrity from '../../components/ModelsMeasurementIntegrity.astro';
import ModelsComparison from '../../components/ModelsComparison.astro';
import ModelsDisagreement from '../../components/ModelsDisagreement.astro';
import ModelsComparedStories from '../../components/ModelsComparedStories.astro';
import ModelsRegistry from '../../components/ModelsRegistry.astro';
import ModelsChannelAverages from '../../components/ModelsChannelAverages.astro';
import ModelsRaters from '../../components/ModelsRaters.astro';
import ModelsCoverageProgression from '../../components/ModelsCoverageProgression.astro';
import ModelsCalibration from '../../components/ModelsCalibration.astro';
import ModelsSignalCompleteness from '../../components/ModelsSignalCompleteness.astro';
import ModelsScoreDistribution from '../../components/ModelsScoreDistribution.astro';
import ModelsSectionDivergences from '../../components/ModelsSectionDivergences.astro';
import ModelsPerSectionAverages from '../../components/ModelsPerSectionAverages.astro';
import ModelsExcluded from '../../components/ModelsExcluded.astro';
// shared-eval imports moved to extracted components
import {
  getRaterStatusBreakdown,
  getModelTrustHistory,
  groupTrustByModel,
  getModelStats,
  getModelComparisonStats,
  getRaterSummaryStats,
  getLatestCalibrationRun,
  getLatestLiteCalibrationRun,
  getSignalCompleteness,
  getContentTypeValidation,
  getContentTypeDisagreement,
  getMisclassificationSummary,
  getModelDriftStats,
  getGlobalGateStats,
  getMethodologyDistribution,
  getModelChannelAverages,
  getCoverageProgression,
  getContentTypeEvalMix,
  getTruncationImpact,
  getCostStats,
  getDailyCostStats,
  MODEL_COMPARISON_KV_KEY,
} from '../../lib/db';
import type { ModelComparisonBlob, ComparedStory } from '../../lib/db';
import { cachedQuery, readDb } from '../../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

let _pageError: string | null = null;

// Variable declarations with typed defaults
let statusBreakdown: Awaited<ReturnType<typeof getRaterStatusBreakdown>> = [];
let trustHistory: Awaited<ReturnType<typeof getModelTrustHistory>> = [];
let models: Awaited<ReturnType<typeof getModelStats>> = [];
let modelComparison: Awaited<ReturnType<typeof getModelComparisonStats>> = [];
let raterSummary: Awaited<ReturnType<typeof getRaterSummaryStats>> = [];
let lastCalibration: Awaited<ReturnType<typeof getLatestCalibrationRun>> | null = null;
let lastLiteCalibration: Awaited<ReturnType<typeof getLatestLiteCalibrationRun>> | null = null;
let signalCompleteness: Awaited<ReturnType<typeof getSignalCompleteness>> = [];
let ctValidation: Awaited<ReturnType<typeof getContentTypeValidation>> = [];
let ctDisagreement: Awaited<ReturnType<typeof getContentTypeDisagreement>> = [];
let ctMisclass: { structural_heavy_total: number; structural_heavy_missing: number; misclassification_pct: number; disagreement_count: number } = { structural_heavy_total: 0, structural_heavy_missing: 0, misclassification_pct: 0, disagreement_count: 0 };
let driftStats: { models: any[]; overlapping: number; meanDelta: number | null } = { models: [], overlapping: 0, meanDelta: null };
let methodologyDist: Awaited<ReturnType<typeof getMethodologyDistribution>> = [];
let globalGate: { total: number; gated: number; gate_pct: number; breakdown: { gate_category: string; cnt: number }[] } = { total: 0, gated: 0, gate_pct: 0, breakdown: [] };
let channelAverages: Awaited<ReturnType<typeof getModelChannelAverages>> = [];
let coverageProgression: Awaited<ReturnType<typeof getCoverageProgression>> = [];
let ctEvalMix: Awaited<ReturnType<typeof getContentTypeEvalMix>> = [];
let truncationImpact: Awaited<ReturnType<typeof getTruncationImpact>> = [];
let costStats: Awaited<ReturnType<typeof getCostStats>> = [];
let dailyCostStats: Awaited<ReturnType<typeof getDailyCostStats>> = [];

// Timed query helper — wraps cachedQuery + records per-query timing
const _timings: { name: string; ms: number }[] = [];
async function tq<T>(name: string, key: string, fn: () => Promise<T>, ttl: number, fallback: T): Promise<T> {
  const t0 = Date.now();
  try {
    const result = await cachedQuery(kv, key, fn, ttl);
    _timings.push({ name, ms: Date.now() - t0 });
    return result;
  } catch {
    _timings.push({ name: name + '!ERR', ms: Date.now() - t0 });
    return fallback;
  }
}

// --- Phase 1: Lightweight queries (run in Pages worker, KV-cached) ---
const _t0 = Date.now();
try {
  models         = await tq('modelStats',    'sys:modelStats',    () => getModelStats(db), 120, [] as typeof models);
  modelComparison = await tq('modelComp',    'sys:modelComparison', () => getModelComparisonStats(db), 300, [] as typeof modelComparison);
  channelAverages = await tq('channelAvg',   'sys:channelAvg',    () => getModelChannelAverages(db), 120, [] as typeof channelAverages);
  statusBreakdown = await tq('statusBkdn',   'sys:statusBkdn',    () => getRaterStatusBreakdown(db), 60, [] as typeof statusBreakdown);
  raterSummary    = await tq('raterSum',     'sys:raterSummary',  () => getRaterSummaryStats(db), 120, [] as typeof raterSummary);
  trustHistory    = await tq('trustHist',    'sys:trustHist',     () => getModelTrustHistory(db, 14), 120, [] as typeof trustHistory);
  lastCalibration = await tq('lastCal',      'sys:lastCal',       () => getLatestCalibrationRun(db), 600, null);
  lastLiteCalibration = await tq('lastLiteCal', 'sys:lastLiteCal', () => getLatestLiteCalibrationRun(db), 600, null);
  signalCompleteness = await tq('sigComplete', 'sys:signalComplete', () => getSignalCompleteness(db), 300, [] as typeof signalCompleteness);
  globalGate      = await tq('globalGate',   'sys:globalGate',    () => getGlobalGateStats(db), 600, { total: 0, gated: 0, gate_pct: 0, breakdown: [] as { gate_category: string; cnt: number }[] });
  driftStats      = await tq('modelDrift',   'sys:modelDrift',    () => getModelDriftStats(db), 300, { models: [] as any[], overlapping: 0, meanDelta: null });
  methodologyDist = await tq('methDist',     'sys:methDist',      () => getMethodologyDistribution(db), 600, [] as typeof methodologyDist);
  ctValidation    = await tq('ctValid',      'sys:ctValidation',  () => getContentTypeValidation(db), 300, [] as typeof ctValidation);
  ctDisagreement  = await tq('ctDisagree',   'sys:ctDisagreement', () => getContentTypeDisagreement(db), 300, [] as typeof ctDisagreement);
  ctMisclass      = await tq('ctMisclass',   'sys:ctMisclass',    () => getMisclassificationSummary(db), 300, { structural_heavy_total: 0, structural_heavy_missing: 0, misclassification_pct: 0, disagreement_count: 0 });
  coverageProgression = await tq('covProg',  'sys:covProg',       () => getCoverageProgression(db), 600, [] as typeof coverageProgression);
  ctEvalMix       = await tq('ctEvalMix',    'sys:ctEvalMix',     () => getContentTypeEvalMix(db), 600, [] as typeof ctEvalMix);
  truncationImpact = await tq('truncImpact', 'sys:truncImpact',   () => getTruncationImpact(db), 300, [] as typeof truncationImpact);
  costStats       = await tq('costStats',    'sys:costStats',     () => getCostStats(db), 300, [] as typeof costStats);
  dailyCostStats  = await tq('dailyCost',    'sys:dailyCost',     () => getDailyCostStats(db), 300, [] as typeof dailyCostStats);
} catch (err: unknown) {
  _pageError = `Query phase: ${err instanceof Error ? err.message : String(err)}`;
}
const _queryMs = Date.now() - _t0;

// --- Phase 2: Read pre-computed comparison blob from KV (computed by cron worker) ---
// Heavy multi-model queries + O(n²) compute run in cron (30s CPU budget), not here (10ms limit).
const _t1 = Date.now();

const emptyBlob: ModelComparisonBlob = {
  aggregates: [], modelIds: [], totalStories: 0, agreeCount: 0, agreePct: 0,
  classAgreeCount: 0, classAgreePct: 0, avgDelta: 0, medianDelta: 0,
  pairCorrelations: [], histograms: [], histMaxCount: 1,
  sectionDivergence: [], topDivergent: [], biasAnalysis: [],
  mostDisagreed: [], mostAgreed: [], comparedStories: [],
  excludedModels: [], sectionAverages: [], computedAt: '',
};

let cmp: ModelComparisonBlob = emptyBlob;
try {
  const raw = await kv.get(MODEL_COMPARISON_KV_KEY, 'json');
  if (raw) {
    cmp = raw as ModelComparisonBlob;
    _timings.push({ name: 'cmpBlob', ms: Date.now() - _t1 });
  } else {
    _timings.push({ name: 'cmpBlob!MISS', ms: Date.now() - _t1 });
  }
} catch {
  _timings.push({ name: 'cmpBlob!ERR', ms: Date.now() - _t1 });
}

// Destructure blob for template use
const { modelIds, totalStories, agreeCount, agreePct, classAgreeCount, classAgreePct,
        avgDelta, medianDelta, pairCorrelations, histMaxCount,
        biasAnalysis, mostDisagreed, mostAgreed, comparedStories, excludedModels,
        topDivergent, sectionDivergence } = cmp;
const aggregates = cmp.aggregates;
const histograms = cmp.histograms;

// Simple compute (no heavy loops — safe for 10ms CPU)
const trustByModel = groupTrustByModel(trustHistory);

const STRUCTURAL_HEAVY = new Set(['PO', 'LP', 'AD', 'AC', 'CO']);
const CT_WEIGHTS: Record<string, { e: number; s: number }> = {
  ED: { e: 0.6, s: 0.4 }, PO: { e: 0.3, s: 0.7 }, LP: { e: 0.3, s: 0.7 },
  AD: { e: 0.2, s: 0.8 }, AC: { e: 0.4, s: 0.6 }, CO: { e: 0.5, s: 0.5 },
  RE: { e: 0.7, s: 0.3 }, SA: { e: 0.8, s: 0.2 }, MX: { e: 0.5, s: 0.5 },
};
const MIN_STORIES = 10;

const _computeMs = Date.now() - _t1;
const _totalMs = Date.now() - _t0;

// Model pricing table ($/MTok). Workers AI = free; OpenRouter free tier = free.
const MODEL_PRICING: Record<string, { inPerMTok: number; outPerMTok: number }> = {
  'claude-haiku-4-5-20251001':       { inPerMTok: 0.80,  outPerMTok: 4.00  },
  'claude-haiku-4-5':                { inPerMTok: 0.80,  outPerMTok: 4.00  },
  'claude-sonnet-4-5-20251022':      { inPerMTok: 3.00,  outPerMTok: 15.00 },
  'claude-sonnet-4-6':               { inPerMTok: 3.00,  outPerMTok: 15.00 },
  'claude-opus-4-6':                 { inPerMTok: 15.00, outPerMTok: 75.00 },
};
function modelCost(model: string, tokIn: number, tokOut: number): number {
  const p = MODEL_PRICING[model];
  if (!p) return 0;
  return (tokIn / 1_000_000) * p.inPerMTok + (tokOut / 1_000_000) * p.outPerMTok;
}

// Daily burn rate chart data
const dcDays = [...new Set(dailyCostStats.map(r => r.eval_day))].sort();
const dcTotals = dcDays.map(d =>
  dailyCostStats
    .filter(r => r.eval_day === d)
    .reduce((s, r) => s + modelCost(r.eval_model, r.tokens_in, r.tokens_out), 0)
);
const dcMax = Math.max(0.001, ...dcTotals);
---

<Base title="Models">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'status', href: '/status' }, { label: 'models' }]} />
  <SubNav items={[{ label: 'Models', href: '/status/models' }, { label: 'Events', href: '/status/events' }]} current="/status/models" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Models</span>
        <span style="color: var(--fg-secondary); margin-left: var(--space-lg);">
          Model registry, performance comparison, and measurement integrity.
        </span>
      </td>
    </tr>
  </table>

  {_pageError && (
    <div style="padding: 10px; margin-bottom: 10px; background: #2d0000; border: 1px solid var(--color-negative); border-radius: 6px; color: var(--color-negative-light); font-size: var(--font-sm); font-family: monospace;">
      <strong>Page Error:</strong> {_pageError}
    </div>
  )}

  <div style="padding: 6px 10px; margin-bottom: 10px; background: var(--bg-surface); border: 1px solid var(--color-border); border-radius: 4px; font-size: 9px; color: var(--fg-secondary); font-family: monospace;">
    <span style="color: var(--fg-primary);">queries {_queryMs}ms</span> · <span style="color: var(--fg-primary);">compute {_computeMs}ms</span> · <span style="color: var(--fg-primary);">total {_totalMs}ms</span>
    {_timings.length > 0 && (
      <span style="margin-left: 8px;">
        | {_timings.sort((a, b) => b.ms - a.ms).slice(0, 5).map(t => (
          <span style={`color: ${t.ms > 2000 ? 'var(--color-negative)' : t.ms > 500 ? 'var(--color-warning)' : 'var(--fg-secondary)'}; margin-right: 6px;`}>
            {t.name}:{t.ms}ms
          </span>
        ))}
      </span>
    )}
  </div>

  <ModelsRegistry models={models} modelComparison={modelComparison} />

  <ModelsChannelAverages channelAverages={channelAverages} />

  <ModelsRaters statusBreakdown={statusBreakdown} raterSummary={raterSummary} />

  <ModelsCoverageProgression coverageProgression={coverageProgression} />

  {trustHistory.length > 0 && (
    <ModelsTrustIndex trustByModel={trustByModel} />
  )}

  <ModelsCalibration
    lastCalibration={lastCalibration}
    lastLiteCalibration={lastLiteCalibration}
    methodologyDist={methodologyDist}
    globalGate={globalGate}
  />

  <ModelsCostAttribution
    costStats={costStats}
    dailyCostStats={dailyCostStats}
    MODEL_PRICING={MODEL_PRICING}
    modelCost={modelCost}
    dcDays={dcDays}
    dcTotals={dcTotals}
    dcMax={dcMax}
  />

  <ModelsSignalCompleteness signalCompleteness={signalCompleteness} />

  <ModelsMeasurementIntegrity
    driftStats={driftStats}
    ctMisclass={ctMisclass}
    ctValidation={ctValidation}
    ctDisagreement={ctDisagreement}
    truncationImpact={truncationImpact}
    ctEvalMix={ctEvalMix}
    STRUCTURAL_HEAVY={STRUCTURAL_HEAVY}
    CT_WEIGHTS={CT_WEIGHTS}
  />

  <ModelsScoreDistribution
    totalStories={totalStories}
    modelIds={modelIds}
    histograms={histograms}
    histMaxCount={histMaxCount}
  />

  <ModelsComparison
    totalStories={totalStories}
    agreeCount={agreeCount}
    agreePct={agreePct}
    classAgreeCount={classAgreeCount}
    classAgreePct={classAgreePct}
    avgDelta={avgDelta}
    medianDelta={medianDelta}
    pairCorrelations={pairCorrelations}
    modelIds={modelIds}
    aggregates={aggregates}
    biasAnalysis={biasAnalysis}
  />

  <ModelsSectionDivergences
    totalStories={totalStories}
    modelIds={modelIds}
    topDivergent={topDivergent}
  />

  <ModelsDisagreement
    totalStories={totalStories}
    modelIds={modelIds}
    mostDisagreed={mostDisagreed}
    mostAgreed={mostAgreed}
  />

  <ModelsPerSectionAverages
    totalStories={totalStories}
    modelIds={modelIds}
    sectionAverages={cmp.sectionAverages}
  />

  <ModelsComparedStories
    totalStories={totalStories}
    modelIds={modelIds}
    comparedStories={comparedStories}
  />

  <ModelsExcluded excludedModels={excludedModels} minStories={MIN_STORIES} />
</Base>
