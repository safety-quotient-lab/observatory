---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import { scoreToColor, formatScore, classificationColor, confidenceToColor } from '../../lib/colors';
import { modelDisplayName, ALL_SECTIONS, isLiteMode, getModelDef, MODEL_REGISTRY } from '../../lib/shared-eval';
import { ARTICLE_TITLES } from '../../lib/udhr';
import { CALIBRATION_SET, LITE_CALIBRATION_SET } from '../../lib/calibration';
import {
  getMultiModelStories,
  getModelComparisonAggregates,
  getModelSectionAverages,
  getRaterStatusBreakdown,
  getModelTrustHistory,
  groupTrustByModel,
  getModelStats,
  getModelComparisonStats,
  getRaterSummaryStats,
  getLatestCalibrationRun,
  getLatestLiteCalibrationRun,
  getSignalCompleteness,
  getContentTypeValidation,
  getContentTypeDisagreement,
  getMisclassificationSummary,
  getModelDriftStats,
  getGlobalGateStats,
  getModelChannelAverages,
} from '../../lib/db';
import { cachedQuery } from '../../lib/db-utils';

const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

let _pageError: string | null = null;

let stories: Awaited<ReturnType<typeof getMultiModelStories>> = [];
let allAggregates: Awaited<ReturnType<typeof getModelComparisonAggregates>> = [];
let sectionAvgs: Awaited<ReturnType<typeof getModelSectionAverages>> = [];
let statusBreakdown: Awaited<ReturnType<typeof getRaterStatusBreakdown>> = [];
let trustHistory: Awaited<ReturnType<typeof getModelTrustHistory>> = [];
let models: Awaited<ReturnType<typeof getModelStats>> = [];
let modelComparison: Awaited<ReturnType<typeof getModelComparisonStats>> = [];
let raterSummary: Awaited<ReturnType<typeof getRaterSummaryStats>> = [];
let lastCalibration: Awaited<ReturnType<typeof getLatestCalibrationRun>> | null = null;
let lastLiteCalibration: Awaited<ReturnType<typeof getLatestLiteCalibrationRun>> | null = null;
let signalCompleteness: Awaited<ReturnType<typeof getSignalCompleteness>> = [];
let ctValidation: Awaited<ReturnType<typeof getContentTypeValidation>> = [];
let ctDisagreement: Awaited<ReturnType<typeof getContentTypeDisagreement>> = [];
let ctMisclass: { structural_heavy_total: number; structural_heavy_missing: number; misclassification_pct: number; disagreement_count: number } = { structural_heavy_total: 0, structural_heavy_missing: 0, misclassification_pct: 0, disagreement_count: 0 };
let driftStats: { models: any[]; overlapping: number; meanDelta: number | null } = { models: [], overlapping: 0, meanDelta: null };
let globalGate: { total: number; gated: number; gate_pct: number; breakdown: { gate_category: string; cnt: number }[] } = { total: 0, gated: 0, gate_pct: 0, breakdown: [] };
let channelAverages: Awaited<ReturnType<typeof getModelChannelAverages>> = [];

try {
// Batch 1: lightweight/cached queries
[
  models, modelComparison, raterSummary,
  lastCalibration, lastLiteCalibration,
  signalCompleteness, globalGate,
] = await Promise.all([
  getModelStats(db).catch(() => [] as Awaited<ReturnType<typeof getModelStats>>),
  cachedQuery(kv, 'sys:modelComparison', () => getModelComparisonStats(db), 300).catch(() => [] as Awaited<ReturnType<typeof getModelComparisonStats>>),
  cachedQuery(kv, 'sys:raterSummary', () => getRaterSummaryStats(db), 120).catch(() => [] as Awaited<ReturnType<typeof getRaterSummaryStats>>),
  cachedQuery(kv, 'sys:lastCal', () => getLatestCalibrationRun(db), 600).catch(() => null),
  cachedQuery(kv, 'sys:lastLiteCal', () => getLatestLiteCalibrationRun(db), 600).catch(() => null),
  cachedQuery(kv, 'sys:signalComplete', () => getSignalCompleteness(db), 300).catch(() => [] as Awaited<ReturnType<typeof getSignalCompleteness>>),
  cachedQuery(kv, 'sys:globalGate', () => getGlobalGateStats(db), 600).catch(() => ({ total: 0, gated: 0, gate_pct: 0, breakdown: [] as { gate_category: string; cnt: number }[] })),
]);

// Batch 2: heavier queries
[
  stories, allAggregates, sectionAvgs, statusBreakdown, trustHistory,
  channelAverages,
] = await Promise.all([
  getMultiModelStories(db, 500).catch(() => [] as Awaited<ReturnType<typeof getMultiModelStories>>),
  getModelComparisonAggregates(db).catch(() => [] as Awaited<ReturnType<typeof getModelComparisonAggregates>>),
  getModelSectionAverages(db).catch(() => [] as Awaited<ReturnType<typeof getModelSectionAverages>>),
  getRaterStatusBreakdown(db).catch(() => [] as Awaited<ReturnType<typeof getRaterStatusBreakdown>>),
  getModelTrustHistory(db, 14).catch(() => [] as Awaited<ReturnType<typeof getModelTrustHistory>>),
  getModelChannelAverages(db).catch(() => [] as Awaited<ReturnType<typeof getModelChannelAverages>>),
]);

// Batch 3: measurement integrity queries
[
  ctValidation, ctDisagreement, ctMisclass, driftStats,
] = await Promise.all([
  cachedQuery(kv, 'sys:ctValidation', () => getContentTypeValidation(db), 300).catch(() => [] as Awaited<ReturnType<typeof getContentTypeValidation>>),
  cachedQuery(kv, 'sys:ctDisagreement', () => getContentTypeDisagreement(db), 300).catch(() => [] as Awaited<ReturnType<typeof getContentTypeDisagreement>>),
  cachedQuery(kv, 'sys:ctMisclass', () => getMisclassificationSummary(db), 300).catch(() => ({ structural_heavy_total: 0, structural_heavy_missing: 0, misclassification_pct: 0, disagreement_count: 0 })),
  cachedQuery(kv, 'sys:modelDrift', () => getModelDriftStats(db), 300).catch(() => ({ models: [] as any[], overlapping: 0, meanDelta: null })),
]);
} catch (err: unknown) {
  _pageError = `Query phase: ${err instanceof Error ? err.message : String(err)}`;
}

let trustByModel = new Map<string, any[]>();
let aggregates: typeof allAggregates = [];
let modelIds: string[] = [];
let filteredStories: typeof stories = [];
let storyStats: any[] = [];
let totalStories = 0;
let agreeCount = 0;
let agreePct = 0;
let classAgreeCount = 0;
let classAgreePct = 0;
let avgDelta = 0;
let medianDelta = 0;
let mostDisagreed: any[] = [];
let mostAgreed: any[] = [];
let pairCorrelations: { modelA: string; modelB: string; r: number | null; n: number }[] = [];
let histogramByModel = new Map<string, number[]>();
let histMaxCount = 1;
let sectionDivergence: any[] = [];
let topDivergent: any[] = [];
let biasAnalysis: any[] = [];
let excludedModels: typeof allAggregates = [];
let sectionByModelMap = new Map<string, Map<string, number>>();

try {
trustByModel = groupTrustByModel(trustHistory);

// Content type validation constants (extracted to frontmatter — Astro generics gotcha)
const STRUCTURAL_HEAVY = new Set(['PO', 'LP', 'AD', 'AC', 'CO']);
const CT_WEIGHTS: Record<string, { e: number; s: number }> = {
  ED: { e: 0.6, s: 0.4 }, PO: { e: 0.3, s: 0.7 }, LP: { e: 0.3, s: 0.7 },
  AD: { e: 0.2, s: 0.8 }, AC: { e: 0.4, s: 0.6 }, CO: { e: 0.5, s: 0.5 },
  RE: { e: 0.7, s: 0.3 }, SA: { e: 0.8, s: 0.2 }, MX: { e: 0.5, s: 0.5 },
};
const MIN_STORIES = 10;

function pearsonCorrelation(xs: number[], ys: number[]): number | null {
  if (xs.length < 3) return null;
  const n = xs.length;
  const meanX = xs.reduce((a, b) => a + b, 0) / n;
  const meanY = ys.reduce((a, b) => a + b, 0) / n;
  let num = 0, denomX = 0, denomY = 0;
  for (let i = 0; i < n; i++) {
    const dx = xs[i] - meanX;
    const dy = ys[i] - meanY;
    num += dx * dy;
    denomX += dx * dx;
    denomY += dy * dy;
  }
  const denom = Math.sqrt(denomX * denomY);
  return denom === 0 ? null : num / denom;
}

aggregates = allAggregates.filter(a => a.story_count >= MIN_STORIES);
modelIds = aggregates.map(a => a.model);

filteredStories = stories.map(s => ({
  ...s,
  models: s.models.filter(m => modelIds.includes(m.model)),
})).filter(s => s.models.length >= 2);

// Build section averages lookup: model -> section -> avg_final
for (const row of sectionAvgs) {
  if (!modelIds.includes(row.model)) continue;
  if (!sectionByModelMap.has(row.model)) sectionByModelMap.set(row.model, new Map());
  sectionByModelMap.get(row.model)!.set(row.section, row.avg_final);
}

// Compute per-story sign agreement and score delta
storyStats = filteredStories.map(s => {
  const scores = s.models.map(m => m.score);
  const signs = scores.map(sc => sc >= 0 ? 1 : -1);
  const allAgree = signs.every(sg => sg === signs[0]);
  const maxDelta = scores.length >= 2 ? Math.max(...scores) - Math.min(...scores) : 0;
  const classes = s.models.map(m => m.classification).filter(Boolean);
  const classAgree = classes.length >= 2 && classes.every(c => c === classes[0]);
  return { ...s, allAgree, classAgree, maxDelta };
});

totalStories = storyStats.length;
agreeCount = storyStats.filter(s => s.allAgree).length;
agreePct = totalStories > 0 ? Math.round((agreeCount / totalStories) * 100) : 0;
classAgreeCount = storyStats.filter(s => s.classAgree).length;
classAgreePct = totalStories > 0 ? Math.round((classAgreeCount / totalStories) * 100) : 0;
avgDelta = totalStories > 0 ? storyStats.reduce((sum, s) => sum + s.maxDelta, 0) / totalStories : 0;
medianDelta = (() => {
  const sorted = [...storyStats].map(s => s.maxDelta).sort((a, b) => a - b);
  if (sorted.length === 0) return 0;
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
})();

mostDisagreed = [...storyStats].sort((a, b) => b.maxDelta - a.maxDelta).slice(0, 10);
mostAgreed = [...storyStats].sort((a, b) => a.maxDelta - b.maxDelta).slice(0, 10);

pairCorrelations = (() => {
  const pairs: { modelA: string; modelB: string; r: number | null; n: number }[] = [];
  for (let i = 0; i < modelIds.length; i++) {
    for (let j = i + 1; j < modelIds.length; j++) {
      const a = modelIds[i], b = modelIds[j];
      const xs: number[] = [], ys: number[] = [];
      for (const s of filteredStories) {
        const sa = s.models.find(m => m.model === a);
        const sb = s.models.find(m => m.model === b);
        if (sa && sb) { xs.push(sa.score); ys.push(sb.score); }
      }
      pairs.push({ modelA: a, modelB: b, r: pearsonCorrelation(xs, ys), n: xs.length });
    }
  }
  return pairs;
})();

const BINS = 10;
const BIN_MIN = -0.5;
const BIN_MAX = 0.5;
const BIN_WIDTH = (BIN_MAX - BIN_MIN) / BINS;
for (const mid of modelIds) {
  const counts = new Array(BINS).fill(0);
  for (const s of filteredStories) {
    const me = s.models.find(m => m.model === mid);
    if (!me) continue;
    const bin = Math.min(BINS - 1, Math.max(0, Math.floor((me.score - BIN_MIN) / BIN_WIDTH)));
    counts[bin]++;
  }
  histogramByModel.set(mid, counts);
}
histMaxCount = Math.max(1, ...Array.from(histogramByModel.values()).flat());

sectionDivergence = ALL_SECTIONS.map((section, idx) => {
  const vals = modelIds.map(m => sectionByModelMap.get(m)?.get(section) ?? null);
  const validVals = vals.filter((v): v is number => v !== null);
  const delta = validVals.length >= 2 ? Math.max(...validVals) - Math.min(...validVals) : 0;
  const title = idx > 0 && idx <= 30 ? ARTICLE_TITLES[idx - 1] : 'Preamble';
  return { section, idx, vals, delta, title };
}).sort((a, b) => b.delta - a.delta);

topDivergent = sectionDivergence.slice(0, 5);

biasAnalysis = modelIds.map(mid => {
  let higher = 0, lower = 0, total = 0;
  for (const s of storyStats) {
    const me = s.models.find(m => m.model === mid);
    if (!me || s.models.length < 2) continue;
    const otherScores = s.models.filter(m => m.model !== mid).map(m => m.score);
    const otherMean = otherScores.reduce((a, b) => a + b, 0) / otherScores.length;
    if (me.score > otherMean + 0.01) higher++;
    else if (me.score < otherMean - 0.01) lower++;
    total++;
  }
  return { model: mid, higher, lower, total, higherPct: total > 0 ? Math.round((higher / total) * 100) : 0, lowerPct: total > 0 ? Math.round((lower / total) * 100) : 0 };
});

excludedModels = allAggregates.filter(a => a.story_count < MIN_STORIES && a.story_count > 0);
} catch (err: unknown) {
  _pageError = _pageError ?? `Compute phase: ${err instanceof Error ? err.message : String(err)}`;
}
---

<Base title="Models">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'status', href: '/status' }, { label: 'models' }]} />
  <SubNav items={[{ label: 'Models', href: '/status/models' }, { label: 'Events', href: '/status/events' }]} current="/status/models" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">Models</span>
        <span style="color: #5b7279; margin-left: var(--space-lg);">
          Model registry, performance comparison, and measurement integrity.
        </span>
      </td>
    </tr>
  </table>

  {_pageError && (
    <div style="padding: 10px; margin-bottom: 10px; background: #2d0000; border: 1px solid #dc2626; border-radius: 6px; color: #f87171; font-size: var(--font-sm); font-family: monospace;">
      <strong>Page Error:</strong> {_pageError}
    </div>
  )}

  {/* ═══ Evaluation Models (absorbed from /system) — always visible ═══ */}
  {models.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Evaluation Models
            {modelComparison.length > 1 && (
              <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
                {modelComparison.length} models in history
              </span>
            )}
          </div>
          <div class="table-wrap">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #5b7279; font-size: var(--font-xs);">
              <td>Model</td>
              <td width="60" align="center">Status</td>
              <td width="70" align="center">Provider</td>
              <td width="70" align="center">Evals</td>
              <td width="70" align="center">Avg HRCB</td>
              <td width="50" align="center">Min</td>
              <td width="50" align="center">Max</td>
            </tr>
            {MODEL_REGISTRY.map((reg) => {
              const active = models.find(m => m.eval_model === reg.id);
              const hist = modelComparison.find(mc => mc.eval_model === reg.id);
              const evalCount = active?.count ?? hist?.count ?? 0;
              const avgScore = active?.avg_score ?? hist?.avg_score ?? null;
              return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style={`color: ${reg.enabled ? '#98a8a8' : '#5b7279'};`} class="score-font">
                  {reg.api_model_id}
                </td>
                <td align="center" class="score-font">
                  {reg.enabled
                    ? <span style="color: #4ade80;">on</span>
                    : <span style="color: #5b7279;">off</span>
                  }
                </td>
                <td align="center" class="score-font" style={`color: ${reg.provider === 'anthropic' ? '#c084fc' : reg.provider === 'workers-ai' ? '#f59e0b' : '#60a5fa'};`}>
                  {reg.provider === 'anthropic' ? 'anth' : reg.provider === 'workers-ai' ? 'CF' : 'OR'}{reg.is_free ? '' : ''}
                </td>
                <td align="center" class="score-font" style="color: #5b7279;">
                  {evalCount > 0 ? evalCount : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(avgScore)}; white-space: nowrap;`}>
                  {avgScore != null ? formatScore(avgScore) : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.min_score ?? null)}; white-space: nowrap;`}>
                  {hist ? formatScore(hist.min_score) : '---'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.max_score ?? null)}; white-space: nowrap;`}>
                  {hist ? formatScore(hist.max_score) : '---'}
                </td>
              </tr>
              );
            })}
          </table>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* ═══ Channel Averages (HRCB · E · S per model) ═══ */}
  {channelAverages.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Channel Averages
            <span style="text-transform: none; letter-spacing: 0; color: #1a5568; margin-left: 6px; font-size: var(--font-xs);">avg HRCB · E · S per model · done evals</span>
          </div>
          {(() => {
            const MAX_BAR = Math.max(0.01, ...channelAverages.flatMap(r => [
              Math.abs(r.avg_hrcb ?? 0),
              Math.abs(r.avg_e ?? 0),
              Math.abs(r.avg_s ?? 0),
            ]));
            const BAR_W = 80; // max bar width px
            return channelAverages.map(r => {
              const hrcbW = Math.round((Math.abs(r.avg_hrcb ?? 0) / MAX_BAR) * BAR_W);
              const eW    = Math.round((Math.abs(r.avg_e    ?? 0) / MAX_BAR) * BAR_W);
              const sW    = r.avg_s != null ? Math.round((Math.abs(r.avg_s) / MAX_BAR) * BAR_W) : null;
              const isLite = r.prompt_mode === 'lite' || r.prompt_mode === 'light';
              return (
                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0; border-top: 1px solid #0d4655; font-size: var(--font-xs);">
                  <div style="width: 140px; color: #98a8a8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-shrink: 0;" title={r.eval_model}>
                    {modelDisplayName(r.eval_model)}
                    {isLite && <span style="color: #d56500; margin-left: 3px; font-size: 8px;">~lite</span>}
                  </div>
                  <div style="flex: 1; display: flex; flex-direction: column; gap: 2px;">
                    {/* HRCB bar */}
                    <div style="display: flex; align-items: center; gap: 4px;">
                      <span style="color: #5b7279; width: 28px; text-align: right; font-size: 8px;">HRCB</span>
                      <div style={`width: ${hrcbW}px; height: 7px; background: #259d94; border-radius: 2px;`}></div>
                      <span class="score-font" style={`color: ${scoreToColor(r.avg_hrcb)}; font-size: var(--font-xs);`}>{r.avg_hrcb != null ? r.avg_hrcb.toFixed(3) : '—'}</span>
                    </div>
                    {/* E bar */}
                    <div style="display: flex; align-items: center; gap: 4px;">
                      <span style="color: #5b7279; width: 28px; text-align: right; font-size: 8px;">E</span>
                      <div style={`width: ${eW}px; height: 7px; background: #60a5fa; border-radius: 2px;`}></div>
                      <span class="score-font" style={`color: ${scoreToColor(r.avg_e)}; font-size: var(--font-xs);`}>{r.avg_e != null ? r.avg_e.toFixed(3) : '—'}</span>
                    </div>
                    {/* S bar — full models only */}
                    {!isLite && (
                      <div style="display: flex; align-items: center; gap: 4px;">
                        <span style="color: #5b7279; width: 28px; text-align: right; font-size: 8px;">S</span>
                        {sW != null
                          ? <div style={`width: ${sW}px; height: 7px; background: #a78bfa; border-radius: 2px;`}></div>
                          : <span style="color: #1a5568; font-size: 8px;">n/a</span>
                        }
                        <span class="score-font" style={`color: ${scoreToColor(r.avg_s)}; font-size: var(--font-xs);`}>{r.avg_s != null ? r.avg_s.toFixed(3) : '—'}</span>
                      </div>
                    )}
                  </div>
                  <div style="color: #1a5568; font-size: 8px; flex-shrink: 0; width: 36px; text-align: right;">{r.n.toLocaleString()}</div>
                </div>
              );
            });
          })()}
          <div style="display: flex; gap: 12px; margin-top: 8px; padding-top: 6px; border-top: 1px solid #0d4655; font-size: var(--font-xs); color: #5b7279;">
            <span><span style="color: #259d94;">■</span> HRCB</span>
            <span><span style="color: #60a5fa;">■</span> E editorial</span>
            <span><span style="color: #a78bfa;">■</span> S structural</span>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* ═══ Multi-Model Raters (absorbed from /system) — always visible ═══ */}
  {statusBreakdown.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Multi-Model Raters</div>
          <div class="table-wrap">
          <table cellpadding="0" cellspacing="0" width="100%">
            <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td style="padding: 4px 8px;">Model</td>
              <td style="padding: 4px 8px; text-align: center;">Avg Score</td>
              <td style="padding: 4px 8px; text-align: center;">Conf</td>
              <td style="padding: 4px 8px; text-align: center;">Done</td>
              <td style="padding: 4px 8px; text-align: center;">Queued</td>
              <td style="padding: 4px 8px; text-align: center;">Failed</td>
              <td style="padding: 4px 8px; text-align: center;">Coverage</td>
            </tr>
            {statusBreakdown.map(rs => {
              const summary = raterSummary.find(s => s.model === rs.model);
              const coveragePct = rs.total_primary > 0 ? Math.round((rs.done / rs.total_primary) * 100) : 0;
              const coverageColor = coveragePct >= 95 ? '#34d399' : coveragePct >= 50 ? '#eab308' : '#dc2626';
              const inFlight = rs.queued + rs.pending + rs.evaluating;
              return (
                <tr style="border-top: 1px solid #0d4655;">
                  <td style="padding: 6px 8px; color: #98a8a8; font-size: var(--font-sm); font-weight: bold;">
                    {modelDisplayName(rs.model)}
                    {isLiteMode(getModelDef(rs.model)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 4px; font-weight: normal;" title="Lite evaluation — editorial only">lite</span>}
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style={`color: ${summary?.avg_score != null ? scoreToColor(summary.avg_score) : '#5b7279'}; font-weight: bold;`}>
                      {summary?.avg_score != null ? summary.avg_score.toFixed(3) : '---'}
                    </span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style={`color: ${summary?.avg_confidence != null ? confidenceToColor(summary.avg_confidence) : '#5b7279'};`}>
                      {summary?.avg_confidence != null ? summary.avg_confidence.toFixed(2) : '---'}
                    </span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <span class="score-font" style="color: #34d399;">{rs.done}</span>
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    {inFlight > 0
                      ? <span class="score-font" style="color: #eab308;">{inFlight}</span>
                      : <span style="color: #5b7279;">0</span>
                    }
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    {rs.failed > 0
                      ? <span class="score-font" style="color: #dc2626;">{rs.failed}</span>
                      : <span style="color: #5b7279;">0</span>
                    }
                  </td>
                  <td style="padding: 6px 8px; text-align: center;">
                    <div style="display: inline-flex; align-items: center; gap: 4px;">
                      <div style="width: 50px; height: 6px; background: #0d4655; border-radius: 3px; overflow: hidden;">
                        <div style={`width: ${coveragePct}%; height: 100%; background: ${coverageColor}; border-radius: 3px;`}></div>
                      </div>
                      <span class="score-font" style={`color: ${coverageColor}; font-size: var(--font-xs);`}>{coveragePct}%</span>
                    </div>
                  </td>
                </tr>
              );
            })}
          </table>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* ═══ Evaluator Trust Index — always visible ═══ */}
  {trustHistory.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Evaluator Trust Index
            <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">14-day composite trust score per model</span>
          </div>
          <div class="table-wrap">
          <table cellpadding="0" cellspacing="0" width="100%" style="min-width: 500px;">
            <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td style="padding: 3px 8px;">Model</td>
              <td style="padding: 3px 8px; text-align: center;">Latest</td>
              <td style="padding: 3px 8px; text-align: center;">Cal Acc</td>
              <td style="padding: 3px 8px; text-align: center;">Consensus</td>
              <td style="padding: 3px 8px; text-align: center;">Parse%</td>
              <td style="padding: 3px 8px; text-align: center;">Evals/7d</td>
              <td style="padding: 3px 8px;">14d Trend</td>
            </tr>
            {[...trustByModel.entries()].map(([modelId, snaps]) => {
              const latest = snaps[snaps.length - 1];
              const trust = latest?.trust_score ?? null;
              const trustColor = trust === null ? '#5b7279' : trust >= 0.7 ? '#34d399' : trust >= 0.5 ? '#eab308' : '#dc2626';
              const sparkW = 80, sparkH = 20;
              const sparkVals = snaps.map(s => s.trust_score ?? null);
              const validVals = sparkVals.filter((v): v is number => v !== null);
              const sparkMin = validVals.length > 0 ? Math.min(...validVals) : 0;
              const sparkMax = Math.max(validVals.length > 0 ? Math.max(...validVals) : 1, sparkMin + 0.01);
              const sparkPoints = sparkVals.map((v, i) => {
                const x = sparkW * (i / Math.max(sparkVals.length - 1, 1));
                const y = v !== null ? sparkH - ((v - sparkMin) / (sparkMax - sparkMin)) * sparkH : null;
                return { x, y, v };
              }).filter((p): p is { x: number; y: number; v: number } => p.y !== null);
              const polyPoints = sparkPoints.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
              return (
                <tr style="border-top: 1px solid #0d4655;">
                  <td style="padding: 5px 8px; color: #98a8a8; font-size: var(--font-sm);">
                    {modelDisplayName(modelId)}
                    {isLiteMode(getModelDef(modelId)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 4px;">lite</span>}
                  </td>
                  <td style={`padding: 5px 8px; text-align: center; font-weight: bold; color: ${trustColor};`}>
                    {trust !== null ? trust.toFixed(2) : '—'}
                  </td>
                  <td style="padding: 5px 8px; text-align: center; color: #8faaab; font-size: var(--font-sm);">
                    {latest?.calibration_accuracy !== null && latest?.calibration_accuracy !== undefined ? (latest.calibration_accuracy * 100).toFixed(0) + '%' : '—'}
                  </td>
                  <td style="padding: 5px 8px; text-align: center; color: #8faaab; font-size: var(--font-sm);">
                    {latest?.consensus_agreement !== null && latest?.consensus_agreement !== undefined ? (latest.consensus_agreement * 100).toFixed(0) + '%' : '—'}
                  </td>
                  <td style="padding: 5px 8px; text-align: center; color: #8faaab; font-size: var(--font-sm);">
                    {latest?.parse_success_rate !== null && latest?.parse_success_rate !== undefined ? (latest.parse_success_rate * 100).toFixed(0) + '%' : '—'}
                  </td>
                  <td style="padding: 5px 8px; text-align: center; color: #5b7279; font-size: var(--font-sm);">
                    {latest?.eval_count ?? 0}
                  </td>
                  <td style="padding: 5px 8px;">
                    {sparkPoints.length >= 2 ? (
                      <svg width={sparkW} height={sparkH} viewBox={`0 0 ${sparkW} ${sparkH}`} style="display: block;">
                        <polyline points={polyPoints} fill="none" stroke={trustColor} stroke-width="1.5" stroke-linejoin="round" />
                        {sparkPoints.length > 0 && (
                          <circle cx={sparkPoints[sparkPoints.length - 1].x} cy={sparkPoints[sparkPoints.length - 1].y} r="2" fill={trustColor} />
                        )}
                      </svg>
                    ) : (
                      <span style="color: #1a5568; font-size: var(--font-xs);">no history</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </table>
          </div>
          <div style="color: #1a5568; font-size: var(--font-xs); margin-top: 6px;">
            Trust = calibration accuracy (40%) + consensus agreement (35%) + parse success (25%) · updated hourly · &lt;0.3 for 7+ days triggers review alert
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* ═══ Calibration (absorbed from /system) — details open ═══ */}
  <details open class="collapsible-section">
    <summary>Calibration</summary>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      {/* Full calibration */}
      <div style={`flex: 1; min-width: 200px; padding: 6px 8px; background: #0d4655; border: 1px solid ${lastCalibration?.status === 'fail' ? '#dc262640' : '#0d4655'}; border-radius: 4px;`}>
        <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Full Model</div>
        {!lastCalibration ? (
          <div style="font-size: var(--font-xs);">
            <div style="color: #eab308;">No runs yet</div>
            <div style="color: #1a5568; font-size: 9px;">{CALIBRATION_SET.length} URLs defined</div>
          </div>
        ) : (
          <div style="font-size: var(--font-xs);">
            <span style={`color: ${lastCalibration.status === 'pass' ? '#16a34a' : lastCalibration.status === 'fail' ? '#dc2626' : '#eab308'}; font-weight: bold; text-transform: uppercase;`}>{lastCalibration.status}</span>
            <span style="color: #5b7279;"> · {lastCalibration.passed}/{lastCalibration.total_urls} passed</span>
            {lastCalibration.failed > 0 && <span style="color: #dc2626;"> · {lastCalibration.failed} failed</span>}
            <div style="color: #1a5568; font-size: 9px; margin-top: 2px;">
              {lastCalibration.model.replace('claude-', '').replace('-20251001', '')} · {lastCalibration.created_at.slice(0, 10)}
            </div>
          </div>
        )}
      </div>

      {/* Lite calibration */}
      <div style={`flex: 1; min-width: 200px; padding: 6px 8px; background: #0d4655; border: 1px solid ${lastLiteCalibration?.status === 'fail' ? '#dc262640' : '#0d4655'}; border-radius: 4px;`}>
        <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Lite Model</div>
        {!lastLiteCalibration ? (
          <div style="font-size: var(--font-xs);">
            <div style="color: #eab308;">No runs yet</div>
            <div style="color: #1a5568; font-size: 9px;">{LITE_CALIBRATION_SET.length} URLs defined</div>
          </div>
        ) : (
          <div style="font-size: var(--font-xs);">
            <span style={`color: ${lastLiteCalibration.status === 'pass' ? '#16a34a' : lastLiteCalibration.status === 'fail' ? '#dc2626' : '#eab308'}; font-weight: bold; text-transform: uppercase;`}>{lastLiteCalibration.status}</span>
            <span style="color: #5b7279;"> · {lastLiteCalibration.passed}/{lastLiteCalibration.total_urls} passed</span>
            {lastLiteCalibration.failed > 0 && <span style="color: #dc2626;"> · {lastLiteCalibration.failed} failed</span>}
            <div style="color: #1a5568; font-size: 9px; margin-top: 2px;">
              {lastLiteCalibration.model ?? 'lite-1.4'} · {lastLiteCalibration.created_at.slice(0, 10)}
            </div>
          </div>
        )}
      </div>

      {/* Content Gates */}
      <div style={`flex: 1; min-width: 200px; padding: 6px 8px; background: #0d4655; border: 1px solid ${globalGate.gate_pct > 20 ? '#eab30840' : '#0d4655'}; border-radius: 4px;`}>
        <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Content Gates</div>
        <div style="font-size: var(--font-xs);">
          <span style={`color: ${globalGate.gate_pct > 20 ? '#eab308' : '#5b7279'}; font-weight: bold;`}>{globalGate.gate_pct}%</span>
          <span style="color: #5b7279;"> gated ({globalGate.gated}/{globalGate.total})</span>
        </div>
        {globalGate.breakdown.length > 0 && (
          <div style="margin-top: 3px; font-size: 9px;">
            {globalGate.breakdown.slice(0, 4).map(b => (
              <div style="color: #5b7279;">
                <span style={`color: ${b.gate_category === 'paywall' ? '#d56500' : b.gate_category === 'bot_protection' ? '#dc2626' : b.gate_category === 'error_page' ? '#5b7279' : '#eab308'};`}>
                  {b.gate_category.replace(/_/g, ' ')}
                </span>
                <span style="color: #1a5568;"> · {b.cnt}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </details>

  {/* ═══ Signal Completeness (absorbed from /system) — details open ═══ */}
  {signalCompleteness.length > 0 && (
    <details open class="collapsible-section">
      <summary>
        Signal Completeness
        {signalCompleteness.some(r => r.any_below_80) && (
          <span style="text-transform: none; letter-spacing: 0; color: #eab308; margin-left: 6px;">gaps detected</span>
        )}
      </summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: #1a5568; font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Epistemic quality">EQ</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Solution orientation">SO</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Temporal dimension">TD</td>
          <td style="padding: 2px 6px; text-align: right; width: 40px;" title="Propaganda flags">PT</td>
          <td style="padding: 2px 6px; text-align: right; width: 50px;" title="Primary tone">Tone</td>
        </tr>
        {signalCompleteness.map(row => {
          const pct = (v: number | null) => v == null ? '—' : `${Math.round(v)}%`;
          const col = (v: number | null) => v == null ? '#1a5568' : v < 80 ? '#dc2626' : v < 95 ? '#eab308' : '#5b7279';
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 3px 6px; color: #98a8a8;">{row.eval_model}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.eq_pct)};`}>{pct(row.eq_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.so_pct)};`}>{pct(row.so_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.td_pct)};`}>{pct(row.td_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.pt_pct)};`}>{pct(row.pt_pct)}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${col(row.tone_pct)};`}>{pct(row.tone_pct)}</td>
            </tr>
          );
        })}
      </table>
      </div>
    </details>
  )}

  {/* ═══ Model Drift + Content Type Validation (absorbed from /system) — collapsed ═══ */}
  <details class="collapsible-section">
    <summary>Measurement Integrity</summary>
    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px;">
      {/* Model Drift */}
      <div style="flex: 1; min-width: 200px; padding: 6px 8px; background: #0d4655; border: 1px solid #0d4655; border-radius: 4px;">
        <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Model Drift</div>
        {driftStats.models.length === 0 ? (
          <div style="color: #5b7279; font-size: var(--font-xs);">No data</div>
        ) : (
          <div style="font-size: var(--font-xs);">
            {driftStats.models.map((m) => (
              <div style="color: #5b7279;">
                <span style="color: #60a5fa;">{m.eval_model}</span>
                <span style="color: #5b7279;"> · {m.count} evals · avg </span>
                <span style={`color: ${m.avg_score > 0.05 ? '#16a34a' : m.avg_score < -0.05 ? '#dc2626' : '#5b7279'};`}>{m.avg_score?.toFixed(3)}</span>
                <span style="color: #1a5568;"> ±{m.stddev?.toFixed(3)}</span>
              </div>
            ))}
            {driftStats.overlapping > 0 && (
              <div style="margin-top: 2px; color: #5b7279; font-size: 9px;">
                {driftStats.overlapping} overlapping
                {driftStats.meanDelta !== null && (
                  <span> · mean |Δ| = <span style={`color: ${driftStats.meanDelta > 0.1 ? '#eab308' : '#5b7279'};`}>{driftStats.meanDelta.toFixed(3)}</span></span>
                )}
              </div>
            )}
          </div>
        )}
      </div>

      {/* Content Type Validation */}
      <div style={`flex: 1; min-width: 200px; padding: 6px 8px; background: #0d4655; border: 1px solid ${ctMisclass.misclassification_pct > 15 ? '#dc262640' : ctMisclass.misclassification_pct > 5 ? '#eab30840' : '#0d4655'}; border-radius: 4px;`}>
        <div style="color: #5b7279; font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">Content Type Validation</div>
        <div style="font-size: var(--font-xs);">
          <span style={`color: ${ctMisclass.misclassification_pct > 15 ? '#dc2626' : ctMisclass.misclassification_pct > 5 ? '#eab308' : '#16a34a'}; font-weight: bold;`}>{ctMisclass.misclassification_pct}%</span>
          <span style="color: #5b7279;"> suspect rate</span>
        </div>
        <div style="font-size: 9px; margin-top: 2px; color: #5b7279;">
          {ctMisclass.structural_heavy_missing}/{ctMisclass.structural_heavy_total} structural-heavy missing S data
        </div>
        {ctMisclass.disagreement_count > 0 && (
          <div style="font-size: 9px; margin-top: 1px;">
            <span style="color: #eab308;">{ctMisclass.disagreement_count}</span>
            <span style="color: #5b7279;"> stories with model disagreement</span>
          </div>
        )}
      </div>
    </div>

    {/* Content Type Breakdown (nested collapse) */}
    {ctValidation.length > 0 && (
      <details style="margin-bottom: 8px;">
        <summary style="color: #5b7279; font-size: 9px; text-transform: uppercase; cursor: pointer; margin-bottom: 4px;">Content Type Breakdown</summary>
        <div class="table-wrap">
        <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tr style="color: #5b7279; border-bottom: 1px solid #1a5568;">
            <td style="padding: 3px 6px;">Type</td>
            <td style="padding: 3px 6px; text-align: right;">Count</td>
            <td style="padding: 3px 6px; text-align: right;">Avg Score</td>
            <td style="padding: 3px 6px; text-align: center;">Weights</td>
            <td style="padding: 3px 6px; text-align: right;">Suspect</td>
          </tr>
          {ctValidation.map(row => {
            const isHeavy = STRUCTURAL_HEAVY.has(row.content_type);
            const w = CT_WEIGHTS[row.content_type];
            const suspect = row.missing_structural + row.low_evidence_only;
            const suspectPct = row.total > 0 ? Math.round((suspect / row.total) * 100) : 0;
            const suspectColor = suspectPct > 15 ? '#dc2626' : suspectPct > 5 ? '#eab308' : '#5b7279';
            return (
              <tr style="border-bottom: 1px solid #093946;">
                <td style={`padding: 3px 6px; color: ${isHeavy ? '#d56500' : '#98a8a8'}; font-weight: ${isHeavy ? 'bold' : 'normal'};`}>
                  {row.content_type}{isHeavy && <span style="color: #5b7279; font-weight: normal;" title="Structural-heavy type"> S</span>}
                </td>
                <td style="padding: 3px 6px; text-align: right; color: #98a8a8;">{row.total}</td>
                <td style={`padding: 3px 6px; text-align: right; color: ${row.avg_score != null ? scoreToColor(row.avg_score) : '#5b7279'};`}>
                  {row.avg_score != null ? row.avg_score.toFixed(3) : '—'}
                </td>
                <td style="padding: 3px 6px; text-align: center; color: #5b7279; font-family: monospace;">
                  {w ? `E:${w.e} S:${w.s}` : '—'}
                </td>
                <td style={`padding: 3px 6px; text-align: right; color: ${suspectColor};`}>
                  {suspect > 0 ? `${suspect} (${suspectPct}%)` : '—'}
                </td>
              </tr>
            );
          })}
        </table>
        </div>
      </details>
    )}

    {/* Cross-Model Type Disagreement (nested collapse) */}
    {ctDisagreement.length > 0 && (
      <details style="margin-bottom: 8px;">
        <summary style="color: #5b7279; font-size: 9px; text-transform: uppercase; cursor: pointer; margin-bottom: 4px;">
          Cross-Model Disagreement ({ctDisagreement.length})
        </summary>
        <div style="font-size: var(--font-xs);">
          {ctDisagreement.slice(0, 10).map(row => (
            <div style="padding: 2px 0; border-bottom: 1px solid #093946;">
              <a href={`/item/${row.hn_id}`} style="color: #2b90d8;">{row.hn_id}</a>
              <span style="color: #5b7279;"> · </span>
              <span style="color: #eab308;">{row.types_seen}</span>
              <span style="color: #5b7279;"> · {row.models}</span>
            </div>
          ))}
        </div>
      </details>
    )}
  </details>

  {/* ═══ Score Distribution — details open ═══ */}
  {totalStories > 0 && (
    <details open class="collapsible-section">
      <summary>Score Distribution</summary>
      <div style="display: flex; gap: 24px; flex-wrap: wrap;">
        {modelIds.map(mid => {
          const counts = histogramByModel.get(mid) || [];
          return (
            <div style="flex: 1; min-width: 200px;">
              <div style="color: #8faaab; font-size: var(--font-sm); font-weight: bold; margin-bottom: 6px;">
                {modelDisplayName(mid)}
                {isLiteMode(getModelDef(mid)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 4px; font-weight: normal;">lite</span>}
              </div>
              <div style="display: flex; align-items: flex-end; gap: 2px; height: 60px;">
                {counts.map((count, i) => {
                  const binStart = BIN_MIN + i * BIN_WIDTH;
                  const binMid = binStart + BIN_WIDTH / 2;
                  const heightPct = (count / histMaxCount) * 100;
                  return (
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end;" title={`${binStart.toFixed(1)} to ${(binStart + BIN_WIDTH).toFixed(1)}: ${count} stories`}>
                      <div style={`width: 100%; height: ${Math.max(heightPct, count > 0 ? 3 : 0)}%; background: ${scoreToColor(binMid)}; border-radius: 2px 2px 0 0; min-height: ${count > 0 ? '2px' : '0'};`}></div>
                    </div>
                  );
                })}
              </div>
              <div style="display: flex; justify-content: space-between; margin-top: 2px;">
                <span style="color: #5b7279; font-size: 8px;">-0.5</span>
                <span style="color: #5b7279; font-size: 8px;">0</span>
                <span style="color: #5b7279; font-size: 8px;">+0.5</span>
              </div>
            </div>
          );
        })}
      </div>
    </details>
  )}

  {/* ═══ Multi-Model Comparison (summary + profiles) — details open ═══ */}
  {totalStories > 0 && (
    <details open class="collapsible-section">
      <summary>
        Multi-Model Comparison
        <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
          {totalStories} shared stories
        </span>
      </summary>

      {/* Summary stats */}
      <div style="display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 10px; padding: 10px; background: #0d4655; border-radius: 4px;">
        <div>
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Sign Agreement</div>
          <span class="score-font" style={`color: ${agreePct >= 80 ? '#34d399' : agreePct >= 60 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
            {agreePct}%
          </span>
          <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 4px;">{agreeCount}/{totalStories}</span>
        </div>
        <div>
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Class Agreement</div>
          <span class="score-font" style={`color: ${classAgreePct >= 60 ? '#34d399' : classAgreePct >= 40 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
            {classAgreePct}%
          </span>
          <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 4px;">{classAgreeCount}/{totalStories}</span>
        </div>
        <div>
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Median Delta</div>
          <span class="score-font" style={`color: ${medianDelta < 0.1 ? '#34d399' : medianDelta < 0.2 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
            {medianDelta.toFixed(3)}
          </span>
        </div>
        <div>
          <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Mean Delta</div>
          <span class="score-font" style={`color: ${avgDelta < 0.1 ? '#34d399' : avgDelta < 0.2 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
            {avgDelta.toFixed(3)}
          </span>
        </div>
        {pairCorrelations.map(pc => (
          <div>
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Pearson r</div>
            <span class="score-font" style={`color: ${pc.r !== null && pc.r >= 0.7 ? '#34d399' : pc.r !== null && pc.r >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
              {pc.r !== null ? pc.r.toFixed(3) : '---'}
            </span>
            <span style="color: #5b7279; font-size: var(--font-xs); margin-left: 4px;">n={pc.n}</span>
          </div>
        ))}
      </div>

      {/* Model Profiles table */}
      <div class="table-wrap">
      <table cellpadding="0" cellspacing="0" width="100%" style="min-width: 600px;">
        <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 4px 8px;">Model</td>
          <td style="padding: 4px 8px; text-align: center;">Shared</td>
          <td style="padding: 4px 8px; text-align: center;">Avg HRCB</td>
          <td style="padding: 4px 8px; text-align: center;">|HRCB|</td>
          <td style="padding: 4px 8px; text-align: center;">+</td>
          <td style="padding: 4px 8px; text-align: center;">0</td>
          <td style="padding: 4px 8px; text-align: center;">-</td>
          <td style="padding: 4px 8px; text-align: center;">Rates Higher</td>
          <td style="padding: 4px 8px; text-align: center;">Rates Lower</td>
        </tr>
        {aggregates.filter(a => modelIds.includes(a.model)).map(a => {
          const bias = biasAnalysis.find(b => b.model === a.model);
          return (
            <tr style="border-top: 1px solid #0d4655;">
              <td style="padding: 6px 8px; color: #98a8a8; font-weight: bold; font-size: var(--font-sm);">
                {modelDisplayName(a.model)}
                {isLiteMode(getModelDef(a.model)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 4px; font-weight: normal;" title="Lite evaluation — editorial only">lite</span>}
              </td>
              <td style="padding: 6px 8px; text-align: center; color: #5b7279;">{a.story_count}</td>
              <td style={`padding: 6px 8px; text-align: center; font-weight: bold; color: ${scoreToColor(a.avg_score)};`}>
                {formatScore(a.avg_score)}
                {isLiteMode(getModelDef(a.model)?.prompt_mode ?? null) && <span style="color: #5b7279; font-size: var(--font-xs); font-weight: normal; margin-left: 3px;" title="Editorial channel only — not comparable to full model weighted mean">E</span>}
              </td>
              <td style="padding: 6px 8px; text-align: center; color: #8faaab;">{a.avg_abs_score.toFixed(3)}</td>
              <td style="padding: 6px 8px; text-align: center; color: #34d399;">{a.positive_pct}%</td>
              <td style="padding: 6px 8px; text-align: center; color: #5b7279;">{a.neutral_pct}%</td>
              <td style="padding: 6px 8px; text-align: center; color: #dc2626;">{a.negative_pct}%</td>
              <td style="padding: 6px 8px; text-align: center;">
                {bias && <span style={`color: ${bias.higherPct > 55 ? '#34d399' : '#5b7279'}; font-size: var(--font-sm);`}>{bias.higherPct}%</span>}
              </td>
              <td style="padding: 6px 8px; text-align: center;">
                {bias && <span style={`color: ${bias.lowerPct > 55 ? '#dc2626' : '#5b7279'}; font-size: var(--font-sm);`}>{bias.lowerPct}%</span>}
              </td>
            </tr>
          );
        })}
      </table>
      </div>
      <div style="color: #1a5568; font-size: var(--font-xs); margin-top: 8px;">
        Avg HRCB: full models = editorial+structural weighted mean · lite models = editorial only (E) — not directly comparable
      </div>
    </details>
  )}

  {/* ═══ Section Divergences — collapsed ═══ */}
  {totalStories > 0 && (
    <details class="collapsible-section">
      <summary>Section Divergences</summary>
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 3px 6px;">Section</td>
          <td style="padding: 3px 6px; color: #5b7279; font-weight: normal; text-transform: none;">Topic</td>
          {modelIds.map(m => (
            <td style="padding: 3px 6px; text-align: center;">
              {modelDisplayName(m)}
              {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: 6pt; margin-left: 2px;">lite</span>}
            </td>
          ))}
          <td style="padding: 3px 6px; text-align: center;">Gap</td>
        </tr>
        {topDivergent.map(d => (
          <tr style="border-top: 1px solid #0d4655;">
            <td style="padding: 4px 6px; font-size: var(--font-xs);">
              <a href={`/article/${d.idx}`} style="color: #8faaab; text-decoration: none;">{d.section}</a>
            </td>
            <td style="padding: 4px 6px; color: #5b7279; font-size: var(--font-xs); max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title={d.title}>
              {d.title.length > 30 ? d.title.slice(0, 30) + '...' : d.title}
            </td>
            {d.vals.map(v => (
              <td style={`padding: 4px 6px; text-align: center; color: ${v !== null ? scoreToColor(v) : '#5b7279'}; font-size: var(--font-sm); font-weight: bold;`}>
                {v !== null ? formatScore(v) : '---'}
              </td>
            ))}
            <td style={`padding: 4px 6px; text-align: center; color: ${d.delta >= 0.1 ? '#dc2626' : d.delta >= 0.05 ? '#eab308' : '#5b7279'}; font-size: var(--font-sm); font-weight: bold;`}>
              {d.delta.toFixed(3)}
            </td>
          </tr>
        ))}
      </table>
    </details>
  )}

  {/* ═══ Most Disagreed / Most Agreed — collapsed ═══ */}
  {totalStories > 0 && (
    <details class="collapsible-section">
      <summary>Most Disagreed / Most Agreed</summary>
      <div class="two-col" style="margin-bottom: 10px;">
        <div>
          <div style="padding: 10px; background: #0d4655; border-radius: 4px; height: 100%;">
            <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Disagreed</div>
            <table cellpadding="0" cellspacing="0" width="100%">
              <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">
                <td style="padding: 3px 6px;">Story</td>
                {modelIds.map(m => (
                  <td style="padding: 3px 6px; text-align: center;">
                    {modelDisplayName(m)}
                    {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: 6pt; margin-left: 2px;">lite</span>}
                  </td>
                ))}
                <td style="padding: 3px 6px; text-align: center;">&Delta;</td>
              </tr>
              {mostDisagreed.map(s => (
                <tr style="border-top: 1px solid #093946;">
                  <td style="padding: 3px 6px; font-size: var(--font-xs);">
                    <a href={`/item/${s.hn_id}`} style="color: #98a8a8; text-decoration: none;" title={s.title}>
                      {s.title.length > 40 ? s.title.slice(0, 40) + '...' : s.title}
                    </a>
                  </td>
                  {modelIds.map(mid => {
                    const me = s.models.find(m => m.model === mid);
                    return (
                      <td style={`padding: 3px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#5b7279'}; font-size: var(--font-sm); font-weight: bold;`}>
                        {me ? formatScore(me.score) : '---'}
                      </td>
                    );
                  })}
                  <td style={`padding: 3px 6px; text-align: center; color: ${s.maxDelta >= 0.3 ? '#dc2626' : s.maxDelta >= 0.15 ? '#eab308' : '#5b7279'}; font-size: var(--font-sm); font-weight: bold;`}>
                    {s.maxDelta.toFixed(2)}
                  </td>
                </tr>
              ))}
            </table>
          </div>
        </div>
        <div>
          <div style="padding: 10px; background: #0d4655; border-radius: 4px; height: 100%;">
            <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Agreed</div>
            <table cellpadding="0" cellspacing="0" width="100%">
              <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase;">
                <td style="padding: 3px 6px;">Story</td>
                {modelIds.map(m => (
                  <td style="padding: 3px 6px; text-align: center;">
                    {modelDisplayName(m)}
                    {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: 6pt; margin-left: 2px;">lite</span>}
                  </td>
                ))}
                <td style="padding: 3px 6px; text-align: center;">&Delta;</td>
              </tr>
              {mostAgreed.map(s => (
                <tr style="border-top: 1px solid #093946;">
                  <td style="padding: 3px 6px; font-size: var(--font-xs);">
                    <a href={`/item/${s.hn_id}`} style="color: #98a8a8; text-decoration: none;" title={s.title}>
                      {s.title.length > 40 ? s.title.slice(0, 40) + '...' : s.title}
                    </a>
                  </td>
                  {modelIds.map(mid => {
                    const me = s.models.find(m => m.model === mid);
                    return (
                      <td style={`padding: 3px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#5b7279'}; font-size: var(--font-sm); font-weight: bold;`}>
                        {me ? formatScore(me.score) : '---'}
                      </td>
                    );
                  })}
                  <td style="padding: 3px 6px; text-align: center; color: #34d399; font-size: var(--font-sm);">
                    {s.maxDelta.toFixed(2)}
                  </td>
                </tr>
              ))}
            </table>
          </div>
        </div>
      </div>
    </details>
  )}

  {/* ═══ Per-Section Averages — collapsed ═══ */}
  {totalStories > 0 && (
    <details class="collapsible-section">
      <summary>Per-Section Averages</summary>
      <div class="table-wrap">
      <div style="max-height: 500px; overflow-y: auto;">
        <table cellpadding="0" cellspacing="0" width="100%" style="min-width: 400px;">
          <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; position: sticky; top: 0; background: #093946;">
            <td style="padding: 3px 6px;">Section</td>
            {modelIds.map(m => (
              <td style="padding: 3px 6px; text-align: center;">
                {modelDisplayName(m)}
                {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: 6pt; margin-left: 2px;">lite</span>}
              </td>
            ))}
            {modelIds.length >= 2 && <td style="padding: 3px 6px; text-align: center;">Gap</td>}
          </tr>
          {ALL_SECTIONS.map((section, idx) => {
            const vals = modelIds.map(m => sectionByModelMap.get(m)?.get(section) ?? null);
            const validVals = vals.filter((v): v is number => v !== null);
            const delta = validVals.length >= 2 ? Math.max(...validVals) - Math.min(...validVals) : null;
            const deltaColor = delta !== null
              ? delta < 0.05 ? '#5b7279' : delta < 0.1 ? '#eab308' : '#dc2626'
              : '#5b7279';
            const title = idx > 0 && idx <= 30 ? ARTICLE_TITLES[idx - 1] : '';
            return (
              <tr style="border-top: 1px solid #0d4655;">
                <td style="padding: 2px 6px; color: #8faaab; font-size: var(--font-xs);" title={title}>
                  <a href={`/article/${idx}`} style="color: #8faaab; text-decoration: none;">{section}</a>
                </td>
                {vals.map(v => (
                  <td style={`padding: 2px 6px; text-align: center; color: ${v !== null ? scoreToColor(v) : '#5b7279'}; font-size: var(--font-sm);`}>
                    {v !== null ? v.toFixed(3) : '---'}
                  </td>
                ))}
                {delta !== null && (
                  <td style={`padding: 2px 6px; text-align: center; color: ${deltaColor}; font-size: var(--font-sm);`}>
                    {delta.toFixed(3)}
                  </td>
                )}
              </tr>
            );
          })}
        </table>
      </div>
      </div>
    </details>
  )}

  {/* ═══ All Compared Stories — collapsed ═══ */}
  {totalStories > 0 && (
    <details class="collapsible-section">
      <summary>
        All Compared Stories
        <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">{totalStories}</span>
      </summary>
      <div class="table-wrap">
      <div style="max-height: 600px; overflow-y: auto;">
        <table cellpadding="0" cellspacing="0" width="100%" style="min-width: 500px;">
          <tr style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; position: sticky; top: 0; background: #093946;">
            <td style="padding: 3px 6px;">Story</td>
            <td style="padding: 3px 6px;">Domain</td>
            {modelIds.map(m => (
              <td style="padding: 3px 6px; text-align: center;">
                {modelDisplayName(m)}
                {isLiteMode(getModelDef(m)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: 6pt; margin-left: 2px;">lite</span>}
              </td>
            ))}
            <td style="padding: 3px 6px; text-align: center;">&Delta;</td>
          </tr>
          {storyStats.map(s => (
            <tr style={`border-top: 1px solid #0d4655;${!s.allAgree ? ' background: rgba(220, 38, 38, 0.04);' : ''}`}>
              <td style="padding: 2px 6px; font-size: var(--font-xs);">
                <a href={`/item/${s.hn_id}`} style="color: #8faaab; text-decoration: none;" title={s.title}>
                  {s.title.length > 50 ? s.title.slice(0, 50) + '...' : s.title}
                </a>
              </td>
              <td style="padding: 2px 6px; font-size: var(--font-xs); color: #5b7279;">
                {s.domain ? (
                  <a href={`/domain/${s.domain}`} style="color: #5b7279; text-decoration: none;">{s.domain.length > 20 ? s.domain.slice(0, 20) + '...' : s.domain}</a>
                ) : '---'}
              </td>
              {modelIds.map(mid => {
                const me = s.models.find(m => m.model === mid);
                return (
                  <td style={`padding: 2px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#5b7279'}; font-size: var(--font-sm);`}>
                    {me ? formatScore(me.score) : '---'}
                  </td>
                );
              })}
              <td style={`padding: 2px 6px; text-align: center; color: ${s.maxDelta >= 0.3 ? '#dc2626' : s.maxDelta >= 0.15 ? '#eab308' : '#5b7279'}; font-size: var(--font-sm);`}>
                {s.maxDelta.toFixed(2)}
              </td>
            </tr>
          ))}
        </table>
      </div>
      </div>
    </details>
  )}

  {/* Excluded models note */}
  {excludedModels.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 8px 10px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
          <div style="color: #5b7279; font-size: var(--font-xs);">
            <span style="color: #5b7279; text-transform: uppercase; letter-spacing: 0.05em;">Excluded models</span> (fewer than {MIN_STORIES} shared stories):
            {excludedModels.map((m, i) => (
              <span>
                {i > 0 ? ', ' : ' '}
                <span style="color: #5b7279;">{modelDisplayName(m.model)}</span>
                {isLiteMode(getModelDef(m.model)?.prompt_mode ?? null) && <span style="color: #d56500; font-size: var(--font-xs); margin-left: 2px;">lite</span>}
                <span style="color: #1a5568;"> ({m.story_count})</span>
              </span>
            ))}
          </div>
        </td>
      </tr>
    </table>
  )}
</Base>
