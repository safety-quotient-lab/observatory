---
// SPDX-License-Identifier: Apache-2.0
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SubNav from '../../components/SubNav.astro';
import { scoreToColor, formatScore } from '../../lib/colors';
import { modelDisplayName } from '../../lib/shared-eval';
import {
  getFailedStories,
  getQueueStories,
  getEventStats,
  getRecentEvents,
  getDailyErrorCounts,
  getEvalsPerCycle,
  getLatestRateLimitSnapshot,
  getDlqStats,
  getDlqMessages,
  getDlqTrend,
  getSelfThrottleImpact,
  getEvalLatencyStats,
} from '../../lib/db';
import { cachedQuery, readDb } from '../../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

const emptyEventStats = { total: 0, by_type: {}, by_severity: {}, last_24h: 0, last_7d: 0, error_count_7d: 0 };

const [
  failed, queue, eventStats, recentPipelineEvents,
  dailyErrors, cycleStats,
  rateLimitSnapshot, dlqStats, dlqMessages,
  dlqTrend, throttleImpact, latencyStats,
] = await Promise.all([
  getFailedStories(db, 5),
  getQueueStories(db),
  cachedQuery(kv, 'sys:eventStats', () => getEventStats(db, 7), 60).catch(() => emptyEventStats),
  getRecentEvents(db, 15).catch(() => [] as Awaited<ReturnType<typeof getRecentEvents>>),
  cachedQuery(kv, 'sys:dailyErrors', () => getDailyErrorCounts(db, 7), 300).catch(() => [] as Awaited<ReturnType<typeof getDailyErrorCounts>>),
  cachedQuery(kv, 'sys:evalsPerCycle', () => getEvalsPerCycle(db, 10), 120).catch(() => [] as Awaited<ReturnType<typeof getEvalsPerCycle>>),
  getLatestRateLimitSnapshot(db),
  getDlqStats(db),
  getDlqMessages(db, 'pending', 10),
  cachedQuery(kv, 'sys:dlqTrend', () => getDlqTrend(db), 300).catch(() => null as Awaited<ReturnType<typeof getDlqTrend>> | null),
  cachedQuery(kv, 'sys:throttle', () => getSelfThrottleImpact(db), 300).catch(() => [] as Awaited<ReturnType<typeof getSelfThrottleImpact>>),
  getEvalLatencyStats(db).catch(() => [] as Awaited<ReturnType<typeof getEvalLatencyStats>>),
]);

// Event type color map
const EVENT_TYPE_COLORS: Record<string, string> = {
  eval_failure: 'var(--color-negative)', eval_retry: 'var(--color-orange)', eval_skip: 'var(--color-muted)',
  eval_success: 'var(--color-positive)', rate_limit: 'var(--color-warning)', self_throttle: 'var(--color-violet)',
  credit_exhausted: 'var(--color-negative)', fetch_error: 'var(--color-negative)',
  parse_error: 'var(--color-negative)', cron_run: 'var(--channel-editorial)', cron_error: 'var(--color-orange)',
  crawl_error: 'var(--color-orange)', r2_error: 'var(--color-orange)', dlq: 'var(--color-negative)', dlq_replay: 'var(--color-positive-medium)',
  calibration: 'var(--color-purple)', trigger: 'var(--channel-structural)',
  rater_validation_warn: 'var(--color-orange)', rater_validation_fail: 'var(--color-negative)',
  rater_auto_disable: 'var(--color-negative)', rater_auto_enable: 'var(--color-positive-medium)',
  setl_spike: 'var(--color-amber)', coverage_crawl: 'var(--color-cyan)',
  auto_calibration: 'var(--color-purple)', auto_retry: '#6366f1',
  dlq_auto_replay: 'var(--color-inference)', dcp_stale: 'var(--color-orange)',
  r2_cleanup: '#64748b', story_flagged: 'var(--color-negative)',
  model_divergence: 'var(--color-pink)',
};
---

<Base title="System Events">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'status', href: '/status' }, { label: 'events' }]} />
  <SubNav items={[{ label: 'Models', href: '/status/models' }, { label: 'Events', href: '/status/events' }]} current="/status/events" />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Events</span>
        <span style="color: var(--fg-secondary); margin-left: var(--space-lg);">Pipeline activity log, diagnostics, and operational metrics.</span>
      </td>
    </tr>
  </table>

  {/* Pipeline Events — always visible */}
  {(eventStats.total > 0 || recentPipelineEvents.length > 0) && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Pipeline Events
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
              {eventStats.last_24h} last 24h · {eventStats.last_7d} last 7d
            </span>
          </div>

          {/* Event type breakdown */}
          {Object.keys(eventStats.by_type).length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;">
              {Object.entries(eventStats.by_type).sort((a, b) => b[1] - a[1]).map(([type, count]) => {
                const color = EVENT_TYPE_COLORS[type] || 'var(--fg-secondary)';
                return (
                  <span class="badge" style={`background: ${color}20; color: ${color}; font-size: var(--font-xs);`}>
                    {type}: {count}
                  </span>
                );
              })}
            </div>
          )}

          {/* Recent events table */}
          {recentPipelineEvents.length > 0 && (
            <div>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 4px;">Recent Events</div>
              <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
                {recentPipelineEvents.map((ev) => {
                  const sevColor = ev.severity === 'error' ? 'var(--color-negative)' : ev.severity === 'warn' ? 'var(--color-warning)' : 'var(--fg-secondary)';
                  const typeColor = EVENT_TYPE_COLORS[ev.event_type] || 'var(--fg-secondary)';
                  return (
                    <tr style="border-top: 1px solid var(--bg-surface);">
                      <td style="color: var(--fg-secondary); white-space: nowrap; width: 140px;">{ev.created_at.slice(0, 16)}</td>
                      <td style="width: 90px;">
                        <span class="badge" style={`background: ${typeColor}20; color: ${typeColor}; font-size: var(--font-xs);`}>
                          {ev.event_type}
                        </span>
                      </td>
                      <td style={`color: ${sevColor};`}>
                        {ev.hn_id ? (
                          <a href={`/item/${ev.hn_id}`} style={`color: ${sevColor};`}>{ev.message}</a>
                        ) : (
                          ev.message
                        )}
                      </td>
                      <td style="width: 60px; text-align: center; white-space: nowrap;">
                        {ev.investigated === 1
                          ? <span style="color: var(--color-blue);" title="Investigated">INV</span>
                          : ev.investigated === 0
                            ? <span style="color: var(--fg-secondary);" title="Not investigated">--</span>
                            : <span style="color: var(--bg-surface);" title="Not triaged">-</span>
                        }
                        {' '}
                        {ev.resolved === 1
                          ? <span style="color: var(--color-positive-vivid);" title="Resolved">RES</span>
                          : ev.resolved === 0
                            ? <span style="color: var(--fg-secondary);" title="Not resolved">--</span>
                            : <span style="color: var(--bg-surface);" title="Not triaged">-</span>
                        }
                      </td>
                    </tr>
                  );
                })}
              </table>
            </div>
          )}
        </td>
      </tr>
    </table>
  )}

  {/* Recent Failures — always visible */}
  {failed.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Recent Failures
            <span style="text-transform: none; letter-spacing: 0; color: var(--color-negative); margin-left: 6px;">{failed.length}</span>
          </div>
          <div class="table-wrap">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            {failed.map((s) => (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="color: var(--fg-primary);">
                  {s.title}
                  {s.domain && <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td style="color: var(--color-negative); font-size: var(--font-xs); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.eval_error?.slice(0, 80) || 'Unknown error'}
                </td>
              </tr>
            ))}
          </table>
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* Evaluation Queue — always visible */}
  {queue.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Evaluation Queue
            <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
              {queue.length} stories waiting
            </span>
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: var(--fg-secondary); font-size: var(--font-xs);">
              <td width="24">#</td>
              <td width="70">Status</td>
              <td>Story</td>
              <td width="140">Domain</td>
            </tr>
            {queue.map((s, i) => (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="color: var(--fg-secondary);" class="score-font">{i + 1}</td>
                <td>
                  {s.eval_status === 'evaluating' ? (
                    <span class="badge" style="background: rgba(96,165,250,0.2); color: var(--channel-editorial); font-size: var(--font-xs);">evaluating</span>
                  ) : (
                    <span class="badge" style="background: rgba(234,179,8,0.15); color: var(--color-warning); font-size: var(--font-xs);">pending</span>
                  )}
                </td>
                <td>
                  <a href={s.url || `https://news.ycombinator.com/item?id=${s.hn_id}`}
                     target="_blank" rel="noopener" style="color: var(--fg-primary);">
                    {s.title}
                  </a>
                </td>
                <td style="color: var(--fg-secondary); font-size: var(--font-xs);">{s.domain || 'self'}</td>
              </tr>
            ))}
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* DLQ Details — details open */}
  <details open class="collapsible-section">
    <summary>
      Dead Letter Queue
      {dlqStats.pending > 0 && (
        <span style="text-transform: none; letter-spacing: 0; color: var(--color-negative); margin-left: 6px;">{dlqStats.pending} pending</span>
      )}
    </summary>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <div style={`flex: 1; min-width: 200px; padding: 6px 8px; background: var(--bg-surface); border: 1px solid ${dlqStats.pending > 0 ? 'var(--color-negative)40' : 'var(--bg-surface)'}; border-radius: 4px;`}>
        <div style="color: var(--fg-secondary); font-size: 9px; text-transform: uppercase; margin-bottom: 3px;">
          Status
          {dlqTrend?.backlog_growing && <span style="color: var(--color-negative); margin-left: 4px;" title="Backlog growing over last 7 days">↑</span>}
          {dlqTrend && !dlqTrend.backlog_growing && dlqStats.pending > 0 && <span style="color: var(--color-positive); margin-left: 4px;" title="Backlog stable or shrinking">→</span>}
        </div>
        {dlqStats.total === 0 ? (
          <div style="color: var(--fg-secondary); font-size: var(--font-xs);">Empty</div>
        ) : (
          <div style="font-size: var(--font-xs);">
            <span style={`color: ${dlqStats.pending > 0 ? 'var(--color-negative)' : 'var(--color-positive)'}; font-weight: bold;`}>{dlqStats.pending}</span>
            <span style="color: var(--fg-secondary);"> pending</span>
            {dlqStats.replayed > 0 && <span style="color: var(--fg-secondary);"> · {dlqStats.replayed} replayed</span>}
            {dlqStats.discarded > 0 && <span style="color: var(--color-border);"> · {dlqStats.discarded} discarded</span>}
          </div>
        )}
        {dlqTrend && dlqTrend.days.length > 0 && (
          <div style="margin-top: 4px; display: flex; align-items: flex-end; gap: 1px; height: 16px;" title="14-day DLQ new entries">
            {dlqTrend.days.map(d => {
              const maxNew = Math.max(...dlqTrend!.days.map(x => x.new_count), 1);
              const h = Math.max(2, Math.round((d.new_count / maxNew) * 16));
              return (
                <div style={`width: 6px; height: ${h}px; background: ${d.new_count > 0 ? 'var(--color-negative)80' : 'var(--bg-surface)'}; border-radius: 1px;`} title={`${d.day}: ${d.new_count} new`}></div>
              );
            })}
          </div>
        )}
        {dlqMessages.length > 0 && (
          <div style="margin-top: 4px; font-size: 9px;">
            {dlqMessages.slice(0, 5).map((m) => (
              <div style="color: var(--fg-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px;" title={`hn_id=${m.hn_id}: ${m.title}`}>
                <a href={`/item/${m.hn_id}`} style="color: var(--color-negative);">{m.hn_id}</a> {m.title.slice(0, 40)}...
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </details>

  {/* API & Rate Limits — details open */}
  {rateLimitSnapshot && (
    <details open class="collapsible-section">
      <summary>
        API & Rate Limits
        <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
          {eventStats.error_count_7d > 0 ? `${eventStats.error_count_7d} errors 7d` : 'no errors'}
        </span>
      </summary>

      {/* Error sparkline (last 7 days) */}
      {dailyErrors.length > 0 && (
        <div style="margin-bottom: 10px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 4px;">Errors/warnings (7d)</div>
          <div style="display: flex; align-items: flex-end; gap: 2px; height: 24px;">
            {dailyErrors.map((d) => {
              const maxCount = Math.max(...dailyErrors.map(x => x.count), 1);
              const h = Math.max(2, Math.round((d.count / maxCount) * 24));
              return (
                <div
                  title={`${d.day}: ${d.count}`}
                  style={`width: ${Math.floor(100 / Math.max(dailyErrors.length, 1))}%; height: ${h}px; background: ${d.count > 5 ? 'var(--color-negative)' : d.count > 0 ? 'var(--color-warning)' : 'var(--bg-surface)'}; border-radius: 1px;`}
                ></div>
              );
            })}
          </div>
        </div>
      )}

      {/* API Headroom */}
      <div style="margin-bottom: 10px; padding: 8px; background: var(--bg-surface); border: 1px solid var(--bg-surface); border-radius: 4px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 6px;">
          API Headroom
          <span style="text-transform: none; color: var(--color-border); margin-left: 6px;">
            {rateLimitSnapshot.model} · {rateLimitSnapshot.created_at.slice(0, 16)}
          </span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px; font-size: var(--font-xs);">
          {/* Requests */}
          <div style="flex: 1; min-width: 100px;">
            <div style="color: var(--fg-secondary); margin-bottom: 2px;">Requests</div>
            <div style="display: flex; align-items: center; gap: 4px;">
              <div style="flex: 1; height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                {rateLimitSnapshot.requests_remaining != null && rateLimitSnapshot.requests_limit != null && rateLimitSnapshot.requests_limit > 0 && (
                  <div style={`width: ${Math.round((rateLimitSnapshot.requests_remaining / rateLimitSnapshot.requests_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.1 ? 'var(--color-negative)' : rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.3 ? 'var(--color-warning)' : 'var(--color-positive)'}; border-radius: 3px;`}></div>
                )}
              </div>
              <span style={`color: ${rateLimitSnapshot.requests_remaining != null && rateLimitSnapshot.requests_limit != null && rateLimitSnapshot.requests_remaining < rateLimitSnapshot.requests_limit * 0.1 ? 'var(--color-negative)' : 'var(--fg-secondary)'};`}>
                {rateLimitSnapshot.requests_remaining ?? '?'}/{rateLimitSnapshot.requests_limit ?? '?'}
              </span>
            </div>
          </div>
          {/* Input tokens */}
          <div style="flex: 1; min-width: 100px;">
            <div style="color: var(--fg-secondary); margin-bottom: 2px;">Input Tokens</div>
            <div style="display: flex; align-items: center; gap: 4px;">
              <div style="flex: 1; height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                {rateLimitSnapshot.input_tokens_remaining != null && rateLimitSnapshot.input_tokens_limit != null && rateLimitSnapshot.input_tokens_limit > 0 && (
                  <div style={`width: ${Math.round((rateLimitSnapshot.input_tokens_remaining / rateLimitSnapshot.input_tokens_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.1 ? 'var(--color-negative)' : rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.3 ? 'var(--color-warning)' : 'var(--color-positive)'}; border-radius: 3px;`}></div>
                )}
              </div>
              <span style={`color: ${rateLimitSnapshot.input_tokens_remaining != null && rateLimitSnapshot.input_tokens_limit != null && rateLimitSnapshot.input_tokens_remaining < rateLimitSnapshot.input_tokens_limit * 0.1 ? 'var(--color-negative)' : 'var(--fg-secondary)'}; white-space: nowrap;`}>
                {rateLimitSnapshot.input_tokens_remaining != null ? (rateLimitSnapshot.input_tokens_remaining > 999999 ? `${(rateLimitSnapshot.input_tokens_remaining / 1000000).toFixed(1)}M` : rateLimitSnapshot.input_tokens_remaining > 999 ? `${(rateLimitSnapshot.input_tokens_remaining / 1000).toFixed(0)}k` : rateLimitSnapshot.input_tokens_remaining) : '?'}
              </span>
            </div>
          </div>
          {/* Output tokens */}
          <div style="flex: 1; min-width: 100px;">
            <div style="color: var(--fg-secondary); margin-bottom: 2px;">Output Tokens</div>
            <div style="display: flex; align-items: center; gap: 4px;">
              <div style="flex: 1; height: 6px; background: var(--bg-surface); border-radius: 3px; overflow: hidden;">
                {rateLimitSnapshot.output_tokens_remaining != null && rateLimitSnapshot.output_tokens_limit != null && rateLimitSnapshot.output_tokens_limit > 0 && (
                  <div style={`width: ${Math.round((rateLimitSnapshot.output_tokens_remaining / rateLimitSnapshot.output_tokens_limit) * 100)}%; height: 100%; background: ${rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.1 ? 'var(--color-negative)' : rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.3 ? 'var(--color-warning)' : 'var(--color-positive)'}; border-radius: 3px;`}></div>
                )}
              </div>
              <span style={`color: ${rateLimitSnapshot.output_tokens_remaining != null && rateLimitSnapshot.output_tokens_limit != null && rateLimitSnapshot.output_tokens_remaining < rateLimitSnapshot.output_tokens_limit * 0.1 ? 'var(--color-negative)' : 'var(--fg-secondary)'}; white-space: nowrap;`}>
                {rateLimitSnapshot.output_tokens_remaining != null ? (rateLimitSnapshot.output_tokens_remaining > 999999 ? `${(rateLimitSnapshot.output_tokens_remaining / 1000000).toFixed(1)}M` : rateLimitSnapshot.output_tokens_remaining > 999 ? `${(rateLimitSnapshot.output_tokens_remaining / 1000).toFixed(0)}k` : rateLimitSnapshot.output_tokens_remaining) : '?'}
              </span>
            </div>
          </div>
        </div>
        <div style="display: flex; gap: 12px; margin-top: 6px; font-size: var(--font-xs);">
          {rateLimitSnapshot.cache_hit_rate != null && (
            <span style="color: var(--fg-secondary);">
              Cache: <span style={`color: ${rateLimitSnapshot.cache_hit_rate > 0.5 ? 'var(--color-positive)' : rateLimitSnapshot.cache_hit_rate > 0.2 ? 'var(--color-warning)' : 'var(--fg-secondary)'};`}>{(rateLimitSnapshot.cache_hit_rate * 100).toFixed(0)}%</span>
            </span>
          )}
          <span style={`color: ${rateLimitSnapshot.consecutive_429s === 0 ? 'var(--color-positive)' : rateLimitSnapshot.consecutive_429s <= 2 ? 'var(--color-warning)' : 'var(--color-negative)'};`}>
            429s: {rateLimitSnapshot.consecutive_429s}{rateLimitSnapshot.consecutive_429s >= 3 ? ' (circuit open)' : ''}
          </span>
        </div>
      </div>
    </details>
  )}

  {/* Cycle Performance — collapsed */}
  {cycleStats.length > 0 && (
    <details class="collapsible-section">
      <summary>Cycle Performance</summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: var(--color-border); font-size: 9px; text-transform: uppercase;">
          <td width="130">Cycle Start</td>
          <td width="50" align="center">Crawl</td>
          <td width="40" align="center" title="Stories found by cron">Found</td>
          <td width="35" align="center" title="New stories queued">New</td>
          <td width="45" align="center" title="Evaluations completed">Evals</td>
          <td width="35" align="center" title="Failed evaluations">Fail</td>
          <td title="Time until next cycle">Cycle Time</td>
        </tr>
        {cycleStats.map((c) => {
          const cycleDuration = c.cycle_end
            ? Math.round((new Date(c.cycle_end).getTime() - new Date(c.cycle_start).getTime()) / 1000)
            : null;
          const cycleMins = cycleDuration !== null ? Math.floor(cycleDuration / 60) : null;
          const cycleSecs = cycleDuration !== null ? cycleDuration % 60 : null;
          return (
            <tr style="border-top: 1px solid var(--bg-surface);">
              <td style="color: var(--fg-secondary); white-space: nowrap;">{c.cycle_start.slice(0, 16)}</td>
              <td align="center" style="color: var(--fg-secondary); white-space: nowrap;">
                {c.duration_ms !== null ? `${(c.duration_ms / 1000).toFixed(1)}s` : '---'}
              </td>
              <td align="center" style="color: var(--fg-secondary);">{c.stories_found ?? '---'}</td>
              <td align="center" style={`color: ${(c.stories_new ?? 0) > 0 ? 'var(--color-positive)' : 'var(--fg-secondary)'};`}>{c.stories_new ?? '---'}</td>
              <td align="center" style={`color: ${c.evals_completed > 0 ? 'var(--channel-editorial)' : 'var(--fg-secondary)'}; font-weight: ${c.evals_completed > 0 ? 'bold' : 'normal'};`}>{c.evals_completed}</td>
              <td align="center" style={`color: ${c.evals_failed > 0 ? 'var(--color-negative)' : 'var(--fg-secondary)'};`}>{c.evals_failed || '---'}</td>
              <td style="color: var(--fg-secondary);">
                {cycleMins !== null ? `${cycleMins}m ${cycleSecs}s` : <span style="color: var(--bg-surface);">current</span>}
              </td>
            </tr>
          );
        })}
      </table>
      </div>
      {cycleStats.length >= 2 && (() => {
        const withDurations = cycleStats.filter(c => c.cycle_end !== null);
        if (withDurations.length === 0) return null;
        const totalEvals = withDurations.reduce((sum, c) => sum + c.evals_completed, 0);
        const avgEvals = totalEvals / withDurations.length;
        const cycleDurations = withDurations.map(c =>
          (new Date(c.cycle_end!).getTime() - new Date(c.cycle_start).getTime()) / 1000
        );
        const avgCycle = cycleDurations.reduce((a, b) => a + b, 0) / cycleDurations.length;
        const avgCycleMins = Math.floor(avgCycle / 60);
        const avgCycleSecs = Math.round(avgCycle % 60);
        return (
          <div style="margin-top: 6px; font-size: var(--font-xs); color: var(--fg-secondary);">
            Avg: <span style="color: var(--channel-editorial);">{avgEvals.toFixed(1)}</span> evals/cycle
            <span style="color: var(--bg-surface);"> · </span>
            <span style="color: var(--fg-secondary);">{avgCycleMins}m {avgCycleSecs}s</span> cycle time
          </div>
        );
      })()}
    </details>
  )}

  {/* Throttle Impact — collapsed */}
  {throttleImpact.length > 0 && (
    <details class="collapsible-section">
      <summary>
        Throttle Impact
        <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
          {Math.round(throttleImpact.reduce((s, r) => s + r.total_delay_sec, 0) / 60)}m wasted 7d
        </span>
      </summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: var(--color-border); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">Events</td>
          <td style="padding: 2px 6px; text-align: right; width: 80px;">Wasted (7d)</td>
        </tr>
        {throttleImpact.map(row => (
          <tr style="border-top: 1px solid var(--bg-surface);">
            <td style="padding: 3px 6px; color: var(--fg-primary);">{row.model}</td>
            <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{row.event_count}</td>
            <td style={`padding: 3px 6px; text-align: right; color: ${row.total_delay_sec > 600 ? 'var(--color-warning)' : 'var(--fg-secondary)'};`}>
              {row.total_delay_sec >= 60
                ? `${Math.round(row.total_delay_sec / 60)}m ${Math.round(row.total_delay_sec % 60)}s`
                : `${Math.round(row.total_delay_sec)}s`}
            </td>
          </tr>
        ))}
      </table>
      </div>
    </details>
  )}

  {/* Eval Latency — collapsed */}
  {latencyStats.length > 0 && (
    <details class="collapsible-section">
      <summary>Eval Latency</summary>
      <div class="table-wrap">
      <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
        <tr style="color: var(--color-border); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
          <td style="padding: 2px 6px;">Model</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;" title="Median latency (story crawled → eval done)">P50</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">P95</td>
          <td style="padding: 2px 6px; text-align: right; width: 60px;">P99</td>
          <td style="padding: 2px 6px; text-align: right; width: 50px;">N</td>
        </tr>
        {latencyStats.map(row => {
          const fmt = (s: number | null) => s == null ? '—' : s < 3600 ? `${Math.round(s / 60)}m` : `${(s / 3600).toFixed(1)}h`;
          return (
            <tr style="border-top: 1px solid var(--bg-surface);">
              <td style="padding: 3px 6px; color: var(--fg-primary);">{row.eval_model}</td>
              <td style={`padding: 3px 6px; text-align: right; color: ${row.p50_sec != null && row.p50_sec > 3600 ? 'var(--color-warning)' : 'var(--fg-secondary)'};`}>{fmt(row.p50_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{fmt(row.p95_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">{fmt(row.p99_sec)}</td>
              <td style="padding: 3px 6px; text-align: right; color: var(--color-border);">{row.sample_count}</td>
            </tr>
          );
        })}
      </table>
      </div>
    </details>
  )}
</Base>
