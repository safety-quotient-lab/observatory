---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { modelDisplayName, MODEL_REGISTRY, isLiteMode, getModelDef } from '../lib/shared-eval';
import {
  getStatusCounts,
  getVelocityStats,
  getCronRuns,
  getProviderStats,
  getModelQueueStats,
  getDlqStats,
  getRecentEvents,
  getDailyEvalVelocity,
} from '../lib/db';
import { cachedQuery, readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

const status = await getStatusCounts(db);

const [
  velocity, cronRuns, providerStats, modelQueueStats,
  dlqStats, recentPipelineEvents, evalVelocity, lastDlqRow,
] = await Promise.all([
  getVelocityStats(db, status.pending),
  getCronRuns(db, 5).catch(() => [] as Awaited<ReturnType<typeof getCronRuns>>),
  getProviderStats(db).catch(() => [] as Awaited<ReturnType<typeof getProviderStats>>),
  getModelQueueStats(db).catch(() => [] as Awaited<ReturnType<typeof getModelQueueStats>>),
  getDlqStats(db),
  getRecentEvents(db, 15).catch(() => [] as Awaited<ReturnType<typeof getRecentEvents>>),
  getDailyEvalVelocity(db, 60).catch(() => [] as Awaited<ReturnType<typeof getDailyEvalVelocity>>),
  db.prepare("SELECT created_at FROM events WHERE event_type IN ('dlq','dlq_replay','dlq_auto_replay') ORDER BY created_at DESC LIMIT 1").first<{created_at: string}>().catch(() => null),
]);

// Prep eval velocity chart data
const velDays = [...new Set(evalVelocity.map(r => r.day))].sort();
const velFull = velDays.map(d => evalVelocity.find(r => r.day === d && r.prompt_mode === 'full')?.count ?? 0);
const velLite = velDays.map(d => evalVelocity.find(r => r.day === d && (r.prompt_mode === 'lite' || r.prompt_mode === 'light'))?.count ?? 0);
const velMax = Math.max(1, ...velFull.map((f, i) => f + velLite[i]));

// Worker health helpers
function relativeTime(ts: string | null | undefined): string {
  if (!ts) return 'never';
  const s = Math.floor((Date.now() - new Date(ts).getTime()) / 1000);
  if (s < 60) return `${s}s ago`;
  if (s < 3600) return `${Math.floor(s / 60)}m ago`;
  if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
  return `${Math.floor(s / 86400)}d ago`;
}
function workerDot(ts: string | null | undefined): { color: string; title: string } {
  if (!ts) return { color: 'var(--color-border)', title: 'never active' };
  const s = Math.floor((Date.now() - new Date(ts).getTime()) / 1000);
  if (s < 600) return { color: 'var(--color-positive)', title: 'active (<10m)' };
  if (s < 3600) return { color: 'var(--color-warning)', title: 'idle (<1h)' };
  if (s < 86400) return { color: 'var(--fg-secondary)', title: 'sleeping (<24h)' };
  return { color: 'var(--color-border)', title: 'inactive (>24h)' };
}

// Map eval_provider values to display names
const PROVIDER_META: Record<string, { name: string; role: string }> = {
  'anthropic':             { name: 'consumer-anthropic',  role: 'evaluate · Anthropic API' },
  'openrouter':            { name: 'consumer-openrouter', role: 'evaluate · OpenRouter' },
  'workers-ai':            { name: 'consumer-workers-ai', role: 'evaluate · Workers AI (~lite)' },
  'claude-code-standalone':{ name: 'standalone',          role: 'evaluate · local CLI' },
};

// Static queue → model → consumer mapping
const QUEUE_CONFIG = [
  { queue: 'hrcb-eval-queue',      model: 'claude-haiku-4-5-20251001', consumer: 'consumer-anthropic',  provider: 'anthropic'  },
  { queue: 'hrcb-eval-deepseek',   model: 'deepseek-v3.2',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-trinity',    model: 'trinity-large',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-nemotron',   model: 'nemotron-nano-30b',         consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-step',       model: 'step-3.5-flash',            consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-qwen',       model: 'qwen3-next-80b',            consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-llama',      model: 'llama-3.3-70b',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-mistral',    model: 'mistral-small-3.1',         consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-hermes',     model: 'hermes-3-405b',             consumer: 'consumer-openrouter', provider: 'openrouter' },
  { queue: 'hrcb-eval-workers-ai', model: 'llama-4-scout-wai',         consumer: 'consumer-workers-ai', provider: 'workers-ai' },
  { queue: 'hrcb-eval-workers-ai', model: 'llama-3.3-70b-wai',         consumer: 'consumer-workers-ai', provider: 'workers-ai' },
];

// Coverage spectrum percentages (of non-skipped stories)
const evaluable = status.total - status.skipped;
const pctCovMulti = evaluable > 0 ? Math.round((status.coverageMultiModel / evaluable) * 100) : 0;
const pctCovFull = evaluable > 0 ? Math.round(((status.coverageFull - status.coverageMultiModel) / evaluable) * 100) : 0;
const pctCovLite = evaluable > 0 ? Math.round((status.coverageLite / evaluable) * 100) : 0;
const pctCovNone = Math.max(0, 100 - pctCovMulti - pctCovFull - pctCovLite);
---

<Base title="Status">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'status' }]} />
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">Status</span>
        <span style="color: var(--fg-secondary); margin-left: var(--space-lg);">Pipeline health at a glance.</span>
        <span id="live-indicator" style="margin-left: var(--space-lg); font-size: var(--font-xs); color: var(--fg-secondary);">connecting...</span>
      </td>
    </tr>
  </table>

  {/* Coverage Spectrum */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Coverage</div>

        {/* Coverage spectrum bar (excludes skipped) */}
        <div style="width: 100%; height: 8px; background: var(--bg-surface); border-radius: 4px; overflow: hidden; display: flex; margin-bottom: 10px;">
          {pctCovMulti > 0 && <div style={`width: ${pctCovMulti}%; background: var(--channel-hrcb);`} title={`Multi-model: ${status.coverageMultiModel}`}></div>}
          {pctCovFull > 0 && <div style={`width: ${pctCovFull}%; background: var(--color-positive);`} title={`Full: ${status.coverageFull - status.coverageMultiModel}`}></div>}
          {pctCovLite > 0 && <div style={`width: ${pctCovLite}%; background: var(--color-orange);`} title={`Lite: ${status.coverageLite}`}></div>}
          {pctCovNone > 0 && <div style={`width: ${pctCovNone}%; background: var(--bg-surface);`}></div>}
        </div>

        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-base);">
          <tr>
            <td style="text-align: center; width: 25%;">
              <div class="score-font" style="font-size: var(--font-lg); color: var(--channel-hrcb); font-weight: bold;">{status.coverageMultiModel}</div>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase;">Multi-Model</div>
            </td>
            <td style="text-align: center; width: 25%;">
              <div class="score-font" style="font-size: var(--font-lg); color: var(--color-positive); font-weight: bold;">{status.coverageFull}</div>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase;">Full</div>
            </td>
            <td style="text-align: center; width: 25%;">
              <div class="score-font" style="font-size: var(--font-lg); color: var(--color-orange); font-weight: bold;">{status.coverageLite}</div>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase;">Lite</div>
            </td>
            <td style="text-align: center; width: 25%;">
              <div class="score-font" style="font-size: var(--font-lg); color: var(--fg-secondary); font-weight: bold;">{evaluable > 0 ? evaluable - status.coverageFull - status.coverageLite : 0}</div>
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase;">No Coverage</div>
            </td>
          </tr>
        </table>

        {/* Pipeline status row */}
        <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--bg-surface); display: flex; gap: 12px; flex-wrap: wrap; font-size: var(--font-sm); color: var(--fg-secondary);">
          <span><span class="score-font" style="color: var(--color-positive);">{status.done}</span> done</span>
          <span><span class="score-font" style="color: var(--color-warning);">{status.pending}</span> pending</span>
          {status.evaluating > 0 && <span><span class="score-font" style="color: var(--channel-editorial);">{status.evaluating}</span> evaluating</span>}
          {status.failed > 0 && <span><span class="score-font" style="color: var(--color-negative);">{status.failed}</span> failed</span>}
          <span><span class="score-font" style="color: var(--fg-secondary);">{status.skipped}</span> skipped</span>
          <span style="color: var(--color-border);">|</span>
          <span><span class="score-font" style="color: var(--fg-primary);">{status.total}</span> total</span>
        </div>

        {/* Clearance estimate — aggregate rate across all queues */}
        {velocity.daysToClearing !== null && status.pending > 0 && (
          <div style="margin-top: 6px; font-size: var(--font-sm); color: var(--fg-secondary);">
            est. <span class="score-font" style="color: var(--color-warning);">{velocity.daysToClearing < 1 ? '<1' : Math.ceil(velocity.daysToClearing)}</span> {velocity.daysToClearing < 1.5 ? 'day' : 'days'} to clear backlog
          </div>
        )}
      </td>
    </tr>
  </table>

  {/* Workers Health */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Workers</div>
        <div class="table-wrap">
        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tr style="color: var(--color-border); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 2px 6px;"></td>
            <td style="padding: 2px 6px;">Worker</td>
            <td style="padding: 2px 6px;">Role</td>
            <td style="padding: 2px 6px; text-align: right;">Last Active</td>
            <td style="padding: 2px 6px; text-align: right;">24h</td>
            <td style="padding: 2px 6px; text-align: right;">7d</td>
            <td style="padding: 2px 6px; text-align: right;">Errs 24h</td>
          </tr>

          {/* Cron worker */}
          {(() => {
            const lastActive = cronRuns[0]?.created_at ?? null;
            const dot = workerDot(lastActive);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: var(--fg-primary); font-weight: bold;">hn-hrcb-cron</td>
                <td style="padding: 4px 6px; color: var(--fg-secondary);">crawl HN · dispatch to queues</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary); white-space: nowrap;">{relativeTime(lastActive)}</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary);">—</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary);">—</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary);">—</td>
              </tr>
            );
          })()}

          {/* Consumer workers */}
          {providerStats.map(ps => {
            const meta = PROVIDER_META[ps.eval_provider] ?? { name: ps.eval_provider, role: 'evaluate' };
            const dot = workerDot(ps.last_eval);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: var(--fg-primary); font-weight: bold;">{meta.name}</td>
                <td style="padding: 4px 6px; color: var(--fg-secondary);">{meta.role}</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary); white-space: nowrap;">{relativeTime(ps.last_eval)}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.evals_24h > 0 ? 'var(--channel-editorial)' : 'var(--fg-secondary)'};`}>{ps.evals_24h > 0 ? ps.evals_24h : '—'}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.evals_7d > 0 ? 'var(--fg-secondary)' : 'var(--color-border)'};`}>{ps.evals_7d > 0 ? ps.evals_7d : '—'}</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${ps.failed_24h > 0 ? 'var(--color-negative)' : 'var(--fg-secondary)'};`}>{ps.failed_24h > 0 ? ps.failed_24h : '—'}</td>
              </tr>
            );
          })}

          {/* DLQ worker */}
          {(() => {
            const lastActive = lastDlqRow?.created_at ?? null;
            const dot = workerDot(lastActive);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 4px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 4px 6px; color: var(--fg-primary); font-weight: bold;">hn-hrcb-dlq</td>
                <td style="padding: 4px 6px; color: var(--fg-secondary);">dead letter handler</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary); white-space: nowrap;">{relativeTime(lastActive)}</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary);">—</td>
                <td style="padding: 4px 6px; text-align: right; color: var(--fg-secondary);">—</td>
                <td style={`padding: 4px 6px; text-align: right; color: ${dlqStats.pending > 0 ? 'var(--color-negative)' : 'var(--fg-secondary)'};`}>
                  {dlqStats.pending > 0 ? `${dlqStats.pending}p` : '—'}
                </td>
              </tr>
            );
          })()}
        </table>
        </div>
      </td>
    </tr>
  </table>

  {/* Queue Breakdown */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
          Queues
          <span style="text-transform: none; letter-spacing: 0; color: var(--color-border); margin-left: 6px; font-size: var(--font-xs);">{QUEUE_CONFIG.length} queues + hrcb-eval-dlq</span>
        </div>
        <div class="table-wrap">
        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
          <tr style="color: var(--color-border); font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em;">
            <td style="padding: 2px 6px;"></td>
            <td style="padding: 2px 6px;">Queue</td>
            <td style="padding: 2px 6px;">Model</td>
            <td style="padding: 2px 6px;">Consumer</td>
            <td style="padding: 2px 6px; text-align: right;">Last Eval</td>
            <td style="padding: 2px 6px; text-align: right;" title="Items in rater_evals with queued/evaluating status">In-flight</td>
            <td style="padding: 2px 6px; text-align: right;">24h</td>
            <td style="padding: 2px 6px; text-align: right;">avg/d</td>
          </tr>

          {QUEUE_CONFIG.map(qc => {
            const stat = modelQueueStats.find(s => s.eval_model === qc.model);
            const dot = workerDot(stat?.last_eval ?? null);
            const isEnabled = MODEL_REGISTRY.find(r => r.id === qc.model)?.enabled ?? false;
            return (
              <tr style={`border-top: 1px solid var(--bg-surface); ${!isEnabled ? 'opacity: 0.5;' : ''}`}>
                <td style="padding: 3px 6px; text-align: center;">
                  <span style={`color: ${dot.color}; font-size: 8px;`} title={dot.title}>●</span>
                </td>
                <td style="padding: 3px 6px; color: var(--fg-secondary); font-family: monospace; white-space: nowrap;" title={qc.queue}>
                  {qc.queue.replace('hrcb-eval-', '')}
                </td>
                <td style="padding: 3px 6px; color: var(--fg-primary); white-space: nowrap;">
                  {modelDisplayName(qc.model)}
                  {isLiteMode(getModelDef(qc.model)?.prompt_mode ?? null) && <span style="color: var(--color-orange); margin-left: 3px; font-size: 8px;">~lite</span>}
                  {!isEnabled && <span style="color: var(--color-border); margin-left: 4px; font-size: 8px;">off</span>}
                </td>
                <td style="padding: 3px 6px; color: var(--fg-secondary); font-size: 9px;">{qc.consumer}</td>
                <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary); white-space: nowrap;">{relativeTime(stat?.last_eval ?? null)}</td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.in_flight ?? 0) > 0 ? 'var(--color-warning)' : 'var(--color-border)'};`}>
                  {(stat?.in_flight ?? 0) > 0 ? stat!.in_flight : '—'}
                </td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.evals_24h ?? 0) > 0 ? 'var(--channel-editorial)' : 'var(--color-border)'};`}>
                  {(stat?.evals_24h ?? 0) > 0 ? stat!.evals_24h : '—'}
                </td>
                <td style={`padding: 3px 6px; text-align: right; color: ${(stat?.evals_7d ?? 0) > 0 ? 'var(--fg-secondary)' : 'var(--color-border)'};`}>
                  {(stat?.evals_7d ?? 0) > 0 ? (stat!.evals_7d / 7).toFixed(1) : '—'}
                </td>
              </tr>
            );
          })}

          {/* DLQ row */}
          {(() => {
            const lastDlqEvent = recentPipelineEvents.find(e => e.event_type === 'dlq' || e.event_type === 'dlq_replay');
            const dot = workerDot(lastDlqEvent?.created_at ?? null);
            return (
              <tr style="border-top: 1px solid var(--bg-surface);">
                <td style="padding: 3px 6px; text-align: center;">
                  <span style={`color: ${dlqStats.pending > 0 ? 'var(--color-negative)' : dot.color}; font-size: 8px;`} title={dlqStats.pending > 0 ? `${dlqStats.pending} pending` : dot.title}>●</span>
                </td>
                <td style="padding: 3px 6px; color: var(--fg-secondary); font-family: monospace;">eval-dlq</td>
                <td style="padding: 3px 6px; color: var(--fg-secondary); font-size: 9px;">dead letters</td>
                <td style="padding: 3px 6px; color: var(--fg-secondary); font-size: 9px;">hn-hrcb-dlq</td>
                <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary); white-space: nowrap;">{relativeTime(lastDlqEvent?.created_at ?? null)}</td>
                <td style={`padding: 3px 6px; text-align: right; color: ${dlqStats.pending > 0 ? 'var(--color-negative)' : 'var(--color-border)'};`}>
                  {dlqStats.pending > 0 ? `${dlqStats.pending}` : '—'}
                </td>
                <td style="padding: 3px 6px; text-align: right; color: var(--color-border);">—</td>
                <td style="padding: 3px 6px; text-align: right; color: var(--fg-secondary);">
                  {dlqStats.total > 0 ? dlqStats.total : '—'}
                </td>
              </tr>
            );
          })()}
        </table>
        </div>
      </td>
    </tr>
  </table>

  {/* Eval Velocity */}
  {velDays.length > 1 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
          <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Eval Velocity
            <span style="text-transform: none; letter-spacing: 0; color: var(--color-border); margin-left: 6px; font-size: var(--font-xs);">evals/day · last 60 days</span>
          </div>
          <svg viewBox={`0 0 ${velDays.length * 8} 60`} style="width: 100%; height: 60px; overflow: visible;" preserveAspectRatio="none">
            {/* Full evals (bottom) */}
            {velFull.map((v, i) => {
              const h = velMax > 0 ? (v / velMax) * 56 : 0;
              return h > 0 ? <rect x={i * 8} y={60 - h} width={7} height={h} fill="var(--color-positive)" opacity="0.8" /> : null;
            })}
            {/* Lite evals (stacked on top) */}
            {velLite.map((v, i) => {
              const hFull = velMax > 0 ? (velFull[i] / velMax) * 56 : 0;
              const hLite = velMax > 0 ? (v / velMax) * 56 : 0;
              return hLite > 0 ? <rect x={i * 8} y={60 - hFull - hLite} width={7} height={hLite} fill="var(--color-orange)" opacity="0.8" /> : null;
            })}
          </svg>
          <div style="display: flex; gap: 12px; margin-top: 4px; font-size: var(--font-xs); color: var(--fg-secondary);">
            <span><span style="color: var(--color-positive);">■</span> full</span>
            <span><span style="color: var(--color-orange);">■</span> lite</span>
            {velDays.length > 0 && <span style="margin-left: auto;">{velDays[0].slice(5)} – {velDays[velDays.length - 1].slice(5)}</span>}
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* Operations — always visible (promoted from collapsed tertiary) */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Operations</div>
        <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <tr>
            <td style="color: var(--fg-secondary); width: 140px;">Cron interval</td>
            <td style="color: var(--fg-primary);">Every 5 minutes</td>
          </tr>
          <tr>
            <td style="color: var(--fg-secondary);">Score refresh</td>
            <td style="color: var(--fg-primary);">Every 5 min (updates) · 48h sweep every 10 min</td>
          </tr>
          <tr>
            <td style="color: var(--fg-secondary);">Crawl surface</td>
            <td style="color: var(--fg-primary);">top · new · best · ask · show (5 lists)</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* Hub cards */}
  <div class="two-col" style="margin-bottom: 10px;">
    <div>
      <a href="/status/models" style="text-decoration: none; display: block; padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-left: 3px solid var(--channel-hrcb); border-radius: 6px; height: 100%;">
        <div style="color: var(--channel-hrcb); font-size: var(--font-sm); font-weight: bold;">Models</div>
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-top: 2px;">Registry, trust index, calibration, signal completeness, model comparison, and measurement integrity.</div>
        <div style="color: var(--color-border); font-size: var(--font-xs); margin-top: 4px;">/status/models →</div>
      </a>
    </div>
    <div>
      <a href="/status/events" style="text-decoration: none; display: block; padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-left: 3px solid var(--color-orange); border-radius: 6px; height: 100%;">
        <div style="color: var(--color-orange); font-size: var(--font-sm); font-weight: bold;">Events</div>
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-top: 2px;">Pipeline events, failures, evaluation queue, DLQ, rate limits, cycle performance, and latency.</div>
        <div style="color: var(--color-border); font-size: var(--font-xs); margin-top: 4px;">/status/events →</div>
      </a>
    </div>
  </div>

  {/* Live feed toast area */}
  <div id="live-feed" style="position: fixed; bottom: 10px; right: 10px; z-index: 100; display: flex; flex-direction: column; gap: 4px; max-width: 320px;"></div>

  <script is:inline>
  (function() {
    var indicator = document.getElementById('live-indicator');
    var feed = document.getElementById('live-feed');
    var es;

    function connect() {
      es = new EventSource('/api/events');

      es.addEventListener('connected', function() {
        if (indicator) {
          indicator.style.color = 'var(--color-positive)';
          indicator.textContent = 'live';
        }
      });

      es.addEventListener('evaluation', function(e) {
        var d = JSON.parse(e.data);
        var score = d.hcb_weighted_mean !== null ? d.hcb_weighted_mean.toFixed(2) : '?';
        var toast = document.createElement('div');
        toast.style.cssText = 'background:var(--bg-highlight);border:1px solid var(--color-border);border-radius:4px;padding:6px 10px;font-size:8pt;color:var(--fg-emphasis);';
        var link = document.createElement('a');
        link.href = '/item/' + d.hn_id;
        link.style.color = 'var(--fg-primary)';
        link.textContent = (d.title || '').slice(0, 40);
        var scoreSpan = document.createElement('span');
        scoreSpan.style.cssText = 'color:' + (d.hcb_weighted_mean > 0.05 ? 'var(--color-positive)' : d.hcb_weighted_mean < -0.05 ? 'var(--color-negative)' : 'var(--color-warning)') + ';font-family:monospace;';
        scoreSpan.textContent = ' ' + score;
        toast.appendChild(link);
        toast.appendChild(scoreSpan);
        if (feed) {
          feed.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 15000);
          while (feed.children.length > 3) feed.removeChild(feed.firstChild);
        }
      });

      es.addEventListener('timeout', function() {
        es.close();
        if (indicator) { indicator.style.color = 'var(--fg-secondary)'; indicator.textContent = 'reconnecting...'; }
        setTimeout(connect, 2000);
      });

      es.onerror = function() {
        es.close();
        if (indicator) { indicator.style.color = 'var(--fg-secondary)'; indicator.textContent = 'offline'; }
        setTimeout(connect, 30000);
      };
    }

    connect();
  })();
  </script>
</Base>
