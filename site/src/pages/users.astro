---
// SPDX-License-Identifier: Apache-2.0
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getUserIntelligence, getHourlyPatterns, getDayOfWeekPatterns, getKarmaHrcbCorrelation } from '../lib/db';
import type { UserIntelSortOption } from '../lib/db';
import { scoreToColor, formatScore, normalizePsq, formatPsqScore } from '../lib/colors';
import { cachedQuery, readDb } from '../lib/db-utils';

const db = readDb(Astro.locals.runtime.env.DB);
const kv = Astro.locals.runtime.env.CONTENT_CACHE;

const url = new URL(Astro.request.url);
const sort = (url.searchParams.get('sort') || 'stories') as UserIntelSortOption;
const validSorts: UserIntelSortOption[] = ['stories', 'score', 'comments', 'avg_comments', 'hrcb', 'domains', 'avg_score', 'controversy', 'full_evaluated', 'lite_evaluated', 'editorial_full', 'editorial_lite', 'structural', 'positive', 'negative', 'karma', 'eq'];
const safeSort = validSorts.includes(sort) ? sort : 'stories';
const minStories = Math.max(2, Math.min(20, parseInt(url.searchParams.get('min') || '3', 10) || 3));

const [users, hourly, daily, karmaCorr] = await Promise.all([
  cachedQuery(kv, `sys:users:${safeSort}:${minStories}`, () => getUserIntelligence(db, safeSort, minStories, 200), 60).catch(() => []),
  getHourlyPatterns(db).catch(() => []),
  getDayOfWeekPatterns(db).catch(() => []),
  cachedQuery(kv, 'karmaHrcbCorrelation', () => getKarmaHrcbCorrelation(db), 600).catch(() => ({ points: [], pearson_r: null, pearson_p: null, n: 0 })),
]);

// Aggregate stats
const totalUsers = users.length;
const totalStories = users.reduce((s, u) => s + u.stories, 0);
const usersWithHrcb = users.filter(u => u.avg_hrcb !== null);
const avgHrcb = usersWithHrcb.length > 0 ? usersWithHrcb.reduce((s, u) => s + (u.avg_hrcb || 0), 0) / usersWithHrcb.length : null;

// Insight card data: top submitters, highest HRCB, lowest HRCB, most diverse, most controversial
const topSubmitters = [...users].sort((a, b) => b.stories - a.stories).slice(0, 5);
const hrcbUsers = users.filter(u => u.full_evaluated >= 3 && u.avg_hrcb !== null);
const topHrcb = [...hrcbUsers].sort((a, b) => (b.avg_hrcb || 0) - (a.avg_hrcb || 0)).slice(0, 5);
const bottomHrcb = [...hrcbUsers].sort((a, b) => (a.avg_hrcb || 0) - (b.avg_hrcb || 0)).slice(0, 5);
const mostDiverse = [...users].filter(u => u.stories >= 3).sort((a, b) => b.unique_domains - a.unique_domains).slice(0, 5);
const mostControversial = [...hrcbUsers].filter(u => u.hrcb_range !== null).sort((a, b) => (b.hrcb_range || 0) - (a.hrcb_range || 0)).slice(0, 5);

// Hourly pattern stats
const maxHourlyStories = hourly.length > 0 ? Math.max(...hourly.map(h => h.stories), 1) : 1;
const peakHour = hourly.length > 0 ? hourly.reduce((best, h) => h.avg_hn_score > best.avg_hn_score ? h : best, hourly[0]) : null;
const peakCommentHour = hourly.length > 0 ? hourly.reduce((best, h) => h.avg_comments > best.avg_comments ? h : best, hourly[0]) : null;

// Day of week stats
const maxDailyStories = Math.max(...daily.map(d => d.stories), 1);

// Karma vs HRCB scatter data (pre-resolved for Astro static rendering)
const karmaUserCount = karmaCorr?.count ?? 0;
const karmaPearsonR = karmaCorr?.pearson_r ?? null;
const karmaRLabel = karmaPearsonR != null
  ? `r = ${karmaPearsonR > 0 ? '+' : ''}${karmaPearsonR.toFixed(3)} (${Math.abs(karmaPearsonR) < 0.1 ? 'negligible' : Math.abs(karmaPearsonR) < 0.3 ? 'weak' : Math.abs(karmaPearsonR) < 0.5 ? 'moderate' : 'strong'})`
  : '';
const karmaRColor = karmaPearsonR != null && Math.abs(karmaPearsonR) > 0.3 ? 'var(--color-orange)' : 'var(--fg-secondary)';
const karmaScatterJson = JSON.stringify((karmaCorr?.points ?? []).map(p => ({
  u: p.username, k: p.karma, h: p.avg_hrcb, n: p.story_count,
})));

function sortUrl(s: string): string {
  const p = new URLSearchParams();
  if (s !== 'stories') p.set('sort', s);
  if (minStories !== 3) p.set('min', String(minStories));
  const qs = p.toString();
  return qs ? `/users?${qs}` : '/users';
}

function minUrl(m: number): string {
  const p = new URLSearchParams();
  if (safeSort !== 'stories') p.set('sort', safeSort);
  if (m !== 3) p.set('min', String(m));
  const qs = p.toString();
  return qs ? `/users?${qs}` : '/users';
}

type SortLabels = Record<string, string>;
const sortLabels: SortLabels = {
  stories: 'stories', score: 'total pts', avg_score: 'avg pts', comments: 'comments',
  hrcb: 'hrcb', domains: 'domains', controversy: 'range', karma: 'karma',
  full_evaluated: 'full eval', eq: 'eq',
};

function thStyle(col: string): string {
  const active = safeSort === col;
  return `cursor: pointer; ${active ? 'color: var(--color-orange); font-weight: bold;' : 'color: var(--fg-secondary);'}`;
}
---

<Base title="User Profiles — HRO">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'sources', href: '/sources' }, { label: 'users' }]} />
  <div class="filter-bar" style="padding-bottom: 10px;">
    <span style="font-size: var(--font-md); color: var(--fg-primary); font-weight: bold;">User Profiles</span>
    <span class="filter-stats" style="margin-left: 8px; font-size: var(--font-base);">
      {totalUsers} users, {totalStories} stories
    </span>
    <div class="subtext" style="margin-top: 4px;">
      <div class="filter-row">
        <span class="filter-label">sort:</span>
        {Object.entries(sortLabels).map(([key, label], i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {safeSort === key
              ? <span class="filter-active">{label}</span>
              : <a href={sortUrl(key)} class="filter-link">{label}</a>
            }
          </>
        ))}
      </div>
      <div class="filter-row">
        <span class="filter-label">min stories:</span>
        {[2, 3, 5, 10].map((m, i) => (
          <>
            {i > 0 && <span class="filter-sep"> | </span>}
            {minStories === m
              ? <span class="filter-active">{m}</span>
              : <a href={minUrl(m)} class="filter-link">{m}</a>
            }
          </>
        ))}
      </div>
    </div>
  </div>

  {/* --- Insight cards --- */}
  <div style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; margin-bottom: 10px;">
    <div class="insight-grid">
      {/* Top submitters */}
      <div style="padding: 4px 8px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Top Submitters</div>
        {topSubmitters.map(u => (
          <div style="margin-bottom: 3px;">
            <a href={`/user/${u.username}`} style="color: var(--fg-primary); font-size: var(--font-sm);">{u.username}</a>
            <span class="score-font" style="color: var(--channel-editorial); font-size: var(--font-sm); margin-left: 4px;">{u.stories}</span>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 2px;">stories</span>
          </div>
        ))}
      </div>
      {/* Most Rights-Aligned */}
      <div style="padding: 4px 8px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Rights-Aligned</div>
        {topHrcb.map(u => (
          <div style="margin-bottom: 3px;">
            <a href={`/user/${u.username}`} style="color: var(--fg-primary); font-size: var(--font-sm);">{u.username}</a>
            <span class="score-font" style={`color: ${scoreToColor(u.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(u.avg_hrcb)}</span>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 2px;">({u.full_evaluated})</span>
          </div>
        ))}
      </div>
      {/* Least Rights-Aligned */}
      <div style="padding: 4px 8px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Least Rights-Aligned</div>
        {bottomHrcb.map(u => (
          <div style="margin-bottom: 3px;">
            <a href={`/user/${u.username}`} style="color: var(--fg-primary); font-size: var(--font-sm);">{u.username}</a>
            <span class="score-font" style={`color: ${scoreToColor(u.avg_hrcb)}; font-size: var(--font-sm); margin-left: 4px;`}>{formatScore(u.avg_hrcb)}</span>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 2px;">({u.full_evaluated})</span>
          </div>
        ))}
      </div>
      {/* Most Diverse (domains) */}
      <div style="padding: 4px 8px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Diverse</div>
        {mostDiverse.map(u => (
          <div style="margin-bottom: 3px;">
            <a href={`/user/${u.username}`} style="color: var(--fg-primary); font-size: var(--font-sm);">{u.username}</a>
            <span class="score-font" style="color: var(--channel-structural); font-size: var(--font-sm); margin-left: 4px;">{u.unique_domains}</span>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 2px;">domains</span>
          </div>
        ))}
      </div>
      {/* Most Controversial */}
      <div style="padding: 4px 8px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Most Contested</div>
        {mostControversial.map(u => (
          <div style="margin-bottom: 3px;">
            <a href={`/user/${u.username}`} style="color: var(--fg-primary); font-size: var(--font-sm);">{u.username}</a>
            <span class="score-font" style="color: var(--color-hn-score); font-size: var(--font-sm); margin-left: 4px;">
              {u.hrcb_range !== null ? u.hrcb_range.toFixed(2) : '—'}
            </span>
            <span style="color: var(--fg-secondary); font-size: var(--font-xs); margin-left: 2px;">range</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* --- Posting patterns --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <table cellpadding="0" cellspacing="0" width="100%">
          <tr>
            {/* Hourly pattern */}
            <td style="vertical-align: top; width: 65%; padding: 4px 8px;">
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Hourly Posting Pattern (UTC)
                {peakHour && <span style="color: var(--fg-secondary); text-transform: none; letter-spacing: normal; margin-left: 8px;">
                  peak engagement: {peakHour.hour}:00 ({peakHour.avg_hn_score} avg pts)
                </span>}
              </div>
              <div style="display: flex; align-items: flex-end; gap: 2px; height: 50px;">
                {hourly.map(h => {
                  const pct = (h.stories / maxHourlyStories) * 100;
                  const hrcbColor = h.avg_hrcb !== null ? scoreToColor(h.avg_hrcb) : 'var(--color-border)';
                  return (
                    <div style={`flex: 1; display: flex; flex-direction: column; align-items: center;`} title={`${h.hour}:00 UTC — ${h.stories} stories, avg ${h.avg_hn_score} pts, avg ${h.avg_comments} cmt${h.avg_hrcb !== null ? `, HRCB ${formatScore(h.avg_hrcb)}` : ''}`}>
                      <div style={`width: 100%; height: ${pct}%; min-height: 2px; background: ${hrcbColor}; border-radius: 1px 1px 0 0; opacity: 0.8;`}></div>
                    </div>
                  );
                })}
              </div>
              <div style="display: flex; gap: 2px; margin-top: 2px;">
                {hourly.map(h => (
                  <div style="flex: 1; text-align: center; font-size: 7px; color: var(--fg-secondary);" class="score-font">
                    {h.hour % 3 === 0 ? h.hour : ''}
                  </div>
                ))}
              </div>
            </td>
            {/* Day of week pattern */}
            <td style="vertical-align: top; width: 35%; padding: 4px 8px; border-left: 1px solid var(--bg-surface);">
              <div style="color: var(--fg-secondary); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Day of Week
              </div>
              {daily.map(d => {
                const pct = (d.stories / maxDailyStories) * 100;
                const hrcbColor = d.avg_hrcb !== null ? scoreToColor(d.avg_hrcb) : 'var(--color-border)';
                return (
                  <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 2px;" title={`${d.day_name}: ${d.stories} stories, avg ${d.avg_hn_score} pts, avg ${d.avg_comments} cmt${d.avg_hrcb !== null ? `, HRCB ${formatScore(d.avg_hrcb)}` : ''}`}>
                    <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 28px;" class="score-font">{d.day_name.slice(0, 3)}</span>
                    <div style="flex: 1; height: 8px; background: var(--bg-surface); border-radius: 2px; overflow: hidden;">
                      <div style={`width: ${pct}%; height: 100%; background: ${hrcbColor}; border-radius: 2px; opacity: 0.8;`}></div>
                    </div>
                    <span style="color: var(--fg-secondary); font-size: var(--font-xs); width: 30px; text-align: right;" class="score-font">{d.stories}</span>
                  </div>
                );
              })}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* --- Karma vs HRCB correlation scatter --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style={`margin-bottom: 10px;${karmaUserCount < 5 ? ' display: none;' : ''}`}>
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px;">
        <div style="color: var(--fg-secondary); font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
          Karma vs HRCB
          <span style="text-transform: none; letter-spacing: 0; color: var(--fg-secondary); margin-left: 6px;">
            does HN reputation predict human rights alignment? · {karmaUserCount} users
          </span>
          <span style={`margin-left: 8px; padding: 1px 6px; border-radius: 3px; font-size: var(--font-xs); text-transform: none; letter-spacing: 0; background: var(--bg-surface); color: ${karmaRColor};`}>
            {karmaRLabel}
          </span>
        </div>
        <div style="color: var(--fg-secondary); font-size: var(--font-xs); margin-bottom: 4px;">
          X: karma (log scale) · Y: avg HRCB · hover for details
        </div>
        <canvas id="karma-scatter" width="800" height="400" style="width: 100%; max-width: 800px; height: auto; aspect-ratio: 2/1; background: var(--bg-primary); border-radius: 4px;" aria-label="User karma vs HRCB scatter plot"></canvas>
      </td>
    </tr>
  </table>

  {/* --- Main user table --- */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 20px;">
    <tr>
      <td style="padding: 10px; background: var(--bg-highlight); border: 1px solid var(--color-border); border-radius: 6px; overflow-x: auto;">
        <div style="overflow-x: auto;">
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm); min-width: 1050px;">
            <tr style="font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
              <td width="20" style="color: var(--fg-secondary);">#</td>
              <td style="color: var(--fg-secondary);">User</td>
              <td width="55" align="center" title="Stories seen in our crawl">
                <a href={sortUrl('stories')} style={thStyle('stories')}>Stories</a>
              </td>
              <td width="55" align="center" title="HN account karma">
                <a href={sortUrl('karma')} style={thStyle('karma')}>Karma</a>
              </td>
              <td width="55" align="center" title="Unique domains submitted">
                <a href={sortUrl('domains')} style={thStyle('domains')}>Domains</a>
              </td>
              <td width="80" align="center" style="color: var(--fg-secondary);" title="Most frequently submitted domain">Top Domain</td>
              <td width="65" align="center" title="Average HN score per story">
                <a href={sortUrl('avg_score')} style={thStyle('avg_score')}>Avg Pts</a>
              </td>
              <td width="65" align="center" title="Composite HRCB (full eval) — sort by HRCB">
                <a href={sortUrl('hrcb')} style={thStyle('hrcb')}>HRCB</a>
              </td>
              <td width="130" align="center" title="Full editorial (Claude, section-aggregate) / Structural. [E] = lite-only estimate.">
                <a href={sortUrl('editorial_full')} style={thStyle('editorial_full')}>E-full</a>
                <span style="color: var(--color-border);">/</span>
                <a href={sortUrl('structural')} style={thStyle('structural')}>S</a>
              </td>
              <td width="130" align="center" title="Percentage positive / neutral / negative HRCB">
                <a href={sortUrl('positive')} style={thStyle('positive')}>+</a>
                <span style="color: var(--color-border);">/</span>
                <span style="color: var(--fg-secondary);">0</span>
                <span style="color: var(--color-border);">/</span>
                <a href={sortUrl('negative')} style={thStyle('negative')}>-</a>
              </td>
              <td width="50" align="center" title="Epistemic Quality score (full evals)">
                <a href={sortUrl('eq')} style={thStyle('eq')}>EQ</a>
              </td>
              <td width="55" align="center" title="Full evaluations / lite-only evaluations">
                <a href={sortUrl('full_evaluated')} style={thStyle('full_evaluated')}>Evals</a>
              </td>
            </tr>
            {users.map((u, i) => {
              const eBarW = 50;
              const sBarW = 50;
              const ePct = u.avg_editorial_full !== null ? Math.abs(u.avg_editorial_full) * 50 : 0;
              const sPct = u.avg_structural !== null ? Math.abs(u.avg_structural) * 50 : 0;
              const eColor = u.avg_editorial_full !== null ? scoreToColor(u.avg_editorial_full) : 'var(--bg-surface)';
              const sColor = u.avg_structural !== null ? scoreToColor(u.avg_structural) : 'var(--bg-surface)';
              const isLiteOnly = u.full_evaluated === 0 && u.lite_evaluated > 0;
              return (
                <tr style="border-top: 1px solid var(--bg-surface);">
                  <td style="color: var(--fg-secondary);" class="score-font">{i + 1}</td>
                  <td>
                    <a href={`/user/${u.username}`} style="color: var(--fg-primary);">{u.username}</a>
                  </td>
                  <td align="center" class="score-font" style="color: var(--fg-secondary);">{u.stories}</td>
                  <td align="center" class="score-font" style="color: var(--fg-secondary);">
                    {u.karma != null ? u.karma.toLocaleString() : <span style="color: var(--color-border);">—</span>}
                  </td>
                  <td align="center" class="score-font" style="color: var(--fg-secondary);">{u.unique_domains}</td>
                  <td align="center" style="font-size: var(--font-xs);">
                    {u.top_domain
                      ? <a href={`/domain/${u.top_domain}`} style="color: var(--fg-secondary);">{u.top_domain.length > 15 ? u.top_domain.slice(0, 14) + '...' : u.top_domain}</a>
                      : <span style="color: var(--fg-secondary);">—</span>
                    }
                  </td>
                  <td align="center" class="score-font" style="color: var(--fg-secondary);">{u.avg_hn_score}</td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(u.avg_hrcb)}; font-weight: bold;`}>
                    {u.avg_hrcb !== null
                      ? formatScore(u.avg_hrcb)
                      : u.avg_editorial_lite !== null
                        ? <span style="color: var(--fg-secondary); font-size: var(--font-xs);">[E] {formatScore(u.avg_editorial_lite)}</span>
                        : <span style="color: var(--color-border);">—</span>
                    }
                  </td>
                  <td align="center">
                    {u.avg_editorial_full !== null && u.avg_structural !== null ? (
                      <div style="display: inline-flex; gap: 4px; align-items: center;" title={`E-full: ${formatScore(u.avg_editorial_full)} | S: ${formatScore(u.avg_structural)}`}>
                        <span style="color: var(--fg-secondary); font-size: 8px;">E</span>
                        <div style={`width: ${eBarW}px; height: 6px; background: var(--bg-surface); border-radius: 2px; position: relative; overflow: hidden;`}>
                          <div style={`position: absolute; ${(u.avg_editorial_full || 0) >= 0 ? 'left: 50%' : `left: ${50 - ePct}%`}; width: ${ePct}%; height: 100%; background: ${eColor}; border-radius: 1px;`}></div>
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--bg-surface);"></div>
                        </div>
                        <span style="color: var(--fg-secondary); font-size: 8px;">S</span>
                        <div style={`width: ${sBarW}px; height: 6px; background: var(--bg-surface); border-radius: 2px; position: relative; overflow: hidden;`}>
                          <div style={`position: absolute; ${(u.avg_structural || 0) >= 0 ? 'left: 50%' : `left: ${50 - sPct}%`}; width: ${sPct}%; height: 100%; background: ${sColor}; border-radius: 1px;`}></div>
                          <div style="position: absolute; left: 50%; top: 0; width: 1px; height: 100%; background: var(--bg-surface);"></div>
                        </div>
                      </div>
                    ) : <span style="color: var(--color-border);">—</span>}
                  </td>
                  <td align="center">
                    {u.positive_pct !== null ? (
                      <div style="display: inline-flex; gap: 0; width: 100px; height: 8px; border-radius: 2px; overflow: hidden;" title={`+${u.positive_pct}% / ${u.neutral_pct}% / ${u.negative_pct}%`}>
                        <div style={`width: ${u.positive_pct}%; background: var(--color-positive-vivid);`}></div>
                        <div style={`width: ${u.neutral_pct || 0}%; background: var(--fg-secondary);`}></div>
                        <div style={`width: ${u.negative_pct || 0}%; background: var(--color-negative);`}></div>
                      </div>
                    ) : <span style="color: var(--color-border);">—</span>}
                  </td>
                  <td align="center" class="score-font" style={`color: ${u.avg_eq !== null && u.avg_eq > 0.5 ? 'var(--channel-structural)' : 'var(--fg-secondary)'};`}>
                    {u.avg_eq !== null ? u.avg_eq.toFixed(2) : '—'}
                  </td>
                  <td align="center" class="score-font" style="color: var(--fg-secondary);">
                    {u.full_evaluated > 0
                      ? <span>{u.full_evaluated}{isLiteOnly ? '' : (u.lite_evaluated > 0 ? <span style="color: var(--color-border);">+{u.lite_evaluated}L</span> : '')}</span>
                      : u.lite_evaluated > 0
                        ? <span style="color: var(--fg-secondary); font-size: var(--font-xs);">{u.lite_evaluated}<span style="color: var(--color-border);">L</span></span>
                        : <span style="color: var(--color-border);">—</span>
                    }
                  </td>
                </tr>
              );
            })}
          </table>
        </div>
      </td>
    </tr>
  </table>

  <script define:vars={{ karmaScatterJson }}>
    const data = JSON.parse(karmaScatterJson);
    const canvas = document.getElementById('karma-scatter');
    if (canvas && data.length > 0) {
      const ctx = canvas.getContext('2d');
      const W = canvas.width, H = canvas.height;
      const pad = 50;

      const logKarmas = data.map(d => Math.log10(Math.max(d.k, 1)));
      const minLogK = Math.min(...logKarmas);
      const maxLogK = Math.max(...logKarmas, minLogK + 1);
      const minHrcb = Math.min(...data.map(d => d.h), -0.5);
      const maxHrcb = Math.max(...data.map(d => d.h), 0.5);

      function x(logK) { return pad + ((logK - minLogK) / (maxLogK - minLogK)) * (W - pad * 2); }
      function y(hrcb) { return H - pad - ((hrcb - minHrcb) / (maxHrcb - minHrcb)) * (H - pad * 2); }

      // Axes
      ctx.strokeStyle = '#1a5568';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad, pad); ctx.lineTo(pad, H - pad); ctx.lineTo(W - pad, H - pad);
      ctx.stroke();

      // Zero HRCB line
      if (minHrcb < 0 && maxHrcb > 0) {
        const zeroY = y(0);
        ctx.strokeStyle = '#0d4655';
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.moveTo(pad, zeroY); ctx.lineTo(W - pad, zeroY);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = '#5b7279';
        ctx.font = '10px monospace';
        ctx.fillText('0', pad - 12, zeroY + 3);
      }

      // Axis labels
      ctx.fillStyle = '#5b7279';
      ctx.font = '10px monospace';
      for (let p = Math.ceil(minLogK); p <= Math.floor(maxLogK); p++) {
        const xPos = x(p);
        const label = p >= 3 ? (Math.pow(10, p) / 1000) + 'K' : String(Math.pow(10, p));
        ctx.fillText(label, xPos - 8, H - pad + 15);
        ctx.strokeStyle = '#0d4655';
        ctx.beginPath();
        ctx.moveTo(xPos, H - pad); ctx.lineTo(xPos, H - pad + 4);
        ctx.stroke();
      }
      ctx.fillText(fmtScore(maxHrcb), 2, pad + 3);
      ctx.fillText(fmtScore(minHrcb), 2, H - pad + 3);
      ctx.fillText('karma', W / 2 - 15, H - 5);

      // Use shared scoreColor/fmtScore from Base.astro (window.scoreColor, window.fmtScore)
      const scoreColor = window.scoreColor;
      function fmtScore(s) {
        return window.fmtScore(s);
      }

      // Points
      for (let i = 0; i < data.length; i++) {
        const d = data[i];
        const radius = Math.min(3 + Math.log2(d.n), 7);
        ctx.beginPath();
        ctx.arc(x(logKarmas[i]), y(d.h), radius, 0, 2 * Math.PI);
        ctx.fillStyle = scoreColor(d.h);
        ctx.globalAlpha = 0.7;
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      // Hover tooltip
      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const scale = canvas.clientWidth / W;
        const mx = (e.clientX - rect.left) / scale;
        const my = (e.clientY - rect.top) / scale;
        let found = null;
        for (let i = 0; i < data.length; i++) {
          if (Math.hypot(x(logKarmas[i]) - mx, y(data[i].h) - my) < 8) {
            found = data[i];
            break;
          }
        }
        canvas.title = found
          ? `${found.u}\nkarma: ${found.k.toLocaleString()} · avg HRCB: ${fmtScore(found.h)} · ${found.n} stories`
          : '';
      });
    }
  </script>
</Base>
