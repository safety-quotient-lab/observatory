---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getSignalOverview } from '../lib/db';

const db = Astro.locals.runtime.env.DB;

let signalCount = 0;
let eqLabel = 'N/A';
let soLabel = 'N/A';
let srLabel = 'N/A';
let tdLabel = 'N/A';
try {
  const s = await getSignalOverview(db);
  signalCount = s.total_with_signals;
  eqLabel = s.avg_eq != null ? s.avg_eq.toFixed(2) : 'N/A';
  soLabel = s.avg_so != null ? s.avg_so.toFixed(2) : 'N/A';
  srLabel = s.avg_sr != null ? s.avg_sr.toFixed(2) : 'N/A';
  tdLabel = s.avg_td != null ? s.avg_td.toFixed(2) : 'N/A';
} catch { /* graceful fallback */ }
---

<Base title="Trends">
  <Breadcrumb crumbs={[{ label: 'home', href: '/' }, { label: 'trends' }]} />
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #98a8a8; font-weight: bold;">Trends</span>
        <span style="color: #5b7279; margin-left: 8px; font-size: var(--font-sm);">
          Temporal analysis and signal landscapes.
        </span>
      </td>
    </tr>
  </table>

  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0;">
    <tr>
      <td style="padding: 14px; background: #093946; border: 1px solid #1a5568; border-radius: 6px;">
        <div style="color: #5b7279; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">
          Key Signals
          <span style="text-transform: none; letter-spacing: 0; color: #5b7279; margin-left: 6px;">
            4 of 9 dimensions · {signalCount} stories
          </span>
        </div>

        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 100px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; padding: 10px; text-align: center;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
              Epistemic Quality
            </div>
            <div style="color: #60a5fa; font-size: var(--font-md); font-weight: bold; font-family: 'Fira Code', 'Courier New', monospace;">
              {eqLabel}
            </div>
            <div style="color: #1a5568; font-size: var(--font-xs);">avg EQ</div>
          </div>

          <div style="flex: 1; min-width: 100px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; padding: 10px; text-align: center;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
              Solution Orientation
            </div>
            <div style="color: #34d399; font-size: var(--font-md); font-weight: bold; font-family: 'Fira Code', 'Courier New', monospace;">
              {soLabel}
            </div>
            <div style="color: #1a5568; font-size: var(--font-xs);">avg SO</div>
          </div>

          <div style="flex: 1; min-width: 100px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; padding: 10px; text-align: center;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
              Stakeholder Rep
            </div>
            <div style="color: #fbbf24; font-size: var(--font-md); font-weight: bold; font-family: 'Fira Code', 'Courier New', monospace;">
              {srLabel}
            </div>
            <div style="color: #1a5568; font-size: var(--font-xs);">avg SR</div>
          </div>

          <div style="flex: 1; min-width: 100px; background: #0d4655; border: 1px solid #1a5568; border-radius: 4px; padding: 10px; text-align: center;">
            <div style="color: #5b7279; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
              Transparency
            </div>
            <div style="color: #a78bfa; font-size: var(--font-md); font-weight: bold; font-family: 'Fira Code', 'Courier New', monospace;">
              {tdLabel}
            </div>
            <div style="color: #1a5568; font-size: var(--font-xs);">avg TD</div>
          </div>
        </div>
      </td>
    </tr>
  </table>

  {/* Sub-page cards */}
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; padding: 5px 0 20px 0;">
    <a href="/seldon" style="text-decoration: none; display: block;">
      <div class="hub-card" style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; height: 100%; border-left: 3px solid #a78bfa; transition: border-color 0.15s;">
        <div style="color: #a78bfa; font-size: var(--font-md); font-weight: bold;">Seldon</div>
        <div style="color: #5b7279; font-size: var(--font-sm); margin-top: 4px; line-height: 1.5;">
          Psychohistorical trends. Regime change detection, rolling averages, per-feed analysis, and SETL drift.
        </div>
        <div style="color: #5b7279; font-size: var(--font-xs); margin-top: 6px;">/seldon &rarr;</div>
      </div>
    </a>
    <a href="/velocity" style="text-decoration: none; display: block;">
      <div class="hub-card" style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; height: 100%; border-left: 3px solid #34d399; transition: border-color 0.15s;">
        <div style="color: #34d399; font-size: var(--font-md); font-weight: bold;">Velocity</div>
        <div style="color: #5b7279; font-size: var(--font-sm); margin-top: 4px; line-height: 1.5;">
          Score-vs-velocity scatter plots and fastest-rising stories.
        </div>
        <div style="color: #5b7279; font-size: var(--font-xs); margin-top: 6px;">/velocity &rarr;</div>
      </div>
    </a>
    <a href="/dynamics" style="text-decoration: none; display: block;">
      <div class="hub-card" style="background: #093946; border: 1px solid #1a5568; border-radius: 6px; padding: 14px; height: 100%; border-left: 3px solid #60a5fa; transition: border-color 0.15s;">
        <div style="color: #60a5fa; font-size: var(--font-md); font-weight: bold;">Dynamics</div>
        <div style="color: #5b7279; font-size: var(--font-sm); margin-top: 4px; line-height: 1.5;">
          Engagement patterns, comment ratios, and slow burners.
        </div>
        <div style="color: #5b7279; font-size: var(--font-xs); margin-top: 6px;">/dynamics &rarr;</div>
      </div>
    </a>
  </div>

  <style>
    .hub-card:hover {
      border-color: #259d94 !important;
    }
  </style>
</Base>
