---
import Base from '../layouts/Base.astro';
import { scoreToColor, formatScore, confidenceToColor, formatConfidence } from '../lib/colors';
import { modelDisplayName, ALL_SECTIONS } from '../lib/shared-eval';
import { ARTICLE_TITLES } from '../lib/udhr';
import {
  getMultiModelStories,
  getModelComparisonAggregates,
  getModelSectionAverages,
  getRaterStatusBreakdown,
} from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [stories, aggregates, sectionAvgs, statusBreakdown] = await Promise.all([
  getMultiModelStories(db, 500),
  getModelComparisonAggregates(db),
  getModelSectionAverages(db),
  getRaterStatusBreakdown(db),
]);

// Get distinct model IDs from aggregates
const modelIds = aggregates.map(a => a.model);

// Build section averages lookup: model -> section -> avg_final
type SectionMap = Record<string, Record<string, number>>;
const sectionByModel: SectionMap = {};
for (const row of sectionAvgs) {
  if (!sectionByModel[row.model]) sectionByModel[row.model] = {};
  sectionByModel[row.model][row.section] = row.avg_final;
}

// Compute per-story sign agreement and score delta
const storyStats = stories.map(s => {
  const scores = s.models.map(m => m.score);
  const signs = scores.map(sc => sc >= 0 ? 1 : -1);
  const allAgree = signs.every(sg => sg === signs[0]);
  const maxDelta = scores.length >= 2
    ? Math.max(...scores) - Math.min(...scores)
    : 0;
  return { ...s, allAgree, maxDelta };
});

// Overall sign agreement rate
const totalStories = storyStats.length;
const agreeCount = storyStats.filter(s => s.allAgree).length;
const agreePct = totalStories > 0 ? Math.round((agreeCount / totalStories) * 100) : 0;

// Average delta
const avgDelta = totalStories > 0
  ? storyStats.reduce((sum, s) => sum + s.maxDelta, 0) / totalStories
  : 0;

// Most disagreed stories (largest delta)
const mostDisagreed = [...storyStats].sort((a, b) => b.maxDelta - a.maxDelta).slice(0, 10);

// Most agreed stories (smallest delta among evaluated)
const mostAgreed = [...storyStats].sort((a, b) => a.maxDelta - b.maxDelta).slice(0, 10);

// Correlation: Pearson between model pairs (if 2 models)
function pearsonCorrelation(xs: number[], ys: number[]): number | null {
  if (xs.length < 3) return null;
  const n = xs.length;
  const meanX = xs.reduce((a, b) => a + b, 0) / n;
  const meanY = ys.reduce((a, b) => a + b, 0) / n;
  let num = 0, denomX = 0, denomY = 0;
  for (let i = 0; i < n; i++) {
    const dx = xs[i] - meanX;
    const dy = ys[i] - meanY;
    num += dx * dy;
    denomX += dx * dx;
    denomY += dy * dy;
  }
  const denom = Math.sqrt(denomX * denomY);
  return denom === 0 ? null : num / denom;
}

// Build correlation matrix for model pairs
type PairCorrelation = { modelA: string; modelB: string; r: number | null; n: number };
const pairCorrelations: PairCorrelation[] = [];
for (let i = 0; i < modelIds.length; i++) {
  for (let j = i + 1; j < modelIds.length; j++) {
    const a = modelIds[i], b = modelIds[j];
    const xs: number[] = [], ys: number[] = [];
    for (const s of stories) {
      const sa = s.models.find(m => m.model === a);
      const sb = s.models.find(m => m.model === b);
      if (sa && sb) { xs.push(sa.score); ys.push(sb.score); }
    }
    pairCorrelations.push({ modelA: a, modelB: b, r: pearsonCorrelation(xs, ys), n: xs.length });
  }
}
---

<Base title="Model Comparison">
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 10px 0;">
    <tr>
      <td>
        <div style="color: #ccc; font-size: var(--font-lg); font-weight: bold; margin-bottom: 4px;">
          Model Comparison
        </div>
        <div style="color: #666; font-size: var(--font-sm);">
          {totalStories} stories evaluated by 2+ models
        </div>
      </td>
    </tr>
  </table>

  {totalStories === 0 ? (
    <table width="100%">
      <tr>
        <td style="padding: 40px 20px; text-align: center;">
          <div style="color: #828282; margin-bottom: 12px;">
            No stories have been evaluated by multiple models yet.
          </div>
          <div style="color: #555; font-size: var(--font-sm);">
            The backfill is in progress. Check the <a href="/dashboard" style="color: #ff6600;">dashboard</a> for status.
          </div>
        </td>
      </tr>
    </table>
  ) : (
    <>
      {/* Summary stats */}
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="display: flex; gap: 20px; flex-wrap: wrap;">
              <div>
                <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Sign Agreement</div>
                <span class="score-font" style={`color: ${agreePct >= 80 ? '#34d399' : agreePct >= 60 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
                  {agreePct}%
                </span>
                <span style="color: #555; font-size: var(--font-xs); margin-left: 4px;">{agreeCount}/{totalStories}</span>
              </div>
              <div>
                <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">Avg Score Delta</div>
                <span class="score-font" style={`color: ${avgDelta < 0.1 ? '#34d399' : avgDelta < 0.2 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
                  {avgDelta.toFixed(3)}
                </span>
              </div>
              {pairCorrelations.map(pc => (
                <div>
                  <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase; margin-bottom: 2px;">
                    r ({modelDisplayName(pc.modelA)} vs {modelDisplayName(pc.modelB)})
                  </div>
                  <span class="score-font" style={`color: ${pc.r !== null && pc.r >= 0.7 ? '#34d399' : pc.r !== null && pc.r >= 0.4 ? '#eab308' : '#dc2626'}; font-size: var(--font-lg); font-weight: bold;`}>
                    {pc.r !== null ? pc.r.toFixed(3) : '—'}
                  </span>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 4px;">n={pc.n}</span>
                </div>
              ))}
            </div>
          </td>
        </tr>
      </table>

      {/* Per-model aggregates */}
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Model Aggregates (shared stories only)</div>
            <table cellpadding="0" cellspacing="0" width="100%">
              <tr style="color: #666; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em;">
                <td style="padding: 4px 8px;">Model</td>
                <td style="padding: 4px 8px; text-align: center;">Stories</td>
                <td style="padding: 4px 8px; text-align: center;">Avg HRCB</td>
                <td style="padding: 4px 8px; text-align: center;">Avg |HRCB|</td>
                <td style="padding: 4px 8px; text-align: center;">Positive</td>
                <td style="padding: 4px 8px; text-align: center;">Neutral</td>
                <td style="padding: 4px 8px; text-align: center;">Negative</td>
                <td style="padding: 4px 8px; text-align: center;">Coverage</td>
              </tr>
              {aggregates.map(a => {
                const status = statusBreakdown.find(s => s.model === a.model);
                const coveragePct = status && status.total_primary > 0 ? Math.round((status.done / status.total_primary) * 100) : 100;
                return (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td style="padding: 6px 8px; color: #ccc; font-weight: bold; font-size: var(--font-sm);">{modelDisplayName(a.model)}</td>
                    <td style="padding: 6px 8px; text-align: center; color: #888;">{a.story_count}</td>
                    <td style={`padding: 6px 8px; text-align: center; font-weight: bold; color: ${scoreToColor(a.avg_score)};`}>
                      {formatScore(a.avg_score)}
                    </td>
                    <td style="padding: 6px 8px; text-align: center; color: #aaa;">{a.avg_abs_score.toFixed(3)}</td>
                    <td style="padding: 6px 8px; text-align: center; color: #34d399;">{a.positive_pct}%</td>
                    <td style="padding: 6px 8px; text-align: center; color: #888;">{a.neutral_pct}%</td>
                    <td style="padding: 6px 8px; text-align: center; color: #dc2626;">{a.negative_pct}%</td>
                    <td style="padding: 6px 8px; text-align: center;">
                      <div style="display: inline-flex; align-items: center; gap: 4px;">
                        <div style="width: 40px; height: 5px; background: #1a1a25; border-radius: 3px; overflow: hidden;">
                          <div style={`width: ${coveragePct}%; height: 100%; background: ${coveragePct >= 95 ? '#34d399' : coveragePct >= 50 ? '#eab308' : '#dc2626'}; border-radius: 3px;`}></div>
                        </div>
                        <span style={`color: ${coveragePct >= 95 ? '#34d399' : coveragePct >= 50 ? '#eab308' : '#dc2626'}; font-size: var(--font-xs);`}>{coveragePct}%</span>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </table>
          </td>
        </tr>
      </table>

      {/* Per-section heatmap */}
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Per-Section Average Scores</div>
            <div style="max-height: 500px; overflow-y: auto;">
              <table cellpadding="0" cellspacing="0" width="100%">
                <tr style="color: #666; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; position: sticky; top: 0; background: #12121a;">
                  <td style="padding: 3px 6px;">Section</td>
                  {modelIds.map(m => (
                    <td style="padding: 3px 6px; text-align: center;">{modelDisplayName(m)}</td>
                  ))}
                  {modelIds.length === 2 && <td style="padding: 3px 6px; text-align: center;">Delta</td>}
                </tr>
                {ALL_SECTIONS.map((section, idx) => {
                  const vals = modelIds.map(m => sectionByModel[m]?.[section] ?? null);
                  const delta = modelIds.length === 2 && vals[0] !== null && vals[1] !== null
                    ? vals[0]! - vals[1]!
                    : null;
                  const deltaColor = delta !== null
                    ? Math.abs(delta) < 0.05 ? '#555' : Math.abs(delta) < 0.15 ? '#eab308' : '#dc2626'
                    : '#555';
                  const title = idx > 0 && idx <= 30 ? ARTICLE_TITLES[idx - 1] : '';
                  return (
                    <tr style="border-top: 1px solid #1a1a25;">
                      <td style="padding: 2px 6px; color: #aaa; font-size: var(--font-xs);" title={title}>
                        <a href={`/article/${idx === 0 ? 'preamble' : idx}`} style="color: #aaa; text-decoration: none;">{section}</a>
                      </td>
                      {vals.map(v => (
                        <td style={`padding: 2px 6px; text-align: center; color: ${v !== null ? scoreToColor(v) : '#555'}; font-size: var(--font-sm);`}>
                          {v !== null ? v.toFixed(3) : '—'}
                        </td>
                      ))}
                      {delta !== null && (
                        <td style={`padding: 2px 6px; text-align: center; color: ${deltaColor}; font-size: var(--font-sm);`}>
                          {delta >= 0 ? '+' : ''}{delta.toFixed(3)}
                        </td>
                      )}
                    </tr>
                  );
                })}
              </table>
            </div>
          </td>
        </tr>
      </table>

      {/* Most disagreed stories */}
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td width="50%" valign="top" style="padding-right: 5px;">
            <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Disagreed</div>
              <table cellpadding="0" cellspacing="0" width="100%">
                <tr style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">
                  <td style="padding: 3px 6px;">Story</td>
                  {modelIds.map(m => (
                    <td style="padding: 3px 6px; text-align: center;">{modelDisplayName(m)}</td>
                  ))}
                  <td style="padding: 3px 6px; text-align: center;">Delta</td>
                </tr>
                {mostDisagreed.map(s => (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td style="padding: 3px 6px; font-size: var(--font-xs);">
                      <a href={`/item/${s.hn_id}`} style="color: #ccc; text-decoration: none;" title={s.title}>
                        {s.title.length > 50 ? s.title.slice(0, 50) + '...' : s.title}
                      </a>
                    </td>
                    {modelIds.map(mid => {
                      const me = s.models.find(m => m.model === mid);
                      return (
                        <td style={`padding: 3px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#555'}; font-size: var(--font-sm); font-weight: bold;`}>
                          {me ? formatScore(me.score) : '—'}
                        </td>
                      );
                    })}
                    <td style={`padding: 3px 6px; text-align: center; color: ${s.maxDelta >= 0.3 ? '#dc2626' : s.maxDelta >= 0.15 ? '#eab308' : '#555'}; font-size: var(--font-sm); font-weight: bold;`}>
                      {s.maxDelta.toFixed(3)}
                    </td>
                  </tr>
                ))}
              </table>
            </div>
          </td>
          <td width="50%" valign="top" style="padding-left: 5px;">
            <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
              <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Agreed</div>
              <table cellpadding="0" cellspacing="0" width="100%">
                <tr style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">
                  <td style="padding: 3px 6px;">Story</td>
                  {modelIds.map(m => (
                    <td style="padding: 3px 6px; text-align: center;">{modelDisplayName(m)}</td>
                  ))}
                  <td style="padding: 3px 6px; text-align: center;">Delta</td>
                </tr>
                {mostAgreed.map(s => (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td style="padding: 3px 6px; font-size: var(--font-xs);">
                      <a href={`/item/${s.hn_id}`} style="color: #ccc; text-decoration: none;" title={s.title}>
                        {s.title.length > 50 ? s.title.slice(0, 50) + '...' : s.title}
                      </a>
                    </td>
                    {modelIds.map(mid => {
                      const me = s.models.find(m => m.model === mid);
                      return (
                        <td style={`padding: 3px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#555'}; font-size: var(--font-sm); font-weight: bold;`}>
                          {me ? formatScore(me.score) : '—'}
                        </td>
                      );
                    })}
                    <td style={`padding: 3px 6px; text-align: center; color: #34d399; font-size: var(--font-sm);`}>
                      {s.maxDelta.toFixed(3)}
                    </td>
                  </tr>
                ))}
              </table>
            </div>
          </td>
        </tr>
      </table>

      {/* Full story-by-story comparison */}
      <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
        <tr>
          <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
            <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
              All Compared Stories
              <span style="color: #555; text-transform: none; letter-spacing: normal; margin-left: 8px;">{totalStories} stories</span>
            </div>
            <div style="max-height: 600px; overflow-y: auto;">
              <table cellpadding="0" cellspacing="0" width="100%">
                <tr style="color: #666; font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.05em; position: sticky; top: 0; background: #12121a;">
                  <td style="padding: 3px 6px;">Story</td>
                  {modelIds.map(m => (
                    <td style="padding: 3px 6px; text-align: center;">{modelDisplayName(m)}</td>
                  ))}
                  <td style="padding: 3px 6px; text-align: center;">Delta</td>
                  <td style="padding: 3px 6px; text-align: center;">Agree</td>
                </tr>
                {storyStats.map(s => (
                  <tr style="border-top: 1px solid #1a1a25;">
                    <td style="padding: 2px 6px; font-size: var(--font-xs);">
                      <a href={`/item/${s.hn_id}`} style="color: #aaa; text-decoration: none;" title={s.title}>
                        {s.title.length > 60 ? s.title.slice(0, 60) + '...' : s.title}
                      </a>
                    </td>
                    {modelIds.map(mid => {
                      const me = s.models.find(m => m.model === mid);
                      return (
                        <td style={`padding: 2px 6px; text-align: center; color: ${me ? scoreToColor(me.score) : '#555'}; font-size: var(--font-sm);`}>
                          {me ? formatScore(me.score) : '—'}
                        </td>
                      );
                    })}
                    <td style={`padding: 2px 6px; text-align: center; color: ${s.maxDelta >= 0.3 ? '#dc2626' : s.maxDelta >= 0.15 ? '#eab308' : '#555'}; font-size: var(--font-sm);`}>
                      {s.maxDelta.toFixed(3)}
                    </td>
                    <td style={`padding: 2px 6px; text-align: center; color: ${s.allAgree ? '#34d399' : '#dc2626'}; font-size: var(--font-sm);`}>
                      {s.allAgree ? 'Y' : 'N'}
                    </td>
                  </tr>
                ))}
              </table>
            </div>
          </td>
        </tr>
      </table>
    </>
  )}
</Base>
