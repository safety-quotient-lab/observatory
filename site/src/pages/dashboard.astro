---
import Base from '../layouts/Base.astro';
import { scoreToColor, formatScore, computeSetl, formatSetl, setlToColor, computeHotl, formatHotl, hotlToColor } from '../lib/colors';
import { ARTICLE_TITLES, ALL_SECTIONS } from '../lib/udhr';
import { CONTENT_TYPE_LABELS } from '../lib/types';
import {
  getStatusCounts,
  getScoreStats,
  getContentTypeStats,
  getArticleAverages,
  getTopPositiveStories,
  getTopNegativeStories,
  getRecentEvaluations,
  getDomainStats,
  getFailedStories,
  getQueueStories,
  getModelStats,
  getMeanSetl,
  getMeanHotl,
  getModelComparisonStats,
  getCostStats,
} from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [status, stats, contentTypes, articleAvgs, topPositive, topNegative, recent, domains, failed, queue, models, meanSetl, meanHotl, modelComparison, costStats] = await Promise.all([
  getStatusCounts(db),
  getScoreStats(db),
  getContentTypeStats(db),
  getArticleAverages(db),
  getTopPositiveStories(db, 5),
  getTopNegativeStories(db, 5),
  getRecentEvaluations(db, 10),
  getDomainStats(db, 10),
  getFailedStories(db, 5),
  getQueueStories(db),
  getModelStats(db),
  getMeanSetl(db),
  getMeanHotl(db),
  getModelComparisonStats(db),
  getCostStats(db),
]);

// Format token counts for display
function formatTokens(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return String(n);
}

// Helper to compute HOTL from a Story
function storyHotl(s: { hn_score: number | null; hn_comments: number | null }): number | null {
  return computeHotl(s.hn_score, s.hn_comments);
}

// Helper to compute aggregate SETL from a Story's hcb_json
function storySetl(s: { hcb_json: string | null }): number | null {
  if (!s.hcb_json) return null;
  try {
    const data = JSON.parse(s.hcb_json);
    const scores = data.scores as Array<{ editorial: number | null; structural: number | null }>;
    if (!scores) return null;
    const vals = scores
      .map((sc: { editorial: number | null; structural: number | null }) => computeSetl(sc.structural, sc.editorial))
      .filter((v: number | null): v is number => v !== null);
    if (vals.length === 0) return null;
    return vals.reduce((a: number, b: number) => a + b, 0) / vals.length;
  } catch { return null; }
}

const pctDone = status.total > 0 ? Math.round((status.done / status.total) * 100) : 0;
const pctPending = status.total > 0 ? Math.round((status.pending / status.total) * 100) : 0;
const pctFailed = status.total > 0 ? Math.round((status.failed / status.total) * 100) : 0;
const pctSkipped = status.total > 0 ? Math.round((status.skipped / status.total) * 100) : 0;

// Find the max signal count for relative bar widths
const maxSignal = Math.max(...articleAvgs.map(a => a.signal_count), 1);
---

<Base title="Dashboard">
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">Dashboard</span>
        <span style="color: #828282; margin-left: var(--space-lg);">Evaluation pipeline status &amp; analytics</span>
        <span id="live-indicator" style="margin-left: var(--space-lg); font-size: var(--font-xs); color: #555;">connecting...</span>
      </td>
    </tr>
  </table>

  {/* Pipeline Status */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Pipeline</div>

        {/* Progress bar */}
        <div style="width: 100%; height: 8px; background: #1a1a25; border-radius: 4px; overflow: hidden; display: flex; margin-bottom: 10px;">
          {status.done > 0 && <div style={`width: ${pctDone}%; background: #16a34a;`}></div>}
          {status.skipped > 0 && <div style={`width: ${pctSkipped}%; background: #555;`}></div>}
          {status.failed > 0 && <div style={`width: ${pctFailed}%; background: #dc2626;`}></div>}
          {status.pending > 0 && <div style={`width: ${pctPending}%; background: #333;`}></div>}
        </div>

        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-base);">
          <tr>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #16a34a; font-weight: bold;">{status.done}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Done</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #eab308; font-weight: bold;">{status.pending}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Pending</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #60a5fa; font-weight: bold;">{status.evaluating}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Evaluating</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #dc2626; font-weight: bold;">{status.failed}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Failed</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #555; font-weight: bold;">{status.skipped}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Skipped</div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* Score Overview + Distribution */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">HRCB Overview</div>
          <table cellpadding="6" cellspacing="0" width="100%" style="font-size: var(--font-base);">
            <tr>
              <td style="color: #666;">Mean HRCB</td>
              <td class="score-font" style={`color: ${scoreToColor(stats.avgScore)}; font-size: var(--font-lg); font-weight: bold;`}>
                {formatScore(stats.avgScore)}
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Structural-Editorial Tension Level">Mean SETL</td>
              <td class="score-font" style={`color: ${setlToColor(meanSetl)}; font-size: var(--font-base);`}>
                {formatSetl(meanSetl)}
                <span style="color: #555; font-size: var(--font-xs); margin-left: var(--space-sm);">{meanSetl !== null ? (meanSetl > 0 ? 'E-dominant' : meanSetl < 0 ? 'S-dominant' : 'Balanced') : ''}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Higher Order Tension Level — comments vs points">Mean HOTL</td>
              <td class="score-font" style={`color: ${hotlToColor(meanHotl)}; font-size: var(--font-base);`}>
                {formatHotl(meanHotl)}
                <span style="color: #555; font-size: var(--font-xs); margin-left: var(--space-sm);">{meanHotl !== null ? (meanHotl > 0 ? 'Contentious' : meanHotl < 0 ? 'Consensus' : 'Balanced') : ''}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Positive (&gt;+0.05)</td>
              <td>
                <span class="score-font" style="color: #16a34a;">{stats.positiveCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.positiveCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Neutral</td>
              <td>
                <span class="score-font" style="color: #888;">{stats.neutralCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.neutralCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Negative (&lt;-0.05)</td>
              <td>
                <span class="score-font" style="color: #dc2626;">{stats.negativeCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.negativeCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
          </table>
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Content Types</div>
          {contentTypes.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              {contentTypes.map((ct) => (
                <tr>
                  <td style="color: #c9c9c9; width: 80px;">
                    <span class="badge" style="background: #1a1a25; color: #888; font-size: var(--font-xs); cursor: help;"
                          title={CONTENT_TYPE_LABELS[ct.content_type] || ct.content_type}>
                      {ct.content_type}
                    </span>
                    <span style="margin-left: 3px;">{CONTENT_TYPE_LABELS[ct.content_type] || ct.content_type}</span>
                  </td>
                  <td class="score-font" style="color: #888; text-align: right; width: 30px;">{ct.count}</td>
                  <td class="score-font" style={`color: ${scoreToColor(ct.avg_score)}; text-align: right; width: 50px;`}>
                    {formatScore(ct.avg_score)}
                  </td>
                </tr>
              ))}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
    </tr>
  </table>

  {/* UDHR Article Heatmap — aggregate across all stories */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Average Score by UDHR Article</div>
        {articleAvgs.length > 0 ? (
          <>
            <table cellpadding="0" cellspacing="2" width="100%" style="font-size: var(--font-xs);">
              <tr>
                {articleAvgs.map((a) => {
                  const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                  return (
                    <td style="text-align: center; vertical-align: bottom; width: 3.2%;">
                      <a href={`/article/${a.sort_order}`} title={`${a.section}: ${ARTICLE_TITLES[a.section]}`} style="text-decoration: none;">
                        <div style={`width: 100%; height: 24px; background: ${scoreToColor(a.signal_count > 0 ? a.avg_final : null)}; border-radius: 2px; margin-bottom: 2px;`}></div>
                        <div style="color: #555;">{label}</div>
                      </a>
                    </td>
                  );
                })}
              </tr>
            </table>
            <div style="display: flex; gap: 12px; margin-top: 6px; font-size: var(--font-xs); color: #555;">
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #dc2626; border-radius: 2px;"></span> Negative</span>
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #eab308; border-radius: 2px;"></span> Neutral</span>
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #16a34a; border-radius: 2px;"></span> Positive</span>
              <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: #2a2a35; border-radius: 2px;"></span> No Data</span>
            </div>
          </>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Signal Coverage — bar chart showing how many stories have signal per article */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Signal Coverage by Article</div>
        {articleAvgs.length > 0 ? (
          <table cellpadding="1" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
            {articleAvgs.map((a) => {
              const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
              const pct = maxSignal > 0 ? Math.round((a.signal_count / maxSignal) * 100) : 0;
              return (
                <tr>
                  <td style="color: #666; width: 20px; text-align: right; padding-right: 6px;" class="score-font">
                    <a href={`/article/${a.sort_order}`} style="color: #666;">{label}</a>
                  </td>
                  <td>
                    <div style="display: flex; align-items: center; gap: 4px;">
                      <div style={`height: 6px; width: ${Math.max(pct, 2)}%; background: ${scoreToColor(a.signal_count > 0 ? a.avg_final : null)}; border-radius: 2px;`}></div>
                      <span style="color: #555;" class="score-font">{a.signal_count}</span>
                    </div>
                  </td>
                  <td style="width: 50px; text-align: right;" class="score-font">
                    <span style={`color: ${scoreToColor(a.signal_count > 0 ? a.avg_final : null)};`}>
                      {a.signal_count > 0 ? formatScore(a.avg_final) : <span title="No Data">—</span>}
                    </span>
                  </td>
                </tr>
              );
            })}
          </table>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Top Positive + Top Negative */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Positive</div>
          {topPositive.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              {topPositive.map((s, i) => {
                const setl = storySetl(s);
                const hotl = storyHotl(s);
                return (
                <tr>
                  <td style="color: #555; width: 16px;" class="score-font">{i + 1}.</td>
                  <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; width: 44px; font-weight: bold;`}>
                    {formatScore(s.hcb_weighted_mean)}
                  </td>
                  <td class="score-font" style={`color: ${setlToColor(setl)}; width: 36px;`}>
                    {formatSetl(setl)}
                  </td>
                  <td class="score-font" style={`color: ${hotlToColor(hotl)}; width: 36px;`}>
                    {formatHotl(hotl)}
                  </td>
                  <td>
                    <a href={`/item/${s.hn_id}`}>{s.title}</a>
                    {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                  </td>
                </tr>
                );
              })}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Most Negative</div>
          {topNegative.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              {topNegative.map((s, i) => {
                const setl = storySetl(s);
                const hotl = storyHotl(s);
                return (
                <tr>
                  <td style="color: #555; width: 16px;" class="score-font">{i + 1}.</td>
                  <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; width: 44px; font-weight: bold;`}>
                    {formatScore(s.hcb_weighted_mean)}
                  </td>
                  <td class="score-font" style={`color: ${setlToColor(setl)}; width: 36px;`}>
                    {formatSetl(setl)}
                  </td>
                  <td class="score-font" style={`color: ${hotlToColor(hotl)}; width: 36px;`}>
                    {formatHotl(hotl)}
                  </td>
                  <td>
                    <a href={`/item/${s.hn_id}`}>{s.title}</a>
                    {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                  </td>
                </tr>
                );
              })}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
    </tr>
  </table>

  {/* Domains */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Top Domains</div>
        {domains.length > 0 ? (
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td>Domain</td>
              <td width="60" align="center">Stories</td>
              <td width="60" align="center">Avg HRCB</td>
              <td width="50" align="center" title="Structural-Editorial Tension Level">SETL</td>
              <td width="50" align="center" title="Higher Order Tension Level">HOTL</td>
            </tr>
            {domains.map((d) => (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9;">{d.domain}</a>
                </td>
                <td align="center" class="score-font" style="color: #888;">{d.count}</td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(d.avg_score)};`}>
                  {formatScore(d.avg_score)}
                </td>
                <td align="center" class="score-font" style={`color: ${setlToColor(d.avg_setl)};`}>
                  {formatSetl(d.avg_setl)}
                </td>
                <td align="center" class="score-font" style={`color: ${hotlToColor(d.avg_hotl)};`}>
                  {formatHotl(d.avg_hotl)}
                </td>
              </tr>
            ))}
          </table>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Recent Evaluations */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Recent Evaluations</div>
        {recent.length > 0 ? (
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td width="50">HRCB</td>
              <td width="40">SETL</td>
              <td width="40">HOTL</td>
              <td>Story</td>
              <td width="60">Type</td>
              <td width="120">Evaluated</td>
            </tr>
            {recent.map((s) => {
              const setl = storySetl(s);
              const hotl = storyHotl(s);
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; font-weight: bold;`}>
                  {formatScore(s.hcb_weighted_mean)}
                </td>
                <td class="score-font" style={`color: ${setlToColor(setl)}; font-size: var(--font-sm);`}>
                  {formatSetl(setl)}
                </td>
                <td class="score-font" style={`color: ${hotlToColor(hotl)}; font-size: var(--font-sm);`}>
                  {formatHotl(hotl)}
                </td>
                <td>
                  <a href={`/item/${s.hn_id}`}>{s.title}</a>
                  {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td>
                  <span class="badge" style="background: #1a1a25; color: #888; font-size: var(--font-xs); cursor: help;"
                        title={CONTENT_TYPE_LABELS[s.content_type] || s.content_type}>
                    {s.content_type}
                  </span>
                </td>
                <td style="color: #555; font-size: var(--font-xs);">{s.evaluated_at || ''}</td>
              </tr>
              );
            })}
          </table>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Failed Stories */}
  {failed.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Recent Failures</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            {failed.map((s) => (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;">
                  {s.title}
                  {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td style="color: #dc2626; font-size: var(--font-xs); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.eval_error?.slice(0, 80) || 'Unknown error'}
                </td>
              </tr>
            ))}
          </table>
        </div>
      </td>
    </tr>
  </table>
  )}

  {/* Eval Model */}
  {models.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Evaluation Models
            {modelComparison.length > 1 && (
              <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                {modelComparison.length} models in history
              </span>
            )}
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td>Model</td>
              <td width="80" align="center">Active Evals</td>
              <td width="80" align="center">Avg HRCB</td>
              <td width="80" align="center">History</td>
              <td width="60" align="center">Min</td>
              <td width="60" align="center">Max</td>
            </tr>
            {models.map((m) => {
              const hist = modelComparison.find(mc => mc.eval_model === m.eval_model);
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;" class="score-font">{m.eval_model}</td>
                <td align="center" class="score-font" style="color: #888;">{m.count}</td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(m.avg_score)};`}>
                  {formatScore(m.avg_score)}
                </td>
                <td align="center" class="score-font" style="color: #555;">
                  {hist ? hist.count : '—'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.min_score ?? null)};`}>
                  {hist ? formatScore(hist.min_score) : '—'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.max_score ?? null)};`}>
                  {hist ? formatScore(hist.max_score) : '—'}
                </td>
              </tr>
              );
            })}
            {/* Show models only in history but not active */}
            {modelComparison
              .filter(mc => !models.find(m => m.eval_model === mc.eval_model))
              .map(mc => (
                <tr style="border-top: 1px solid #1a1a25;">
                  <td style="color: #666;" class="score-font">{mc.eval_model}</td>
                  <td align="center" class="score-font" style="color: #555;">—</td>
                  <td align="center" class="score-font" style="color: #555;">—</td>
                  <td align="center" class="score-font" style="color: #888;">{mc.count}</td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(mc.min_score)};`}>
                    {formatScore(mc.min_score)}
                  </td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(mc.max_score)};`}>
                    {formatScore(mc.max_score)}
                  </td>
                </tr>
              ))
            }
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Evaluation Queue */}
  {queue.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Queue
            <span style="color: #555; text-transform: none; letter-spacing: 0; margin-left: 6px;">
              {queue.length} stories waiting &middot; ~20 per batch &middot; est. {Math.ceil(queue.length / 20) * 10} min to clear
            </span>
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td width="24">#</td>
              <td width="70">Status</td>
              <td>Story</td>
              <td width="140">Domain</td>
            </tr>
            {queue.map((s, i) => (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #555;" class="score-font">{i + 1}</td>
                <td>
                  {s.eval_status === 'evaluating' ? (
                    <span class="badge" style="background: rgba(96,165,250,0.2); color: #60a5fa; font-size: var(--font-xs);">evaluating</span>
                  ) : (
                    <span class="badge" style="background: rgba(234,179,8,0.15); color: #eab308; font-size: var(--font-xs);">pending</span>
                  )}
                </td>
                <td>
                  <a href={s.url || `https://news.ycombinator.com/item?id=${s.hn_id}`}
                     target="_blank" rel="noopener" style="color: #c9c9c9;">
                    {s.title}
                  </a>
                </td>
                <td style="color: #555; font-size: var(--font-xs);">{s.domain || 'self'}</td>
              </tr>
            ))}
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Operations */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Operations</div>
        <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <tr>
            <td style="color: #666; width: 140px;">Cron interval</td>
            <td style="color: #c9c9c9;">Every 5 minutes</td>
          </tr>
          <tr>
            <td style="color: #666;">Score refresh</td>
            <td style="color: #c9c9c9;">Every 5 min (updates) · 48h sweep every 10 min</td>
          </tr>
          <tr>
            <td style="color: #666;">Eval today</td>
            <td>
              <span class="score-font" style="color: #eab308;">{costStats.today_evals}</span>
              <span style="color: #555;"> evals · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.today_input_tokens)}</span>
              <span style="color: #555;"> in · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.today_output_tokens)}</span>
              <span style="color: #555;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Total usage</td>
            <td>
              <span class="score-font" style="color: #16a34a;">{costStats.total_evals}</span>
              <span style="color: #555;"> evals · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.total_input_tokens)}</span>
              <span style="color: #555;"> in · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.total_output_tokens)}</span>
              <span style="color: #555;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Queue</td>
            <td>
              <span class="score-font" style="color: #60a5fa;">{status.evaluating}</span>
              <span style="color: #555;"> evaluating · </span>
              <span class="score-font" style="color: #eab308;">{queue.length}</span>
              <span style="color: #555;"> queued/pending</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Crawl surface</td>
            <td style="color: #c9c9c9;">top · new · best · ask · show (5 lists)</td>
          </tr>
          <tr>
            <td style="color: #666;">Architecture</td>
            <td style="color: #555; font-size: var(--font-xs);">Cron v5 → Queue → Consumer (fan-out) · KV content cache · KV DCP cache</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* Live feed toast area */}
  <div id="live-feed" style="position: fixed; bottom: 10px; right: 10px; z-index: 100; display: flex; flex-direction: column; gap: 4px; max-width: 320px;"></div>

  <script is:inline>
  (function() {
    const indicator = document.getElementById('live-indicator');
    const feed = document.getElementById('live-feed');
    let es;

    function connect() {
      es = new EventSource('/api/events');

      es.addEventListener('connected', function() {
        if (indicator) {
          indicator.style.color = '#16a34a';
          indicator.textContent = 'live';
        }
      });

      es.addEventListener('evaluation', function(e) {
        const d = JSON.parse(e.data);
        const score = d.hcb_weighted_mean !== null ? d.hcb_weighted_mean.toFixed(2) : '?';
        const toast = document.createElement('div');
        toast.style.cssText = 'background:#12121a;border:1px solid #222230;border-radius:4px;padding:6px 10px;font-size:8pt;color:#aaa;animation:fadeIn 0.3s;';
        toast.innerHTML = '<a href="/item/' + d.hn_id + '" style="color:#c9c9c9;">' + d.title.slice(0, 40) + '</a>' +
          ' <span style="color:' + (d.hcb_weighted_mean > 0.05 ? '#16a34a' : d.hcb_weighted_mean < -0.05 ? '#dc2626' : '#eab308') + ';font-family:monospace;">' + score + '</span>';
        if (feed) {
          feed.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 15000);
          // Keep max 3 toasts
          while (feed.children.length > 3) feed.removeChild(feed.firstChild);
        }
      });

      es.addEventListener('timeout', function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'reconnecting...'; }
        setTimeout(connect, 2000);
      });

      es.onerror = function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'offline'; }
        setTimeout(connect, 30000);
      };
    }

    connect();
  })();
  </script>
</Base>
