                      <>
                        <line x1={toX(v)} y1={m.t} x2={toX(v)} y2={m.t + ph} stroke={v === 0 ? '#2a2a35' : '#151520'} stroke-width="0.5" />
                        <line x1={m.l} y1={toY(v)} x2={m.l + pw} y2={toY(v)} stroke={v === 0 ? '#2a2a35' : '#151520'} stroke-width="0.5" />
                      </>
                    ))}
                    {/* Diagonal E=S (alignment line) */}
                    <line x1={toX(-1)} y1={toY(-1)} x2={toX(1)} y2={toY(1)} stroke="#333" stroke-width="1" stroke-dasharray="4,3" />
