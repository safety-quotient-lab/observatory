                      </circle>
                    ))}
                    {/* Axis tick labels */}
                    <text x={toX(-1)} y={h - 14} fill="#444" font-size="7" font-family="monospace" text-anchor="middle">-1</text>
                    <text x={toX(0)} y={h - 14} fill="#555" font-size="7" font-family="monospace" text-anchor="middle">0</text>
                    <text x={toX(1)} y={h - 14} fill="#444" font-size="7" font-family="monospace" text-anchor="middle">+1</text>
                    <text x={m.l - 4} y={toY(-1) + 3} fill="#444" font-size="7" font-family="monospace" text-anchor="end">-1</text>
