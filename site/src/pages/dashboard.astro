  </table>

  {/* Most/Least Confidence */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Highest Confidence</div>
          {topConf.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              <tr style="color: #444; font-size: 9px; text-transform: uppercase;">
                <td width="16">#</td><td width="34" title="Evidence-weighted confidence">Conf</td><td width="44" title="Human Rights Compatibility Bias">HRCB</td><td width="36" title="Structural-Editorial Tension Level">SETL</td><td>Story</td>
              </tr>
              {topConf.map((s, i) => {
                const setl = storySetl(s);
                const conf = storyConfidence(s);
                return (
                <tr>
                  <td style="color: #555; width: 16px;" class="score-font">{i + 1}.</td>
                  <td class="score-font" style={`color: ${confidenceToColor(conf)}; width: 34px; font-weight: bold;`}>
                    {formatConfidence(conf)}
                  </td>
                  <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; width: 44px;`}>
                    {formatScore(s.hcb_weighted_mean)}
                  </td>
                  <td class="score-font" style={`color: ${setlToColor(setl)}; width: 36px;`}>
                    {formatSetl(setl)}
                  </td>
                  <td>
                    <a href={`/item/${s.hn_id}`}>{s.title}</a>
                    {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                  </td>
                </tr>
                );
              })}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Lowest Confidence</div>
          {bottomConf.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              <tr style="color: #444; font-size: 9px; text-transform: uppercase;">
                <td width="16">#</td><td width="34">Conf</td><td width="44">HRCB</td><td width="36">SETL</td><td>Story</td>
              </tr>
              {bottomConf.map((s, i) => {
                const setl = storySetl(s);
                const conf = storyConfidence(s);
                return (
                <tr>
                  <td style="color: #555; width: 16px;" class="score-font">{i + 1}.</td>
                  <td class="score-font" style={`color: ${confidenceToColor(conf)}; width: 34px; font-weight: bold;`}>
                    {formatConfidence(conf)}
                  </td>
                  <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; width: 44px;`}>
                    {formatScore(s.hcb_weighted_mean)}
                  </td>
                  <td class="score-font" style={`color: ${setlToColor(setl)}; width: 36px;`}>
                    {formatSetl(setl)}
                  </td>
                  <td>
                    <a href={`/item/${s.hn_id}`}>{s.title}</a>
                    {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                  </td>
                </tr>
                );
              })}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
    </tr>
  </table>

  {/* Most Contested Articles (highest stddev) */}
  {contestedArticles.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Most Contested Articles
            <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">(highest score variance)</span>
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #444; font-size: 9px; text-transform: uppercase;">
              <td width="16">#</td>
              <td>Article</td>
              <td width="50" align="center" title="Standard deviation of scores">StdDev</td>
              <td width="50" align="center">Avg</td>
              <td width="50" align="center">Signals</td>
              <td width="75" align="center" title="Score range visualization">Range</td>
            </tr>
            {contestedArticles.map((a, i) => {
              const mean = a.avg_final ?? 0;
              const sd = a.stddev_final;
              const meanX = 30 + (mean + 1) * 30;
              const sdLow = 30 + Math.max(-1, mean - sd + 1) * 30;
              const sdHigh = 30 + Math.min(1, mean + sd + 1) * 30;
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #555;" class="score-font">{i + 1}.</td>
                <td>
                  <a href={`/article/${a.sort_order}`} style="color: #c9c9c9;">{a.section}</a>
                  <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">{ARTICLE_TITLES[a.section]}</span>
                </td>
                <td align="center" class="score-font" style="color: #fb923c; font-weight: bold;">{sd.toFixed(2)}</td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(a.avg_final)};`}>{formatScore(a.avg_final)}</td>
                <td align="center" class="score-font" style="color: #888;">{a.signal_count}</td>
                <td align="center">
                  <svg width="60" height="10" viewBox="0 0 60 10">
                    <line x1="0" y1="5" x2="60" y2="5" stroke="#1a1a25" stroke-width="1" />
                    <line x1="30" y1="2" x2="30" y2="8" stroke="#333" stroke-width="0.5" />
                    <rect x={sdLow} y="1" width={Math.max(sdHigh - sdLow, 1)} height="8" fill="rgba(251,146,60,0.3)" rx="1" />
                    <circle cx={meanX} cy="5" r="2.5" fill={scoreToColor(a.avg_final)} />
                    <title>Mean: {formatScore(a.avg_final)}, StdDev: {sd.toFixed(2)}</title>
                  </svg>
                </td>
              </tr>
              );
            })}
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Domains */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Top Domains</div>
        {domains.length > 0 ? (
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td>Domain</td>
              <td width="60" align="center">Stories</td>
              <td width="60" align="center">Avg HRCB</td>
              <td width="40" align="center" title="Evidence-weighted confidence">Conf</td>
              <td width="50" align="center" title="Structural-Editorial Tension Level">SETL</td>
              <td width="100" align="center" title="Per-article score fingerprint (P, 1–30)">Fingerprint</td>
            </tr>
            {domains.map((d) => {
              const fp = domainFingerprints.get(d.domain);
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;">
                  <a href={`/domain/${d.domain}`} style="color: #c9c9c9;">{d.domain}</a>
                </td>
                <td align="center" class="score-font" style="color: #888;">{d.count}</td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(d.avg_score)};`}>
                  {formatScore(d.avg_score)}
                </td>
                <td align="center" class="score-font" style={`color: ${confidenceToColor(d.avg_conf)};`}>
                  {formatConfidence(d.avg_conf)}
                </td>
                <td align="center" class="score-font" style={`color: ${setlToColor(d.avg_setl)};`}>
                  {formatSetl(d.avg_setl)}
                </td>
                <td align="center">
                  {fp ? (
                    <svg width="93" height="10" viewBox="0 0 93 10">
                      {fp.map((score, i) => (
                        <rect x={i * 3} y="0" width="2.5" height="10" rx="0.5"
                              fill={scoreToColor(score)}>
                          <title>{i === 0 ? 'Preamble' : `Article ${i}`}: {score !== null ? formatScore(score) : 'ND'}</title>
                        </rect>
                      ))}
                    </svg>
                  ) : (
                    <span style="color: #333;">—</span>
                  )}
                </td>
              </tr>
              );
            })}
          </table>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Recent Evaluations */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Recent Evaluations</div>
        {recent.length > 0 ? (
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td width="50">HRCB</td>
              <td width="34">Conf</td>
              <td width="40">SETL</td>
              <td>Story</td>
              <td width="60">Type</td>
              <td width="120">Evaluated</td>
            </tr>
            {recent.map((s) => {
              const setl = storySetl(s);
              const conf = storyConfidence(s);
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td class="score-font" style={`color: ${scoreToColor(s.hcb_weighted_mean)}; font-weight: bold;`}>
                  {formatScore(s.hcb_weighted_mean)}
                </td>
                <td class="score-font" style={`color: ${confidenceToColor(conf)}; font-size: var(--font-sm);`}>
                  {formatConfidence(conf)}
                </td>
                <td class="score-font" style={`color: ${setlToColor(setl)}; font-size: var(--font-sm);`}>
                  {formatSetl(setl)}
                </td>
                <td>
                  <a href={`/item/${s.hn_id}`}>{s.title}</a>
                  {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td>
                  <span class="badge" style="background: #1a1a25; color: #888; font-size: var(--font-xs); cursor: help;"
                        title={CONTENT_TYPE_LABELS[s.content_type] || s.content_type}>
                    {s.content_type}
                  </span>
                </td>
                <td style="color: #555; font-size: var(--font-xs);">{s.evaluated_at || ''}</td>
              </tr>
              );
            })}
          </table>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Enhanced Signal Coverage by Article */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Signal Coverage by Article</div>
        {articleStats.length > 0 ? (
          <>
            <table cellpadding="2" cellspacing="0" width="100%" style="font-size: var(--font-xs);">
              <tr style="color: #555; font-size: 9px; text-transform: uppercase; letter-spacing: 0.04em;">
                <td style="width: 20px;"></td>
                <td title="Editorial (top) / Structural (bottom) channel bars">E/S</td>
                <td style="width: 75px; text-align: right;" title="Signal count / total evaluated (%)">Cov</td>
                <td style="width: 50px; text-align: right;" title="No-data count (%)">ND</td>
                <td style="width: 32px; text-align: center;" title="Evidence quality: High (green), Medium (yellow), Low (gray)">Evid</td>
                <td style="width: 65px; text-align: center;" title="Score range: mean with standard deviation">Range</td>
                <td style="width: 85px; text-align: center;" title="Trend sparkline of last 30 scores">Trend</td>
                <td style="width: 50px; text-align: right;" title="Average final score">Score</td>
              </tr>
              {articleStats.map((a) => {
                const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                const ePct = maxSignal > 0 ? Math.round((a.signal_count / maxSignal) * 100) : 0;
                const total = totalEvaluated || (a.signal_count + a.nd_count);
                const covPct = total > 0 ? Math.round((a.signal_count / total) * 100) : 0;
                const ndPct = total > 0 ? Math.round((a.nd_count / total) * 100) : 0;
                const evidTotal = a.evidence_h + a.evidence_m + a.evidence_l;
                const hPct = evidTotal > 0 ? (a.evidence_h / evidTotal) * 28 : 0;
                const mPct = evidTotal > 0 ? (a.evidence_m / evidTotal) * 28 : 0;
                const lPct = evidTotal > 0 ? (a.evidence_l / evidTotal) * 28 : 0;
                const mean = a.avg_final ?? 0;
                const sd = a.stddev_final;
                const meanX = 30 + (mean + 1) * 30; // map -1..+1 to 0..60
                const sdLow = 30 + Math.max(-1, mean - sd + 1) * 30;
                const sdHigh = 30 + Math.min(1, mean + sd + 1) * 30;
                const spark = sparklines.get(a.section) || [];
                let sparkPath = '';
                if (spark.length > 1) {
                  const w = 80, h = 16;
                  const step = w / (spark.length - 1);
                  sparkPath = spark.map((v, i) => {
                    const x = i * step;
                    const y = h / 2 - (v * h / 2);
                    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`;
                  }).join(' ');
                }
                return (
                  <tr>
                    <td style="color: #666; width: 20px; text-align: right; padding-right: 6px;" class="score-font">
                      <a href={`/article/${a.sort_order}`} style="color: #666;" title={`${a.section}: ${ARTICLE_TITLES[a.section]}`}>{label}</a>
                    </td>
                    <td>
                      <div style="display: flex; flex-direction: column; gap: 1px;">
                        <div style={`height: 6px; width: ${Math.max(ePct, 2)}%; background: ${scoreToColor(a.signal_count > 0 ? a.avg_editorial : null)}; border-radius: 2px 2px 0 0;`} title={`Editorial: ${a.avg_editorial !== null ? formatScore(a.avg_editorial) : 'ND'}`}></div>
                        <div style={`height: 6px; width: ${Math.max(ePct, 2)}%; background: ${scoreToColor(a.signal_count > 0 ? a.avg_structural : null)}; border-radius: 0 0 2px 2px; opacity: 0.7;`} title={`Structural: ${a.avg_structural !== null ? formatScore(a.avg_structural) : 'ND'}`}></div>
                      </div>
                    </td>
                    <td style="width: 75px; text-align: right; color: #888;" class="score-font">
                      {a.signal_count}/{total} <span style="color: #555;">({covPct}%)</span>
                    </td>
                    <td style="width: 50px; text-align: right; color: #555;" class="score-font">
                      {a.nd_count} <span style="color: #444;">({ndPct}%)</span>
                    </td>
                    <td style="width: 32px; text-align: center;">
                      {evidTotal > 0 ? (
                        <svg width="28" height="10" viewBox="0 0 28 10">
                          <rect x="0" y="0" width={hPct} height="10" fill="#22c55e" rx="1" />
                          <rect x={hPct} y="0" width={mPct} height="10" fill="#eab308" />
                          <rect x={hPct + mPct} y="0" width={lPct} height="10" fill="#6b7280" rx="1" />
                          <title>H:{a.evidence_h} M:{a.evidence_m} L:{a.evidence_l}</title>
                        </svg>
                      ) : (
                        <span style="color: #444;">—</span>
                      )}
                    </td>
                    <td style="width: 65px; text-align: center;">
                      {a.signal_count > 0 ? (
                        <svg width="60" height="10" viewBox="0 0 60 10">
                          <line x1="0" y1="5" x2="60" y2="5" stroke="#1a1a25" stroke-width="1" />
                          <line x1="30" y1="2" x2="30" y2="8" stroke="#333" stroke-width="0.5" />
                          <rect x={sdLow} y="1" width={Math.max(sdHigh - sdLow, 1)} height="8" fill="rgba(99,102,241,0.25)" rx="1" />
                          <circle cx={meanX} cy="5" r="2.5" fill={scoreToColor(a.avg_final)} />
                          <title>Mean: {formatScore(a.avg_final)}, StdDev: {sd.toFixed(2)}</title>
                        </svg>
                      ) : (
                        <span style="color: #444;">—</span>
                      )}
                    </td>
                    <td style="width: 85px; text-align: center;">
                      {spark.length > 1 ? (
                        <svg width="80" height="16" viewBox="0 0 80 16">
                          <line x1="0" y1="8" x2="80" y2="8" stroke="#1a1a25" stroke-width="0.5" />
                          <path d={sparkPath} fill="none" stroke="#6366f1" stroke-width="1" />
                          <title>Last {spark.length} scores</title>
                        </svg>
                      ) : (
                        <span style="color: #444;">—</span>
                      )}
                    </td>
                    <td style="width: 50px; text-align: right;" class="score-font">
                      <span style={`color: ${scoreToColor(a.signal_count > 0 ? a.avg_final : null)};`}>
                        {a.signal_count > 0 ? formatScore(a.avg_final) : <span title="No Data">—</span>}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </table>
            <div style="display: flex; gap: 12px; margin-top: 8px; font-size: 9px; color: #444;">
              <span>E/S: top bar = editorial avg, bottom = structural avg</span>
              <span>Evid: <span style="color: #22c55e;">H</span> <span style="color: #eab308;">M</span> <span style="color: #6b7280;">L</span></span>
              <span>Range: <span style="color: rgba(99,102,241,0.6);">shaded</span> = 1 stddev</span>
              <span>Trend: <span style="color: #6366f1;">sparkline</span> last 30</span>
            </div>
          </>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* Eval Model */}
  {models.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Evaluation Models
            {modelComparison.length > 1 && (
              <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">
                {modelComparison.length} models in history
              </span>
            )}
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td>Model</td>
              <td width="80" align="center">Active Evals</td>
              <td width="80" align="center">Avg HRCB</td>
              <td width="80" align="center">History</td>
              <td width="60" align="center">Min</td>
              <td width="60" align="center">Max</td>
            </tr>
            {models.map((m) => {
              const hist = modelComparison.find(mc => mc.eval_model === m.eval_model);
              return (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;" class="score-font">{m.eval_model}</td>
                <td align="center" class="score-font" style="color: #888;">{m.count}</td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(m.avg_score)};`}>
                  {formatScore(m.avg_score)}
                </td>
                <td align="center" class="score-font" style="color: #555;">
                  {hist ? hist.count : '—'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.min_score ?? null)};`}>
                  {hist ? formatScore(hist.min_score) : '—'}
                </td>
                <td align="center" class="score-font" style={`color: ${scoreToColor(hist?.max_score ?? null)};`}>
                  {hist ? formatScore(hist.max_score) : '—'}
                </td>
              </tr>
              );
            })}
            {/* Show models only in history but not active */}
            {modelComparison
              .filter(mc => !models.find(m => m.eval_model === mc.eval_model))
              .map(mc => (
                <tr style="border-top: 1px solid #1a1a25;">
                  <td style="color: #666;" class="score-font">{mc.eval_model}</td>
                  <td align="center" class="score-font" style="color: #555;">—</td>
                  <td align="center" class="score-font" style="color: #555;">—</td>
                  <td align="center" class="score-font" style="color: #888;">{mc.count}</td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(mc.min_score)};`}>
                    {formatScore(mc.min_score)}
                  </td>
                  <td align="center" class="score-font" style={`color: ${scoreToColor(mc.max_score)};`}>
                    {formatScore(mc.max_score)}
                  </td>
                </tr>
              ))
            }
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Failed Stories */}
  {failed.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Recent Failures</div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            {failed.map((s) => (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #c9c9c9;">
                  {s.title}
                  {s.domain && <span style="color: #555; font-size: var(--font-xs); margin-left: 3px;">({s.domain})</span>}
                </td>
                <td style="color: #dc2626; font-size: var(--font-xs); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {s.eval_error?.slice(0, 80) || 'Unknown error'}
                </td>
              </tr>
            ))}
          </table>
        </div>
      </td>
    </tr>
  </table>
  )}

  {/* Evaluation Queue */}
  {queue.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Queue
            <span style="color: #555; text-transform: none; letter-spacing: 0; margin-left: 6px;">
              {queue.length} stories waiting &middot; ~20 per batch &middot; est. {Math.ceil(queue.length / 20) * 10} min to clear
            </span>
          </div>
          <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
            <tr style="color: #555; font-size: var(--font-xs);">
              <td width="24">#</td>
              <td width="70">Status</td>
              <td>Story</td>
              <td width="140">Domain</td>
            </tr>
            {queue.map((s, i) => (
              <tr style="border-top: 1px solid #1a1a25;">
                <td style="color: #555;" class="score-font">{i + 1}</td>
                <td>
                  {s.eval_status === 'evaluating' ? (
                    <span class="badge" style="background: rgba(96,165,250,0.2); color: #60a5fa; font-size: var(--font-xs);">evaluating</span>
                  ) : (
                    <span class="badge" style="background: rgba(234,179,8,0.15); color: #eab308; font-size: var(--font-xs);">pending</span>
                  )}
                </td>
                <td>
                  <a href={s.url || `https://news.ycombinator.com/item?id=${s.hn_id}`}
                     target="_blank" rel="noopener" style="color: #c9c9c9;">
                    {s.title}
                  </a>
                </td>
                <td style="color: #555; font-size: var(--font-xs);">{s.domain || 'self'}</td>
              </tr>
            ))}
          </table>
        </td>
      </tr>
    </table>
  )}

  {/* Operations */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Operations</div>
        <table cellpadding="4" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
          <tr>
            <td style="color: #666; width: 140px;">Cron interval</td>
            <td style="color: #c9c9c9;">Every 5 minutes</td>
          </tr>
          <tr>
            <td style="color: #666;">Score refresh</td>
            <td style="color: #c9c9c9;">Every 5 min (updates) · 48h sweep every 10 min</td>
          </tr>
          <tr>
            <td style="color: #666;">Eval today</td>
            <td>
              <span class="score-font" style="color: #eab308;">{costStats.today_evals}</span>
              <span style="color: #555;"> evals · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.today_input_tokens)}</span>
              <span style="color: #555;"> in · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.today_output_tokens)}</span>
              <span style="color: #555;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Total usage</td>
            <td>
              <span class="score-font" style="color: #16a34a;">{costStats.total_evals}</span>
              <span style="color: #555;"> evals · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.total_input_tokens)}</span>
              <span style="color: #555;"> in · </span>
              <span class="score-font" style="color: #888;">{formatTokens(costStats.total_output_tokens)}</span>
              <span style="color: #555;"> out</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Queue</td>
            <td>
              <span class="score-font" style="color: #60a5fa;">{status.evaluating}</span>
              <span style="color: #555;"> evaluating · </span>
              <span class="score-font" style="color: #eab308;">{queue.length}</span>
              <span style="color: #555;"> queued/pending</span>
            </td>
          </tr>
          <tr>
            <td style="color: #666;">Crawl surface</td>
            <td style="color: #c9c9c9;">top · new · best · ask · show (5 lists)</td>
          </tr>
          <tr>
            <td style="color: #666;">Architecture</td>
            <td style="color: #555; font-size: var(--font-xs);">Cron v5 → Queue → Consumer (fan-out) · KV content cache · KV DCP cache</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {/* Live feed toast area */}
  <div id="live-feed" style="position: fixed; bottom: 10px; right: 10px; z-index: 100; display: flex; flex-direction: column; gap: 4px; max-width: 320px;"></div>

  <script is:inline>
  (function() {
    // Correlation matrix tab toggle
    var tabCo = document.getElementById('tab-cooccurrence');
    var tabCorr = document.getElementById('tab-correlation');
    var matCo = document.getElementById('matrix-cooccurrence');
    var matCorr = document.getElementById('matrix-correlation');
    if (tabCo && tabCorr && matCo && matCorr) {
      tabCo.addEventListener('click', function() {
        matCo.style.display = ''; matCorr.style.display = 'none';
        tabCo.style.color = '#ff6600'; tabCo.style.fontWeight = 'bold';
        tabCorr.style.color = '#555'; tabCorr.style.fontWeight = 'normal';
      });
      tabCorr.addEventListener('click', function() {
        matCorr.style.display = ''; matCo.style.display = 'none';
        tabCorr.style.color = '#ff6600'; tabCorr.style.fontWeight = 'bold';
        tabCo.style.color = '#555'; tabCo.style.fontWeight = 'normal';
      });
    }

    const indicator = document.getElementById('live-indicator');
    const feed = document.getElementById('live-feed');
    let es;

    function connect() {
      es = new EventSource('/api/events');

      es.addEventListener('connected', function() {
        if (indicator) {
          indicator.style.color = '#16a34a';
          indicator.textContent = 'live';
        }
      });

      es.addEventListener('evaluation', function(e) {
        const d = JSON.parse(e.data);
        const score = d.hcb_weighted_mean !== null ? d.hcb_weighted_mean.toFixed(2) : '?';
        const toast = document.createElement('div');
        toast.style.cssText = 'background:#12121a;border:1px solid #222230;border-radius:4px;padding:6px 10px;font-size:8pt;color:#aaa;animation:fadeIn 0.3s;';
        toast.innerHTML = '<a href="/item/' + d.hn_id + '" style="color:#c9c9c9;">' + d.title.slice(0, 40) + '</a>' +
          ' <span style="color:' + (d.hcb_weighted_mean > 0.05 ? '#16a34a' : d.hcb_weighted_mean < -0.05 ? '#dc2626' : '#eab308') + ';font-family:monospace;">' + score + '</span>';
        if (feed) {
          feed.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 15000);
          // Keep max 3 toasts
          while (feed.children.length > 3) feed.removeChild(feed.firstChild);
        }
      });

      es.addEventListener('timeout', function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'reconnecting...'; }
        setTimeout(connect, 2000);
      });

      es.onerror = function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'offline'; }
        setTimeout(connect, 30000);
      };
    }

    connect();
  })();
  </script>
</Base>
