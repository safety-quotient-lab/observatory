---
import Base from '../layouts/Base.astro';
import { scoreToColor, formatScore, computeSetl, formatSetl, setlToColor, computeConfidence, confidenceToColor, formatConfidence } from '../lib/colors';
import { ARTICLE_TITLES, ALL_SECTIONS } from '../lib/udhr';
import { CONTENT_TYPE_LABELS } from '../lib/types';
import {
  getStatusCounts,
  getScoreStats,
  getContentTypeStats,
  getArticleDetailedStats,
  getArticleSparklines,
  getArticlePairStats,
  getTopPositiveStories,
  getTopNegativeStories,
  getRecentEvaluations,
  getDomainStats,
  getFailedStories,
  getQueueStories,
  getModelStats,
  getMeanSetl,
  getModelComparisonStats,
  getCostStats,
  getTopSetlStories,
  getBottomSetlStories,
  getScoreHistogram,
  getMeanConfidence,
  getVelocityStats,
  getTopConfidenceStories,
  getBottomConfidenceStories,
  getStoryScatterData,
  getDomainFingerprints,
  getContentTypeDistribution,
} from '../lib/db';

const db = Astro.locals.runtime.env.DB;

const [status, stats, contentTypes, articleStats, sparklines, pairStats, topPositive, topNegative, topSetl, bottomSetl, recent, domains, failed, queue, models, meanSetl, modelComparison, costStats, histogram, meanConfidence, topConf, bottomConf, scatterData, ctDist] = await Promise.all([
  getStatusCounts(db),
  getScoreStats(db),
  getContentTypeStats(db),
  getArticleDetailedStats(db),
  getArticleSparklines(db, 30),
  getArticlePairStats(db),
  getTopPositiveStories(db, 5),
  getTopNegativeStories(db, 5),
  getTopSetlStories(db, 5),
  getBottomSetlStories(db, 5),
  getRecentEvaluations(db, 10),
  getDomainStats(db, 10),
  getFailedStories(db, 5),
  getQueueStories(db),
  getModelStats(db),
  getMeanSetl(db),
  getModelComparisonStats(db),
  getCostStats(db),
  getScoreHistogram(db),
  getMeanConfidence(db),
  getTopConfidenceStories(db, 5),
  getBottomConfidenceStories(db, 5),
  getStoryScatterData(db, 500),
  getContentTypeDistribution(db),
]);

// Velocity needs pending count from status
const velocity = await getVelocityStats(db, status.pending);

// Domain fingerprints (depends on domains result)
const domainFingerprints = await getDomainFingerprints(db, domains.map(d => d.domain));

// Format token counts for display
function formatTokens(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(0) + 'K';
  return String(n);
}

// Helper to compute aggregate SETL from a Story's hcb_json
function storySetl(s: { hcb_json: string | null }): number | null {
  if (!s.hcb_json) return null;
  try {
    const data = JSON.parse(s.hcb_json);
    const scores = data.scores as Array<{ editorial: number | null; structural: number | null }>;
    if (!scores) return null;
    const vals = scores
      .map((sc: { editorial: number | null; structural: number | null }) => computeSetl(sc.structural, sc.editorial))
      .filter((v: number | null): v is number => v !== null);
    if (vals.length === 0) return null;
    return vals.reduce((a: number, b: number) => a + b, 0) / vals.length;
  } catch { return null; }
}

// Most contested articles (highest stddev)
const contestedArticles = [...articleStats]
  .filter(a => a.signal_count >= 3)
  .sort((a, b) => b.stddev_final - a.stddev_final)
  .slice(0, 5);

const pctDone = status.total > 0 ? Math.round((status.done / status.total) * 100) : 0;
const pctPending = status.total > 0 ? Math.round((status.pending / status.total) * 100) : 0;
const pctFailed = status.total > 0 ? Math.round((status.failed / status.total) * 100) : 0;
const pctSkipped = status.total > 0 ? Math.round((status.skipped / status.total) * 100) : 0;

// Find the max signal count for relative bar widths
const maxSignal = Math.max(...articleStats.map(a => a.signal_count), 1);
const totalEvaluated = status.done;

// Helper: evidence-weighted confidence for dashboard story rows
function storyConfidence(s: { hcb_evidence_h: number | null; hcb_evidence_m: number | null; hcb_evidence_l: number | null; hcb_nd_count: number | null }): number | null {
  return computeConfidence(s.hcb_evidence_h, s.hcb_evidence_m, s.hcb_evidence_l, s.hcb_nd_count);
}
---

<Base title="Dashboard">
  {/* Header */}
  <table cellpadding="0" cellspacing="0" width="100%" style="padding: 5px 0 10px 0;">
    <tr>
      <td>
        <span style="font-size: var(--font-md); color: #c9c9c9; font-weight: bold;">Dashboard</span>
        <span style="color: #828282; margin-left: var(--space-lg);">Evaluation pipeline status &amp; analytics</span>
        <span id="live-indicator" style="margin-left: var(--space-lg); font-size: var(--font-xs); color: #555;">connecting...</span>
      </td>
    </tr>
  </table>
  {/* Pipeline Status */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Pipeline</div>

        {/* Progress bar */}
        <div style="width: 100%; height: 8px; background: #1a1a25; border-radius: 4px; overflow: hidden; display: flex; margin-bottom: 10px;">
          {status.done > 0 && <div style={`width: ${pctDone}%; background: #16a34a;`}></div>}
          {status.skipped > 0 && <div style={`width: ${pctSkipped}%; background: #555;`}></div>}
          {status.failed > 0 && <div style={`width: ${pctFailed}%; background: #dc2626;`}></div>}
          {status.pending > 0 && <div style={`width: ${pctPending}%; background: #333;`}></div>}
        </div>

        <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-base);">
          <tr>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #16a34a; font-weight: bold;">{status.done}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Done</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #eab308; font-weight: bold;">{status.pending}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Pending</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #60a5fa; font-weight: bold;">{status.evaluating}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Evaluating</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #dc2626; font-weight: bold;">{status.failed}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Failed</div>
            </td>
            <td style="text-align: center; width: 20%;">
              <div class="score-font" style="font-size: var(--font-lg); color: #555; font-weight: bold;">{status.skipped}</div>
              <div style="color: #666; font-size: var(--font-xs); text-transform: uppercase;">Skipped</div>
            </td>
          </tr>
        </table>
        {velocity.evalsPerDay > 0 && (
          <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #1a1a25; display: flex; gap: 16px; font-size: var(--font-sm); color: #666;">
            <span>
              <span class="score-font" style="color: #888;">{velocity.evalsPerDay.toFixed(1)}</span> evals/day
            </span>
            <span>
              <span class="score-font" style="color: #888;">{velocity.daysActive}</span> days active
            </span>
            {velocity.daysToClearing !== null && status.pending > 0 && (
              <span>
                est. <span class="score-font" style="color: #eab308;">{velocity.daysToClearing < 1 ? '<1' : Math.ceil(velocity.daysToClearing)}</span> {velocity.daysToClearing < 1.5 ? 'day' : 'days'} to clear backlog
              </span>
            )}
          </div>
        )}
      </td>
    </tr>
  </table>
  {/* Score Overview + Distribution */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">HRCB Overview</div>
          <table cellpadding="6" cellspacing="0" width="100%" style="font-size: var(--font-base);">
            <tr>
              <td style="color: #666;">Mean HRCB</td>
              <td class="score-font" style={`color: ${scoreToColor(stats.avgScore)}; font-size: var(--font-lg); font-weight: bold;`}>
                {formatScore(stats.avgScore)}
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Evidence-weighted confidence: (H×1.0 + M×0.6 + L×0.2) / total">Mean Confidence</td>
              <td class="score-font" style={`color: ${confidenceToColor(meanConfidence)}; font-size: var(--font-base);`}>
                {formatConfidence(meanConfidence)}
              </td>
            </tr>
            <tr>
              <td style="color: #666;" title="Structural-Editorial Tension Level">Mean SETL</td>
              <td class="score-font" style={`color: ${setlToColor(meanSetl)}; font-size: var(--font-base);`}>
                {formatSetl(meanSetl)}
                <span style="color: #555; font-size: var(--font-xs); margin-left: var(--space-sm);">{meanSetl !== null ? (meanSetl > 0 ? 'E-dominant' : meanSetl < 0 ? 'S-dominant' : 'Balanced') : ''}</span>
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Positive (&gt;+0.05)</td>
              <td>
                <span class="score-font" style="color: #16a34a;">{stats.positiveCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.positiveCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Neutral</td>
              <td>
                <span class="score-font" style="color: #888;">{stats.neutralCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.neutralCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
            <tr>
              <td style="color: #666;">Negative (&lt;-0.05)</td>
              <td>
                <span class="score-font" style="color: #dc2626;">{stats.negativeCount}</span>
                {status.done > 0 && <span style="color: #555; font-size: var(--font-sm); margin-left: 4px;">({Math.round((stats.negativeCount / status.done) * 100)}%)</span>}
              </td>
            </tr>
          </table>
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Content Types</div>
          {contentTypes.length > 0 ? (
            <table cellpadding="3" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
              {contentTypes.map((ct) => (
                <tr>
                  <td style="color: #c9c9c9; width: 80px;">
                    <span class="badge" style="background: #1a1a25; color: #888; font-size: var(--font-xs); cursor: help;"
                          title={CONTENT_TYPE_LABELS[ct.content_type] || ct.content_type}>
                      {ct.content_type}
                    </span>
                    <span style="margin-left: 3px;">{CONTENT_TYPE_LABELS[ct.content_type] || ct.content_type}</span>
                  </td>
                  <td class="score-font" style="color: #888; text-align: right; width: 30px;">{ct.count}</td>
                  <td class="score-font" style={`color: ${scoreToColor(ct.avg_score)}; text-align: right; width: 50px;`}>
                    {formatScore(ct.avg_score)}
                  </td>
                </tr>
              ))}
            </table>
          ) : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
    </tr>
  </table>
  {/* Score Distribution + HRCB Over Time */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td width="50%" valign="top" style="padding-right: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Score Distribution</div>
          {histogram.length > 0 ? (() => {
            const maxCount = Math.max(...histogram.map(h => h.count));
            const barW = 200 / 21; // 21 bins (-10 to +10)
            const chartH = 60;
            // Build full bin array from -10 to +10
            const binMap = new Map(histogram.map(h => [h.bin, h.count]));
            const bins = Array.from({ length: 21 }, (_, i) => {
              const b = i - 10;
              return { bin: b, count: binMap.get(b) || 0 };
            });
            return (
              <>
                <svg width="220" height={chartH + 18} viewBox={`0 0 220 ${chartH + 18}`} style="display: block; margin: 0 auto;">
                  {/* Zero line */}
                  <line x1={10 + 10 * barW} y1="0" x2={10 + 10 * barW} y2={chartH} stroke="#333" stroke-width="0.5" />
                  {bins.map((h, i) => {
                    const barH = maxCount > 0 ? (h.count / maxCount) * chartH : 0;
                    const x = 10 + i * barW;
                    const score = h.bin / 10;
                    return (
                      <rect
                        x={x}
                        y={chartH - barH}
                        width={Math.max(barW - 1, 1)}
                        height={Math.max(barH, 0)}
                        fill={scoreToColor(score)}
                        rx="1"
                      >
                        <title>{score.toFixed(1)} to {(score + 0.1).toFixed(1)}: {h.count} stories</title>
                      </rect>
                    );
                  })}
                  {/* Axis labels */}
                  <text x="10" y={chartH + 12} fill="#555" font-size="7" font-family="monospace">-1.0</text>
                  <text x={10 + 10 * barW} y={chartH + 12} fill="#555" font-size="7" font-family="monospace" text-anchor="middle">0</text>
                  <text x={10 + 20 * barW} y={chartH + 12} fill="#555" font-size="7" font-family="monospace" text-anchor="end">+1.0</text>
                </svg>
                <div style="text-align: center; font-size: 9px; color: #444; margin-top: 2px;">
                  {status.done} stories · mean {formatScore(stats.avgScore)}
                </div>
              </>
            );
          })() : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
          )}
        </div>
      </td>
      <td width="50%" valign="top" style="padding-left: 5px;">
        <div style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px; height: 100%;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Distribution by Content Type</div>
          {ctDist.size > 0 ? (() => {
            const types = [...ctDist.entries()].sort((a, b) => b[1].total - a[1].total);
            const barW = 200 / 21;
            const rowH = 28;
            return (
              <table cellpadding="0" cellspacing="0" width="100%" style="font-size: var(--font-sm);">
                {types.map(([ct, data]) => {
                  const bins = Array.from({ length: 21 }, (_, i) => {
                    const b = i - 10;
                    return { bin: b, count: data.bins.get(b) || 0 };
                  });
                  const localMax = Math.max(...bins.map(b => b.count), 1);
                  return (
                    <tr>
                      <td style="width: 85px; color: #888; vertical-align: middle; padding-right: 6px;">
                        <span class="badge" style="background: #1a1a25; color: #888; font-size: var(--font-xs);">{ct}</span>
                        <div style="font-size: 9px; color: #555; margin-top: 1px;">{data.total}</div>
                      </td>
                      <td style="vertical-align: middle;">
                        <svg width="220" height={rowH} viewBox={`0 0 220 ${rowH}`} style="display: block;">
                          <line x1={10 + 10 * barW} y1="0" x2={10 + 10 * barW} y2={rowH} stroke="#2a2a35" stroke-width="0.5" />
                          {bins.map((h, i) => {
                            const barH = localMax > 0 ? (h.count / localMax) * (rowH - 4) : 0;
                            const x = 10 + i * barW;
                            const score = h.bin / 10;
                            return barH > 0 ? (
                              <rect x={x} y={rowH - 2 - barH} width={Math.max(barW - 1, 1)} height={barH}
                                    fill={scoreToColor(score)} opacity="0.75" rx="0.5">
                                <title>{ct} [{score.toFixed(1)} to {(score + 0.1).toFixed(1)}]: {h.count}</title>
                              </rect>
                            ) : null;
                          })}
                        </svg>
                      </td>
                    </tr>
                  );
                })}
                <tr>
                  <td></td>
                  <td>
                    <svg width="220" height="12" viewBox="0 0 220 12" style="display: block;">
                      <text x="10" y="10" fill="#444" font-size="7" font-family="monospace">-1.0</text>
                      <text x={10 + 10 * barW} y="10" fill="#555" font-size="7" font-family="monospace" text-anchor="middle">0</text>
                      <text x={10 + 20 * barW} y="10" fill="#444" font-size="7" font-family="monospace" text-anchor="end">+1.0</text>
                    </svg>
                  </td>
                </tr>
              </table>
            );
          })() : (
            <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No data yet.</div>
          )}
        </div>
      </td>
    </tr>
  </table>


  {/* UDHR Article Heatmap — aggregate across all stories */}
  <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
    <tr>
      <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
        <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">Average Score by UDHR Article</div>
        {articleStats.length > 0 ? (
          <>
            <table cellpadding="0" cellspacing="2" width="100%" style="font-size: var(--font-xs);">
              <tr>
                {articleStats.map((a) => {
                  const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                  return (
                    <td style="text-align: center; vertical-align: bottom; width: 3.2%;">
                      <a href={`/article/${a.sort_order}`} title={`${a.section}: ${ARTICLE_TITLES[a.section]}`} style="text-decoration: none;">
                        <div style={`width: 100%; height: 24px; background: ${scoreToColor(a.signal_count > 0 ? a.avg_final : null)}; border-radius: 2px; margin-bottom: 2px;`}></div>
                        <div style="color: #555;">{label}</div>
                      </a>
                    </td>
                  );
                })}
              </tr>
            </table>
            <div style="display: flex; gap: 12px; margin-top: 6px; font-size: var(--font-xs); color: #555;">
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #dc2626; border-radius: 2px;"></span> Negative</span>
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #eab308; border-radius: 2px;"></span> Neutral</span>
              <span><span style="display: inline-block; width: 8px; height: 8px; background: #16a34a; border-radius: 2px;"></span> Positive</span>
              <span title="Insufficient evidence to score"><span style="display: inline-block; width: 8px; height: 8px; background: #6b7280; border-radius: 2px;"></span> No Data</span>
            </div>
          </>
        ) : (
          <div style="color: #555; font-size: var(--font-sm); padding: 10px;">No evaluations yet.</div>
        )}
      </td>
    </tr>
  </table>

  {/* UDHR Rights Radar Chart */}
  {articleStats.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            UDHR Rights Profile
            <span style="text-transform: none; letter-spacing: 0; color: #555; margin-left: 6px;">average score per provision across all evaluations</span>
          </div>
          {(() => {
            const n = articleStats.length;
            const cx = 230, cy = 220, R = 175;
            const svgW = 460, svgH = 450;
            const levels = [-1, -0.5, 0, 0.5, 1];

            // Compute polygon vertices
            const vertices = articleStats.map((a, i) => {
              const angle = (2 * Math.PI * i / n) - Math.PI / 2;
              const score = a.signal_count > 0 ? (a.avg_final ?? 0) : 0;
              const normalized = (score + 1) / 2; // map -1..+1 to 0..1
              const r = normalized * R;
              return {
                x: cx + r * Math.cos(angle),
                y: cy + r * Math.sin(angle),
                labelX: cx + (R + 16) * Math.cos(angle),
                labelY: cy + (R + 16) * Math.sin(angle),
                angle,
                score: a.signal_count > 0 ? a.avg_final : null,
                section: a.section,
                label: a.section === 'Preamble' ? 'P' : a.section.replace('Article ', ''),
              };
            });

            const polygonPath = vertices.map((v, i) =>
              `${i === 0 ? 'M' : 'L'}${v.x.toFixed(1)},${v.y.toFixed(1)}`
            ).join(' ') + ' Z';

            return (
              <svg viewBox={`0 0 ${svgW} ${svgH}`} width="100%" style="display: block; max-width: 520px; margin: 0 auto;">
                {/* Reference circles */}
                {levels.map((lev) => {
                  const frac = (lev + 1) / 2;
                  const r = frac * R;
                  return (
                    <circle cx={cx} cy={cy} r={r} fill="none"
                            stroke={lev === 0 ? '#333' : '#1a1a25'}
                            stroke-width={lev === 0 ? '1' : '0.5'}
                            stroke-dasharray={lev === 0 ? '3,2' : 'none'} />
                  );
                })}
                {/* Level labels on right axis */}
                {levels.map((lev) => {
                  const frac = (lev + 1) / 2;
                  const r = frac * R;
                  return (
                    <text x={cx + r + 2} y={cy - 2} fill="#333" font-size="7" font-family="monospace">
                      {lev === 0 ? '0' : (lev > 0 ? `+${lev}` : `${lev}`)}
                    </text>
                  );
                })}
                {/* Axis lines from center to edge */}
                {vertices.map((v) => (
                  <line x1={cx} y1={cy} x2={cx + R * Math.cos(v.angle)} y2={cy + R * Math.sin(v.angle)}
                        stroke="#1a1a25" stroke-width="0.5" />
                ))}
                {/* Data polygon fill */}
                <path d={polygonPath} fill="rgba(255,102,0,0.12)" stroke="#ff6600" stroke-width="1.5" />
                {/* Data points at vertices */}
                {vertices.map((v) => (
                  <circle cx={v.x} cy={v.y} r="3" fill={scoreToColor(v.score)} stroke="#0a0a12" stroke-width="0.5">
                    <title>{`${v.section}: ${v.score !== null ? formatScore(v.score) : 'No Data'}`}</title>
                  </circle>
                ))}
                {/* Labels */}
                {vertices.map((v) => {
                  const cosA = Math.cos(v.angle);
                  const anchor = Math.abs(cosA) < 0.15 ? 'middle' : cosA > 0 ? 'start' : 'end';
                  const dy = Math.abs(Math.sin(v.angle)) > 0.9 ? (Math.sin(v.angle) > 0 ? 4 : -2) : 3;
                  return (
                    <text x={v.labelX} y={v.labelY + dy}
                          text-anchor={anchor}
                          fill={v.score !== null ? '#666' : '#333'}
                          font-size="8" font-family="monospace">
                      {v.label}
                    </text>
                  );
                })}
              </svg>
            );
          })()}
          <div style="text-align: center; font-size: 9px; color: #444; margin-top: 4px;">
            center = -1.0 · dashed ring = 0.0 (neutral) · outer edge = +1.0 · <span style="color: #ff6600;">polygon</span> = rights profile shape
          </div>
        </td>
      </tr>
    </table>
  )}

  {/* Article Correlation Matrix */}
  {articleStats.length > 0 && (
    <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 10px;">
      <tr>
        <td style="padding: 10px; background: #12121a; border: 1px solid #222230; border-radius: 6px;">
          <div style="color: #888; font-size: var(--font-sm); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-lg);">
            Article Correlation Matrix
          </div>
          <div style="margin-bottom: 8px; font-size: var(--font-xs);">
            <span id="tab-cooccurrence" style="color: #ff6600; cursor: pointer; font-weight: bold; margin-right: 12px;" data-tab="cooccurrence">Co-occurrence</span>
            <span id="tab-correlation" style="color: #555; cursor: pointer; margin-right: 12px;" data-tab="correlation">Score Correlation</span>
          </div>
          {/* Co-occurrence matrix */}
          <div id="matrix-cooccurrence">
            <svg width={22 + articleStats.length * 14} height={22 + articleStats.length * 14} viewBox={`0 0 ${22 + articleStats.length * 14} ${22 + articleStats.length * 14}`}>
              {/* Column labels */}
              {articleStats.map((a, i) => {
                const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                return <text x={22 + i * 14 + 7} y={12} text-anchor="middle" fill="#555" font-size="8" font-family="monospace">{label}</text>;
              })}
              {/* Row labels + cells */}
              {articleStats.map((a, i) => {
                const labelA = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                return (
                  <>
                    <text x={18} y={22 + i * 14 + 10} text-anchor="end" fill="#555" font-size="8" font-family="monospace">{labelA}</text>
                    {articleStats.map((b, j) => {
                      const keyFwd = `${a.section}|${b.section}`;
                      const keyRev = `${b.section}|${a.section}`;
                      const co = pairStats.cooccurrence.get(keyFwd) ?? pairStats.cooccurrence.get(keyRev) ?? 0;
                      const maxCo = pairStats.maxCooccurrence || 1;
                      const intensity = co / maxCo;
                      const r = Math.round(26 + intensity * (99 - 26));
                      const g = Math.round(26 + intensity * (102 - 26));
                      const bl = Math.round(37 + intensity * (241 - 37));
                      return (
                        <rect x={22 + j * 14} y={22 + i * 14} width="13" height="13" rx="1"
                              fill={`rgb(${r},${g},${bl})`}>
                          <title>{a.section} × {b.section}: {co} co-occurrences</title>
                        </rect>
                      );
                    })}
                  </>
                );
              })}
            </svg>
            <div style="display: flex; align-items: center; gap: 6px; margin-top: 4px; font-size: 9px; color: #444;">
              <span>0</span>
              <div style="width: 60px; height: 8px; background: linear-gradient(to right, #1a1a25, #6366f1); border-radius: 2px;"></div>
              <span>{pairStats.maxCooccurrence}</span>
            </div>
          </div>
          {/* Score correlation matrix */}
          <div id="matrix-correlation" style="display: none;">
            <svg width={22 + articleStats.length * 14} height={22 + articleStats.length * 14} viewBox={`0 0 ${22 + articleStats.length * 14} ${22 + articleStats.length * 14}`}>
              {/* Column labels */}
              {articleStats.map((a, i) => {
                const label = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                return <text x={22 + i * 14 + 7} y={12} text-anchor="middle" fill="#555" font-size="8" font-family="monospace">{label}</text>;
              })}
              {/* Row labels + cells */}
              {articleStats.map((a, i) => {
                const labelA = a.section === 'Preamble' ? 'P' : a.section.replace('Article ', '');
                return (
                  <>
                    <text x={18} y={22 + i * 14 + 10} text-anchor="end" fill="#555" font-size="8" font-family="monospace">{labelA}</text>
                    {articleStats.map((b, j) => {
                      const keyFwd = `${a.section}|${b.section}`;
                      const keyRev = `${b.section}|${a.section}`;
                      const corr = pairStats.correlation.get(keyFwd) ?? pairStats.correlation.get(keyRev) ?? (i === j ? 1 : null);
                      return (
                        <rect x={22 + j * 14} y={22 + i * 14} width="13" height="13" rx="1"
                              fill={corr !== null ? scoreToColor(corr) : '#1a1a25'}>
                          <title>{a.section} × {b.section}: {corr !== null ? `r = ${corr.toFixed(3)}` : 'N/A'}</title>
                        </rect>
                      );
                    })}
                  </>
                );
              })}
            </svg>
            <div style="display: flex; align-items: center; gap: 6px; margin-top: 4px; font-size: 9px; color: #444;">
              <span>-1</span>
              <div style="width: 60px; height: 8px; background: linear-gradient(to right, #dc2626, #eab308, #16a34a); border-radius: 2px;"></div>
              <span>+1</span>
            </div>
