      });
      tabCorr.addEventListener('click', function() {
        matCorr.style.display = ''; matCo.style.display = 'none';
        tabCorr.style.color = '#ff6600'; tabCorr.style.fontWeight = 'bold';
        tabCo.style.color = '#555'; tabCo.style.fontWeight = 'normal';
      });
    }

    const indicator = document.getElementById('live-indicator');
    const feed = document.getElementById('live-feed');
    let es;

    function connect() {
      es = new EventSource('/api/events');

      es.addEventListener('connected', function() {
        if (indicator) {
          indicator.style.color = '#16a34a';
          indicator.textContent = 'live';
        }
      });

      es.addEventListener('evaluation', function(e) {
        const d = JSON.parse(e.data);
        const score = d.hcb_weighted_mean !== null ? d.hcb_weighted_mean.toFixed(2) : '?';
        const toast = document.createElement('div');
        toast.style.cssText = 'background:#12121a;border:1px solid #222230;border-radius:4px;padding:6px 10px;font-size:8pt;color:#aaa;animation:fadeIn 0.3s;';
        toast.innerHTML = '<a href="/item/' + d.hn_id + '" style="color:#c9c9c9;">' + d.title.slice(0, 40) + '</a>' +
          ' <span style="color:' + (d.hcb_weighted_mean > 0.05 ? '#16a34a' : d.hcb_weighted_mean < -0.05 ? '#dc2626' : '#eab308') + ';font-family:monospace;">' + score + '</span>';
        if (feed) {
          feed.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 15000);
          // Keep max 3 toasts
          while (feed.children.length > 3) feed.removeChild(feed.firstChild);
        }
      });

      es.addEventListener('timeout', function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'reconnecting...'; }
        setTimeout(connect, 2000);
      });

      es.onerror = function() {
        es.close();
        if (indicator) { indicator.style.color = '#555'; indicator.textContent = 'offline'; }
        setTimeout(connect, 30000);
      };
    }

    connect();
  })();
  </script>
</Base>
