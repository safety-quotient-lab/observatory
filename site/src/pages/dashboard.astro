                  </svg>
                  <div style="font-size: 9px; color: #444; margin-top: 2px;">
                    extreme scores with low confidence = noise · high confidence = trustworthy signal
                  </div>
                </>
              );
            })()}
          </div>
        </td>
      </tr>
    </table>
  )}

