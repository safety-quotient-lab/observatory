                    <rect x={m.l} y={m.t} width={pw} height={ph} fill="#0a0a12" rx="2" />
                    {/* Grid lines */}
                    {[-0.5, 0, 0.5].map(v => (
                      <line x1={toX(v)} y1={m.t} x2={toX(v)} y2={m.t + ph} stroke={v === 0 ? '#2a2a35' : '#151520'} stroke-width="0.5" />
                    ))}
                    {[0.25, 0.5, 0.75].map(c => (
                      <line x1={m.l} y1={toY(c)} x2={m.l + pw} y2={toY(c)} stroke={c === 0.5 ? '#2a2a35' : '#151520'} stroke-width="0.5" />
                    ))}
                    {/* Danger zone: low confidence + extreme scores */}
                    <rect x={toX(-1)} y={toY(0.3)} width={toX(-0.3) - toX(-1)} height={toY(0) - toY(0.3)} fill="rgba(220,38,38,0.04)" rx="2" />
                    <rect x={toX(0.3)} y={toY(0.3)} width={toX(1) - toX(0.3)} height={toY(0) - toY(0.3)} fill="rgba(220,38,38,0.04)" rx="2" />
                    <text x={toX(-0.65)} y={toY(0.12)} fill="#2a1515" font-size="7" text-anchor="middle">low trust</text>
                    <text x={toX(0.65)} y={toY(0.12)} fill="#2a1515" font-size="7" text-anchor="middle">low trust</text>
                    {/* High confidence zone */}
                    <rect x={m.l} y={toY(1)} width={pw} height={toY(0.7) - toY(1)} fill="rgba(22,163,106,0.03)" rx="2" />
                    {/* Data points */}
                    {scatterData.map(p => (
                      <circle cx={toX(p.hcb_weighted_mean ?? 0)} cy={toY(p.conf)} r="3.5"
                              fill={scoreToColor(p.hcb_weighted_mean)} opacity="0.6" stroke={scoreToColor(p.hcb_weighted_mean)} stroke-width="0.5" stroke-opacity="0.3">
