#!/usr/bin/env bash
set -euo pipefail

# hn-hrcb-evaluate — Unified CLI for evaluating HN stories via claude -p.
# POSTs results to /api/ingest for full write path (consensus, aggregates, events).
#
# Usage:
#   hn-hrcb-evaluate 12345 67890           # evaluate specific stories by ID
#   hn-hrcb-evaluate --pending 10          # evaluate N pending stories
#   hn-hrcb-evaluate --failed 10           # retry N failed stories
#   hn-hrcb-evaluate --pending 10 --domain archive.org
#   hn-hrcb-evaluate --pending 10 --min-score 200
#   hn-hrcb-evaluate --pending 10 --dry-run
#   hn-hrcb-evaluate --pending 10 --parallel 5 --model sonnet
#   hn-hrcb-evaluate --status

# Allow running from within a Claude Code session
unset CLAUDECODE 2>/dev/null || true

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SITE_DIR="$(dirname "$SCRIPT_DIR")"
SYSTEM_PROMPT_FILE="$SCRIPT_DIR/system-prompt.txt"
INGEST_URL="https://hn-hrcb.pages.dev/api/ingest"

cd "$SITE_DIR"

# ── Defaults ──
MODE=""           # pending | failed | targeted | status
LIMIT=""
DOMAIN=""
MIN_SCORE=""
PARALLEL="${PARALLEL:-3}"
DELAY="${DELAY:-2}"
MODEL="${MODEL:-claude-haiku-4-5-20251001}"
DRY_RUN=false
POSITIONAL_IDS=()

# ── Parse arguments ──
usage() {
  cat <<'USAGE'
hn-hrcb-evaluate — Evaluate HN stories via claude -p

Usage:
  hn-hrcb-evaluate <hn_id> [hn_id ...]       Evaluate specific stories
  hn-hrcb-evaluate --pending N                Evaluate N pending stories
  hn-hrcb-evaluate --failed N                 Retry N failed stories
  hn-hrcb-evaluate --status                   Show pipeline stats

Options:
  --pending N       Evaluate N stories with eval_status='pending'
  --failed N        Evaluate N stories with eval_status='failed'
  --domain DOMAIN   Filter to stories from this domain
  --min-score N     Only stories with hn_score >= N
  --parallel N      Max concurrent evaluations (default: 3, env: PARALLEL)
  --delay N         Seconds between launches (default: 2, env: DELAY)
  --model MODEL     Claude model ID (default: claude-haiku-4-5-20251001, env: MODEL)
  --dry-run         Show what would be evaluated, don't run
  --status          Show pipeline stats and exit
  -h, --help        Show this help

Examples:
  hn-hrcb-evaluate 12345 67890
  hn-hrcb-evaluate --pending 10 --domain nytimes.com --dry-run
  hn-hrcb-evaluate --failed 20 --parallel 5
  hn-hrcb-evaluate --pending 50 --min-score 200 --model sonnet
USAGE
  exit 0
}

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)    usage ;;
    --pending)    MODE="pending"; LIMIT="${2:?--pending requires a number}"; shift 2 ;;
    --failed)     MODE="failed"; LIMIT="${2:?--failed requires a number}"; shift 2 ;;
    --domain)     DOMAIN="${2:?--domain requires a value}"; shift 2 ;;
    --min-score)  MIN_SCORE="${2:?--min-score requires a number}"; shift 2 ;;
    --parallel)   PARALLEL="${2:?--parallel requires a number}"; shift 2 ;;
    --delay)      DELAY="${2:?--delay requires a number}"; shift 2 ;;
    --model)      MODEL="${2:?--model requires a value}"; shift 2 ;;
    --dry-run)    DRY_RUN=true; shift ;;
    --recalc)     echo "NOTE: --recalc is no longer needed (ingest promotes to done automatically)"; shift ;;
    --status)     MODE="status"; shift ;;
    -*)           echo "Unknown option: $1"; echo "Try --help"; exit 1 ;;
    *)            POSITIONAL_IDS+=("$1"); shift ;;
  esac
done

# If positional IDs were given, that's targeted mode
if [ ${#POSITIONAL_IDS[@]} -gt 0 ]; then
  if [ -n "$MODE" ] && [ "$MODE" != "status" ]; then
    echo "ERROR: Cannot combine positional IDs with --pending/--failed"
    exit 1
  fi
  MODE="targeted"
fi

if [ -z "$MODE" ]; then
  echo "ERROR: Specify --pending N, --failed N, --status, or story IDs"
  echo "Try --help"
  exit 1
fi

# ── Status mode ──
if [ "$MODE" = "status" ]; then
  echo "╔══════════════════════════════════════╗"
  echo "║       Pipeline Status                ║"
  echo "╚══════════════════════════════════════╝"
  echo ""

  STATS=$(npx wrangler d1 execute hrcb-db --remote --json --command "
    SELECT
      COUNT(*) FILTER (WHERE eval_status = 'pending') AS pending,
      COUNT(*) FILTER (WHERE eval_status = 'evaluating') AS evaluating,
      COUNT(*) FILTER (WHERE eval_status = 'rescoring') AS rescoring,
      COUNT(*) FILTER (WHERE eval_status = 'done') AS done,
      COUNT(*) FILTER (WHERE eval_status = 'failed') AS failed,
      COUNT(*) FILTER (WHERE eval_status = 'skipped') AS skipped,
      COUNT(*) AS total
    FROM stories
  " 2>/dev/null)

  PENDING=$(echo "$STATS" | jq -r '.[0].results[0].pending')
  EVALUATING=$(echo "$STATS" | jq -r '.[0].results[0].evaluating')
  RESCORING=$(echo "$STATS" | jq -r '.[0].results[0].rescoring')
  DONE=$(echo "$STATS" | jq -r '.[0].results[0].done')
  FAILED=$(echo "$STATS" | jq -r '.[0].results[0].failed')
  SKIPPED=$(echo "$STATS" | jq -r '.[0].results[0].skipped')
  TOTAL=$(echo "$STATS" | jq -r '.[0].results[0].total')

  printf "  %-14s %s\n" "Pending:" "$PENDING"
  printf "  %-14s %s\n" "Evaluating:" "$EVALUATING"
  printf "  %-14s %s\n" "Rescoring:" "$RESCORING"
  printf "  %-14s %s\n" "Done:" "$DONE"
  printf "  %-14s %s\n" "Failed:" "$FAILED"
  printf "  %-14s %s\n" "Skipped:" "$SKIPPED"
  printf "  %-14s %s\n" "Total:" "$TOTAL"
  echo ""

  # Recent evals
  RECENT=$(npx wrangler d1 execute hrcb-db --remote --json --command "
    SELECT COUNT(*) AS cnt, MAX(evaluated_at) AS latest
    FROM stories WHERE evaluated_at >= datetime('now', '-24 hours')
  " 2>/dev/null)

  RECENT_CNT=$(echo "$RECENT" | jq -r '.[0].results[0].cnt')
  LATEST=$(echo "$RECENT" | jq -r '.[0].results[0].latest // "never"')
  printf "  %-14s %s\n" "Last 24h:" "$RECENT_CNT evals"
  printf "  %-14s %s\n" "Latest eval:" "$LATEST"

  # Top failed domains
  TOP_FAIL=$(npx wrangler d1 execute hrcb-db --remote --json --command "
    SELECT domain, COUNT(*) AS cnt FROM stories
    WHERE eval_status = 'failed' AND domain IS NOT NULL
    GROUP BY domain ORDER BY cnt DESC LIMIT 5
  " 2>/dev/null)

  FAIL_COUNT=$(echo "$TOP_FAIL" | jq '.[0].results | length')
  if [ "$FAIL_COUNT" -gt 0 ]; then
    echo ""
    echo "  Top failed domains:"
    echo "$TOP_FAIL" | jq -r '.[0].results[] | "    \(.domain) (\(.cnt))"'
  fi

  exit 0
fi

# ── Validate prereqs ──
if [ ! -f "$SYSTEM_PROMPT_FILE" ]; then
  echo "ERROR: system-prompt.txt not found at $SYSTEM_PROMPT_FILE"
  exit 1
fi

DEV_VARS_FILE="$SITE_DIR/.dev.vars"
TRIGGER_SECRET=$(grep '^TRIGGER_SECRET=' "$DEV_VARS_FILE" 2>/dev/null | cut -d= -f2- || true)
if [ -z "$TRIGGER_SECRET" ]; then
  echo "ERROR: TRIGGER_SECRET not found in $DEV_VARS_FILE"
  exit 1
fi

SYSTEM_PROMPT="$(cat "$SYSTEM_PROMPT_FILE")"

# ── Build query ──
build_query() {
  local SELECT_COLS="SELECT hn_id, url, title, hn_text, domain, hn_score, hn_rank"
  local FROM_WHERE="FROM stories WHERE"
  local CONDITIONS=""
  local ORDER_LIMIT=""

  case "$MODE" in
    pending)
      CONDITIONS="eval_status = 'pending'"
      ORDER_LIMIT="ORDER BY
        CASE WHEN hn_rank IS NOT NULL THEN 0 ELSE 1 END,
        hn_rank ASC,
        hn_score DESC NULLS LAST
      LIMIT $LIMIT"
      ;;
    failed)
      CONDITIONS="eval_status = 'failed'"
      ORDER_LIMIT="ORDER BY hn_score DESC NULLS LAST LIMIT $LIMIT"
      ;;
    targeted)
      local ID_LIST
      ID_LIST=$(printf '%s,' "${POSITIONAL_IDS[@]}")
      ID_LIST="${ID_LIST%,}"
      CONDITIONS="hn_id IN ($ID_LIST)"
      ORDER_LIMIT=""
      ;;
  esac

  # Content filter: must have URL or substantial self-text
  CONDITIONS="$CONDITIONS AND (url IS NOT NULL OR (hn_text IS NOT NULL AND LENGTH(hn_text) >= 50))"

  # Optional domain filter
  if [ -n "$DOMAIN" ]; then
    CONDITIONS="$CONDITIONS AND domain = '$DOMAIN'"
  fi

  # Optional min-score filter
  if [ -n "$MIN_SCORE" ]; then
    CONDITIONS="$CONDITIONS AND hn_score >= $MIN_SCORE"
  fi

  echo "$SELECT_COLS $FROM_WHERE $CONDITIONS $ORDER_LIMIT"
}

QUERY=$(build_query)

# ── Fetch stories ──
STORIES_FILE=$(mktemp)
npx wrangler d1 execute hrcb-db --remote --json --command "$QUERY" 2>/dev/null > "$STORIES_FILE"
COUNT=$(jq '.[0].results | length' "$STORIES_FILE")

# ── Header ──
echo "╔══════════════════════════════════════╗"
echo "║       hn-hrcb-evaluate               ║"
echo "╚══════════════════════════════════════╝"

case "$MODE" in
  pending)  echo "  Mode: pending ($LIMIT)" ;;
  failed)   echo "  Mode: failed ($LIMIT)" ;;
  targeted) echo "  Mode: targeted (${POSITIONAL_IDS[*]})" ;;
esac

[ -n "$DOMAIN" ] && echo "  Domain: $DOMAIN"
[ -n "$MIN_SCORE" ] && echo "  Min score: $MIN_SCORE"
echo "  Model: $MODEL | Parallel: $PARALLEL | Delay: ${DELAY}s"
$DRY_RUN && echo "  *** DRY RUN ***"
echo "  Found $COUNT stories"
echo ""

if [ "$COUNT" -eq 0 ]; then
  rm -f "$STORIES_FILE"
  echo "  Nothing to do."
  exit 0
fi

# ── Dry run: show stories and exit ──
if $DRY_RUN; then
  printf "  %-12s %-8s %-6s %s\n" "hn_id" "score" "rank" "title"
  printf "  %-12s %-8s %-6s %s\n" "──────" "─────" "────" "──────────────────────────"
  jq -r '.[0].results[] | "  \(.hn_id | tostring | .[0:12] | . + " " * (12 - length))  \(.hn_score // "-" | tostring | .[0:6] | . + " " * (6 - length))  \(.hn_rank // "-" | tostring | .[0:4] | . + " " * (4 - length))  \(.title[0:60])"' "$STORIES_FILE"
  echo ""
  echo "  Use without --dry-run to evaluate."
  rm -f "$STORIES_FILE"
  exit 0
fi

# ── Temp dir for per-worker output ──
WORK_DIR=$(mktemp -d)
trap 'rm -rf "$WORK_DIR"' EXIT

# ── Helpers ──
run_d1_silent() {
  npx wrangler d1 execute hrcb-db --remote --command "$1" 2>/dev/null >/dev/null || true
}

fmt_ms() {
  local ms=$1
  if [ "$ms" -lt 1000 ]; then
    echo "${ms}ms"
  else
    local s=$((ms / 1000))
    local r=$((ms % 1000 / 100))
    echo "${s}.${r}s"
  fi
}

# ── Worker: evaluate a single story ──
eval_story() {
  local ROW="$1" SLOT="$2" COUNT="$3"

  local HN_ID URL TITLE HN_TEXT DOMAIN_VAL
  HN_ID=$(echo "$ROW" | jq -r '.hn_id')
  URL=$(echo "$ROW" | jq -r '.url // empty')
  TITLE=$(echo "$ROW" | jq -r '.title')
  HN_TEXT=$(echo "$ROW" | jq -r '.hn_text // empty')
  DOMAIN_VAL=$(echo "$ROW" | jq -r '.domain // empty')

  local LOG="$WORK_DIR/${HN_ID}.log"
  local RESULT="$WORK_DIR/${HN_ID}.result"

  exec > "$LOG" 2>&1

  local STORY_START
  STORY_START=$(date +%s%3N)

  echo "── [$SLOT/$COUNT] hn_id=$HN_ID ──────────────────────────"
  echo "  $TITLE"
  [ -n "$DOMAIN_VAL" ] && echo "  domain: $DOMAIN_VAL"

  # Mark as evaluating (conditional on current status for pending/failed modes)
  local STATUS_FILTER
  case "$MODE" in
    pending)  STATUS_FILTER="AND eval_status = 'pending'" ;;
    failed)   STATUS_FILTER="AND eval_status = 'failed'" ;;
    targeted) STATUS_FILTER="" ;;
  esac
  run_d1_silent "UPDATE stories SET eval_status = 'evaluating' WHERE hn_id = $HN_ID $STATUS_FILTER"

  # --- Phase 1: Fetch content ---
  local FETCH_START FETCH_END FETCH_MS CONTENT CONTENT_LEN
  FETCH_START=$(date +%s%3N)
  CONTENT=""

  if [ -n "$URL" ]; then
    CONTENT=$(curl -sL -m 20 -A "HN-HRCB-Bot/1.0" "$URL" \
      | sed 's/<script[^>]*>.*<\/script>//g; s/<style[^>]*>.*<\/style>//g; s/<[^>]*>//g' \
      | tr -s '[:space:]' ' ' \
      | head -c 20000 2>/dev/null || echo "[fetch failed]")
  fi

  FETCH_END=$(date +%s%3N)
  FETCH_MS=$((FETCH_END - FETCH_START))
  CONTENT_LEN=${#CONTENT}
  [ -n "$URL" ] && echo "  fetch: $(fmt_ms $FETCH_MS) (${CONTENT_LEN} chars)"

  # --- Phase 2: DCP lookup ---
  local DCP_START DCP_END DCP_MS DCP_BLOCK DCP_STATUS DCP_JSON
  DCP_START=$(date +%s%3N)
  DCP_BLOCK=""
  DCP_STATUS="none"

  if [ -n "$DOMAIN_VAL" ]; then
    DCP_JSON=$(npx wrangler d1 execute hrcb-db --remote --json --command \
      "SELECT dcp_json FROM domain_dcp WHERE domain = '$DOMAIN_VAL' AND cached_at >= datetime('now', '-7 days')" \
      2>/dev/null | jq -r '.[0].results[0].dcp_json // empty' 2>/dev/null || true)

    if [ -n "$DCP_JSON" ]; then
      DCP_BLOCK="
The Domain Context Profile for this domain has been pre-evaluated. Use this DCP directly (do not re-evaluate domain-level signals). In your output, set \"domain_context_profile\": \"cached\" instead of repeating the full DCP object.

$DCP_JSON
"
      DCP_STATUS="hit"
    else
      DCP_STATUS="miss"
    fi
  fi

  DCP_END=$(date +%s%3N)
  DCP_MS=$((DCP_END - DCP_START))
  echo "  dcp:   $(fmt_ms $DCP_MS) ($DCP_STATUS)"

  # --- Phase 3: Build prompt + call claude -p ---
  local TODAY TMPFILE CLAUDE_START CLAUDE_END CLAUDE_MS RESULT_FILE EVAL_JSON EVAL_FILE SCORE_COUNT
  TODAY=$(date -u +%Y-%m-%d)
  TMPFILE=$(mktemp)

  if [ -n "$URL" ]; then
    cat > "$TMPFILE" << USERMSG
Evaluate this URL: $URL
${DCP_BLOCK}
Here is the page content:

$CONTENT

Today's date: $TODAY

Output ONLY the JSON evaluation object, no other text.
USERMSG
  else
    cat > "$TMPFILE" << USERMSG
Evaluate this self-post: $TITLE
${DCP_BLOCK}
Here is the self-post text from Hacker News:
$HN_TEXT

Today's date: $TODAY

Output ONLY the JSON evaluation object, no other text.
USERMSG
  fi

  CLAUDE_START=$(date +%s%3N)
  RESULT_FILE=$(mktemp)
  if ! claude -p \
    --system-prompt "$SYSTEM_PROMPT" \
    --output-format json \
    --model "$MODEL" \
    --tools "" \
    --no-session-persistence \
    < "$TMPFILE" > "$RESULT_FILE" 2>/dev/null; then
    CLAUDE_END=$(date +%s%3N)
    CLAUDE_MS=$((CLAUDE_END - CLAUDE_START))
    echo "  claude: $(fmt_ms $CLAUDE_MS) FAILED (non-zero exit)"
    run_d1_silent "UPDATE stories SET eval_status = 'failed', eval_error = 'claude-p failed' WHERE hn_id = $HN_ID"
    rm -f "$TMPFILE" "$RESULT_FILE"
    echo "fail	$FETCH_MS	$DCP_MS	$CLAUDE_MS	0	$DCP_STATUS" > "$RESULT"
    return
  fi

  CLAUDE_END=$(date +%s%3N)
  CLAUDE_MS=$((CLAUDE_END - CLAUDE_START))
  rm -f "$TMPFILE"

  # Extract eval JSON
  EVAL_JSON=$(jq -r '.result // empty' "$RESULT_FILE")
  rm -f "$RESULT_FILE"

  if [ -z "$EVAL_JSON" ]; then
    echo "  claude: $(fmt_ms $CLAUDE_MS) FAILED (no .result)"
    run_d1_silent "UPDATE stories SET eval_status = 'failed', eval_error = 'no result in claude-p output' WHERE hn_id = $HN_ID"
    echo "fail	$FETCH_MS	$DCP_MS	$CLAUDE_MS	0	$DCP_STATUS" > "$RESULT"
    return
  fi

  EVAL_FILE=$(mktemp)
  echo "$EVAL_JSON" > "$EVAL_FILE"

  if ! jq -e '.scores' "$EVAL_FILE" >/dev/null 2>&1; then
    local EXTRACTED
    EXTRACTED=$(sed -n '/^{/,/^}/p' "$EVAL_FILE")
    echo "$EXTRACTED" > "$EVAL_FILE"
    if ! jq -e '.scores' "$EVAL_FILE" >/dev/null 2>&1; then
      echo "  claude: $(fmt_ms $CLAUDE_MS) FAILED (invalid JSON)"
      run_d1_silent "UPDATE stories SET eval_status = 'failed', eval_error = 'invalid eval JSON from claude-p' WHERE hn_id = $HN_ID"
      rm -f "$EVAL_FILE"
      echo "fail	$FETCH_MS	$DCP_MS	$CLAUDE_MS	0	$DCP_STATUS" > "$RESULT"
      return
    fi
  fi

  SCORE_COUNT=$(jq '.scores | length' "$EVAL_FILE")
  if [ "$SCORE_COUNT" -lt 1 ]; then
    echo "  claude: $(fmt_ms $CLAUDE_MS) FAILED (empty scores)"
    run_d1_silent "UPDATE stories SET eval_status = 'failed', eval_error = 'empty scores array' WHERE hn_id = $HN_ID"
    rm -f "$EVAL_FILE"
    echo "fail	$FETCH_MS	$DCP_MS	$CLAUDE_MS	0	$DCP_STATUS" > "$RESULT"
    return
  fi

  echo "  claude: $(fmt_ms $CLAUDE_MS) ($SCORE_COUNT scores)"

  # --- Phase 4: POST to /api/ingest ---
  local DB_START DB_END DB_MS STORY_END STORY_MS INGEST_BODY INGEST_RESP INGEST_OK
  DB_START=$(date +%s%3N)

  # Map claude model shortname to full model ID
  local MODEL_ID
  case "$MODEL" in
    haiku)  MODEL_ID="claude-haiku-4-5-20251001" ;;
    sonnet) MODEL_ID="claude-sonnet-4-5-20250514" ;;
    opus)   MODEL_ID="claude-opus-4-20250514" ;;
    *)      MODEL_ID="$MODEL" ;;
  esac

  local INGEST_FILE
  INGEST_FILE=$(mktemp)
  jq -n \
    --argjson hn_id "$HN_ID" \
    --arg model_id "$MODEL_ID" \
    --arg provider "claude-code-standalone" \
    --slurpfile result "$EVAL_FILE" \
    '{
      hn_id: $hn_id,
      model_id: $model_id,
      provider: $provider,
      prompt_mode: "full",
      input_tokens: 0,
      output_tokens: 0,
      prompt_hash: null,
      methodology_hash: null,
      result: $result[0]
    }' > "$INGEST_FILE"

  local HTTP_CODE
  INGEST_RESP=$(curl -s -w '\n%{http_code}' -X POST \
    -H "Authorization: Bearer $TRIGGER_SECRET" \
    -H "Content-Type: application/json" \
    -d @"$INGEST_FILE" \
    "$INGEST_URL" 2>/dev/null || echo -e '{"error":"curl failed"}\n000')
  rm -f "$INGEST_FILE"

  HTTP_CODE=$(echo "$INGEST_RESP" | tail -1)
  INGEST_RESP=$(echo "$INGEST_RESP" | sed '$d')

  INGEST_OK=$(echo "$INGEST_RESP" | jq -r '.ok // false' 2>/dev/null)

  DB_END=$(date +%s%3N)
  DB_MS=$((DB_END - DB_START))

  if [ "$INGEST_OK" = "true" ]; then
    local WM CLS REPAIRS
    WM=$(echo "$INGEST_RESP" | jq -r '.weighted_mean // "?"')
    CLS=$(echo "$INGEST_RESP" | jq -r '.classification // "?"')
    REPAIRS=$(echo "$INGEST_RESP" | jq -r '.repairs | length // 0')
    echo "  ingest: $(fmt_ms $DB_MS) → done (hrcb=$WM, $CLS, ${REPAIRS} repairs)"
  else
    local ERR_MSG
    ERR_MSG=$(echo "$INGEST_RESP" | jq -r '([.error, .detail, (.details | if type == "array" then join("; ") else . end)] | map(select(. != null)) | join(": "))' 2>/dev/null)
    [ -z "$ERR_MSG" ] && ERR_MSG="HTTP $HTTP_CODE"
    echo "  ingest: $(fmt_ms $DB_MS) FAILED ($ERR_MSG)"
    run_d1_silent "UPDATE stories SET eval_status = 'failed', eval_error = 'ingest failed: $ERR_MSG' WHERE hn_id = $HN_ID"
    rm -f "$EVAL_FILE"
    STORY_END=$(date +%s%3N)
    STORY_MS=$((STORY_END - STORY_START))
    echo "  total: $(fmt_ms $STORY_MS)"
    echo "fail	$FETCH_MS	$DCP_MS	$CLAUDE_MS	$DB_MS	$DCP_STATUS" > "$RESULT"
    return
  fi

  STORY_END=$(date +%s%3N)
  STORY_MS=$((STORY_END - STORY_START))

  rm -f "$EVAL_FILE"

  echo "  total: $(fmt_ms $STORY_MS)"

  echo "ok	$FETCH_MS	$DCP_MS	$CLAUDE_MS	$DB_MS	$DCP_STATUS" > "$RESULT"
}

# ── Main execution ──
BATCH_START=$(date +%s)

LINES_FILE=$(mktemp)
jq -c '.[0].results[]' "$STORIES_FILE" > "$LINES_FILE"
rm -f "$STORIES_FILE"

# Collect hn_ids in order
HN_IDS=()
while IFS= read -r ROW; do
  HN_IDS+=($(echo "$ROW" | jq -r '.hn_id'))
done < "$LINES_FILE"

# Launch workers with concurrency limit
CURRENT=0
ACTIVE_PIDS=()

while IFS= read -r ROW; do
  CURRENT=$((CURRENT + 1))

  # If at capacity, wait for any one to finish
  while [ ${#ACTIVE_PIDS[@]} -ge "$PARALLEL" ]; do
    wait -n "${ACTIVE_PIDS[@]}" 2>/dev/null || true
    STILL_ACTIVE=()
    for pid in "${ACTIVE_PIDS[@]}"; do
      if kill -0 "$pid" 2>/dev/null; then
        STILL_ACTIVE+=("$pid")
      fi
    done
    ACTIVE_PIDS=("${STILL_ACTIVE[@]}")
  done

  # Launch worker in background
  eval_story "$ROW" "$CURRENT" "$COUNT" &
  ACTIVE_PIDS+=($!)

  # Stagger launches
  sleep "$DELAY"
done < "$LINES_FILE"

# Wait for all remaining workers
for pid in "${ACTIVE_PIDS[@]}"; do
  wait "$pid" 2>/dev/null || true
done

rm -f "$LINES_FILE"

# ── Print results in original order ──
for hn_id in "${HN_IDS[@]}"; do
  if [ -f "$WORK_DIR/${hn_id}.log" ]; then
    cat "$WORK_DIR/${hn_id}.log"
  fi
done

# ── Aggregate timing ──
SUCCESS=0
FAILED=0
TOTAL_FETCH_MS=0
TOTAL_DCP_MS=0
TOTAL_CLAUDE_MS=0
TOTAL_DB_MS=0
DCP_HITS=0
DCP_MISSES=0

for hn_id in "${HN_IDS[@]}"; do
  resfile="$WORK_DIR/${hn_id}.result"
  [ -f "$resfile" ] || continue
  IFS=$'\t' read -r status fetch_ms dcp_ms claude_ms db_ms dcp_status < "$resfile"
  if [ "$status" = "ok" ]; then
    SUCCESS=$((SUCCESS + 1))
  else
    FAILED=$((FAILED + 1))
  fi
  TOTAL_FETCH_MS=$((TOTAL_FETCH_MS + fetch_ms))
  TOTAL_DCP_MS=$((TOTAL_DCP_MS + dcp_ms))
  TOTAL_CLAUDE_MS=$((TOTAL_CLAUDE_MS + claude_ms))
  TOTAL_DB_MS=$((TOTAL_DB_MS + db_ms))
  [ "$dcp_status" = "hit" ] && DCP_HITS=$((DCP_HITS + 1))
  [ "$dcp_status" = "miss" ] && DCP_MISSES=$((DCP_MISSES + 1))
done

BATCH_END=$(date +%s)
BATCH_ELAPSED=$((BATCH_END - BATCH_START))
BATCH_MIN=$((BATCH_ELAPSED / 60))
BATCH_SEC=$((BATCH_ELAPSED % 60))
TOTAL_COUNT=$((SUCCESS + FAILED))
TOTAL_COUNT=$((TOTAL_COUNT > 0 ? TOTAL_COUNT : 1))
AVG_FETCH=$((TOTAL_FETCH_MS / TOTAL_COUNT))
AVG_DCP=$((TOTAL_DCP_MS / TOTAL_COUNT))
AVG_CLAUDE=$((TOTAL_CLAUDE_MS / TOTAL_COUNT))
AVG_DB=$((TOTAL_DB_MS / (SUCCESS > 0 ? SUCCESS : 1)))

echo ""
echo "╔══════════════════════════════════════╗"
echo "║       Evaluation Complete            ║"
echo "╚══════════════════════════════════════╝"
echo "  Results:  $SUCCESS ok, $FAILED failed ($TOTAL_COUNT total)"
echo "  Duration: ${BATCH_MIN}m${BATCH_SEC}s (wall clock, ${PARALLEL}x parallel)"
echo ""
echo "  Phase     Avg         Total"
echo "  ──────    ──────      ──────"
echo "  Fetch     $(printf '%-11s' "$(fmt_ms $AVG_FETCH)") $(fmt_ms $TOTAL_FETCH_MS)"
echo "  DCP       $(printf '%-11s' "$(fmt_ms $AVG_DCP)") $(fmt_ms $TOTAL_DCP_MS) ($DCP_HITS hits, $DCP_MISSES misses)"
echo "  Claude    $(printf '%-11s' "$(fmt_ms $AVG_CLAUDE)") $(fmt_ms $TOTAL_CLAUDE_MS)"
echo "  Ingest    $(printf '%-11s' "$(fmt_ms $AVG_DB)") $(fmt_ms $TOTAL_DB_MS)"
echo ""
echo "  Rate: ~$(( TOTAL_COUNT * 60 / (BATCH_ELAPSED > 0 ? BATCH_ELAPSED : 1) )) evals/min"
